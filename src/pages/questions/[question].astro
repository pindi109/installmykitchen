---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import StickyMobileCTA from "../../components/StickyMobileCTA.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import AnswerBlock from "../../components/AnswerBlock.astro";
import FAQ from "../../components/FAQ.astro";
import InternalLinks from "../../components/InternalLinks.astro";
import CTA from "../../components/CTA.astro";
export async function getStaticPaths() {
  const { default: questionsA } = await import("../../data/questions-a.json");
  const { default: questionsB } = await import("../../data/questions-b.json");
  const questionsData = [...questionsA, ...questionsB];
  return questionsData.map((q: any, i: number) => ({
    params: { question: q.slug },
    props: { ...q, index: i },
  }));
}

const { slug, title, metaDescription, answer, bodyHtml, faqs, index } = Astro.props;
const canonical = `https://www.installmykitchen.co.uk/questions/${slug}/`;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((f: any) => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a },
  })),
};
---

<Base
  title={`${title} | Install My Kitchen`}
  description={metaDescription}
  canonical={canonical}
>
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <Header slot="header" />

  <div class="container py-6">
    <Breadcrumbs
      items={[
        { label: "Questions & Answers", href: "/questions/" },
        { label: title, href: canonical },
      ]}
    />
  </div>

  <section style="background: var(--bg-light); padding: 3rem 0;">
    <div class="container" style="max-width: 860px;">
      <h1 style="font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 800; color: var(--navy); margin-bottom: 1.5rem; line-height: 1.2;">
        {title}
      </h1>
      <AnswerBlock answer={answer} />
    </div>
  </section>

  <section style="padding: 3rem 0;">
    <div class="container" style="max-width: 860px;">
      <div class="prose-content" set:html={bodyHtml} />
    </div>
  </section>

  <section style="background: var(--bg-light); padding: 2rem 0;">
    <div class="container" style="max-width: 860px;">
      <h2 style="font-size: 1.5rem; font-weight: 700; color: var(--navy); margin-bottom: 1.5rem;">Related Questions</h2>
      <FAQ items={faqs} schemaId={`faq-q-${index}`} />
    </div>
  </section>

  <section style="padding: 2rem 0;">
    <div class="container" style="max-width: 860px;">
      <InternalLinks
        heading="Explore More"
        links={[
          { label: "Book a Survey — £195", href: "/survey/", description: "Get an accurate fixed quote for your kitchen installation." },
          { label: "Questions & Answers Hub", href: "/questions/", description: "Browse all 50 kitchen installation questions." },
          { label: "Cost Guide", href: "/costs/", description: "Full breakdown of kitchen installation costs." },
          { label: "Contact Us", href: "/contact/", description: "Call 07399 651836 or send an enquiry." },
        ]}
      />
    </div>
  </section>

  <CTA
    heading="Ready to Book Your Kitchen Installation?"
    subtext="Book a survey and get a fixed quote within 24 hours. Survey fee £195 — credited back on booking."
    primaryLabel="Book a Survey"
    primaryHref="/survey/"
    secondaryLabel="Call 07399 651836"
    secondaryHref="tel:07399651836"
    dark={true}
  />

  <Footer slot="footer" />
  <StickyMobileCTA slot="sticky-cta" />
</Base>

<style>
  .prose-content :global(h2) {
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--navy);
    margin: 2rem 0 0.75rem;
    line-height: 1.3;
  }
  .prose-content :global(p) {
    color: var(--text-soft);
    line-height: 1.75;
    margin-bottom: 1rem;
  }
  .prose-content :global(ul) {
    color: var(--text-soft);
    line-height: 1.75;
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }
  .prose-content :global(li) { margin-bottom: 0.4rem; }
  .prose-content :global(strong) { color: var(--charcoal); font-weight: 600; }
</style>
