import FAQ from "../../components/FAQ.astro";
import InternalLinks from "../../components/InternalLinks.astro";
import CTA from "../../components/CTA.astro";

export function getStaticPaths() {
  return [
    // ── 1. Wren vs Howdens ─────────────────────────────────────────────────
    {
      params: { comparison: "wren-vs-howdens-kitchen-installation" },
      props: {
        slug: "wren-vs-howdens-kitchen-installation",
        title: "Wren vs Howdens Kitchen Installation — Which Is Easier to Fit?",
        metaTitle: "Wren vs Howdens Kitchen Installation | Install My Kitchen",
        metaDescription: "Comparing Wren and Howdens kitchen installation. Both supply rigid units but differ in supply route and delivery. Find out which suits independent fitting better.",
        answer: "Both Wren and Howdens kitchens are straightforward to install, but there are differences. Wren delivers direct to consumers as pre-assembled rigid units; Howdens supplies trade-only and units are also rigid. Both are well-suited to independent installation.",
        col1Name: "Wren",
        col2Name: "Howdens",
        criteria: ["Supply method", "Unit construction", "Delivery process", "Installation complexity", "Cost to fit"],
        col1Points: ["Consumer retail, easy to order", "Rigid pre-assembled units", "Direct home delivery", "Efficient installation", "Standard fitting rates apply"],
        col2Points: ["Trade-only, via a tradesperson", "Rigid trade-quality units", "Collected from depot by fitter", "Very efficient installation", "Standard fitting rates apply"],
        bodyHtml: `
          <h2 class="text-2xl font-bold mb-4" style="color: var(--navy);">Overview</h2>
          <p class="mb-4" style="color: var(--text-soft);">Wren Kitchens and Howdens are two of the most popular kitchen suppliers in the UK, but they serve very different markets. Wren is a consumer-facing retailer with showrooms across the country; Howdens is strictly trade-only, supplying exclusively to builders, joiners and kitchen fitters through its depot network. Understanding how each operates helps you make a more informed decision — both about which kitchen to buy and how to arrange installation.</p>

          <h2 class="text-2xl font-bold mb-4 mt-8" style="color: var(--navy);">Supply Route</h2>
          <p class="mb-4" style="color: var(--text-soft);">The most significant difference between Wren and Howdens is who can buy from them. Wren sells directly to homeowners via its showrooms and website. You can browse, design, and order your kitchen without any trade involvement. Howdens, by contrast, only sells to account holders — typically builders, joiners, or kitchen fitters. If you want a Howdens kitchen as a homeowner, you need to arrange it through a tradesperson who holds a Howdens account.</p>
          <p class="mb-4" style="color: var(--text-soft);">This distinction has real practical implications. With Wren, you have direct control over the design process and can attend showroom appointments at your convenience. With Howdens, your fitter typically co-ordinates the design, ordering, and collection on your behalf — which means you are relying on their depot relationship and their familiarity with the Howdens range.</p>

          <h2 class="text-2xl font-bold mb-4 mt-8" style="color: var(--navy);">Unit Construction</h2>
          <p class="mb-4" style="color: var(--text-soft);">Both Wren and Howdens supply rigid, pre-assembled carcasses. This means units arrive ready to install without requiring on-site box-build assembly. Rigid units are faster to fit than flat-pack alternatives and, when properly manufactured, produce a more consistent result. Both brands have invested significantly in carcass quality and the units from either supplier are well-regarded by experienced fitters.</p>
          <p class="mb-4" style="color: var(--text-soft);">Howdens kitchens — particularly from the Tewkesbury and Greenwich ranges — are designed specifically for the trade and have a reputation for robust construction. Wren offers a wider price range, from entry-level to premium, and unit quality varies accordingly. It is worth checking the specific range you are ordering rather than assuming all Wren products are equivalent.</p>

          <h2 class="text-2xl font-bold mb-4 mt-8" style="color: var(--navy);">Delivery and Logistics</h2>
          <p class="mb-4" style="color: var(--text-soft);">Wren delivers directly to your home, typically in a single delivery. This is convenient but requires you to have adequate storage space on site. Wren's delivery teams will usually stack boxes in a specified room, but they do not check individual components or assemble anything. You should plan to check the delivery thoroughly before your installation date.</p>
          <p class="mb-4" style="color: var(--text-soft);">Howdens kitchens are collected from the local depot by the fitter, usually in their van. This means smaller loads over potentially multiple trips but avoids the need for a bulk storage space in your home. Your fitter will typically have a good relationship with the depot and can raise any issues directly if components are missing or damaged.</p>

          <h2 class="text-2xl font-bold mb-4 mt-8" style="color: var(--navy);">Installation Time and Cost</h2>
          <p class="mb-4" style="color: var(--text-soft);">Because both brands supply rigid units, installation timelines are broadly similar. A standard kitchen from either Wren or Howdens would typically take three to seven days to install, depending on size, layout complexity, and the scope of associated trades work (plumbing, electrical, plastering). Neither brand imposes specific fitting requirements or accreditation on independent fitters, so you are free to engage whichever installation service you prefer.</p>
          <p class="mb-4" style="color: var(--text-soft);">Installation costs are also comparable. As a broad guide, professional installation for a Wren or Howdens kitchen in the Coventry and Warwickshire area typically starts from around £1,800 for a simple galley layout and rises to £5,000 or more for large L-shaped or island kitchens with extensive appliance connections. The best way to get an accurate figure is to book a pre-installation survey.</p>

          <h2 class="text-2xl font-bold mb-4 mt-8" style="color: var(--navy);">Which Should You Choose?</h2>
          <p class="mb-4" style="color: var(--text-soft);">The choice between Wren and Howdens often comes down to your preference for direct involvement in the purchase process. If you want to drive the design yourself and deal directly with the supplier, Wren gives you that. If you are happy to work through a trusted fitter who can source and co-ordinate a Howdens kitchen on your behalf, you may benefit from the trade-quality products and depot proximity that Howdens offers.</p>
          <p class="mb-4" style="color: var(--text-soft);">From a pure installation standpoint, there is no meaningful difference. Both brands supply rigid units that an experienced independent fitter can install efficiently. The key variable in any kitchen installation is the skill and approach of the fitter, not the brand of the kitchen itself.</p>
        `,
        takeaways: [
          "Both Wren and Howdens supply rigid units — installation complexity and timelines are broadly equivalent.",
          "Wren sells direct to homeowners; Howdens is trade-only, requiring a fitter with a depot account.",
          "An independent fitter can install either brand — the quality of the installation depends on the fitter, not the supplier.",
        ],
        faqs: [
          { q: "Can an independent fitter install a Wren kitchen?", a: "Yes. Wren does not require homeowners to use an appointed installer. You can purchase your Wren kitchen and arrange independent installation separately, which often offers more flexibility and competitive pricing." },
          { q: "Do I need a Howdens account to buy a Howdens kitchen?", a: "Yes. Howdens only sells to trade account holders. As a homeowner, you need to work with a fitter who has a Howdens account and can order on your behalf." },
          { q: "Is Howdens better quality than Wren?", a: "Both supply rigid units suitable for professional installation. Howdens has a strong trade reputation. Wren offers a wider range at various price points. Quality depends on the specific range selected rather than the brand overall." },
          { q: "How long does it take to install a Wren or Howdens kitchen?", a: "A standard Wren or Howdens kitchen typically takes three to seven days to install. Larger, more complex layouts with island units or extensive appliance connections may take longer. A pre-installation survey will give you a more accurate timeline." },
        ],
      },
    },

    // ── 2. Magnet vs Wren ──────────────────────────────────────────────────
    {
      params: { comparison: "magnet-vs-wren-kitchen-installation" },
      props: {
        slug: "magnet-vs-wren-kitchen-installation",
        title: "Magnet vs Wren Kitchen Installation — What's the Difference?",
        metaTitle: "Magnet vs Wren Kitchen Installation | Install My Kitchen",
        metaDescription: "Comparing Magnet and Wren kitchen installation. Both offer rigid units at similar price points. See how they compare on installation time, cost and range.",
        answer: "Both Magnet and Wren offer quality kitchens that install efficiently. Magnet kitchens are rigid and well-finished; Wren offers a wide range at various price points. Both are suitable for independent installation.",
        col1Name: "Magnet",
        col2Name: "Wren",
        criteria: ["Unit construction", "Range & styles", "Delivery", "Installation time", "Cost range"],
        col1Points: ["Rigid assembled units", "Mid to premium range", "Home delivery", "3–7 days typical", "Mid-market pricing"],
        col2Points: ["Rigid assembled units", "Entry to premium range", "Home delivery", "3–8 days typical", "Entry to mid pricing"],
        bodyHtml: `
          <h2 class="text-2xl font-bold mb-4" style="color: var(--navy);">Overview</h2>
          <p class="mb-4" style="color: var(--text-soft);">Magnet and Wren are two of the best-known consumer kitchen retailers in the UK. Both operate showrooms, sell directly to homeowners, and offer a full kitchen design service. From an installation perspective, they share a number of key characteristics — but there are meaningful differences in product positioning, range, and the buying experience that are worth understanding before you commit.</p>

          <h2 class="text-2xl font-bold mb-4 mt-8" style="color: var(--navy);">Unit Construction</h2>
          <p class="mb-4" style="color: var(--text-soft);">Both Magnet and Wren supply rigid, pre-assembled carcasses. Neither brand requires on-site box-build assembly, which means installation proceeds efficiently regardless of which you choose. Rigid units are the preferred format for professional kitchen fitters — they are more consistent, quicker to fit, and produce a more accurate result than flat-pack alternatives.</p>
          <p class="mb-4" style="color: var(--text-soft);">Magnet positions itself firmly in the mid-to-premium market and its carcasses reflect this. Construction is typically solid and consistent across the range. Wren spans a wider spectrum, from budget-friendly entry-level options through to its Infinity Plus premium cabinetry. If you are comparing like-for-like quality, make sure you are looking at equivalent ranges rather than comparing a Wren entry unit to a Magnet premium unit.</p>

          <h2 class="text-2xl font-bold mb-4 mt-8" style="color: var(--navy);">Range and Styles</h2>
          <p class="mb-4" style="color: var(--text-soft);">Wren has a notably wider range of door styles, colours, and finishes than Magnet. This can be an advantage if you have a very specific aesthetic in mind, but can also make the design process more complex. Magnet's more focused range is arguably easier to navigate, and the company's in-store design consultants are well-regarded.</p>
          <p class="mb-4" style="color: var(--text-soft);">Both retailers offer a design and planning service as part of the purchase process. Magnet tends to be more consultative; Wren's model is often more transactional. Neither approach is inherently better — it comes down to your preference for how involved you want the retailer to be.</p>

          <h2 class="text-2xl font-bold mb-4 mt-8" style="color: var(--navy);">Delivery</h2>
          <p class="mb-4" style="color: var(--text-soft);">Both Magnet and Wren deliver directly to the installation address. Delivery logistics, lead times, and the level of checking done at the point of delivery are broadly similar. As with any kitchen delivery, we recommend thoroughly checking all components against your order before your installation date and reporting any discrepancies immediately.</p>

          <h2 class="text-2xl font-bold mb-4 mt-8" style="color: var(--navy);">Installation Time and Cost</h2>
          <p class="mb-4" style="color: var(--text-soft);">Because both brands supply rigid units, installation timelines are very similar. A standard Magnet or Wren kitchen of average size would typically take three to seven days to install. Complex layouts, island units, or extensive appliance connections will add time to either brand.</p>
          <p class="mb-4" style="color: var(--text-soft);">Installation costs are also comparable. Neither brand mandates use of its own fitting service for the product warranty to be valid. You are entirely free to arrange independent installation for either a Magnet or Wren kitchen, and doing so often results in more competitive pricing and greater scheduling flexibility.</p>

          <h2 class="text-2xl font-bold mb-4 mt-8" style="color: var(--navy);">Which Is Better for Independent Installation?</h2>
          <p class="mb-4" style="color: var(--text-soft);">Neither Magnet nor Wren presents any particular advantage or disadvantage from a pure installation standpoint. Both supply rigid units with standard fixings and dimensions that any experienced kitchen fitter will be familiar with. The decision between the two should be driven by range preference, budget, and your experience of the buying process — not by installation considerations.</p>
          <p class="mb-4" style="color: var(--text-soft);">What matters far more than the brand of kitchen is the quality of the installation. A well-fitted Wren kitchen will outlast and outperform a poorly fitted Magnet kitchen of higher intrinsic quality, and vice versa. Invest in a thorough pre-installation survey and choose a fitter with a verifiable track record.</p>
        `,
        takeaways: [
          "Both Magnet and Wren supply rigid units — installation time and complexity are broadly the same.",
          "Wren has a wider product range; Magnet sits more firmly in the mid-to-premium segment.",
          "Independent installation is fully compatible with both brands and typically offers better value than retailer-appointed fitting.",
        ],
        faqs: [
          { q: "Can I use an independent fitter for a Magnet kitchen?", a: "Yes. Magnet does not require you to use its own installation service. Your kitchen warranty relates to the product, not who fits it. An independent fitter is a perfectly valid choice." },
          { q: "Is Magnet more expensive than Wren?", a: "Magnet generally sits in the mid-to-premium price bracket. Wren has a wider range including entry-level options, but its premium lines are comparable to Magnet pricing. Always compare equivalent ranges." },
          { q: "How long does a Magnet kitchen take to install?", a: "A standard Magnet kitchen typically takes three to seven days to install. The exact timeline depends on kitchen size, layout complexity, and the scope of trades work required." },
          { q: "Do I need a survey before installing a Magnet or Wren kitchen?", a: "Yes. A pre-installation survey is advisable regardless of which brand you choose. It ensures your kitchen plan matches your actual room dimensions and identifies any issues before installation day." },
        ],
      },
    },

    // ── 3. IKEA vs Wren ────────────────────────────────────────────────────
    {
      params: { comparison: "ikea-vs-wren-kitchen-installation" },
      props: {
        slug: "ikea-vs-wren-kitchen-installation",
        title: "IKEA vs Wren Kitchen Installation — Cost & Complexity Compared",
        metaTitle: "IKEA vs Wren Kitchen Installation — Cost & Complexity | Install My Kitchen",
        metaDescription: "IKEA flat-pack vs Wren rigid units — comparing installation time, assembly requirements, labour cost and complexity for UK homeowners in 2025.",
        answer: "IKEA kitchens are flat-pack and require full assembly on-site, typically adding 1–2 days to installation time versus pre-assembled units from Wren. Wren delivers rigid units requiring less assembly. Both are widely installed by independent fitters.",
        col1Name: "IKEA",
        col2Name: "Wren",
        criteria: ["Unit format", "Assembly required", "Installation time", "Cost to fit", "Customisation"],
        col1Points: ["Flat-pack", "Full assembly on-site", "Adds 1–2 days", "Slightly higher labour cost", "Modular system"],
        col2Points: ["Rigid assembled", "Minimal assembly", "Standard timeline", "Standard labour cost", "Wide bespoke options"],
        bodyHtml: `
          <h2 class="text-2xl font-bold mb-4" style="color: var(--navy);">Overview</h2>
          <p class="mb-4" style="color: var(--text-soft);">IKEA and Wren represent two very different approaches to kitchen supply. IKEA's METOD system is a modular flat-pack product available from stock in store and online, designed to be affordable and accessible. Wren is a UK-specialist kitchen retailer offering a designed and delivered service, with rigid pre-assembled units across a range of price points. From an installation standpoint, the differences are significant.</p>

          <h2 class="text-2xl font-bold mb-4 mt-8" style="color: var(--navy);">Unit Format: Flat-Pack vs Rigid</h2>
          <p class="mb-4" style="color: var(--text-soft);">The single biggest installation difference between IKEA and Wren is unit format. IKEA kitchens are flat-pack — every carcass arrives disassembled and must be built on-site before it can be fitted. Wren kitchens are supplied as rigid, pre-assembled carcasses that are ready to position, level, and fix without any preliminary box-building.</p>
          <p class="mb-4" style="color: var(--text-soft);">This difference is material. Assembling flat-pack IKEA carcasses is not difficult, but it is time-consuming. For a standard 10–15 unit kitchen, the assembly stage alone typically takes a full day. Add to this the time required to fit, level, and finish the units, and an IKEA kitchen installation will generally take one to two days longer than an equivalent Wren installation.</p>

          <h2 class="text-2xl font-bold mb-4 mt-8" style="color: var(--navy);">Installation Time</h2>
          <p class="mb-4" style="color: var(--text-soft);">A standard Wren kitchen of average size — say, 15–20 rigid units with standard appliance connections — would typically take three to six days to install. The equivalent IKEA kitchen would typically take four to eight days, depending on unit count and complexity. For large kitchens with 25 or more units, the gap can be two days or more.</p>
          <p class="mb-4" style="color: var(--text-soft);">This has implications for both scheduling and cost. If your fitter charges a day rate, additional installation days translate directly into a higher labour bill. The lower purchase price of an IKEA kitchen can be partially offset by higher installation labour costs — something worth factoring into your total budget comparison.</p>

          <h2 class="text-2xl font-bold mb-4 mt-8" style="color: var(--navy);">Labour Cost</h2>
          <p class="mb-4" style="color: var(--text-soft);">Most professional kitchen fitters price IKEA installations at a slightly higher rate than equivalent rigid-unit kitchens, reflecting the additional assembly time. As a rule of thumb, expect to add 15–25% to the base installation cost for an IKEA kitchen versus a comparably sized Wren kitchen. This is not a penalty — it simply reflects the additional work involved.</p>
          <p class="mb-4" style="color: var(--text-soft);">IKEA also has some specific fitting considerations that not all fitters are familiar with. The METOD system uses a proprietary rail-fixing system for wall units that differs from standard kitchen wall unit brackets. The SEKTION system (sold in North America) differs again. Make sure your chosen fitter has specific experience with IKEA METOD before you book.</p>

          <h2 class="text-2xl font-bold mb-4 mt-8" style="color: var(--navy);">Customisation</h2>
          <p class="mb-4" style="color: var(--text-soft);">Wren's bespoke design service allows for non-standard unit sizes, made-to-measure panels, and a wide range of finishes. IKEA's modular system is, by definition, limited to standard dimensions and configurations. For kitchens with unusual dimensions or complex layouts, Wren's flexibility is a significant advantage. For straightforward rectangular or galley kitchens, IKEA's modular system is more than adequate.</p>

          <h2 class="text-2xl font-bold mb-4 mt-8" style="color: var(--navy);">Overall Value Comparison</h2>
          <p class="mb-4" style="color: var(--text-soft);">IKEA is typically cheaper to purchase but costs more to install per unit. Wren has a higher purchase price at the mid-range but lower installation labour costs. For a full cost comparison, you need to add the kitchen purchase price, installation labour, worktops, appliances, and any additional trades work. On a total-cost basis, the gap between IKEA and a mid-range Wren kitchen is often smaller than the headline purchase prices suggest.</p>
        `,
        takeaways: [
          "IKEA flat-pack units require on-site assembly, typically adding one to two days to installation versus pre-assembled Wren units.",
          "IKEA installation labour costs are 15–25% higher than equivalent rigid-unit kitchens to reflect the additional assembly time.",
          "On a total fitted cost basis, the gap between IKEA and mid-range Wren is often smaller than headline kitchen prices suggest.",
        ],
        faqs: [
          { q: "Can an independent fitter install an IKEA kitchen?", a: "Yes. IKEA does not require use of its own installation service. Many independent fitters are experienced with IKEA METOD kitchens. Confirm your fitter has specific IKEA experience before booking." },
          { q: "Why does IKEA installation cost more than other kitchens?", a: "IKEA kitchens are flat-pack and require full on-site assembly before fitting. This assembly stage adds time to the installation, which increases labour costs compared to pre-assembled rigid-unit kitchens." },
          { q: "How long does it take to install an IKEA kitchen?", a: "A standard IKEA METOD kitchen typically takes four to eight days to install, depending on the number of units and layout complexity. This is one to two days longer than an equivalent pre-assembled kitchen." },
          { q: "Is Wren worth the extra cost over IKEA?", a: "Wren's pre-assembled units reduce installation time and labour cost. Wren also offers a wider range of sizes and finishes. Whether the premium is worthwhile depends on your total budget, kitchen size, and design requirements." },
        ],
      },
    },

    // ── 4. Howdens vs Benchmarx ────────────────────────────────────────────
    {
      params: { comparison: "howdens-vs-benchmarx-kitchen-installation" },
      props: {
        slug: "howdens-vs-benchmarx-kitchen-installation",
        title: "Howdens vs Benchmarx Kitchen Installation",
        metaTitle: "Howdens vs Benchmarx Kitchen Installation | Install My Kitchen",
        metaDescription: "Both Howdens and Benchmarx are trade-only kitchen suppliers with rigid units. Compare supply route, range, availability and installation ease for UK tradespeople.",
        answer: "Both Howdens and Benchmarx are trade-only kitchen suppliers. Howdens operates nationwide through local depots; Benchmarx is part of Travis Perkins. Both supply rigid, trade-quality units and are well-suited to independent installation.",
        col1Name: "Howdens",
        col2Name: "Benchmarx",
        criteria: ["Supply route", "Unit quality", "Range", "Availability", "Installation ease"],
        col1Points: ["Trade account, nationwide depots", "Solid trade-quality construction", "Extensive range of styles", "Over 700 depots UK-wide", "Rigid units, efficient fitting"],
        col2Points: ["Trade account, Travis Perkins branches", "Solid trade-quality construction", "Focused, practical range", "400+ UK locations", "Rigid units, efficient fitting"],
        bodyHtml: `
          <h2 class="text-2xl font-bold mb-4" style="color: var(--navy);">Overview</h2>
          <p class="mb-4" style="color: var(--text-soft);">Howdens and Benchmarx are both trade-only kitchen suppliers, meaning neither is directly accessible to homeowners. Both operate through branch or depot networks and require a trade account to purchase from. If you are a kitchen fitter or builder sourcing a kitchen for a client, you will likely have encountered both. Here is how they compare from an installation perspective.</p>

          <h2 class="text-2xl font-bold mb-4 mt-8" style="color: var(--navy);">Supply Route and Accounts</h2>
          <p class="mb-4" style="color: var(--text-soft);">Howdens operates through its own dedicated depot network — over 700 branches across the UK. Account holders collect kitchen components directly from their local depot. Howdens accounts are relatively straightforward to obtain for established tradespeople and small builders. The depot model means your fitter will typically have an ongoing relationship with depot staff, which can be advantageous when chasing replacement components or resolving delivery issues.</p>
          <p class="mb-4" style="color: var(--text-soft);">Benchmarx is part of the Travis Perkins Group and operates through Travis Perkins merchant branches. This means Benchmarx is co-located with a builders' merchant, which can be convenient for tradespeople who are already using Travis Perkins for other materials. If you already have a Travis Perkins account, opening a Benchmarx account is typically straightforward.</p>

          <h2 class="text-2xl font-bold mb-4 mt-8" style="color: var(--navy);">Product Range</h2>
          <p class="mb-4" style="color: var(--text-soft);">Howdens has a broad range of kitchen styles, from classic shaker designs to contemporary handleless kitchens, at multiple price points. Its ranges include Tewkesbury, Greenwich, and Burford, among many others. The extensive range gives fitters significant flexibility in matching a client's aesthetic requirements and budget.</p>
          <p class="mb-4" style="color: var(--text-soft);">Benchmarx has a more focused range, concentrating on practical, well-constructed kitchens at competitive trade prices. The range has expanded in recent years but remains narrower than Howdens. For clients with specific style requirements, Howdens may offer more options; for straightforward projects where value and practicality are the priority, Benchmarx is a strong contender.</p>

          <h2 class="text-2xl font-bold mb-4 mt-8" style="color: var(--navy);">Unit Quality and Construction</h2>
          <p class="mb-4" style="color: var(--text-soft);">Both Howdens and Benchmarx supply rigid, pre-assembled carcasses. Both are manufactured to trade standards and are robust enough for professional installation. Experienced fitters generally report a high standard of construction from both suppliers, with consistent tolerances that make fitting straightforward.</p>
          <p class="mb-4" style="color: var(--text-soft);">Howdens is sometimes regarded as the benchmark (no pun intended) for trade kitchen quality, having built its reputation in the sector over many decades. Benchmarx has made significant improvements to its quality standards and is increasingly competitive. For most residential installations, either brand will perform well over the long term.</p>

          <h2 class="text-2xl font-bold mb-4 mt-8" style="color: var(--navy);">Installation Ease</h2>
          <p class="mb-4" style="color: var(--text-soft);">Both brands supply rigid units with standard UK kitchen dimensions and fixings. Any experienced kitchen fitter will be equally comfortable installing either. Installation timelines are broadly equivalent — a standard kitchen from either Howdens or Benchmarx would take three to seven days depending on size and complexity.</p>
          <p class="mb-4" style="color: var(--text-soft);">One practical advantage of Howdens is the density of its depot network. With over 700 locations, a replacement component can often be collected the same day if something is found to be damaged or missing on installation morning. Benchmarx's network, while extensive, is somewhat smaller, which can occasionally mean a longer wait for replacement parts.</p>

          <h2 class="text-2xl font-bold mb-4 mt-8" style="color: var(--navy);">Cost</h2>
          <p class="mb-4" style="color: var(--text-soft);">Both Howdens and Benchmarx offer trade pricing, which is generally more competitive than consumer-facing retailers. Pricing varies by range and account status. Howdens fitters with established accounts and high purchasing volumes often receive preferential pricing that can represent good value for clients. Benchmarx pricing is also competitive and can in some cases undercut Howdens at equivalent specification.</p>
          <p class="mb-4" style="color: var(--text-soft);">For homeowners sourcing through a fitter, the overall cost will depend on the fitter's trade pricing and mark-up. A transparent fitter will show you the trade price and apply a clear margin, rather than quoting a single opaque supply-and-fit price. Ask your fitter to itemise kitchen supply and installation separately so you can make a fair comparison.</p>
        `,
        takeaways: [
          "Both Howdens and Benchmarx are trade-only suppliers — homeowners access them through a fitter or builder with an account.",
          "Howdens has a larger depot network and broader range; Benchmarx is competitive on price and is backed by Travis Perkins.",
          "Installation ease is broadly equivalent for both — rigid units, standard dimensions, and a familiar fitting process.",
        ],
        faqs: [
          { q: "Can a homeowner buy directly from Howdens or Benchmarx?", a: "No. Both are trade-only suppliers. As a homeowner, you need to arrange your kitchen through a fitter or builder who holds an account with the relevant supplier." },
          { q: "Is Howdens better than Benchmarx?", a: "Both supply quality rigid units for professional installation. Howdens has a wider range and larger depot network. Benchmarx is competitive on price and benefits from the Travis Perkins infrastructure. Your fitter's familiarity with each brand is often the deciding factor." },
          { q: "What is the advantage of a trade-only kitchen over a consumer kitchen?", a: "Trade kitchens are designed for professional installation at volume. They tend to have consistent tolerances, robust carcass construction, and efficient component logistics. Pricing is often more competitive than consumer retail when accessed through a fitter with an established trade account." },
          { q: "How do I get a Howdens or Benchmarx kitchen as a homeowner?", a: "You need a fitter or builder with a trade account. Explain that you are interested in a Howdens or Benchmarx kitchen and ask your fitter to arrange the design and ordering on your behalf. A good fitter will be transparent about trade pricing and mark-ups." },
        ],
      },
    },

    // ── 5. Wickes vs B&Q ───────────────────────────────────────────────────
    {
      params: { comparison: "wickes-vs-bq-kitchen-installation" },
      props: {
        slug: "wickes-vs-bq-kitchen-installation",
