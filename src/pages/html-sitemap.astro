  { slug: "in-frame", name: "In-Frame Kitchen Installation" },
  { slug: "luxury", name: "Luxury Kitchen Installation" },
];

const costGuides = [
  { href: "/costs/", name: "Kitchen Installation Cost Guide" },
  { href: "/cost/small-kitchen-cost/", name: "Small Kitchen Installation Cost" },
