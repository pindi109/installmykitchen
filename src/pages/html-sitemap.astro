---

<Base
  title={title}
  description={description}
  canonical={canonical}
>
  <meta slot="schema" name="robots" content="noindex, follow" />

  <Header slot="header" />

  <div class="container py-6">
    <Breadcrumbs
      items={[
        { label: "HTML Sitemap", href: "/html-sitemap/" },
      ]}
    />
  </div>

  <section class="section" style="background: var(--bg-light);">
    <div class="container">
      <div class="max-w-3xl">
        <h1 class="text-4xl font-extrabold mb-4 leading-tight" style="color: var(--navy);">
          Site Map
        </h1>
        <p class="text-lg leading-relaxed" style="color: var(--text-soft);">
          A complete listing of all pages on Install My Kitchen, organised by section.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="max-w-4xl">

        <!-- Core Pages -->
        <div class="mb-12 fade-up">
          <h2 class="text-2xl font-bold mb-5 pb-2 border-b" style="color: var(--navy); border-color: var(--teal);">
            Core Pages
          </h2>
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2">
            {[
              { href: "/", name: "Home" },
              { href: "/about/", name: "About Us" },
              { href: "/services/", name: "Our Services" },
              { href: "/survey/", name: "Book a Survey" },
              { href: "/contact/", name: "Contact" },
              { href: "/areas/", name: "Areas We Cover" },
              { href: "/retailers/", name: "Kitchen Retailers" },
              { href: "/premium/", name: "Premium Kitchen Installation" },
              { href: "/costs/", name: "Installation Costs" },
              { href: "/answers/", name: "Questions & Answers" },
              { href: "/privacy/", name: "Privacy Policy" },
              { href: "/terms/", name: "Terms & Conditions" },
            ].map((page) => (
              <li>
                <a
                  href={page.href}
                  class="flex items-center gap-2 py-1.5 hover:underline text-sm font-medium"
                  style="color: var(--teal);"
                >
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
                  {page.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Areas -->
        <div class="mb-12 fade-up">
          <h2 class="text-2xl font-bold mb-5 pb-2 border-b" style="color: var(--navy); border-color: var(--teal);">
            Areas We Cover
          </h2>
          <ul class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-2">
            {areaSlugs.map((area) => (
              <li>
                <a
                  href={`/areas/${area.slug}/`}
                  class="flex items-center gap-2 py-1.5 hover:underline text-sm"
                  style="color: var(--teal);"
                >
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
                  Kitchen Installation in {area.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Retailers -->
        <div class="mb-12 fade-up">
          <h2 class="text-2xl font-bold mb-5 pb-2 border-b" style="color: var(--navy); border-color: var(--teal);">
            Kitchen Retailers
          </h2>
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2">
            {retailerSlugs.map((retailer) => (
              <li>
                <a
                  href={`/retailers/${retailer.slug}/`}
                  class="flex items-center gap-2 py-1.5 hover:underline text-sm"
                  style="color: var(--teal);"
                >
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
                  {retailer.name} Kitchen Installation
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Kitchen Styles -->
        <div class="mb-12 fade-up">
          <h2 class="text-2xl font-bold mb-5 pb-2 border-b" style="color: var(--navy); border-color: var(--teal);">
            Kitchen Styles
          </h2>
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2">
            {styleSlugs.map((style) => (
              <li>
                <a
                  href={`/styles/${style.slug}/`}
                  class="flex items-center gap-2 py-1.5 hover:underline text-sm"
                  style="color: var(--teal);"
                >
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
                  {style.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Cost Guides -->
        <div class="mb-12 fade-up">
          <h2 class="text-2xl font-bold mb-5 pb-2 border-b" style="color: var(--navy); border-color: var(--teal);">
            Cost Guides
          </h2>
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2">
            {costGuides.map((guide) => (
              <li>
                <a
                  href={guide.href}
                  class="flex items-center gap-2 py-1.5 hover:underline text-sm"
                  style="color: var(--teal);"
                >
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
                  {guide.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Questions & Answers -->
        <div class="mb-12 fade-up">
          <h2 class="text-2xl font-bold mb-5 pb-2 border-b" style="color: var(--navy); border-color: var(--teal);">
            Questions &amp; Answers
          </h2>
          <ul class="grid grid-cols-1 gap-2">
            {questionSlugs.map((q) => (
              <li>
                <a
                  href={`/answers/${q.slug}/`}
                  class="flex items-start gap-2 py-1.5 hover:underline text-sm"
                  style="color: var(--teal);"
                >
                  <svg class="mt-0.5 flex-shrink-0" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
                  {q.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Base>
