  { slug: "how-many-units-in-a-small-kitchen", name: "How many units are in a small kitchen?" },
  { slug: "what-worktops-do-you-supply", name: "What worktops do you supply?" },
  { slug: "do-you-tile-after-kitchen-installation", name: "Do you tile after kitchen installation?" },
