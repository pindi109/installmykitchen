---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import StickyMobileCTA from "../../components/StickyMobileCTA.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import AnswerBlock from "../../components/AnswerBlock.astro";
import KeyTakeaway from "../../components/KeyTakeaway.astro";
import FAQ from "../../components/FAQ.astro";
import SupplierLogos from "../../components/SupplierLogos.astro";
import InternalLinks from "../../components/InternalLinks.astro";
import CTA from "../../components/CTA.astro";
import EnquiryForm from "../../components/EnquiryForm.astro";

import locationsData from "../../data/locations.json";

export function getStaticPaths() {
  return locationsData.map((loc, index) => ({
    params: { location: loc.slug },
    props: { location: loc, locationIndex: index },
  }));
}

const { location, locationIndex } = Astro.props;
const { name, slug, county, description, nearby } = location;

const canonical = `https://www.installmykitchen.co.uk/fitter/${slug}/`;

// Title — all are ≤60 chars (verified); longest is Stratford-upon-Avon at 55
const title = `Kitchen Fitter ${name} | Install My Kitchen`;

// Meta description — 140–160 chars, "kitchen fitter" intent
// Stratford-upon-Avon + county pushes past 160 chars, so county is omitted for that entry
const metaDescriptionBase = `Independent kitchen fitter in ${name}, ${county}. We fit Wren, Howdens, Magnet, IKEA & all retailers. Survey £195, credited back. Call 07399 651836.`;
const metaDescription = metaDescriptionBase.length <= 160
  ? metaDescriptionBase
  : `Independent kitchen fitter in ${name}. We fit Wren, Howdens, Magnet, IKEA & all major retailers. Survey £195, credited back. Call 07399 651836.`;

// KeyTakeaway points — 4 points relevant to finding a fitter in this area
const takeawayPoints = [
  `Independent kitchen fitter serving ${name} and surrounding ${county} areas — we work for you, not the retailer.`,
  `We fit kitchens from Wren, Howdens, Magnet, IKEA, Wickes, B&Q, Benchmarx and all major UK retailers.`,
  `A thorough pre-installation survey (£195, credited back on booking) ensures a fixed-price, no-surprise quote.`,
  `Call 07399 651836 or book online to arrange your survey in ${name} — appointments usually within two weeks.`,
];

// FAQ sets — alternated by locationIndex % 4 offset
// Set A: indices where (locationIndex % 2 === 0)
// Set B: indices where (locationIndex % 2 === 1)
// Using locationIndex % 4 to offset which FAQ set as instructed

const faqSetA = [
  {
    q: `How do I find a reliable kitchen fitter in ${name}?`,
    a: `Start by looking for an independent fitter with verifiable local experience — one who operates in ${name} regularly and can provide a detailed, itemised quote after visiting your home. Install My Kitchen carries out a pre-installation survey before quoting, so you receive a fixed price with no hidden extras. Call us on 07399 651836 or submit an enquiry online.`,
  },
  {
    q: `Do you cover ${name} postcodes?`,
    a: `Yes. We cover ${name} and the surrounding ${county} area as part of our core service region. If you are unsure whether your specific postcode falls within our operating area, please call 07399 651836 or email info@installmykitchen.co.uk and we will confirm straight away.`,
  },
  {
    q: `How much does a kitchen fitter cost in ${name}?`,
    a: `Kitchen fitting costs in ${name} vary depending on the size of your kitchen, the complexity of the installation, and the appliances involved. We provide fixed-price quotations following a £195 pre-installation survey (fully credited against your installation balance when you proceed). This ensures you have an accurate, itemised cost before committing.`,
  },
  {
    q: `How long does kitchen fitting take?`,
    a: `A straightforward kitchen replacement in ${name} typically takes three to five working days for a standard sized kitchen. Larger kitchens, those with island units, or projects requiring additional trades (plumbing, electrical, plastering) may take longer. We confirm a realistic timescale during your pre-installation survey so you can plan accordingly.`,
  },
];

const faqSetB = [
  {
    q: `Are you an independent kitchen fitter?`,
    a: `Yes — Install My Kitchen is fully independent. We are not affiliated with, employed by, or tied to any kitchen retailer. This means our advice and workmanship are focused entirely on your satisfaction rather than retailer sales targets. We fit kitchens purchased from any major UK retailer, including Wren, Howdens, Magnet, and IKEA.`,
  },
  {
    q: `What retailers do you fit in ${name}?`,
    a: `We fit kitchens from all major UK retailers in ${name}, including Wren Kitchens, Howdens Joinery, Magnet, IKEA, Wickes, B&Q, Benchmarx, DIY Kitchens, Kutchenhaus, Symphony, and Masterclass. We also install premium British and German brands. If you have already purchased your kitchen from another supplier, call us on 07399 651836 and we will confirm coverage.`,
  },
  {
    q: `Do you offer a survey before fitting?`,
    a: `Yes — every project begins with a pre-installation survey priced at £195, which is credited in full against your installation balance when you book. During the survey, one of our experienced fitters visits your ${name} home to take precise measurements, review your kitchen plan, and identify any potential complications before installation day. This ensures your final quote is fixed and fully itemised.`,
  },
  {
    q: `What areas near ${name} do you cover?`,
    a: `As well as ${name}, we regularly carry out kitchen fitting across ${county} and neighbouring areas. ${nearby.slice(0, 3).map((s: string) => {
      const n = locationsData.find((l) => l.slug === s);
      return n ? n.name : s;
    }).join(", ")} are among the locations we serve nearby. Visit our areas pages or call 07399 651836 to confirm coverage for your postcode.`,
  },
];

// Select FAQ set based on locationIndex % 2; use locationIndex % 4 to offset starting question
const useSetB = locationIndex % 2 === 1;
const rawFaqs = useSetB ? faqSetB : faqSetA;
// Rotate the 4 questions by (locationIndex % 4) positions for variety across pages
const offset = locationIndex % 4;
const faqItems = [...rawFaqs.slice(offset), ...rawFaqs.slice(0, offset)];

// Nearby fitter links — up to first 4 nearby slugs → /fitter/{slug}/
const nearbyFitterLinks = (nearby as string[])
  .slice(0, 4)
  .map((nearbySlug) => {
    const nearbyLocation = locationsData.find((l) => l.slug === nearbySlug);
    return nearbyLocation
      ? {
          label: `Kitchen Fitter in ${nearbyLocation.name}`,
          href: `/fitter/${nearbySlug}/`,
          description: `${nearbyLocation.county} — independent kitchen fitting`,
        }
      : null;
  })
  .filter(Boolean) as { label: string; href: string; description: string }[];

// Also add a link back to the /areas/{slug}/ installation page
const areaLink = {
  label: `Kitchen Installation in ${name}`,
  href: `/areas/${slug}/`,
  description: `Full installation service for ${name} and ${county}`,
};

const allNearbyLinks = [...nearbyFitterLinks, areaLink];

// LocalBusiness + Service JSON-LD
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "Install My Kitchen",
  url: "https://www.installmykitchen.co.uk",
  telephone: "07399651836",
  email: "info@installmykitchen.co.uk",
  address: {
    "@type": "PostalAddress",
    streetAddress: "242 Hollyfast Road, Coundon",
    addressLocality: "Coventry",
    postalCode: "CV6 2AH",
    addressCountry: "GB",
  },
  areaServed: {
    "@type": "Place",
    name: name,
  },
  description: `Independent kitchen fitting service covering ${name} and the wider ${county} area.`,
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: `Kitchen Fitter in ${name}`,
  provider: {
    "@type": "LocalBusiness",
    name: "Install My Kitchen",
    url: "https://www.installmykitchen.co.uk",
  },
  areaServed: {
    "@type": "Place",
    name: name,
  },
  description: `Professional independent kitchen fitting service in ${name}, covering all major UK retailers including Wren, Howdens, Magnet, IKEA and Wickes.`,
  serviceType: "Kitchen Fitting",
};
---

<Base
  title={title}
  description={metaDescription}
  canonical={canonical}
>
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

  <Header slot="header" />

  <!-- Breadcrumbs -->
  <div class="container py-6">
    <Breadcrumbs
      items={[
        { label: "Areas", href: "/areas/" },
        { label: name, href: `/areas/${slug}/` },
        { label: "Kitchen Fitter", href: `/fitter/${slug}/` },
      ]}
    />
  </div>

  <!-- Hero -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-extrabold mb-5 leading-tight" style="color: var(--navy);">
          Kitchen Fitter in {name} — Independent Installation Service
        </h1>
        <AnswerBlock
          answer={`Install My Kitchen is an independent kitchen fitter based in Coventry, serving ${name} and surrounding ${county} areas. We fit kitchens purchased from Wren, Howdens, Magnet, IKEA and all major retailers. Call 07399 651836 or book a survey online.`}
        />
        <KeyTakeaway points={takeawayPoints} />
      </div>
    </div>
  </section>

  <!-- Section 1: Why Choose an Independent Kitchen Fitter -->
  <section class="section">
    <div class="container">
      <div class="max-w-3xl fade-up">
        <h2 class="text-3xl font-bold mb-4" style="color: var(--navy);">
          Why Choose an Independent Kitchen Fitter in {name}?
        </h2>
        <p class="text-lg leading-relaxed mb-4" style="color: var(--text-soft);">
          {description}
        </p>
        <p class="leading-relaxed" style="color: var(--text-soft);">
          Choosing an independent kitchen fitter in {name} means your fitter has no commercial tie to the retailer you purchased from. Install My Kitchen works exclusively for the homeowner — we are not employed by Wren, Howdens, or any other supplier, which means our priority is the quality of your installation rather than throughput targets. Our fitters take the time to get the details right, from perfectly level cabinets to correctly routed pipework, delivering a finish that an in-house retail fitting team often cannot match. Based in Coundon, Coventry, we are well placed to serve {name} and can typically offer a survey appointment within a fortnight.
        </p>
      </div>
    </div>
  </section>

  <!-- Section 2: Kitchens We Fit -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container">
      <div class="max-w-3xl fade-up">
        <h2 class="text-3xl font-bold mb-4" style="color: var(--navy);">
          Kitchens We Fit in {name}
        </h2>
        <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
          We fit kitchens from every major UK retailer across {name}. Whether you have chosen a range from <strong>Wren Kitchens</strong>, <strong>Howdens Joinery</strong>, <strong>Magnet</strong>, <strong>IKEA</strong>, <strong>Wickes</strong>, <strong>B&amp;Q</strong>, or <strong>Benchmarx</strong>, our team can handle the full installation — units, worktops, appliances, plinths, and cornices. We also install kitchens from DIY Kitchens, Kutchenhaus, Symphony, Masterclass, and a wide range of premium British and German brands.
        </p>
        <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
          Because we hold trade accounts with Howdens and Benchmarx, we can source and collect directly from the local depot where required — useful for fill-in items and remedial parts without you having to chase the supplier yourself. For retail-supplied kitchens from Wren, Magnet, IKEA, or similar, we co-ordinate the delivery schedule with you to make sure everything is on site and accounted for before we begin.
        </p>
        <p class="leading-relaxed" style="color: var(--text-soft);">
          If you have already purchased your kitchen and are now looking for a reliable fitter in {name}, call us on <a href="tel:07399651836" class="font-semibold" style="color: var(--teal);">07399 651836</a> to discuss your project. If you are still in the planning stage, we are happy to advise on layout, worktop selection, and appliance choices before you commit to a retailer.
        </p>
      </div>
      <div class="mt-10 fade-up">
        <SupplierLogos />
      </div>
    </div>
  </section>

  <!-- Section 3: The Survey Process -->
  <section class="section">
    <div class="container">
      <div class="max-w-3xl fade-up">
        <h2 class="text-3xl font-bold mb-4" style="color: var(--navy);">
          The Survey Process
        </h2>
        <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
          Every kitchen fitting project we undertake in {name} starts with a pre-installation survey. The survey fee is <strong>£195</strong> and is credited back in full against your installation balance when you proceed with the booking — so if you go ahead, the survey costs you nothing.
        </p>
        <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
          During the survey, one of our experienced fitters visits your home in {name} to take precise measurements of the room, review your kitchen plan or retailer drawings, and assess the existing conditions — including wall straightness, floor levels, ceiling heights, existing pipework routes, and appliance positions. We identify any potential complications before they become expensive problems on installation day, and if the project requires input from a plumber, electrician, or plasterer, we flag this at the survey stage so you can arrange and budget for those trades in advance.
        </p>
        <p class="leading-relaxed" style="color: var(--text-soft);">
          Following the survey you receive a fully itemised, fixed-price installation quote. No estimates, no day-rate surprises — just a clear figure covering everything we have agreed to do. To book your survey in {name}, call <a href="tel:07399651836" class="font-semibold" style="color: var(--teal);">07399 651836</a>, email <a href="mailto:info@installmykitchen.co.uk" class="font-semibold" style="color: var(--teal);">info@installmykitchen.co.uk</a>, or complete the enquiry form below.
        </p>
      </div>
    </div>
  </section>

  <!-- Nearby Areas & Internal Links -->
  {allNearbyLinks.length > 0 && (
    <section class="section" style="background: var(--bg-light);">
      <div class="container">
        <div class="fade-up">
          <InternalLinks
            links={allNearbyLinks}
            heading={`Kitchen Fitters Near ${name}`}
          />
        </div>
      </div>
    </section>
  )}

  <!-- FAQ -->
  <section class="section">
    <div class="container">
      <div class="max-w-3xl fade-up">
        <h2 class="text-3xl font-bold mb-8" style="color: var(--navy);">
          Frequently Asked Questions
        </h2>
        <FAQ items={faqItems} schemaId={`faq-fitter-${slug}`} />
      </div>
    </div>
  </section>

  <!-- Enquiry Form -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container">
      <div class="max-w-2xl mx-auto fade-up">
        <EnquiryForm formTitle={`Book Your Kitchen Fitting Survey in ${name}`} showSurveyOption={true} />
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTA
    heading={`Book Your Kitchen Fitting Survey in ${name}`}
    subtext={`Survey fee £195 — credited back in full when you proceed. Independent kitchen fitters covering ${name} and the wider ${county} area.`}
    primaryLabel="Book Your Survey"
    primaryHref="/survey/"
    secondaryLabel="Call 07399 651836"
    secondaryHref="tel:07399651836"
    dark={true}
  />

  <Footer slot="footer" />
  <StickyMobileCTA slot="sticky-cta" />
</Base>
