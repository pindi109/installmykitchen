---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import StickyMobileCTA from "../../components/StickyMobileCTA.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import AnswerBlock from "../../components/AnswerBlock.astro";
import KeyTakeaway from "../../components/KeyTakeaway.astro";
import EnquiryForm from "../../components/EnquiryForm.astro";
import FAQ from "../../components/FAQ.astro";
import InternalLinks from "../../components/InternalLinks.astro";
import CTA from "../../components/CTA.astro";

import locationsData from "../../data/locations.json";

// ── Inline appliance data ──────────────────────────────────────────────────
interface FAQItem {
  q: string;
  a: string;
}

interface Appliance {
  slug: string;
  name: string;
  h1Fragment: string;
  description: string;
  fromPriceCW: number;
  fromPriceBerks: number;
  faqs: FAQItem[];
}

const APPLIANCES: Appliance[] = [
  {
    slug: "integrated-dishwasher-installation",
    name: "Integrated Dishwasher Installation",
    h1Fragment: "integrated dishwasher installation",
    description: "Installing an integrated dishwasher requires correctly positioning the appliance within its housing, making the water supply and waste connections, fitting or rehinging the door panel, and testing every cycle before handover. Our fitters handle all connection work and ensure the unit operates correctly before leaving.",
    fromPriceCW: 75,
    fromPriceBerks: 95,
    faqs: [
      {
        "q": "Do I need a plumber as well as a fitter for a dishwasher installation?",
        "a": "No — our kitchen fitters are experienced in making the standard hot or cold water supply and waste connections required for a dishwasher installation. A separate plumber is not normally needed."
      },
      {
        "q": "Can you fit any brand of integrated dishwasher?",
        "a": "Yes — we work with all major brands including Bosch, Siemens, AEG, Miele, Neff, Hotpoint, and Beko. We confirm appliance dimensions against the housing cabinet before installation day."
      },
      {
        "q": "Do I need to supply the appliance or can you source it?",
        "a": "We fit appliances supplied by you. We recommend purchasing from a reputable retailer and having the appliance on site before our arrival."
      },
      {
        "q": "How long does an integrated dishwasher installation take?",
        "a": "A straightforward installation into an existing housing with existing supply points typically takes 1.5–2.5 hours. Installations requiring new supply or waste routing take longer and will be quoted accordingly."
      }
    ]
  },
  {
    slug: "integrated-fridge-installation",
    name: "Integrated Fridge Installation",
    h1Fragment: "integrated fridge installation",
    description: "An integrated fridge must sit level, be correctly ventilated according to the manufacturer's requirements, and have its door panel and hinges set up to match your kitchen doors. We handle every element of the installation and leave the unit clean and fully tested.",
    fromPriceCW: 65,
    fromPriceBerks: 85,
    faqs: [
      {
        "q": "Does an integrated fridge need any special electrical work?",
        "a": "Integrated fridges simply plug into a standard 13-amp socket within the housing cabinet. If no socket is present inside the unit, an electrician will need to add one before we install the appliance."
      },
      {
        "q": "How important is ventilation for an integrated fridge?",
        "a": "Ventilation is critical for efficiency and appliance longevity. We fit the manufacturer-specified ventilation grilles and ensure adequate airflow clearances are maintained within the housing."
      },
      {
        "q": "Can you rehinge the door to open in the opposite direction?",
        "a": "Yes — many integrated fridge models support door reversal. We can carry this out at the time of installation if your kitchen layout requires it."
      },
      {
        "q": "What if my housing cabinet is a non-standard size?",
        "a": "We assess housing dimensions before installation and advise if any adaptation is needed. In some cases, the housing plinth or top infill panel requires adjustment to achieve a flush finish."
      }
    ]
  },
  {
    slug: "integrated-fridge-freezer-installation",
    name: "Integrated Fridge Freezer Installation",
    h1Fragment: "integrated fridge freezer installation",
    description: "Integrated fridge freezers require careful positioning within a tall housing, correct levelling to prevent door misalignment, and precise fitting of the door panels across both compartments. We carry out the full installation including panel alignment, ventilation checks, and post-installation testing.",
    fromPriceCW: 85,
    fromPriceBerks: 110,
    faqs: [
      {
        "q": "Why is levelling particularly important for a fridge freezer?",
        "a": "A fridge freezer that is not level will not drain condensation correctly and its doors may not seal properly, leading to reduced efficiency. We always level the appliance precisely before fitting the door panels."
      },
      {
        "q": "Can you fit door panels that match my existing kitchen doors?",
        "a": "Yes — we fit door panels supplied by you or your kitchen retailer. The panels are attached to the appliance door using a fixing kit and aligned to match the rest of your kitchen."
      },
      {
        "q": "How long does a fridge freezer installation take?",
        "a": "Fitting a fridge freezer into an existing tall housing typically takes 2–3 hours, including levelling, panel fitting, and testing. Installations requiring housing adjustment will take longer."
      },
      {
        "q": "Does the housing need any preparation before you arrive?",
        "a": "The housing should be clear of any previous appliance and have a working 13-amp socket inside or immediately adjacent. We will confirm all requirements when you book."
      }
    ]
  },
  {
    slug: "washing-machine-installation",
    name: "Washing Machine Installation",
    h1Fragment: "washing machine installation",
    description: "Whether freestanding or integrated, washing machine installation involves connecting the machine to hot and cold water supplies and a suitable waste outlet, levelling the appliance, removing transit bolts, and running a test wash before handover. We carry out the full installation and dispose of all packaging on request.",
    fromPriceCW: 65,
    fromPriceBerks: 85,
    faqs: [
      {
        "q": "Do you remove transit bolts and run a test wash?",
        "a": "Yes — removing transit bolts before use is essential, and we always carry this out as part of the installation. We then run a short test cycle to confirm the machine is operating and draining correctly."
      },
      {
        "q": "Can you disconnect and remove my old washing machine?",
        "a": "Yes — old appliance disconnection and removal can be added to the installation visit. Please let us know when enquiring so we can allow extra time."
      },
      {
        "q": "What supply connections are needed for a washing machine?",
        "a": "Most washing machines require a cold water supply connection only (hot-fill models are now rare). You also need a waste outlet — typically into the sink waste via a standpipe or directly into a trap."
      },
      {
        "q": "Can you install a washing machine in a non-kitchen location?",
        "a": "Yes — we install washing machines in utility rooms, bathrooms with suitable drainage, and outbuildings where appropriate supply and waste points are available."
      }
    ]
  },
  {
    slug: "integrated-oven-installation",
    name: "Integrated Oven Installation",
    h1Fragment: "integrated oven installation",
    description: "Fitting an integrated oven into a housing column requires correct electrical connection by a Part P-qualified installer, precise positioning within the housing, and careful testing of all functions. We coordinate the electrical connection and carry out all mechanical installation work to leave the oven fully operational.",
    fromPriceCW: 95,
    fromPriceBerks: 120,
    faqs: [
      {
        "q": "Do you carry out the electrical connection for an oven?",
        "a": "Oven electrical connections must be made by a Part P-registered electrician. We work alongside a qualified electrician and coordinate the connection as part of our installation service — this is included in the price we quote."
      },
      {
        "q": "What type of electrical supply does an integrated oven need?",
        "a": "Most integrated ovens require a dedicated 13-amp or 16-amp circuit, depending on the appliance rating. We confirm the supply requirements with you before installation and arrange any necessary electrical work."
      },
      {
        "q": "Can you fit both an oven and a combi-microwave in the same column?",
        "a": "Yes — fitting a double oven stack or an oven and microwave combination is a standard job for our team. We confirm the housing dimensions and electrical supply requirements during the quote stage."
      },
      {
        "q": "How long does an integrated oven installation take?",
        "a": "A single oven installation typically takes 1.5–2.5 hours including all testing. A double oven or oven-microwave combination takes 2.5–4 hours depending on the housing configuration."
      }
    ]
  },
];

const REMEDIAL_LOCATION_SLUGS = [
  "coventry",
  "solihull",
  "leamington-spa",
  "warwick",
  "kenilworth",
  "nuneaton",
  "rugby",
  "reading",
  "bracknell",
  "slough",
  "maidenhead",
  "windsor",
  "wokingham",
  "newbury",
  "ascot",
];

export function getStaticPaths() {
  const APPLIANCES_LOCAL: { slug: string; name: string; h1Fragment: string; description: string; fromPriceCW: number; fromPriceBerks: number; faqs: { q: string; a: string }[] }[] = [
    {
      slug: "integrated-dishwasher-installation",
      name: "Integrated Dishwasher Installation",
      h1Fragment: "integrated dishwasher installation",
      description: "Installing an integrated dishwasher requires correctly positioning the appliance within its housing, making the water supply and waste connections, fitting or rehinging the door panel, and testing every cycle before handover.",
      fromPriceCW: 75,
      fromPriceBerks: 95,
      faqs: [
        { q: "Do I need a plumber as well as a fitter for a dishwasher installation?", a: "No — our kitchen fitters are experienced in making the standard hot or cold water supply and waste connections required for a dishwasher installation. A separate plumber is not normally needed." },
        { q: "Can you fit any brand of integrated dishwasher?", a: "Yes — we work with all major brands including Bosch, Siemens, AEG, Miele, Neff, Hotpoint, and Beko. We confirm appliance dimensions against the housing cabinet before installation day." },
        { q: "Do I need to supply the appliance or can you source it?", a: "We fit appliances supplied by you. We recommend purchasing from a reputable retailer and having the appliance on site before our arrival." },
        { q: "How long does an integrated dishwasher installation take?", a: "A straightforward installation into an existing housing with existing supply points typically takes 1.5–2.5 hours. Installations requiring new supply or waste routing take longer and will be quoted accordingly." }
      ]
    },
    {
      slug: "integrated-fridge-installation",
      name: "Integrated Fridge Installation",
      h1Fragment: "integrated fridge installation",
      description: "An integrated fridge must sit level, be correctly ventilated according to the manufacturer's requirements, and have its door panel and hinges set up to match your kitchen doors.",
      fromPriceCW: 65,
      fromPriceBerks: 85,
      faqs: [
        { q: "Does an integrated fridge need any special electrical work?", a: "Integrated fridges simply plug into a standard 13-amp socket within the housing cabinet. If no socket is present inside the unit, an electrician will need to add one before we install the appliance." },
        { q: "How important is ventilation for an integrated fridge?", a: "Ventilation is critical for efficiency and appliance longevity. We fit the manufacturer-specified ventilation grilles and ensure adequate airflow clearances are maintained within the housing." },
        { q: "Can you rehinge the door to open in the opposite direction?", a: "Yes — many integrated fridge models support door reversal. We can carry this out at the time of installation if your kitchen layout requires it." },
        { q: "What if my housing cabinet is a non-standard size?", a: "We assess housing dimensions before installation and advise if any adaptation is needed. In some cases, the housing plinth or top infill panel requires adjustment to achieve a flush finish." }
      ]
    },
    {
      slug: "integrated-fridge-freezer-installation",
      name: "Integrated Fridge Freezer Installation",
      h1Fragment: "integrated fridge freezer installation",
      description: "Integrated fridge freezers require careful positioning within a tall housing, correct levelling to prevent door misalignment, and precise fitting of the door panels across both compartments.",
      fromPriceCW: 85,
      fromPriceBerks: 110,
      faqs: [
        { q: "Why is levelling particularly important for a fridge freezer?", a: "A fridge freezer that is not level will not drain condensation correctly and its doors may not seal properly, leading to reduced efficiency. We always level the appliance precisely before fitting the door panels." },
        { q: "Can you fit door panels that match my existing kitchen doors?", a: "Yes — we fit door panels supplied by you or your kitchen retailer. The panels are attached to the appliance door using a fixing kit and aligned to match the rest of your kitchen." },
        { q: "How long does a fridge freezer installation take?", a: "Fitting a fridge freezer into an existing tall housing typically takes 2–3 hours, including levelling, panel fitting, and testing. Installations requiring housing adjustment will take longer." },
        { q: "Does the housing need any preparation before you arrive?", a: "The housing should be clear of any previous appliance and have a working 13-amp socket inside or immediately adjacent. We will confirm all requirements when you book." }
      ]
    },
    {
      slug: "washing-machine-installation",
      name: "Washing Machine Installation",
      h1Fragment: "washing machine installation",
      description: "Whether freestanding or integrated, washing machine installation involves connecting the machine to hot and cold water supplies and a suitable waste outlet, levelling the appliance, removing transit bolts, and running a test wash before handover.",
      fromPriceCW: 65,
      fromPriceBerks: 85,
      faqs: [
        { q: "Do you remove transit bolts and run a test wash?", a: "Yes — removing transit bolts before use is essential, and we always carry this out as part of the installation. We then run a short test cycle to confirm the machine is operating and draining correctly." },
        { q: "Can you disconnect and remove my old washing machine?", a: "Yes — old appliance disconnection and removal can be added to the installation visit. Please let us know when enquiring so we can allow extra time." },
        { q: "What supply connections are needed for a washing machine?", a: "Most washing machines require a cold water supply connection only. You also need a waste outlet — typically into the sink waste via a standpipe or directly into a trap." },
        { q: "Can you install a washing machine in a non-kitchen location?", a: "Yes — we install washing machines in utility rooms, bathrooms with suitable drainage, and outbuildings where appropriate supply and waste points are available." }
      ]
    },
    {
      slug: "integrated-oven-installation",
      name: "Integrated Oven Installation",
      h1Fragment: "integrated oven installation",
      description: "Fitting an integrated oven into a housing column requires correct electrical connection by a Part P-qualified installer, precise positioning within the housing, and careful testing of all functions.",
      fromPriceCW: 95,
      fromPriceBerks: 120,
      faqs: [
        { q: "Do you carry out the electrical connection for an oven?", a: "Oven electrical connections must be made by a Part P-registered electrician. We work alongside a qualified electrician and coordinate the connection as part of our installation service — this is included in the price we quote." },
        { q: "What type of electrical supply does an integrated oven need?", a: "Most integrated ovens require a dedicated 13-amp or 16-amp circuit, depending on the appliance rating. We confirm the supply requirements with you before installation and arrange any necessary electrical work." },
        { q: "Can you fit both an oven and a combi-microwave in the same column?", a: "Yes — fitting a double oven stack or an oven and microwave combination is a standard job for our team. We confirm the housing dimensions and electrical supply requirements during the quote stage." },
        { q: "How long does an integrated oven installation take?", a: "A single oven installation typically takes 1.5–2.5 hours including all testing. A double oven or oven-microwave combination takes 2.5–4 hours depending on the housing configuration." }
      ]
    },
  ];

  const REMEDIAL_LOCATION_SLUGS_LOCAL = [
    "coventry", "solihull", "leamington-spa", "warwick", "kenilworth",
    "nuneaton", "rugby", "reading", "bracknell", "slough",
    "maidenhead", "windsor", "wokingham", "newbury", "ascot",
  ];

  const locations = REMEDIAL_LOCATION_SLUGS_LOCAL
    .map((slug) => locationsData.find((l) => l.slug === slug))
    .filter(Boolean) as typeof locationsData;

  const paths: {
    params: { appliance: string; location: string };
    props: {
      appliance: typeof APPLIANCES_LOCAL[0];
      location: typeof locationsData[0];
      applianceIndex: number;
      locationIndex: number;
    };
  }[] = [];

  APPLIANCES_LOCAL.forEach((appliance, applianceIndex) => {
    locations.forEach((location, locationIndex) => {
      paths.push({
        params: {
          appliance: appliance.slug,
          location: location.slug,
        },
        props: { appliance, location, applianceIndex, locationIndex },
      });
    });
  });

  return paths;
}

const { appliance, location, applianceIndex, locationIndex } = Astro.props;
const { name: applianceName, slug: applianceSlug, h1Fragment, description: applianceDescription, fromPriceCW, fromPriceBerks, faqs: applianceFaqs } = appliance;
const { name: locationName, slug: locationSlug, county, localNote, kitchenNotes } = location;

// Is this a Berkshire/southern location?
const BERKS_SLUGS = ["reading", "bracknell", "slough", "maidenhead", "windsor", "wokingham", "newbury", "ascot"];
const isBerks = BERKS_SLUGS.includes(locationSlug);
const fromPrice = isBerks ? fromPriceBerks : fromPriceCW;

const canonical = `https://installmykitchen.co.uk/appliances/${applianceSlug}-${locationSlug}/`;

// Title ≤60 chars
const rawTitle = `${applianceName} ${locationName} | Install My Kitchen`;
const title = rawTitle.length <= 60
  ? rawTitle
  : `${applianceName} in ${locationName} | IMK`.length <= 60
    ? `${applianceName} in ${locationName} | IMK`
    : `${applianceName.slice(0, 30)} ${locationName} | IMK`;

// Meta desc 140–160 chars
const metaDescription = `Professional ${h1Fragment} in ${locationName}, ${county}. Expert independent appliance fitting — from £${fromPrice}. Fixed-price quote, no call-out fee. Call Install My Kitchen today.`;

// Key takeaway points
const takeawayPoints = [
  `From £${fromPrice} — fixed-price quote, no hidden extras`,
  `Specialist ${h1Fragment} across ${locationName} and ${county}`,
  "All connections, levelling, and post-installation testing included",
  "Experienced independent fitters — no retailer affiliation",
];

// Internal links — 8 links as specified
const internalLinks = [
  {
    label: "Repairs & Remedial Services",
    href: "/repairs/",
    description: "All remedial kitchen fitting services",
  },
  {
    label: "Appliance Installation Service",
    href: "/services/appliance-installation/",
    description: "Our full appliance installation offering",
  },
  {
    label: `Kitchen Services in ${locationName}`,
    href: `/areas/${locationSlug}/`,
    description: `All fitting services available in ${locationName}`,
  },
  {
    label: `Kitchen Cost in ${locationName}`,
    href: `/kitchen-cost/${locationSlug}/`,
    description: `Installation pricing guide for ${locationName} homeowners`,
  },
  {
    label: `Book a Survey in ${locationName}`,
    href: `/survey/${locationSlug}/`,
    description: `Home survey and fixed-price quote for ${locationName}`,
  },
  {
    label: "Contact Us",
    href: "/contact/",
    description: "Get in touch to discuss your kitchen project",
  },
  {
    label: "All Services",
    href: "/services/",
    description: "Browse our complete kitchen fitting service range",
  },
  {
    label: "Kitchen Costs Guide",
    href: "/costs/",
    description: "Detailed pricing guide for every type of kitchen job",
  },
];

// Service JSON-LD
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: `${applianceName} in ${locationName}`,
  provider: {
    "@type": "LocalBusiness",
    name: "Install My Kitchen",
    url: "https://installmykitchen.co.uk",
    telephone: "07399651836",
    address: {
      "@type": "PostalAddress",
      streetAddress: "242 Hollyfast Road, Coundon",
      addressLocality: "Coventry",
      postalCode: "CV6 2AH",
      addressCountry: "GB",
    },
  },
  areaServed: {
    "@type": "Place",
    name: locationName,
  },
  description: `Professional ${h1Fragment} in ${locationName}, ${county}. Expert independent appliance fitting from £${fromPrice}.`,
  serviceType: applianceName,
  offers: {
    "@type": "Offer",
    priceCurrency: "GBP",
    price: String(fromPrice),
    description: `From £${fromPrice} — fixed-price quote provided after assessment`,
  },
};
---

<Base
  title={title}
  description={metaDescription}
  canonical={canonical}
  noHero={true}
>
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

  <Header slot="header" />

  <!-- Breadcrumbs -->
  <div class="container py-6">
    <Breadcrumbs
      items={[
        { label: "Appliances", href: "/appliances/" },
        { label: `${applianceName} in ${locationName}`, href: canonical },
      ]}
    />
  </div>

  <!-- Hero / H1 -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-extrabold mb-5 leading-tight" style="color: var(--navy);">
          {applianceName} in {locationName}
        </h1>

        <AnswerBlock
          answer={`Install My Kitchen provides professional ${h1Fragment} across ${locationName} and the wider ${county} area. We handle all connections, levelling, and testing — leaving the appliance fully operational from day one. From £${fromPrice} with a fixed-price quote guaranteed upfront.`}
        />

        <KeyTakeaway points={takeawayPoints} />
      </div>
    </div>
  </section>

  <!-- What's involved -->
  <section class="section">
    <div class="container">
      <div class="max-w-3xl fade-up">
        <h2 class="text-3xl font-bold mb-4" style="color: var(--navy);">
          What Does {applianceName} Involve?
        </h2>
        <p class="text-lg leading-relaxed mb-4" style="color: var(--text-soft);">
          {applianceDescription}
        </p>
        <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
          Every installation we carry out in {locationName} begins with a check of the housing, supply points, and any existing appliance before we start work. This allows us to identify any additional requirements — such as a missing isolation valve or a non-standard housing depth — before the appliance is in position.
        </p>
        <p class="leading-relaxed" style="color: var(--text-soft);">
          We carry the tools and fittings needed for a complete installation in a single visit. No return trips, no extra charges for standard connection work.
        </p>
      </div>
    </div>
  </section>

  <!-- Why professional fitting matters -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container">
      <div class="max-w-3xl fade-up">
        <h2 class="text-3xl font-bold mb-4" style="color: var(--navy);">
          Why Professional {applianceName} Matters
        </h2>
        <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
          Appliance manufacturers and many home insurers require that appliances are professionally installed to maintain warranty coverage and ensure compliance with water supply regulations. A poorly installed appliance can also cause water damage, inefficient operation, and premature failure — costs that far exceed a professional installation fee.
        </p>
        <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
          Our fitters carry out {h1Fragment} to the manufacturer's specification and to current UK building and water regulations. We test every connection and run a post-installation check before leaving your property.
        </p>
        <p class="leading-relaxed" style="color: var(--text-soft);">
          {kitchenNotes ?? `${locationName} properties vary considerably in their plumbing layouts, and our fitters are experienced in adapting connections to suit the range of configurations found across ${county}.`}
        </p>
      </div>
    </div>
  </section>

  <!-- Pricing section -->
  <section class="section">
    <div class="container">
      <div class="max-w-3xl fade-up">
        <h2 class="text-3xl font-bold mb-4" style="color: var(--navy);">
          {applianceName} Pricing in {locationName}
        </h2>
        <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
          Our {h1Fragment} service in {locationName} starts from <strong>£{fromPrice}</strong>. The final price depends on the complexity of the connections required, whether any existing appliance needs to be disconnected and removed, and any additional adaptation needed to the housing cabinet.
        </p>
        <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
          Combining appliance installation with other work — such as a door replacement or full unit adjustment — allows us to complete everything in a single visit and reduce the overall cost.
        </p>
        <div class="card p-6 border-l-4 mt-4" style="border-left-color: var(--teal); background: rgba(15,118,110,0.05);">
          <p class="font-semibold mb-1" style="color: var(--navy);">From £{fromPrice} — {locationName} area</p>
          <p class="text-sm" style="color: var(--text-soft);">Fixed-price quote provided before work starts. No call-out fee for combined visits with other installation work.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Local context -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container">
      <div class="max-w-3xl fade-up">
        <h2 class="text-3xl font-bold mb-4" style="color: var(--navy);">
          {applianceName} Across {locationName}
        </h2>
        <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
          We cover {locationName} and the surrounding {county} area as part of our broader service territory. Our fitters are based locally and familiar with the property types and kitchen configurations commonly found across the area.
        </p>
        <p class="leading-relaxed" style="color: var(--text-soft);">
          {localNote ?? `Whether you are in a new-build property or an older home with an existing kitchen that needs an appliance upgrade, our team brings the same level of care and expertise to every installation in ${locationName}.`}
        </p>
      </div>
    </div>
  </section>

  <!-- Enquiry Form mid-page -->
  <section class="section">
    <div class="container">
      <div class="max-w-2xl mx-auto fade-up">
        <p class="text-center text-sm mb-6 font-medium" style="color: var(--teal);">
          Get a Fixed-Price Quote for {applianceName} in {locationName}
        </p>
        <EnquiryForm formTitle={`Quote: ${applianceName} — ${locationName}`} showSurveyOption={false} />
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container">
      <div class="max-w-3xl fade-up">
        <h2 class="text-3xl font-bold mb-8" style="color: var(--navy);">
          Frequently Asked Questions
        </h2>
        <FAQ items={applianceFaqs} schemaId={`faq-appliances-${applianceSlug}-${locationSlug}`} />
      </div>
    </div>
  </section>

  <!-- Internal Links -->
  <section class="section">
    <div class="container fade-up">
      <InternalLinks
        links={internalLinks}
        heading="Related Services"
      />
    </div>
  </section>

  <!-- CTA -->
  <CTA
    heading={`Book Your ${applianceName} in ${locationName}`}
