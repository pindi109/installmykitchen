---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import StickyMobileCTA from "../../components/StickyMobileCTA.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import AnswerBlock from "../../components/AnswerBlock.astro";
import FAQ from "../../components/FAQ.astro";
import EnquiryForm from "../../components/EnquiryForm.astro";
import InternalLinks from "../../components/InternalLinks.astro";
import CTA from "../../components/CTA.astro";

const title = "Integrated Appliance Installation | Install My Kitchen";
const metaDescription =
  "Professional integrated appliance installation across Coventry, Warwickshire and Berkshire. Dishwashers, fridges, fridge-freezers, washing machines and ovens. From £50 in Coventry.";
const canonical = "https://installmykitchen.co.uk/appliances/";

const applianceServices = [
  {
    name: "Integrated Dishwasher Installation",
    href: "/appliances/integrated-dishwasher-installation-coventry/",
    description:
      "We position the appliance within its housing, make all water supply and waste connections, fit or rehinge the door panel, and run a full test cycle before handover.",
    fromPriceCW: 75,
  },
  {
    name: "Integrated Fridge Installation",
    href: "/appliances/integrated-fridge-installation-coventry/",
    description:
      "We level the appliance, fit the manufacturer-specified ventilation grilles, align and hinge the door panel, and confirm the unit is cooling correctly before leaving.",
    fromPriceCW: 65,
  },
  {
    name: "Integrated Fridge Freezer Installation",
    href: "/appliances/integrated-fridge-freezer-installation-coventry/",
    description:
      "We position and level the appliance within its tall housing, align door panels across both compartments, and carry out ventilation and post-installation checks.",
    fromPriceCW: 85,
  },
  {
    name: "Washing Machine Installation",
    href: "/appliances/washing-machine-installation-coventry/",
    description:
      "We connect to hot and cold water supplies and waste, level the appliance, remove transit bolts, and run a test wash cycle to confirm correct operation and drainage.",
    fromPriceCW: 65,
  },
  {
    name: "Integrated Oven Installation",
    href: "/appliances/integrated-oven-installation-coventry/",
    description:
      "We coordinate the Part P electrical connection, position and secure the oven within its housing column, and test all functions before handover.",
    fromPriceCW: 95,
  },
];

const applianceFaqs = [
  {
    q: "Do I need to supply the appliance or can you source it?",
    a: "We fit appliances supplied by you. We recommend purchasing from a reputable retailer and ensuring the appliance is on site before our arrival. We confirm appliance dimensions against the housing cabinet before installation day to avoid any surprises.",
  },
  {
    q: "Can you fit the door panel to match my existing kitchen doors?",
    a: "Yes — fitting and aligning the door panel is a core part of every integrated appliance installation we carry out. The panel is attached to the appliance door using the manufacturer's fixing kit and adjusted until it sits flush with surrounding cabinet doors. We also set sliders and hinges so the panel swings and closes in line with the rest of the kitchen.",
  },
  {
    q: "What areas do you cover for appliance installation?",
    a: "We cover two main regions: Coventry, Solihull, Leamington Spa, Warwick, Kenilworth, Nuneaton, and Rugby in the Midlands (from £50 call-out); and Reading, Bracknell, Slough, Maidenhead, Windsor, Wokingham, Newbury, and Ascot in Berkshire (from £75 call-out). If your property is outside these areas, contact us and we will advise whether we can assist.",
  },
  {
    q: "Can you carry out appliance installation as part of a larger kitchen fitting job?",
    a: "Yes — and this is often the most cost-effective approach. When appliance installation is combined with a broader fitting visit — such as a full kitchen installation, door replacement, or worktop fitting — we include all appliance work within the same visit and price the job as a whole. There is no separate call-out charge for appliance work carried out alongside other installation work.",
  },
];

const internalLinks = [
  {
    label: "Kitchen Repairs & Remedial Work",
    href: "/repairs/",
    description: "Independent repair service covering doors, drawers, hinges, worktops, and snagging",
  },
  {
    label: "All service areas",
    href: "/areas/",
    description: "See the full list of locations we cover across the Midlands and Berkshire",
  },
  {
    label: "Kitchen installation costs",
    href: "/costs/",
    description: "Detailed cost guide covering every element of a kitchen installation",
  },
  {
    label: "Book a pre-installation survey",
    href: "/survey/",
    description: "£195 survey credited back when you proceed to installation",
  },
  {
    label: "Our installation services",
    href: "/services/",
    description: "Full independent kitchen installation from survey to snagging",
  },
];

// Service JSON-LD
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Integrated Appliance Installation",
  provider: {
    "@type": "LocalBusiness",
    name: "Install My Kitchen",
    url: "https://installmykitchen.co.uk",
    telephone: "+447399651836",
    address: {
      "@type": "PostalAddress",
      streetAddress: "242 Hollyfast Road, Coundon",
      addressLocality: "Coventry",
      postalCode: "CV6 2AH",
      addressCountry: "GB",
    },
  },
  areaServed: [
    { "@type": "Place", name: "Coventry & Warwickshire" },
    { "@type": "Place", name: "Berkshire" },
  ],
  description:
    "Professional integrated appliance installation across Coventry, Warwickshire, and Berkshire. Dishwashers, fridges, fridge-freezers, washing machines, and ovens — door panel fitting, slider adjustment, and alignment included.",
  serviceType: "Integrated Appliance Installation",
  offers: {
    "@type": "Offer",
    priceCurrency: "GBP",
    price: "50",
    description: "Appliance installation from £50 in Coventry — fixed-price quote provided before work starts",
  },
};

// BreadcrumbList JSON-LD
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://installmykitchen.co.uk/" },
    { "@type": "ListItem", position: 2, name: "Appliance Installation", item: "https://installmykitchen.co.uk/appliances/" },
  ],
};
---

<Base
  title={title}
  description={metaDescription}
  canonical={canonical}
  noHero={true}
>
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <Header slot="header" />

  <!-- Breadcrumbs -->
  <div class="container py-6">
    <Breadcrumbs
      items={[
        { label: "Appliance Installation", href: "/appliances/" },
      ]}
    />
  </div>

  <!-- Hero -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-extrabold mb-5 leading-tight" style="color: var(--navy);">
          Integrated Appliance Installation
        </h1>
        <AnswerBlock
          answer="Install My Kitchen fits integrated appliances into existing kitchen housing units across Coventry, Warwickshire and Berkshire. We handle the door panel fitting, slider adjustment, and alignment — leaving the appliance flush with surrounding cabinet doors."
        />
      </div>
    </div>
  </section>

  <!-- About the service -->
  <section class="section">
    <div class="container">
      <div class="max-w-3xl fade-up">
        <h2 class="text-3xl font-bold mb-4" style="color: var(--navy);">
          A Complete Appliance Fitting Service
        </h2>
        <p class="text-lg leading-relaxed mb-4" style="color: var(--text-soft);">
          Getting an integrated appliance to look and work correctly involves more than simply sliding it into position. The door panel must be secured to the appliance door with the correct fixing kit and then adjusted so it sits flush with the surrounding cabinet fronts. Sliders, hinges, and alignment rails all need setting up precisely — and the appliance itself must be levelled, connected, and tested before the job is complete.
        </p>
        <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
          Because we are entirely independent — not tied to any retailer or manufacturer — we can work with any brand and any kitchen, assess the housing before we start, and identify any issues before the appliance is in position. We carry all standard fixing kits, connection fittings, and tools to complete a full installation in a single visit.
        </p>
        <p class="leading-relaxed" style="color: var(--text-soft);">
          All work is priced before we begin. For straightforward installations the price is fixed. Where the scope is uncertain — for example when existing connections need adaptation — we provide an hourly rate with a ceiling, so you always know the maximum before we start.
        </p>
      </div>
    </div>
  </section>

  <!-- Appliance services grid -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container">
      <div class="fade-up">
        <h2 class="text-3xl font-bold mb-2" style="color: var(--navy);">
          Appliances We Install
        </h2>
        <p class="mb-8 text-base" style="color: var(--text-soft);">
          Select a service below to see pricing, timescales, and location-specific information.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {applianceServices.map((service) => (
            <a
              href={service.href}
              class="card p-6 flex flex-col gap-3 no-underline group"
              style="border: 1.5px solid #E5E7EB; transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;"
            >
              <h3
                class="font-bold text-base leading-snug"
                style="color: var(--teal);"
              >
                {service.name}
              </h3>
              <p
                class="text-sm leading-relaxed flex-1"
                style="color: var(--text-soft);"
              >
                {service.description}
              </p>
              <div class="flex items-center justify-between mt-auto pt-2" style="border-top: 1px solid #F3F4F6;">
                <span class="text-xs font-semibold" style="color: var(--teal);">
                  From £{service.fromPriceCW}
                </span>
                <span
                  class="text-xs font-semibold flex items-center gap-1"
                  style="color: var(--teal);"
                >
                  See details
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <line x1="5" y1="12" x2="19" y2="12"/>
                    <polyline points="12 5 19 12 12 19"/>
                  </svg>
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Service areas -->
  <section class="section">
    <div class="container">
      <div class="max-w-3xl fade-up">
        <h2 class="text-3xl font-bold mb-4" style="color: var(--navy);">
          Service Areas
        </h2>
        <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
          Our appliance installation service operates across two main regions. In the Midlands, we cover Coventry, Solihull, Leamington Spa, Warwick, Kenilworth, Nuneaton, and Rugby, with appliance installation from £50.
        </p>
        <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
          In Berkshire, we cover Reading, Bracknell, Slough, Maidenhead, Windsor, Wokingham, Newbury, and Ascot. Prices reflect the additional travel time from our Coventry base.
        </p>
        <p class="leading-relaxed" style="color: var(--text-soft);">
          If your property is outside these areas but nearby, please contact us — we assess out-of-area requests on a case-by-case basis and will advise on whether we can help and what any travel supplement would be.
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mt-8">
          <div class="card p-6">
            <h3 class="font-bold text-base mb-3" style="color: var(--navy);">
              Coventry &amp; Warwickshire
            </h3>
            <ul class="space-y-1 text-sm" style="color: var(--text-soft);">
              <li>Coventry · Solihull</li>
              <li>Leamington Spa · Warwick</li>
              <li>Kenilworth · Nuneaton · Rugby</li>
            </ul>
            <p class="text-xs mt-3 font-semibold" style="color: var(--teal);">
              From £50
            </p>
          </div>
          <div class="card p-6">
            <h3 class="font-bold text-base mb-3" style="color: var(--navy);">
              Berkshire
            </h3>
            <ul class="space-y-1 text-sm" style="color: var(--text-soft);">
              <li>Reading · Bracknell · Slough</li>
              <li>Maidenhead · Windsor · Wokingham</li>
              <li>Newbury · Ascot</li>
            </ul>
            <p class="text-xs mt-3 font-semibold" style="color: var(--teal);">
              From £65
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Enquiry form -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container">
      <div class="max-w-2xl mx-auto fade-up">
        <h2 class="text-2xl font-bold mb-2 text-center" style="color: var(--navy);">
          Book an Appliance Installation
        </h2>
        <p class="text-center text-sm mb-8" style="color: var(--text-soft);">
          Tell us which appliance you need fitting and we will respond within one working day with availability and a cost indication.
        </p>
        <EnquiryForm formTitle="Request Appliance Installation" showSurveyOption={false} />
      </div>
    </div>
  </section>

  <!-- Internal links -->
  <section class="section">
    <div class="container">
      <div class="fade-up">
        <InternalLinks
          links={internalLinks}
          heading="Related Pages"
        />
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container">
      <div class="max-w-3xl fade-up">
        <h2 class="text-3xl font-bold mb-8" style="color: var(--navy);">
          Frequently Asked Questions
        </h2>
        <FAQ items={applianceFaqs} schemaId="faq-appliances-hub" />
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTA
    heading="Ready to Book an Appliance Installation?"
    subtext="We cover Coventry, Warwickshire, and Berkshire. Call us or send an enquiry and we will confirm availability and pricing within one working day."
    primaryLabel="Send an Enquiry"
    primaryHref="/contact/"
    secondaryLabel="Call 07399 651836"
    secondaryHref="tel:07399651836"
    dark={true}
  />

  <Footer slot="footer" />
  <StickyMobileCTA slot="sticky-cta" />
</Base>

<style>
  .card {
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }
  .card:hover {
    border-color: var(--teal) !important;
    box-shadow: 0 4px 14px rgba(15, 118, 110, 0.12);
    transform: translateY(-1px);
  }
</style>
