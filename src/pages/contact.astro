---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import StickyMobileCTA from "../components/StickyMobileCTA.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import EnquiryForm from "../components/EnquiryForm.astro";

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": "https://installmykitchen.co.uk/#business",
  name: "Install My Kitchen",
  url: "https://installmykitchen.co.uk",
  telephone: "07399651836",
  email: "info@installmykitchen.co.uk",
  address: {
    "@type": "PostalAddress",
    streetAddress: "242 Hollyfast Road, Coundon",
    addressLocality: "Coventry",
    addressRegion: "West Midlands",
    postalCode: "CV6 2AH",
    addressCountry: "GB",
  },
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
      opens: "08:00",
      closes: "18:00",
    },
  ],
};
---

<Base
  title="Contact Install My Kitchen | Coventry CV6 2AH"
  description="Contact Install My Kitchen in Coventry. Call 07399 651836, email info@installmykitchen.co.uk or fill in our form. Based at 242 Hollyfast Road, CV6 2AH."
  canonical="https://installmykitchen.co.uk/contact/"
>
  <!-- Schema -->
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />

  <!-- Header -->
  <Header slot="header" />

  <!-- ══════════════════════════════ PAGE HEADER ══════════════════ -->
  <section class="page-header" aria-label="Page header">
    <div class="container">
      <Breadcrumbs items={[{ label: "Contact", href: "/contact/" }]} />
      <h1 class="page-h1">Contact Install My Kitchen</h1>
      <p class="page-sub">Get in touch to book a survey, ask about our services, or check available installation dates across Coventry and Warwickshire.</p>
    </div>
  </section>

  <!-- ══════════════════════════════ CONTACT CONTENT ═══════════ -->
  <section class="section" style="background: #fff;" aria-label="Contact details and enquiry form">
    <div class="container">
      <div class="contact-grid">

        <!-- Left: NAP + hours + map -->
        <div class="contact-info">

          <!-- NAP card -->
          <div class="nap-card" itemscope itemtype="https://schema.org/LocalBusiness">
            <h2 class="nap-heading">Get in Touch</h2>

            <address class="nap-address not-italic">
              <div class="nap-row">
                <span class="nap-icon" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                </span>
                <div>
                  <p class="nap-label">Address</p>
                  <p class="nap-value" itemprop="address" itemscope itemtype="https://schema.org/PostalAddress">
                    <span itemprop="streetAddress">242 Hollyfast Road, Coundon</span><br />
                    <span itemprop="addressLocality">Coventry</span>,
                    <span itemprop="postalCode">CV6 2AH</span>
                  </p>
                </div>
              </div>

              <div class="nap-row">
                <span class="nap-icon" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.1a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                </span>
                <div>
                  <p class="nap-label">Phone</p>
                  <a href="tel:07399651836" class="nap-link" itemprop="telephone">07399 651836</a>
                </div>
              </div>

              <div class="nap-row">
                <span class="nap-icon" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                </span>
                <div>
                  <p class="nap-label">Email</p>
                  <a href="mailto:info@installmykitchen.co.uk" class="nap-link" itemprop="email">info@installmykitchen.co.uk</a>
                </div>
              </div>

              <div class="nap-row">
                <span class="nap-icon" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                </span>
                <div>
                  <p class="nap-label">Business Hours</p>
                  <p class="nap-value">Monday – Saturday: 8am – 6pm</p>
                  <p class="nap-value nap-closed">Sunday: Closed</p>
                </div>
              </div>
            </address>

            <!-- Quick action links -->
            <div class="nap-actions">
              <a href="tel:07399651836" class="btn-primary nap-action-btn">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.1a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                Call Now
              </a>
              <a href="mailto:info@installmykitchen.co.uk" class="btn-secondary nap-action-btn">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                Send Email
              </a>
            </div>
          </div>

          <!-- Map placeholder -->
          <div class="map-placeholder" aria-label="Map location placeholder" role="img">
            <div class="map-inner">
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="color: var(--teal); opacity: 0.5;">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
              <p class="map-label">242 Hollyfast Road, Coundon, Coventry CV6 2AH</p>
              <a
                href="https://maps.google.com/?q=242+Hollyfast+Road,+Coventry,+CV6+2AH"
                target="_blank"
                rel="noopener noreferrer"
                class="map-link"
              >
                Open in Google Maps
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
              </a>
            </div>
          </div>

        </div>

        <!-- Right: enquiry form -->
        <div id="quote" class="contact-form">
          <EnquiryForm formTitle="Send Us a Message" showSurveyOption={true} />
        </div>

      </div>
    </div>
  </section>

  <!-- Footer -->
  <Footer slot="footer" />
  <StickyMobileCTA slot="sticky-cta" />
</Base>

<style>
  /* Page header */
  .page-header {
    background: var(--hero-gradient);
    padding: 3rem 0 3.5rem;
  }

  .page-h1 {
    font-size: clamp(1.625rem, 3vw, 2.5rem);
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.02em;
    margin-top: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .page-sub {
    color: rgba(255, 255, 255, 0.75);
    font-size: 1.0625rem;
    line-height: 1.6;
    max-width: 540px;
  }

  /* Contact grid */
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
  }

  @media (min-width: 1024px) {
    .contact-grid {
      grid-template-columns: 400px 1fr;
    }
  }

  /* NAP card */
  .nap-card {
    background: var(--bg-light);
    border: 1.5px solid var(--border);
    border-radius: 1.25rem;
    padding: 1.75rem;
    margin-bottom: 1.5rem;
  }

  .nap-heading {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--charcoal);
    margin-bottom: 1.5rem;
  }

  .nap-address {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-bottom: 1.5rem;
  }

  .nap-row {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
  }

  .nap-icon {
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 0.5rem;
    background: rgba(15, 118, 110, 0.1);
    color: var(--teal);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .nap-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-soft);
    margin-bottom: 0.25rem;
  }

  .nap-value {
    font-size: 0.9375rem;
    color: var(--charcoal);
    line-height: 1.5;
  }

  .nap-closed {
    color: var(--text-soft);
    font-size: 0.875rem;
  }

  .nap-link {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--teal);
    transition: color 0.15s;
  }

  .nap-link:hover {
    color: var(--teal-bright);
  }

  .nap-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .nap-action-btn {
    flex: 1;
    justify-content: center;
    font-size: 0.9375rem;
    white-space: nowrap;
  }

  /* Map placeholder */
  .map-placeholder {
    border: 2px dashed var(--border);
    border-radius: 1rem;
    min-height: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-light);
  }

  .map-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding: 2rem;
    text-align: center;
  }

  .map-label {
    font-size: 0.875rem;
    color: var(--text-soft);
    line-height: 1.5;
  }

  .map-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--teal);
    transition: color 0.15s;
  }

  .map-link:hover {
    color: var(--teal-bright);
  }
</style>
