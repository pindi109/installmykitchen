---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import StickyMobileCTA from "../components/StickyMobileCTA.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import AnswerBlock from "../components/AnswerBlock.astro";
import KeyTakeaway from "../components/KeyTakeaway.astro";
import FAQ from "../components/FAQ.astro";
import SupplierLogos from "../components/SupplierLogos.astro";
import InternalLinks from "../components/InternalLinks.astro";
import CTA from "../components/CTA.astro";
import TrustStrip from "../components/TrustStrip.astro";

const title = "Kitchen Fitter Solihull | Install My Kitchen — Pindi Sahota";
const metaDescription = "Expert independent kitchen fitter in Solihull, West Midlands. Pindi Sahota delivers kitchen installation across B91, B92 and B93 with 30 years experience, fixed-price quotes, and a £195 survey credited back on booking.";
const canonical = "https://installmykitchen.co.uk/kitchen-fitter-solihull/";

const takeawayPoints = [
  "Pindi Sahota is an independent kitchen fitter based in Coundon, Coventry — CV6 2AH — serving Solihull and the wider B91, B92 and B93 postcode area.",
  "30 years of professional kitchen fitting experience across Solihull's large detached homes, executive properties in Knowle and Dorridge, and modern developments in Dickens Heath.",
  "Fits kitchens from Wren, Howdens, Magnet, IKEA, Wickes, B&Q, Benchmarx and all other major retailers — fully independent, no retailer tie-in.",
  "Pre-installation survey at £195, credited back in full when you proceed — fixed-price quote guaranteed.",
];

const faqItems = [
  {
    q: "What makes Solihull kitchen fitting different from other areas?",
    a: "Solihull's housing stock is among the most substantial in the West Midlands. The large 1930s detached and semi-detached homes in Solihull town, executive properties in Knowle and Dorridge, and contemporary open-plan homes in Dickens Heath and Cheswick Green all tend to accommodate far larger kitchens than the regional average. It is common for Solihull kitchens to include 20 or more units, a central island, full-height larder towers, integrated appliances in multiple locations, and premium worktop materials such as granite, quartz, or solid stone. Fitting a kitchen of this scale requires the same methodical approach — correct levelling, precise worktop templating, careful appliance co-ordination — but applied across a longer and more complex installation. Pindi has extensive experience with large-scale Solihull kitchens and plans the sequencing of each installation carefully so that the result looks and functions exactly as it should.",
  },
  {
    q: "How much does kitchen fitting cost in Solihull?",
    a: "Kitchen fitting costs in Solihull depend on the number of units, the worktop material and configuration, the number of integrated appliances, whether an island is included, and the condition of the existing room. As a guide, a standard Solihull kitchen in the 15–20 unit range — typical of the area's larger semi-detached and detached homes — will typically cost between £2,000 and £3,500 for the fitting labour alone. Larger installations with islands, multiple integrated appliances, or complex worktop runs will sit higher. Pindi provides a fully itemised, fixed-price quote following a pre-installation survey, so the price you receive is the price you pay. See the full kitchen fitting costs page for a detailed breakdown of the variables involved.",
  },
  {
    q: "Do you cover B91, B92 and B93 postcodes?",
    a: "Yes. Pindi covers all three postcodes in full. B91 covers Solihull town centre and Sharmans Cross; B92 covers Olton, Elmdon, and the areas towards Birmingham Airport; and B93 covers Knowle, Dorridge, and the village communities to the south of the town. He also covers the adjacent areas of Shirley (B90), Monkspath, Bentley Heath, and Cheswick Green, as well as Balsall Common and Meriden to the east. Solihull is approximately 15 miles from Pindi's base in Coventry — a straightforward drive via the A45 — so morning starts are on time and the journey adds no cost to your quote. Call 07399 651836 to confirm coverage for your specific postcode.",
  },
  {
    q: "How long does a large Solihull kitchen take to fit?",
    a: "The fitting duration depends on the scale and complexity of the installation. A standard 12–15 unit kitchen in a Solihull semi-detached will typically take three to five working days. A larger kitchen of 20-plus units with an island, multiple integrated appliances, and complex worktop work — common in Knowle and Dorridge detached homes — will typically take six to eight working days, sometimes more if floor levelling, tiling, or significant making-good is required. During the pre-installation survey Pindi will give you a precise duration estimate based on your specific kitchen plan, so you can plan your household around the work well in advance.",
  },
  {
    q: "Which kitchen retailers do you install in Solihull?",
    a: "Pindi fits kitchens from every major UK retailer and manufacturer. In Solihull, the most common are Wren Kitchens, Magnet (including the Belgravia painted shaker range popular across Solihull's period homes), Howdens Joinery, and a variety of premium brands including Häcker, Nobilia, Mereway, and Masterclass. He has fitted a Magnet Belgravia painted shaker kitchen with granite worktops and range cooker co-ordination in Solihull — the kind of specification typical of the area's larger homes. Because Pindi is fully independent, he is not tied to any retailer's scheme, so you are free to purchase from any supplier and have the kitchen installed to a consistently high standard. If your retailer is not listed, call 07399 651836.",
  },
];

const internalLinks = [
  {
    label: "Book a pre-installation survey",
    href: "/survey/",
    description: "£195 survey credited back in full when you proceed — the essential first step",
  },
  {
    label: "Kitchen fitting costs explained",
    href: "/costs/",
    description: "Fully itemised guide to what affects kitchen installation prices",
  },
  {
    label: "Solihull area page",
    href: "/areas/solihull/",
    description: "Detailed installation information for Solihull postcodes B91, B92 and B93",
  },
  {
    label: "Magnet kitchen — Solihull case study",
    href: "/projects/magnet-kitchen-solihull/",
    description: "Magnet Belgravia painted shaker kitchen with granite worktops, fitted in Solihull",
  },
  {
    label: "About Pindi Sahota",
    href: "/pindi-sahota/",
    description: "Meet the independent kitchen fitter behind Install My Kitchen",
  },
  {
    label: "Magnet kitchen installation",
    href: "/retailers/magnet/",
    description: "Independent fitting for Magnet kitchens — all ranges covered",
  },
  {
    label: "Wren kitchen installation",
    href: "/retailers/wren/",
    description: "Fitting your Wren kitchen independently — what you need to know",
  },
];

// LocalBusiness JSON-LD
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "Install My Kitchen",
  url: "https://installmykitchen.co.uk",
  telephone: "07399651836",
  email: "info@installmykitchen.co.uk",
  image: "https://installmykitchen.co.uk/images/pindi-sahota.jpg",
  address: {
    "@type": "PostalAddress",
    streetAddress: "242 Hollyfast Road, Coundon",
    addressLocality: "Coventry",
    postalCode: "CV6 2AH",
    addressCountry: "GB",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: 52.4197,
    longitude: -1.5379,
  },
  areaServed: {
    "@type": "City",
    name: "Solihull",
  },
  description:
    "Independent kitchen fitting service in Solihull. Pindi Sahota has 30 years of experience fitting kitchens from all major retailers including Wren, Howdens, Magnet and IKEA. Covers B91, B92 and B93. Fixed-price quotes following a £195 pre-installation survey.",
  priceRange: "££",
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      opens: "08:00",
      closes: "18:00",
    },
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: "Saturday",
      opens: "09:00",
      closes: "13:00",
    },
  ],
};

// Service JSON-LD
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Kitchen Fitting in Solihull",
  provider: {
    "@type": "LocalBusiness",
    name: "Install My Kitchen",
    url: "https://installmykitchen.co.uk",
    telephone: "07399651836",
  },
  areaServed: [
    { "@type": "City", name: "Solihull" },
    { "@type": "Place", name: "Knowle" },
    { "@type": "Place", name: "Dorridge" },
    { "@type": "Place", name: "Dickens Heath" },
    { "@type": "Place", name: "Cheswick Green" },
    { "@type": "Place", name: "Shirley" },
  ],
  description:
    "Professional independent kitchen fitting and installation service across Solihull, West Midlands, covering B91, B92 and B93. Fits kitchens from all major UK retailers including Wren, Howdens, Magnet, IKEA and premium brands. Fixed-price quotes following a pre-installation survey.",
  serviceType: "Kitchen Fitting",
  offers: {
    "@type": "Offer",
    name: "Pre-installation Survey",
    price: "195.00",
    priceCurrency: "GBP",
    description: "Pre-installation survey, fully credited back against the fitting quote when you proceed.",
