---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import StickyMobileCTA from "../components/StickyMobileCTA.astro";

const title = "Page Not Found | Install My Kitchen";
const metaDescription = "The page you were looking for could not be found. Return to the Install My Kitchen homepage or explore our services and areas.";
---

<Base
  title={title}
  description={metaDescription}
>
  <Header slot="header" />

  <section class="section" style="min-height: 60vh; display: flex; align-items: center;">
    <div class="container">
      <div class="max-w-xl mx-auto text-center py-16">

        <!-- 404 number -->
        <p class="text-8xl font-extrabold mb-4" style="color: var(--teal); opacity: 0.25; line-height: 1;">404</p>

        <h1 class="text-3xl md:text-4xl font-extrabold mb-4" style="color: var(--navy);">
          Page Not Found
        </h1>
        <p class="text-lg leading-relaxed mb-10" style="color: var(--text-soft);">
          We could not find the page you were looking for. It may have moved, been removed, or the address may have been typed incorrectly. Use the links below to find what you need.
        </p>

        <!-- Quick links grid -->
        <nav aria-label="Helpful links" class="grid grid-cols-2 gap-3 mb-10">
          <a
            href="/"
            class="flex flex-col items-center gap-2 p-5 rounded-xl border transition-all duration-200 hover:-translate-y-1"
            style="border-color: #E5E7EB; background: #fff; text-decoration: none;"
          >
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--teal);" aria-hidden="true">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
              <polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
            <span class="font-semibold text-sm" style="color: var(--charcoal);">Home</span>
          </a>

          <a
            href="/services/"
            class="flex flex-col items-center gap-2 p-5 rounded-xl border transition-all duration-200 hover:-translate-y-1"
            style="border-color: #E5E7EB; background: #fff; text-decoration: none;"
          >
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--teal);" aria-hidden="true">
              <rect x="2" y="7" width="20" height="14" rx="2"/>
              <path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/>
              <line x1="12" y1="12" x2="12" y2="16"/>
              <line x1="10" y1="14" x2="14" y2="14"/>
            </svg>
            <span class="font-semibold text-sm" style="color: var(--charcoal);">Services</span>
          </a>

          <a
            href="/areas/"
            class="flex flex-col items-center gap-2 p-5 rounded-xl border transition-all duration-200 hover:-translate-y-1"
            style="border-color: #E5E7EB; background: #fff; text-decoration: none;"
          >
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--teal);" aria-hidden="true">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            <span class="font-semibold text-sm" style="color: var(--charcoal);">Areas</span>
          </a>

          <a
            href="/contact/"
            class="flex flex-col items-center gap-2 p-5 rounded-xl border transition-all duration-200 hover:-translate-y-1"
            style="border-color: #E5E7EB; background: #fff; text-decoration: none;"
          >
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--teal);" aria-hidden="true">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
            </svg>
            <span class="font-semibold text-sm" style="color: var(--charcoal);">Contact</span>
          </a>
        </nav>

        <!-- Phone CTA -->
        <p class="text-sm mb-3" style="color: var(--text-soft);">
          Or call us directly:
        </p>
        <a
          href="tel:07399651836"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-full font-semibold text-white transition-all duration-200 hover:-translate-y-0.5"
          style="background: var(--teal);"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.1a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          07399 651836
        </a>

      </div>
    </div>
  </section>

  <Footer slot="footer" />
  <StickyMobileCTA slot="sticky-cta" />
</Base>
