---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import StickyMobileCTA from "../../components/StickyMobileCTA.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import AnswerBlock from "../../components/AnswerBlock.astro";
import FAQ from "../../components/FAQ.astro";
import InternalLinks from "../../components/InternalLinks.astro";
import CTA from "../../components/CTA.astro";

import retailersData from "../../data/retailers.json";
import costsData from "../../data/costs.json";
import faqsData from "../../data/faqs.json";

export function getStaticPaths() {
  return retailersData.map((retailer, index) => ({
    params: { retailer: retailer.slug },
    props: { retailer, retailerIndex: index },
  }));
}

const { retailer, retailerIndex } = Astro.props;
const { displayName, slug } = retailer;

const canonical = `https://installmykitchen.co.uk/cost/${slug}-cost/`;

// Title ≤60 chars
const rawTitle = `${displayName} Kitchen Installation Cost | Install My Kitchen`;
const title = rawTitle.length <= 60
  ? rawTitle
  : `${displayName} Kitchen Cost | Install My Kitchen`;

// Meta 140-160 chars
const metaDescription = `Typical ${displayName} kitchen installation costs explained. Find out what affects price, what's included, and how to get a fixed-price quote in Coventry, Warwickshire & Berkshire.`;

// Modifier for this retailer
const modifier = (costsData.modifiers as Record<string, { multiplier: number }>)[slug]?.multiplier ?? 1.0;

// Derived cost ranges with modifier applied
const smallLow = Math.round(costsData.smallKitchen.totalLow * modifier);
const smallHigh = Math.round(costsData.smallKitchen.totalHigh * modifier);
const mediumLow = Math.round(costsData.mediumKitchen.totalLow * modifier);
const mediumHigh = Math.round(costsData.mediumKitchen.totalHigh * modifier);
const largeLow = Math.round(costsData.largeKitchen.totalLow * modifier);
const largeHigh = Math.round(costsData.largeKitchen.totalHigh * modifier);

// Format as currency
function fmt(n: number) {
  return `£${n.toLocaleString("en-GB")}`;
}

// Modifier description
const modifierNote = modifier > 1.0
  ? `${displayName} kitchens carry a modest installation premium of approximately ${Math.round((modifier - 1) * 100)}% above our standard rates, reflecting the additional on-site assembly time or handling complexity involved.`
  : `${displayName} kitchens are priced at our standard installation rates with no additional modifier.`;

// FAQ — offset by retailer index, from costs section
const allCostFaqs = faqsData.costs;
const faqOffset = retailerIndex % allCostFaqs.length;
const faqItems = [
  allCostFaqs[faqOffset % allCostFaqs.length],
  allCostFaqs[(faqOffset + 1) % allCostFaqs.length],
  allCostFaqs[(faqOffset + 2) % allCostFaqs.length],
  allCostFaqs[(faqOffset + 3) % allCostFaqs.length],
];

// Internal links
const internalLinks = [
  {
    label: `${displayName} Kitchen Installation`,
    href: `/retailers/${slug}/`,
    description: `Our independent ${displayName} fitting service`,
  },
  {
    label: "Kitchen Installation Cost Guide",
    href: "/costs/",
    description: "Full breakdown of installation costs and ranges",
  },
  {
    label: "Book a Survey",
    href: "/survey/",
    description: "Get a fixed-price quote with our £195 survey",
  },
  {
    label: "Small Kitchen Installation Cost",
    href: "/cost/small-kitchen-cost/",
    description: "8–12 units — typical cost ranges",
  },
  {
    label: "Medium Kitchen Installation Cost",
    href: "/cost/medium-kitchen-cost/",
    description: "13–20 units — typical cost ranges",
  },
  {
    label: "Large Kitchen Installation Cost",
    href: "/cost/large-kitchen-cost/",
    description: "21+ units — typical cost ranges",
  },
];

// Breadcrumb JSON-LD is emitted once by the <Breadcrumbs> component below.
---

<Base
  title={title}
  description={metaDescription}
  canonical={canonical}
>

  <Header slot="header" />

  <div class="container py-6">
    <Breadcrumbs
      items={[
        { label: "Cost Guide", href: "/costs/" },
        { label: displayName, href: canonical },
      ]}
    />
  </div>

  <!-- Hero -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-extrabold mb-5 leading-tight" style="color: var(--navy);">
          How Much Does {displayName} Kitchen Installation Cost?
        </h1>
        <AnswerBlock
          answer={`${displayName} kitchen installation typically costs between ${fmt(smallLow)} and ${fmt(largeLow)}+ depending on kitchen size and complexity. These are labour-only figures for Coventry, Warwickshire and Berkshire — they do not include the cost of the kitchen itself. All prices are indicative; we provide fixed-price quotes following a survey.`}
        />
      </div>
    </div>
  </section>

  <!-- Cost breakdown table -->
  <section class="section">
    <div class="container">
      <div class="max-w-3xl fade-up">
        <h2 class="text-3xl font-bold mb-6" style="color: var(--navy);">
          Typical {displayName} Installation Cost Ranges
        </h2>
        <p class="leading-relaxed mb-6" style="color: var(--text-soft);">
          {modifierNote} The figures below are typical installation-only ranges for {displayName} kitchens in the Coventry, Warwickshire and Berkshire area. All costs are inclusive of VAT.
        </p>

        <!-- Cost table -->
        <div class="overflow-x-auto rounded-xl border" style="border-color: #E5E7EB;">
          <table class="w-full text-sm" style="border-collapse: collapse;">
            <thead>
              <tr style="background: var(--navy); color: #fff;">
                <th class="px-5 py-4 text-left font-semibold">Kitchen Size</th>
                <th class="px-5 py-4 text-left font-semibold">Number of Units</th>
                <th class="px-5 py-4 text-left font-semibold">Days to Fit</th>
                <th class="px-5 py-4 text-left font-semibold">Typical Range (labour only)</th>
              </tr>
            </thead>
            <tbody>
              <tr style="border-bottom: 1px solid #E5E7EB; background: #fff;">
                <td class="px-5 py-4 font-semibold" style="color: var(--charcoal);">Small</td>
                <td class="px-5 py-4" style="color: var(--text-soft);">{costsData.smallKitchen.units}</td>
                <td class="px-5 py-4" style="color: var(--text-soft);">{costsData.smallKitchen.days}</td>
                <td class="px-5 py-4 font-semibold" style="color: var(--teal);">{fmt(smallLow)} – {fmt(smallHigh)}</td>
              </tr>
              <tr style="border-bottom: 1px solid #E5E7EB; background: #F9FAFB;">
                <td class="px-5 py-4 font-semibold" style="color: var(--charcoal);">Medium</td>
                <td class="px-5 py-4" style="color: var(--text-soft);">{costsData.mediumKitchen.units}</td>
                <td class="px-5 py-4" style="color: var(--text-soft);">{costsData.mediumKitchen.days}</td>
                <td class="px-5 py-4 font-semibold" style="color: var(--teal);">{fmt(mediumLow)} – {fmt(mediumHigh)}</td>
              </tr>
              <tr style="background: #fff;">
                <td class="px-5 py-4 font-semibold" style="color: var(--charcoal);">Large</td>
                <td class="px-5 py-4" style="color: var(--text-soft);">{costsData.largeKitchen.units}</td>
                <td class="px-5 py-4" style="color: var(--text-soft);">{costsData.largeKitchen.days}</td>
                <td class="px-5 py-4 font-semibold" style="color: var(--teal);">{fmt(largeLow)} – {fmt(largeHigh)}</td>
              </tr>
            </tbody>
          </table>
        </div>

        <p class="text-xs mt-4" style="color: var(--text-soft);">
          All figures are typical ranges for installation labour only. They do not include the cost of the kitchen, worktops, appliances, plumbing, electrical work, or tiling. Actual costs depend on specific project requirements. A fixed-price quote is provided following your pre-installation survey.
        </p>
      </div>
    </div>
  </section>

  <!-- Why costs vary -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container">
      <div class="max-w-3xl fade-up">
        <h2 class="text-3xl font-bold mb-4" style="color: var(--navy);">
          Why {displayName} Installation Costs Vary
        </h2>
        <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
          Installation cost is primarily driven by the number of units, the complexity of the layout, and the number of days required on site. A simple galley kitchen with 10 base and wall units is considerably quicker to fit than a U-shaped kitchen with 22 units, an island, and tall housing units, even if both are nominally the same brand.
        </p>
        <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
          The format of the kitchen also affects cost. {displayName === "IKEA Kitchens" || displayName === "B&Q Kitchens" || displayName === "Wickes Kitchens"
            ? "Flat-pack cabinets require full on-site assembly before fitting, which adds time compared to pre-built rigid carcasses. This is reflected in a modest additional day rate for flat-pack projects."
            : "Pre-built rigid carcasses, as supplied by " + displayName + ", typically install more quickly than flat-pack alternatives, which helps keep the overall cost competitive."
          }
        </p>
        <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
          Other factors that can affect the final price include: the condition of the existing kitchen and the difficulty of the strip-out; the levelness of the floor and straightness of the walls, which affect the amount of scribing and packing required; the number of appliances to be integrated; whether a stone worktop template requires a separate visit; and any remedial work to walls or floors revealed after strip-out.
        </p>
        <p class="leading-relaxed" style="color: var(--text-soft);">
          We address all of these factors at the pre-installation survey stage, so your fixed-price quote takes account of your kitchen's specific requirements — not just a generic estimate. There are no hidden costs and no surprises on installation day.
        </p>
      </div>
    </div>
  </section>

  <!-- What affects price -->
  <section class="section">
    <div class="container">
      <div class="max-w-3xl fade-up">
        <h2 class="text-3xl font-bold mb-6" style="color: var(--navy);">
          What Affects the Price of Your {displayName} Installation?
        </h2>
        <ul class="space-y-4 list-none p-0 m-0">
          {[
            { factor: "Number of units", detail: "More units means more fitting time. Our quotes itemise the cost per day rather than per unit, giving you a clear basis for comparison." },
            { factor: "Kitchen format", detail: `${displayName} kitchens are ${modifier >= 1.15 ? "flat-pack or require additional assembly time, which is reflected in our rates" : modifier >= 1.05 ? "supplied in a format that requires modest additional handling, reflected in a small rate adjustment" : "supplied as rigid carcasses and priced at our standard installation rate"}.` },
            { factor: "Layout complexity", detail: "Island units, tall housings, corner solutions, and complex worktop runs all add installation time compared to a simple linear layout." },
            { factor: "Worktop material", detail: "Laminate worktops can often be fitted directly by our team. Stone, quartz, and solid-surface worktops require specialist templating and fabrication by a third party, which is an additional cost." },
            { factor: "Condition of the space", detail: "Uneven floors, out-of-plumb walls, and complex existing services (such as old lead pipework or non-standard socket positions) can add time to the installation." },
            { factor: "Appliances", detail: "Fitting integrated appliances — dishwashers, ovens, hobs, fridges — is included in our standard rate. Free-standing appliances simply need positioning and do not add to installation time." },
          ].map(({ factor, detail }) => (
            <li class="p-5 rounded-xl border" style="border-color: #E5E7EB; background: #fff;">
              <p class="font-semibold mb-1" style="color: var(--charcoal);">{factor}</p>
              <p class="text-sm leading-relaxed" style="color: var(--text-soft);">{detail}</p>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Survey importance -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container">
      <div class="max-w-3xl fade-up">
        <h2 class="text-3xl font-bold mb-4" style="color: var(--navy);">
          Why a Pre-Installation Survey Is Essential
        </h2>
        <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
          The only reliable way to price a kitchen installation accurately is to visit the property. Our £195 pre-installation survey covers a full site visit by an experienced fitter, detailed measurements of the kitchen space, a review of your {displayName} kitchen plan, and a written fixed-price installation quote. If you proceed with the installation, the survey fee is credited back in full against your invoice.
        </p>
        <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
          During the survey, we check everything that affects the installation: floor levels across the entire footprint, wall straightness and the likely scribing requirement, service locations for the sink, dishwasher, and cooker, ceiling heights, and any structural features that may affect the cabinet run. Any issues identified at this stage are flagged to you before you commit, so you can plan and budget accordingly.
        </p>
        <p class="leading-relaxed" style="color: var(--text-soft);">
          We strongly recommend booking a survey before placing your {displayName} kitchen order. We can cross-reference your plan against the actual room dimensions and flag any discrepancies — saving you the significant inconvenience and cost of having to reorder or return components after the kitchen has been delivered.
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container">
      <div class="max-w-3xl fade-up">
        <h2 class="text-3xl font-bold mb-8" style="color: var(--navy);">
          Frequently Asked Questions
        </h2>
        <FAQ items={faqItems} schemaId={`faq-cost-${slug}`} />
      </div>
    </div>
  </section>

  <!-- Internal Links -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container fade-up">
      <InternalLinks
        links={internalLinks}
        heading="Related Pages"
      />
    </div>
  </section>

  <!-- CTA -->
  <CTA
    heading={`Get a Fixed-Price Quote for Your ${displayName} Kitchen`}
    subtext={`Book your pre-installation survey for £195 — credited back in full when you proceed. Covering Coventry, Warwickshire, and surrounding areas.`}
    primaryLabel="Book Your Survey"
    primaryHref="/survey/"
    secondaryLabel="Call 07399 651836"
    secondaryHref="tel:07399651836"
    dark={true}
  />

  <Footer slot="footer" />
  <StickyMobileCTA slot="sticky-cta" />
</Base>
