---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import StickyMobileCTA from "../../components/StickyMobileCTA.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import AnswerBlock from "../../components/AnswerBlock.astro";
import KeyTakeaway from "../../components/KeyTakeaway.astro";
import FAQ from "../../components/FAQ.astro";
import InternalLinks from "../../components/InternalLinks.astro";
import CTA from "../../components/CTA.astro";

const title = "Kitchen Survey Cost | Install My Kitchen Coventry";
const metaDescription =
  "A kitchen survey with Install My Kitchen costs £195, credited back in full on booking. Find out what the survey covers and why it protects your project.";
const canonical = "https://www.installmykitchen.co.uk/cost/kitchen-survey-cost/";

const takeawayPoints = [
  "The pre-installation survey costs £195, credited back in full against your installation balance when you pay your deposit.",
  "The survey produces a written fixed-price installation quote — not a ballpark estimate.",
  "During the survey, the fitter checks floor levels, wall conditions, service positions, and reviews your kitchen plan against the actual space.",
  "Booking a survey before placing your kitchen order allows us to flag any discrepancies between the plan and the room, potentially saving significant rework costs.",
];

const faqs = [
  {
    q: "How much does a kitchen survey cost?",
    a: "A pre-installation survey with Install My Kitchen costs £195. This fee is credited in full against your installation balance when you confirm your booking date and pay your deposit. If you decide not to proceed with the installation after the survey, the survey fee is retained.",
  },
  {
    q: "What does the £195 survey cover?",
    a: "The survey covers a full site visit by an experienced fitter, who will take detailed measurements of the kitchen space, check floor levels across the full footprint, assess wall and ceiling conditions, note all service positions, review your kitchen plan, and produce a written fixed-price installation quote. The survey typically takes 1–2 hours.",
  },
  {
    q: "When should I book a survey — before or after ordering my kitchen?",
    a: "Ideally before you place your kitchen order. A survey allows us to cross-reference your kitchen plan against the actual room dimensions and flag any issues before you commit to an order. This is particularly valuable if your room has unusual dimensions, an existing layout that does not match the plan, or any features that may affect how the units fit. Identifying these at survey stage is far less costly than discovering them after delivery.",
  },
  {
    q: "Can I get a price without a survey?",
    a: "We are happy to provide a ballpark cost range based on your kitchen size and unit count — you can use the size-based cost pages on this site as a starting point. However, a fixed-price quote can only be issued after the pre-installation survey. A ballpark range protects neither you nor us; a fixed price issued after a site visit means you know exactly what you will pay.",
  },
];

const internalLinks = [
  {
    label: "Book a Survey",
    href: "/survey/",
    description: "Book your £195 pre-installation survey online",
  },
  {
    label: "Small Kitchen Installation Cost",
    href: "/cost/small-kitchen-cost/",
    description: "8–12 units — typical cost ranges",
  },
  {
    label: "Medium Kitchen Installation Cost",
    href: "/cost/medium-kitchen-cost/",
    description: "13–20 units — typical cost ranges",
  },
  {
    label: "Large Kitchen Installation Cost",
    href: "/cost/large-kitchen-cost/",
    description: "21+ units — typical cost ranges",
  },
  {
    label: "Kitchen Installation Cost Guide",
    href: "/costs/",
    description: "Full breakdown of installation costs and typical ranges",
  },
  {
    label: "Contact Us",
    href: "/contact/",
    description: "Get in touch with Install My Kitchen",
  },
];
---

<Base title={title} description={metaDescription} canonical={canonical}>
  <Header slot="header" />

  <div class="container py-6">
    <Breadcrumbs
      items={[
        { label: "Cost Guide", href: "/costs/" },
        { label: "Kitchen Survey Cost", href: canonical },
      ]}
    />
  </div>

  <!-- Hero -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container">
      <div class="max-w-3xl">
        <h1
          class="text-4xl md:text-5xl font-extrabold mb-5 leading-tight"
          style="color: var(--navy);"
        >
          Kitchen Survey Cost — £195 Credited Back on Booking
        </h1>
        <AnswerBlock
          answer="A kitchen installation survey with Install My Kitchen costs £195. This fee is credited in full against your installation balance when you confirm your date and pay your deposit. The survey provides a fixed installation quote and identifies any issues before work begins."
        />
        <KeyTakeaway points={takeawayPoints} />
      </div>
    </div>
  </section>

  <!-- What the survey covers -->
  <section class="section">
    <div class="container">
      <div class="max-w-3xl fade-up">
        <h2 class="text-3xl font-bold mb-6" style="color: var(--navy);">
          What the Pre-Installation Survey Covers
        </h2>
        <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
          The pre-installation survey is a full site visit by one of our experienced kitchen fitters. It takes place at your property and typically lasts between one and two hours depending on the complexity of your kitchen plan and the room.
        </p>
        <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
          During the survey we carry out the following checks and assessments. These are not cosmetic questions — they are the specific measurements and observations that allow us to produce a fixed-price quote with confidence.
        </p>

        <ul class="space-y-4 list-none p-0 m-0">
          {[
            {
              item: "Full room measurement",
              detail:
                "We measure the room precisely — all four walls, ceiling height, and any alcoves, chimney breasts, or structural features that affect the unit run. We cross-reference these measurements against your kitchen plan and flag any discrepancies before you commit to an order.",
            },
            {
              item: "Floor level assessment",
              detail:
                "We check floor levels across the entire footprint using a spirit level and straight edge. A floor that rises or falls by 20mm or more across the kitchen run will require significant shimming and plinth scribing, which adds installation time. Identifying this at survey stage allows us to account for it in the fixed-price quote.",
            },
            {
              item: "Wall and ceiling conditions",
              detail:
                "We assess the straightness of walls and the height consistency of the ceiling. Out-of-plumb walls affect how wall units sit and how much scribing is needed at the ends of runs. Low or sloping ceilings can affect the positioning of tall housing units and extractors.",
            },
            {
              item: "Service positions",
              detail:
                "We note the current positions of the water supply, waste outlet, gas supply (if applicable), and electrical sockets and circuits. If any services need moving — to accommodate the new layout — we flag this so you can arrange the relevant trade in advance. Moving services after the kitchen is ordered is a common source of unexpected cost; catching it at survey stage keeps costs predictable.",
            },
            {
              item: "Kitchen plan review",
              detail:
                "We review your kitchen plan — whether from a retailer such as Howdens, Wren, or IKEA, or drawn up independently — against the actual room. We check that the proposed unit run will work in the space as drawn, that appliance apertures are the correct size for the appliances specified, and that the plan accounts for any structural features in the room.",
            },
            {
              item: "Fixed-price installation quote",
              detail:
                "Following the survey, we produce a written fixed-price installation quote. This sets out the scope of work, the number of installation days, the rate, and the total. This is the price you pay for the agreed scope — not a starting point for negotiation or a figure subject to additions.",
            },
          ].map(({ item, detail }) => (
            <li class="p-5 rounded-xl border" style="border-color: #E5E7EB; background: #fff;">
              <p class="font-semibold mb-1" style="color: var(--charcoal);">{item}</p>
              <p class="text-sm leading-relaxed" style="color: var(--text-soft);">{detail}</p>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- How the credit works -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container">
      <div class="max-w-3xl fade-up">
        <h2 class="text-3xl font-bold mb-4" style="color: var(--navy);">
          How the £195 Credit Works
        </h2>
        <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
          The survey fee of £195 is paid at the time of booking the survey. When you receive your fixed-price installation quote and decide to proceed, you confirm your installation date and pay a deposit. At this point, the £195 survey fee is credited in full against your installation balance. You do not pay the survey fee twice — it becomes part of your overall installation payment.
        </p>
        <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
          For example: if your fixed-price installation quote is £3,600 and you pay a 25% deposit (£900), the £195 survey credit is applied to that deposit, meaning you pay £705 at the point of booking rather than £900. The remaining balance is settled on completion of the installation.
        </p>
        <p class="leading-relaxed" style="color: var(--text-soft);">
          If, following the survey, you decide not to proceed with the installation, the survey fee is retained. The fee reflects the time and expertise involved in the site visit and the production of the fixed-price quote, and it is not refundable in this circumstance.
        </p>
      </div>
    </div>
  </section>

  <!-- Why the survey protects you -->
  <section class="section">
    <div class="container">
      <div class="max-w-3xl fade-up">
        <h2 class="text-3xl font-bold mb-4" style="color: var(--navy);">
          Why a Survey Protects Your Kitchen Project
        </h2>
        <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
          A kitchen installation without a pre-installation survey is, in our experience, an installation that carries unnecessary risk — for both the customer and the fitter. Without a survey, any quote is an estimate based on incomplete information. When the fitter arrives on site and discovers issues that the estimate did not account for, the cost conversation becomes difficult for everyone.
        </p>
        <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
          The most common issues we find at survey stage that would have caused problems on installation day: a floor level that varies more than expected; a gas or water supply in the wrong position for the new layout; a kitchen plan that does not quite work in the actual room due to a window position or a structural wall; and appliance aperture sizes that do not match the specified appliances. None of these is unusual — and all of them are straightforward to resolve when identified weeks before installation day rather than on the morning the units are due to go in.
        </p>
        <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
          We strongly recommend booking a survey before finalising your kitchen order. If we find that a unit run needs to change — for example, because the wall is shorter than the plan shows — you can reorder the affected components before delivery rather than dealing with the inconvenience and cost of return logistics after the kitchen has arrived.
        </p>
        <p class="leading-relaxed" style="color: var(--text-soft);">
          The survey is, in effect, the most valuable investment you can make in your kitchen project. It converts an uncertain estimate into a fixed price, and it converts unknown risk into a managed plan.
        </p>
      </div>
    </div>
  </section>

  <!-- How to book -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container">
      <div class="max-w-3xl fade-up">
        <h2 class="text-3xl font-bold mb-4" style="color: var(--navy);">
          How to Book a Pre-Installation Survey
        </h2>
        <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
          Booking a survey is straightforward. You can book online via our survey booking page, or call us on 07399 651836. We will agree a date and time that suits you, and collect the £195 survey fee at the time of booking.
        </p>
        <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
          Before the survey visit, it helps to have your kitchen plan available — a printed copy or a digital plan from your retailer's design software is ideal. If you have not yet finalised the plan, the survey can still go ahead: we assess the room and discuss your plans with you, which often helps to refine the kitchen layout before you commit to an order.
        </p>
        <p class="leading-relaxed" style="color: var(--text-soft);">
          We cover Coventry, Warwickshire, and surrounding areas. If you are unsure whether your address is within our coverage area, please call or use the contact form and we will confirm.
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container">
      <div class="max-w-3xl fade-up">
        <h2 class="text-3xl font-bold mb-8" style="color: var(--navy);">
          Frequently Asked Questions
        </h2>
        <FAQ items={faqs} schemaId="faq-kitchen-survey-cost" />
      </div>
    </div>
  </section>

  <!-- Internal Links -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container fade-up">
      <InternalLinks links={internalLinks} heading="Related Pages" />
    </div>
  </section>

  <!-- CTA -->
  <CTA
    heading="Book Your Pre-Installation Survey"
    subtext="£195 — credited back in full when you confirm your installation date. Covering Coventry, Warwickshire, and surrounding areas. Call 07399 651836 or book online."
    primaryLabel="Book a Survey"
    primaryHref="/survey/"
    secondaryLabel="Call 07399 651836"
    secondaryHref="tel:07399651836"
    dark={true}
  />

  <Footer slot="footer" />
  <StickyMobileCTA slot="sticky-cta" />
</Base>
