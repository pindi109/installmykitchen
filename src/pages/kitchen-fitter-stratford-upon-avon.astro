const takeawayPoints = [
  "Pindi Sahota is an independent kitchen fitter based in Coundon, Coventry — serving Stratford-upon-Avon, CV37, and surrounding areas including Shottery, Tiddington, Wellesbourne, and Henley-in-Arden.",
