    images: [
      { src: "/assets/projects/wren-kenilworth/wren-kenilworth-handleless-kitchen-units-2268x4032.webp", alt: "Wren Infinity Plus handleless units, Kenilworth" },
      { src: "/assets/projects/wren-kenilworth/wren-kenilworth-kitchen-island-fitting-2268x4032.webp", alt: "Kitchen island fitting, Wren Kenilworth" },
      { src: "/assets/projects/wren-kenilworth/wren-kenilworth-kitchen-open-plan-layout-2268x4032.webp", alt: "Open plan Wren kitchen layout, Kenilworth" },
      { src: "/assets/projects/wren-kenilworth/wren-kenilworth-kitchen-integrated-appliances-4032x2268.webp", alt: "Siemens integrated appliances, Wren Kenilworth" },
      { src: "/assets/projects/wren-kenilworth/wren-kenilworth-kitchen-dekton-worktop-4284x5712.webp", alt: "Dekton worktop stage, Wren Kenilworth kitchen" },
      { src: "/assets/projects/wren-kenilworth/wren-kenilworth-kitchen-handleless-doors-4284x5712.webp", alt: "Handleless Wren doors aligned and fitted, Kenilworth" },
      { src: "/assets/projects/wren-kenilworth/wren-kenilworth-kitchen-installation-progress-4284x5712.webp", alt: "Wren kitchen installation in progress, Kenilworth" },
      { src: "/assets/projects/wren-kenilworth/wren-kenilworth-kitchen-finished-island-4032x3024.webp", alt: "Finished Wren kitchen with island, Kenilworth" },
      { src: "/assets/projects/wren-kenilworth/wren-kenilworth-kitchen-completed-result-4032x3024.webp", alt: "Completed Wren Infinity Plus handleless kitchen, Kenilworth" },
    ],
