      { src: "/assets/projects/howdens-earlsdon-coventry/howdens-earlsdon-kitchen-integrated-appliances-4284x5712.webp", alt: "Integrated appliances installed, Howdens Earlsdon" },
      { src: "/assets/projects/howdens-earlsdon-coventry/howdens-earlsdon-kitchen-installation-complete-4284x5712.webp", alt: "Howdens kitchen installation complete, Earlsdon Coventry" },
      { src: "/assets/projects/howdens-earlsdon-coventry/howdens-earlsdon-kitchen-finished-result-3024x4032.webp", alt: "Finished Howdens Greenwich Shaker kitchen, Earlsdon Coventry" },
    ],
  },
