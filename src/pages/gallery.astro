      { src: "/assets/projects/magnet-solihull/magnet-solihull-belgravia-shaker-doors-4032x3024.webp", alt: "Magnet Belgravia painted shaker doors aligned, Solihull" },
      { src: "/assets/projects/magnet-solihull/magnet-solihull-kitchen-installation-progress-3024x4032.webp", alt: "Magnet kitchen installation progress, Solihull" },
