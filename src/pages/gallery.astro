      { src: "/assets/projects/ikea-leamington-spa/ikea-voxtorp-leamington-spa-doors-fitted-3024x4032.webp", alt: "IKEA VOXTORP matt white doors fitted, Leamington Spa" },
      { src: "/assets/projects/ikea-leamington-spa/ikea-voxtorp-leamington-spa-kitchen-layout-3024x4032.webp", alt: "IKEA METOD VOXTORP kitchen layout, Leamington Spa" },
