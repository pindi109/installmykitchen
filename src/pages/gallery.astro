      { src: "/assets/projects/magnet-solihull/magnet-solihull-kitchen-range-cooker-space-3024x4032.webp", alt: "Range cooker gap set within Magnet kitchen, Solihull" },
      { src: "/assets/projects/magnet-solihull/magnet-solihull-kitchen-granite-worktop-3024x4032.webp", alt: "Granite worktop with Magnet kitchen, Solihull" },
