<Base title={title} description={description} canonical={canonical}>
  <Header slot="header" />

  <div class="container py-4">
    <Breadcrumbs items={[{ label: "Gallery", href: "/gallery/" }]} />
  </div>

  <section class="section" style="background: var(--bg-light);">
    <div class="container">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-extrabold mb-4 leading-tight" style="color: var(--navy);">
          Kitchen Installation Gallery
        </h1>
        <p class="text-lg leading-relaxed" style="color: var(--text-soft);">
          Real kitchens installed by Pindi Sahota across Coventry, Kenilworth, Leamington Spa and Solihull. Every photo is from a genuine project — no stock images.
        </p>
      </div>
    </div>
  </section>

  {sections.map((section) => (
    <section class="section">
      <div class="container">
        <div class="section-header">
          <h2 class="section-title">{section.label}</h2>
          <a href={section.href} class="section-link">
            Read project
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>

        <div class="photo-grid">
          {section.images.map((img, i) => (
            <button
              class={`photo-thumb${i === 0 ? " photo-hero" : ""}`}
              data-src={img.src}
              data-alt={img.alt}
              aria-label={`View: ${img.alt}`}
            >
              <img
                src={img.src}
                alt={img.alt}
                loading={i < 2 ? "eager" : "lazy"}
                decoding="async"
              />
            </button>
          ))}
        </div>
      </div>
    </section>
  ))}

  <dialog id="lightbox" aria-label="Photo lightbox">
    <button id="lb-close" aria-label="Close">&#x2715;</button>
    <img id="lb-img" src="" alt="" />
    <p id="lb-caption"></p>
  </dialog>


  <section class="section" style="background: var(--bg-light); padding-top: 0;">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">More of Our Recent Projects</h2>
      </div>
      <div class="photo-grid more-grid">
        {moreImages.map((img, i) => (
          <button
            class="photo-thumb"
            data-src={img.src}
            data-alt={img.alt}
            aria-label={`View: ${img.alt}`}
          >
            <img
              src={img.src}
              alt={img.alt}
              loading="lazy"
              decoding="async"
            />
          </button>
        ))}
      </div>
    </div>
  </section>

  <div class="container pb-10">
    <InternalLinks
      heading="Explore Install My Kitchen"
      links={[
        { label: "All Projects", href: "/projects/", description: "Read the full case study for each kitchen installation." },
        { label: "About Pindi Sahota", href: "/pindi-sahota/", description: "The installer behind every kitchen we fit." },
        { label: "Book a Survey", href: "/survey/", description: "£195 pre-installation survey, credited back when you proceed." },
        { label: "Kitchen Installation Costs", href: "/costs/", description: "Transparent fixed pricing — what your quote includes." },
      ]}
    />
  </div>

  <CTA
    heading="Like What You See?"
    subtext="Book a pre-installation survey with Pindi. Fixed-price quote within 24 hours, survey fee credited back in full when you proceed."
    primaryLabel="Book Your Survey"
    primaryHref="/survey/"
    secondaryLabel="Call 07399 651836"
    secondaryHref="tel:07399651836"
    dark={true}
  />

  <Footer slot="footer" />
  <StickyMobileCTA slot="sticky-cta" />
</Base>

<style>
  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }
  .section-title {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--navy);
  }
  .section-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--teal);
    text-decoration: none;
    white-space: nowrap;
  }
  .section-link:hover {
    text-decoration: underline;
  }

  /* Photo grid */
  .photo-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0.375rem;
    border-radius: 0.625rem;
    overflow: hidden;
  }
  .photo-hero {
    grid-column: span 2;
    grid-row: span 2;
  }
  .photo-thumb {
    display: block;
    padding: 0;
    border: none;
    background: #f3f4f6;
    cursor: pointer;
    overflow: hidden;
    aspect-ratio: 1/1;
  }
  .photo-hero {
    aspect-ratio: auto;
  }
  .photo-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.25s ease;
  }
  .photo-thumb:hover img {
    transform: scale(1.05);
  }
  .more-grid {
    grid-template-columns: repeat(4, 1fr);
  }
  @media (max-width: 900px) {
    .more-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (max-width: 700px) {
    .photo-grid {
      grid-template-columns: repeat(3, 1fr);
    }
    .photo-hero {
      grid-column: span 3;
      grid-row: span 1;
      aspect-ratio: 16/9;
    }
  }

  /* Lightbox */
  #lightbox {
    border: none;
    border-radius: 0.75rem;
    background: #111;
    padding: 0;
    max-width: min(96vw, 1280px);
    max-height: 96vh;
    overflow: hidden;
    box-shadow: 0 30px 80px rgba(0,0,0,0.8);
  }
  #lightbox::backdrop {
    background: rgba(0, 0, 0, 0.88);
    backdrop-filter: blur(5px);
  }
  #lb-img {
    display: block;
    max-width: 100%;
    max-height: 90vh;
    object-fit: contain;
  }
  #lb-caption {
    color: #bbb;
    font-size: 0.8rem;
    padding: 0.5rem 1rem 0.625rem;
    margin: 0;
    text-align: center;
  }
  #lb-close {
    position: absolute;
    top: 0.5rem;
    right: 0.625rem;
    background: rgba(0,0,0,0.55);
    border: none;
    color: #fff;
    font-size: 1rem;
    width: 1.875rem;
    height: 1.875rem;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
  }
</style>

<script>
  const lb = document.getElementById("lightbox") as HTMLDialogElement;
  const lbImg = document.getElementById("lb-img") as HTMLImageElement;
  const lbCap = document.getElementById("lb-caption") as HTMLElement;
  const lbClose = document.getElementById("lb-close") as HTMLButtonElement;

  document.querySelectorAll(".photo-thumb").forEach((btn) => {
    btn.addEventListener("click", () => {
      const src = (btn as HTMLElement).dataset.src || "";
      const alt = (btn as HTMLElement).dataset.alt || "";
      lbImg.src = src;
      lbImg.alt = alt;
      lbCap.textContent = alt;
      lb.showModal();
    });
  });
  lbClose.addEventListener("click", () => lb.close());
  lb.addEventListener("click", (e) => { if (e.target === lb) lb.close(); });
</script>
