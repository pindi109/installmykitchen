---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import StickyMobileCTA from "../../components/StickyMobileCTA.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import AnswerBlock from "../../components/AnswerBlock.astro";
import KeyTakeaway from "../../components/KeyTakeaway.astro";
import FAQ from "../../components/FAQ.astro";
import InternalLinks from "../../components/InternalLinks.astro";
import CTA from "../../components/CTA.astro";

const services = [
  {
    title: "Cabinet Assembly & Installation",
    description: "We assemble and install all base, wall and tall units to manufacturer tolerances, ensuring everything is level, plumb and securely fixed regardless of the room's quirks.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/><line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/></svg>`,
  },
  {
    title: "Worktop Supply & Fitting",
    description: "We supply and fit laminate, solid wood and composite worktops, including all scribing, sink cut-outs, hob cut-outs and joint finishing.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="3" y1="15" x2="21" y2="15"/></svg>`,
  },
  {
    title: "Appliance & Sink Installation",
    description: "Integrated and freestanding appliances positioned and fitted, including ovens, hobs, dishwashers, washing machines, fridges and sink bowl and tap fitting.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 20V6a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v14"/><path d="M2 20h20"/><path d="M14 12v.01"/></svg>`,
  },
  {
    title: "Door & Drawer Fitting",
    description: "All cabinet doors and drawer fronts fitted and adjusted to be perfectly aligned, with soft-close mechanisms checked and set correctly.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="9" y1="3" x2="9" y2="21"/></svg>`,
  },
  {
    title: "Handles & Ironmongery",
    description: "All handles, knobs, cup pulls and other ironmongery fitted precisely and uniformly, using jigs where required for consistent positioning.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
  },
  {
    title: "Snagging & Adjustments",
    description: "A thorough snagging walkthrough at the end of every installation. We identify and resolve any alignment, fitting or finishing issues before we leave.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`,
  },
  {
    title: "Flooring & Tiling",
    description: "Optional — we can lay vinyl, LVT and laminate flooring as well as ceramic and porcelain wall and floor tiles to complete your kitchen transformation.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>`,
    optional: true,
  },
  {
    title: "Decorating",
    description: "Optional — we can paint and decorate your kitchen walls and ceiling as part of the installation project, leaving you with a completely finished space.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22C6.477 22 2 17.523 2 12S6.477 2 12 2s10 4.477 10 10-4.477 10-10 10zm0 0v-4"/><path d="M8 22H16"/></svg>`,
    optional: true,
  },
];

const keyTakeaways = [
  "Full cabinet assembly, worktop fitting, appliance integration and snagging included",
  "Optional flooring, tiling and decorating available on request",
  "All quotes are itemised — no hidden extras",
  "Pre-installation survey carried out before every job",
  "Independent of all retailers — we fit kitchens purchased anywhere",
];

const faqItems = [
  {
    q: "What is included in a standard kitchen installation?",
    a: "A standard installation covers cabinet assembly and fitting, worktop supply and fitting (including cut-outs), appliance and sink installation, door and drawer fitting, handles and ironmongery, and a full snagging walkthrough. Flooring, tiling and decorating are available as optional extras.",
  },
  {
    q: "Do you supply the kitchen units?",
    a: "No — our service is designed for customers who have already purchased their kitchen from a retailer such as Wren, Howdens, Magnet or IKEA. We install what you have bought. We can, however, supply worktops if required.",
  },
  {
    q: "Can you fit worktops from a different supplier?",
    a: "Yes. We can supply and fit laminate, solid wood and composite worktops independently of the kitchen retailer. If you prefer to source your own worktops, we can fit those too.",
  },
  {
    q: "What about plumbing, gas and electrical work?",
    a: "We recommend customers arrange their own qualified plumber, gas engineer and electrician before the installation date. We focus on the cabinetry, worktops, appliances and fittings, and are happy to advise on when specialist trades need to be on-site.",
  },
  {
    q: "Do you offer a warranty on your installation work?",
    a: "Yes — we stand behind the quality of our work. Any issues directly resulting from our installation will be addressed as a priority. Specific terms are confirmed in your written quote.",
  },
  {
    q: "How far in advance should I book?",
    a: "We recommend booking as soon as you have a confirmed kitchen delivery date. Installation slots in Coventry, Warwickshire and Berkshire fill up quickly, particularly in spring and autumn. Booking a survey early helps us secure your preferred dates.",
  },
];
---

<Base
  title="Kitchen Installation Services | Coventry, Warwickshire & Berkshire"
  description="Expert kitchen installation services in Coventry, Warwickshire and Berkshire — cabinet fitting, worktops, appliances, doors, handles and snagging. Independent of all retailers."
  canonical="https://installmykitchen.co.uk/services/"
>
  <!-- Header -->
  <Header slot="header" />

  <!-- ══════════════════════════════ PAGE HEADER ══════════════════ -->
  <section class="page-header" aria-label="Page header">
    <div class="container">
      <Breadcrumbs items={[{ label: "Services", href: "/services/" }]} />
      <h1 class="page-h1">Kitchen Installation Services in Coventry, Warwickshire &amp; Berkshire</h1>
      <p class="page-sub">Everything you need to turn your flat-pack delivery into a finished, functioning kitchen.</p>
    </div>
  </section>

  <!-- ══════════════════════════════ MAIN CONTENT ════════════════ -->
  <section class="section" style="background: #fff;" aria-labelledby="services-heading">
    <div class="container">

      <AnswerBlock answer="Install My Kitchen provides a full independent kitchen installation service across Coventry, Warwickshire and Berkshire, fitting kitchens supplied by Wren, Howdens, Magnet, IKEA and all major retailers. Services include cabinet fitting, worktops, appliances, doors, handles and snagging." />

      <KeyTakeaway points={keyTakeaways} />

      <!-- Services grid -->
      <h2 id="services-heading" class="section-h2 mb-8">What's Included</h2>
      <ul class="services-grid" role="list">
        {services.map((service) => (
          <li class="service-card" role="listitem">
            <div class="service-icon" aria-hidden="true" set:html={service.icon} />
            <div class="service-body">
              <h3 class="service-title">
                {service.title}
                {service.optional && (
                  <span class="optional-badge">Optional</span>
                )}
              </h3>
              <p class="service-desc">{service.description}</p>
            </div>
          </li>
        ))}
      </ul>

      <!-- What's not included -->
      <div class="not-included-box">
        <h2 class="not-included-heading">Specialist Trades</h2>
        <p class="not-included-body">
          Due to high demand and fast-filling slots, we recommend customers arrange their own qualified electricians, plumbers and gas engineers before the installation date wherever possible. We are happy to advise on sequencing and timing so that everything runs smoothly.
        </p>
      </div>

      <!-- Survey section -->
      <div class="survey-box">
        <div class="survey-content">
          <h2 class="survey-heading">Pre-Installation Survey</h2>
          <p class="survey-body">
            Every installation starts with a pre-installation survey. We visit your home to check the room against your kitchen plan, take precise measurements, identify any potential issues and confirm the scope of work. The survey costs £195 and that fee is credited in full against your installation balance when you confirm your booking date.
          </p>
          <a href="/survey/" class="btn-primary survey-btn">
            Book a Survey — £195
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12"/>
              <polyline points="12 5 19 12 12 19"/>
            </svg>
          </a>
        </div>
        <div class="survey-badge">
          <p class="survey-badge-amount">£195</p>
          <p class="survey-badge-label">Survey Fee</p>
          <p class="survey-badge-sub">Credited on booking</p>
        </div>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════ FAQ ═══════════ -->
  <section class="section" style="background: var(--bg-light);" aria-labelledby="faq-heading">
    <div class="container">
      <div class="max-w-3xl mx-auto">
        <h2 id="faq-heading" class="text-2xl md:text-3xl font-bold mb-2 text-center" style="color: var(--charcoal);">
          Services FAQ
        </h2>
        <p class="text-center text-sm mb-10" style="color: var(--text-soft);">
          Common questions about our kitchen installation services.
        </p>
        <FAQ items={faqItems} schemaId="services-faq" />
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════ INTERNAL LINKS ═════ -->
  <section class="section" style="background: #fff;" aria-label="Related pages">
    <div class="container">
      <InternalLinks
        heading="Explore Further"
        links={[
          { label: "Cabinet assembly & installation", href: "/services/cabinet-installation/", description: "Base, wall, larder and tall units levelled, secured and aligned." },
          { label: "Worktop supply & fitting", href: "/services/worktop-fitting/", description: "Laminate worktops supplied and fitted; solid surface co-ordinated." },
          { label: "Appliance & sink installation", href: "/services/appliance-installation/", description: "Ovens, hobs, dishwashers, extractors and sinks fitted correctly." },
          { label: "Door & drawer fitting", href: "/services/door-fitting/", description: "All doors hung and drawers set to perfect alignment." },
          { label: "Trims, plinths & cornices", href: "/services/trims-and-plinths/", description: "Every edge finished — plinths, cornices, pelmet and fillers." },
          { label: "Handles & ironmongery", href: "/services/handles-and-ironmongery/", description: "Handles, knobs and soft-close hardware fitted and aligned." },
          { label: "Snagging & final adjustments", href: "/services/snagging/", description: "Systematic quality walkthrough before every handover." },
          { label: "Flooring & tiling", href: "/services/flooring-tiling/", description: "Vinyl, LVT, laminate, ceramic and porcelain available." },
          { label: "Book a survey — £195 credited back", href: "/survey/", description: "Every installation starts with a pre-installation survey." },
          { label: "Installation cost guide", href: "/costs/", description: "What does a kitchen installation cost in Coventry, Warwickshire and Berkshire?" },
          { label: "Pindi Sahota — 30 years experience", href: "/pindi-sahota/", description: "Meet the fitter behind Install My Kitchen." },
          { label: "Completed kitchen projects", href: "/projects/", description: "Gallery of finished kitchens installed across Coventry, Warwickshire and Berkshire." },
        ]}
      />
    </div>
  </section>

  <!-- ══════════════════════════════════════ DARK CTA ═══════════ -->
  <CTA
    dark={true}
    heading="Ready to Get Your Kitchen Fitted?"
    subtext="Book a pre-installation survey and get a clear, itemised quote. No hidden extras, no surprises."
    primaryLabel="Book a Survey — £195"
    primaryHref="/survey/"
    secondaryLabel="View Areas We Cover"
    secondaryHref="/areas/"
  />

  <!-- Footer -->
  <Footer slot="footer" />
  <StickyMobileCTA slot="sticky-cta" />
</Base>

<style>
  /* Page header */
  .page-header {
    background: var(--hero-gradient);
    padding: 3rem 0 3.5rem;
  }

  .page-h1 {
    font-size: clamp(1.625rem, 3vw, 2.5rem);
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.02em;
    margin-top: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .page-sub {
    color: rgba(255, 255, 255, 0.75);
    font-size: 1.0625rem;
    line-height: 1.6;
    max-width: 540px;
  }

  /* Section heading */
  .section-h2 {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--charcoal);
  }

  /* Services grid */
  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    list-style: none;
    padding: 0;
    margin: 0 0 2.5rem;
  }

  @media (min-width: 640px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .services-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .service-card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    background: var(--bg-light);
    border-radius: 1rem;
    border: 1.5px solid var(--border);
    padding: 1.25rem;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .service-card:hover {
    border-color: var(--teal);
    box-shadow: 0 4px 16px rgba(15, 118, 110, 0.1);
  }

  .service-icon {
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 0.625rem;
    background: rgba(15, 118, 110, 0.08);
    color: var(--teal);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .service-body {
    flex: 1;
  }

  .service-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--charcoal);
    margin-bottom: 0.375rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .service-desc {
    font-size: 0.875rem;
    line-height: 1.65;
    color: var(--text-soft);
  }

  .optional-badge {
    display: inline-block;
    padding: 0.15rem 0.6rem;
    border-radius: 50px;
    background: rgba(212, 160, 23, 0.15);
    color: #92670e;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Not included box */
  .not-included-box {
    background: rgba(15, 118, 110, 0.05);
    border: 1.5px solid rgba(15, 118, 110, 0.2);
    border-left: 4px solid var(--teal);
    border-radius: 0 0.75rem 0.75rem 0;
    padding: 1.25rem 1.5rem;
    margin-bottom: 2.5rem;
  }

  .not-included-heading {
    font-size: 1rem;
    font-weight: 700;
    color: var(--charcoal);
    margin-bottom: 0.5rem;
  }

  .not-included-body {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--text-soft);
  }

  /* Survey box */
  .survey-box {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    background: var(--bg-light);
    border: 1.5px solid var(--border);
    border-radius: 1.25rem;
    padding: 2rem;
  }

  @media (min-width: 768px) {
    .survey-box {
      flex-direction: row;
      align-items: center;
    }
  }

  .survey-content {
    flex: 1;
  }

  .survey-heading {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--charcoal);
    margin-bottom: 0.75rem;
  }

  .survey-body {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--text-soft);
    margin-bottom: 1.25rem;
  }

  .survey-btn {
    white-space: nowrap;
  }

  .survey-badge {
    text-align: center;
    background: var(--teal);
    color: #fff;
    border-radius: 1rem;
    padding: 1.5rem 2rem;
    flex-shrink: 0;
  }

  .survey-badge-amount {
    font-size: 2rem;
    font-weight: 800;
    line-height: 1;
  }

  .survey-badge-label {
    font-size: 0.875rem;
    font-weight: 600;
    opacity: 0.9;
    margin-top: 0.25rem;
  }

  .survey-badge-sub {
    font-size: 0.75rem;
    opacity: 0.75;
    margin-top: 0.25rem;
  }
</style>
