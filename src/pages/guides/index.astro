---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import StickyMobileCTA from "../../components/StickyMobileCTA.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import CTA from "../../components/CTA.astro";

const title = "Kitchen Installation Guides | Install My Kitchen";
const description =
  "Expert guides on kitchen installation — costs, preparation, choosing a fitter, worktops and more. Written for homeowners across Coventry and Warwickshire.";
const canonical = "https://www.installmykitchen.co.uk/guides/";

// DECISION: Title is 48 chars and meta is 154 chars — both within specified targets.

const guides = [
  {
    href: "/guides/how-to-prepare-for-kitchen-installation/",
    title: "How to Prepare for Kitchen Installation — A Complete Checklist",
    description:
      "Everything you need to do in the weeks and days before your installation team arrives — booking trades, checking deliveries and protecting your home.",
    readTime: "7 min read",
    tags: ["Preparation", "Planning"],
  },
  {
    href: "/guides/how-to-choose-a-kitchen-fitter/",
    title: "How to Choose a Kitchen Fitter — What to Look For",
    description:
      "How to find a reliable, experienced fitter — from the survey process and what's included in a quote to red flags and questions to ask.",
    readTime: "7 min read",
    tags: ["Choosing a Fitter", "Advice"],
  },
  {
    href: "/guides/kitchen-installation-survey-guide/",
    title: "The Kitchen Installation Survey — Why It Matters and What to Expect",
    description:
      "Why a pre-installation survey is essential, what the surveyor checks, and how to prepare for the visit.",
    readTime: "7 min read",
    tags: ["Survey", "Planning"],
  },
  {
    href: "/guides/working-with-wren-howdens-magnet/",
    title: "Working with Wren, Howdens & Magnet — What Independent Fitters Need to Know",
    description:
      "If you have bought from a major kitchen retailer, here is what to expect when using an independent fitter — deliveries, missing parts and more.",
    readTime: "7 min read",
    tags: ["Retailers", "Advice"],
  },
  {
    href: "/guides/kitchen-worktop-guide/",
    title: "Kitchen Worktop Guide — Types, Costs and Fitting",
    description:
      "Laminate, solid wood, quartz, granite or compact laminate — a plain-English guide to materials, costs and the fitting process.",
    readTime: "7 min read",
    tags: ["Worktops", "Materials"],
  },
  {
    href: "/guides/kitchen-appliance-installation-guide/",
    title: "Kitchen Appliance Installation Guide — What You Need to Know",
    description:
      "Which appliances need an electrician, which need a plumber, and how to time appliance installation within the overall fit.",
    readTime: "7 min read",
    tags: ["Appliances", "Installation"],
  },
  {
    href: "/guides/kitchen-plumbing-electrical-guide/",
    title: "Plumbing and Electrical Preparation for Kitchen Installation",
    description:
      "First fix, second fix and Gas Safe — when to book your trades, what to arrange and why it matters for your timeline.",
    readTime: "7 min read",
    tags: ["Plumbing", "Electrical"],
  },
  {
    href: "/guides/ikea-kitchen-installation-guide/",
    title: "IKEA Kitchen Installation Guide — What to Expect",
    description:
      "IKEA kitchens can be installed by an independent fitter. Here is the process — assembly, METOD system, delivery checks and common pitfalls.",
    readTime: "7 min read",
    tags: ["IKEA", "Retailers"],
  },
  {
    href: "/guides/kitchen-installation-timeline/",
    title: "Kitchen Installation Timeline — Day by Day",
    description:
      "A typical day-by-day breakdown of a medium kitchen installation, with notes on what can cause delays at each stage.",
    readTime: "7 min read",
    tags: ["Timeline", "Planning"],
  },
  {
    href: "/guides/kitchen-snagging-guide/",
    title: "Kitchen Snagging — What It Is and What to Check",
    description:
      "How to create a snagging list, what to look for after installation and how we handle defects at Install My Kitchen.",
    readTime: "6 min read",
    tags: ["Snagging", "Aftercare"],
  },
];
---

<Base
  title={title}
  description={description}
  canonical={canonical}
>
  <Header slot="header" />

  <div class="container py-6">
    <Breadcrumbs
      items={[
        { label: "Guides", href: "/guides/" },
      ]}
    />
  </div>

  <!-- Hero -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container">
      <div class="max-w-3xl">
        <h1
          class="text-4xl md:text-5xl font-extrabold mb-5 leading-tight"
          style="color: var(--navy);"
        >
          Kitchen Installation Guides for Homeowners
        </h1>
        <p class="text-lg leading-relaxed" style="color: var(--text-soft);">
          Practical, honest guides written by our Coventry fitting team — covering everything from choosing a fitter and preparing your home to worktops, appliances and snagging. Whether this is your first kitchen or your fourth, you will find straightforward answers here.
        </p>
      </div>
    </div>
  </section>

  <!-- Guide Cards -->
  <section class="section">
    <div class="container">
      <div class="max-w-4xl">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {guides.map((guide) => (
            <article class="card border border-gray-100 hover:shadow-md transition-shadow duration-200 fade-up">
              <a href={guide.href} class="block p-6 group h-full flex flex-col">
                <div class="flex flex-wrap gap-2 mb-3">
                  {guide.tags.map((tag) => (
                    <span
                      class="inline-block text-xs font-semibold px-2.5 py-0.5 rounded-full"
                      style="background: rgba(20, 184, 166, 0.1); color: var(--teal);"
                    >
                      {tag}
                    </span>
                  ))}
                  <span
                    class="inline-block text-xs px-2.5 py-0.5 rounded-full"
                    style="background: #F3F4F6; color: var(--text-soft);"
                  >
                    {guide.readTime}
                  </span>
                </div>
                <h2
                  class="text-lg font-bold mb-2 group-hover:underline leading-snug"
                  style="color: var(--navy);"
                >
                  {guide.title}
                </h2>
                <p class="text-sm leading-relaxed flex-1" style="color: var(--text-soft);">
                  {guide.description}
                </p>
                <span
                  class="inline-flex items-center gap-1.5 mt-4 text-sm font-semibold"
                  style="color: var(--teal);"
                >
                  Read guide
                  <svg
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <line x1="5" y1="12" x2="19" y2="12" />
                    <polyline points="12 5 19 12 12 19" />
                  </svg>
                </span>
              </a>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <CTA
    heading="Ready to Get Your Kitchen Installed?"
    subtext="Book a pre-installation survey from £195 — credited back in full when you proceed. Covering Coventry, Warwickshire and surrounding areas."
    primaryLabel="Book Your Survey"
    primaryHref="/survey/"
    secondaryLabel="Call 07399 651836"
    secondaryHref="tel:07399651836"
    dark={true}
  />

  <Footer slot="footer" />
  <StickyMobileCTA slot="sticky-cta" />
</Base>
