---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import StickyMobileCTA from "../../components/StickyMobileCTA.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import AnswerBlock from "../../components/AnswerBlock.astro";
import FAQ from "../../components/FAQ.astro";
import SupplierLogos from "../../components/SupplierLogos.astro";
import InternalLinks from "../../components/InternalLinks.astro";
import CTA from "../../components/CTA.astro";
import TrustStrip from "../../components/TrustStrip.astro";
import WhatHappensNext from "../../components/WhatHappensNext.astro";

import retailersData from "../../data/retailers.json";
import faqsData from "../../data/faqs.json";
import locationsData from "../../data/locations.json";

export function getStaticPaths() {
  return retailersData.map((retailer) => ({
    params: { retailer: retailer.slug },
    props: { retailer },
  }));
}

const { retailer } = Astro.props;
const { slug, displayName, description, installNote } = retailer;

const canonical = `https://installmykitchen.co.uk/retailers/${slug}/`;

// Title — ≤60 chars, abbreviated where necessary
const rawTitle = `${displayName} Kitchen Installation | Install My Kitchen`;
const title = rawTitle.length <= 60 ? rawTitle : `${displayName} Kitchen Fitting | Install My Kitchen`;

// Meta description — 140–160 chars, unique per retailer
const metaDescription = `Independent ${displayName} kitchen installation across Coventry, Warwickshire & Berkshire. We are not affiliated with ${displayName} — we install kitchens you've purchased from them.`;

// Retailer-specific FAQ — pull from retailers section, first 4
const faqItems = faqsData.retailers.slice(0, 4);

// Brand image set
const brandImgMap: Record<string, { overview: string; process: string; detail: string; finished: string }> = {
  wren:    { overview: "/assets/brand/wren/wren-kitchen-overview.webp",    process: "/assets/brand/wren/wren-installation-progress.webp",    detail: "/assets/brand/wren/wren-handleless-doors.webp",    finished: "/assets/brand/wren/wren-finished-result.webp"    },
  howdens: { overview: "/assets/brand/howdens/howdens-kitchen-overview.webp", process: "/assets/brand/howdens/howdens-rigid-units.webp",       detail: "/assets/brand/howdens/howdens-shaker-detail.webp",  finished: "/assets/brand/howdens/howdens-finished-result.webp" },
  ikea:    { overview: "/assets/brand/ikea/ikea-kitchen-overview.webp",    process: "/assets/brand/ikea/ikea-flatpack-assembly.webp",       detail: "/assets/brand/ikea/ikea-door-detail.webp",         finished: "/assets/brand/ikea/ikea-finished-result.webp"    },
  magnet:  { overview: "/assets/brand/magnet/magnet-kitchen-overview.webp",process: "/assets/brand/magnet/magnet-installation.webp",        detail: "/assets/brand/magnet/magnet-door-detail.webp",      finished: "/assets/brand/magnet/magnet-finished-result.webp" },
};
const brandImgs = brandImgMap[slug] ?? {
  overview: "/assets/process/finished-kitchen-neutral.webp",
  process:  "/assets/process/base-units-levelling.webp",
  detail:   "/assets/process/doors-hanging.webp",
  finished: "/assets/process/finished-kitchen-dark.webp",
};

// Related retailer links — up to 4 other retailers
const otherRetailers = retailersData
  .filter((r) => r.slug !== slug)
  .slice(0, 4)
  .map((r) => ({
    label: r.displayName,
    href: `/retailers/${r.slug}/`,
    description: `Independent installation for ${r.displayName} kitchens`,
  }));

// Location links
const locationLinks = [
  { label: "Kitchen Installation in Coventry", href: "/areas/coventry/", description: "Our home city — full coverage" },
  { label: "Kitchen Installation in Leamington Spa", href: "/areas/leamington-spa/", description: "Warwickshire coverage" },
  { label: "Kitchen Installation in Rugby", href: "/areas/rugby/", description: "North Warwickshire coverage" },
  { label: "Kitchen Installation in Kenilworth", href: "/areas/kenilworth/", description: "South Warwickshire coverage" },
];

const additionalLinks = [
  {
    label: `Compare ${displayName} with Alternatives`,
    href: `/comparisons/`,
    description: `Side-by-side comparisons of UK kitchen retailers`,
  },
  {
    label: `${displayName} Kitchen Installation Cost`,
    href: `/cost/${slug}-cost/`,
    description: `What to budget for fitting your ${displayName} kitchen`,
  },
  {
    label: `Book Your Pre-Installation Survey`,
    href: `/survey/`,
    description: `Fixed-price quote after a home visit — fee credited on booking`,
  },
  {
    label: `Completed Kitchen Projects`,
    href: `/projects/`,
    description: `Browse real installations carried out by Install My Kitchen`,
  },
  {
    label: `About Pindi Sahota — Your Installer`,
    href: `/pindi-sahota/`,
    description: `20+ years of trade experience fitting kitchens across Coventry, Warwickshire & Berkshire`,
  },
];

const internalLinks = [...otherRetailers, ...locationLinks, ...additionalLinks].slice(0, 10);

// Breadcrumb JSON-LD is emitted once by the <Breadcrumbs> component below.

// Service JSON-LD
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: `${displayName} Kitchen Installation`,
  provider: {
    "@type": "LocalBusiness",
    name: "Install My Kitchen",
    url: "https://installmykitchen.co.uk",
  },
  areaServed: {
    "@type": "Place",
    name: "Coventry, Warwickshire and Berkshire",
  },
  description: `Independent installation service for ${displayName} kitchens across Coventry, Warwickshire and Berkshire. Install My Kitchen is not affiliated with ${displayName}.`,
  serviceType: "Kitchen Installation",
};
---

<Base
  title={title}
  description={metaDescription}
  canonical={canonical}
>
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

  <Header slot="header" />

  <div class="container py-6">
    <Breadcrumbs
      items={[
        { label: "Retailers", href: "/retailers/" },
        { label: displayName, href: `/retailers/${slug}/` },
      ]}
    />
  </div>

  <!-- Hero -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-extrabold mb-5 leading-tight" style="color: var(--navy);">
          {displayName} Kitchen Installation — Independent Fitting Service
        </h1>
        <AnswerBlock
          answer={`Install My Kitchen provides expert independent installation for ${displayName} kitchens across Coventry, Warwickshire and Berkshire. We are not affiliated with ${displayName} — we install kitchens you've purchased from them.`}
        />
      </div>
    </div>
  </section>

  <!-- About this retailer -->
  <section class="section">
    <div class="container">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; align-items: start;" class="fade-up">
        <div>
          <h2 class="text-3xl font-bold mb-4" style="color: var(--navy);">
            About {displayName} Kitchens
          </h2>
          <p class="text-lg leading-relaxed mb-4" style="color: var(--text-soft);">
            {description}
          </p>
          <p class="leading-relaxed" style="color: var(--text-soft);">
            Install My Kitchen is entirely independent of {displayName}. We install kitchens — not sell them. You benefit from impartial advice and a fitter whose sole focus is the quality of your result.
          </p>
        </div>
        <figure style="margin: 0;">
          <img src={brandImgs.overview} alt={`${displayName} kitchen installed by Install My Kitchen`} width="680" height="510" loading="lazy" style="width: 100%; height: auto; border-radius: 0.75rem; display: block;" />
        </figure>
      </div>
    </div>
  </section>

  <!-- Installation logistics -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container">
      <div class="fade-up">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; align-items: start; margin-bottom: 2rem;">
          <figure style="margin: 0;">
            <img src={brandImgs.process} alt={`${displayName} kitchen installation in progress`} width="680" height="510" loading="lazy" style="width: 100%; height: auto; border-radius: 0.75rem; display: block;" />
          </figure>
          <div>
            <h2 class="text-3xl font-bold mb-4" style="color: var(--navy);">
              What to Expect When We Fit Your {displayName} Kitchen
            </h2>
            <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
              {installNote}
            </p>
            <p class="leading-relaxed" style="color: var(--text-soft);">
              Before installation begins, we carry out a detailed pre-installation survey — taking precise measurements, reviewing your {displayName} plan against the actual room, and identifying any issues before they become problems on the day.
            </p>
          </div>
        </div>
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem;">
          <figure style="margin: 0;"><img src="/assets/process/delivery-checking.webp" alt={`${displayName} delivery being checked`} width="420" height="315" loading="lazy" style="width: 100%; height: auto; border-radius: 0.625rem; display: block;" /></figure>
          <figure style="margin: 0;"><img src={brandImgs.detail} alt={`${displayName} kitchen detail shot`} width="420" height="315" loading="lazy" style="width: 100%; height: auto; border-radius: 0.625rem; display: block;" /></figure>
          <figure style="margin: 0;"><img src={brandImgs.finished} alt={`Completed ${displayName} kitchen`} width="420" height="315" loading="lazy" style="width: 100%; height: auto; border-radius: 0.625rem; display: block;" /></figure>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Process -->
  <section class="section">
    <div class="container">
      <div class="max-w-3xl fade-up">
        <h2 class="text-3xl font-bold mb-6" style="color: var(--navy);">
          Our Installation Process
        </h2>
        <ol class="space-y-5 list-none p-0 m-0">
          <li class="flex gap-4 items-start">
            <span class="flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold text-white" style="background: var(--teal);">1</span>
            <div>
              <p class="font-semibold mb-1" style="color: var(--charcoal);">Pre-Installation Survey</p>
              <p class="text-sm leading-relaxed" style="color: var(--text-soft);">A visit to your home to measure, assess, and review your {displayName} plan. We provide a fixed-price installation quote following the survey.</p>
            </div>
          </li>
          <li class="flex gap-4 items-start">
            <span class="flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold text-white" style="background: var(--teal);">2</span>
            <div>
              <p class="font-semibold mb-1" style="color: var(--charcoal);">Kitchen Delivery Co-ordination</p>
              <p class="text-sm leading-relaxed" style="color: var(--text-soft);">We help you co-ordinate the delivery of your {displayName} kitchen to ensure all components are on site and checked before installation begins.</p>
            </div>
          </li>
          <li class="flex gap-4 items-start">
            <span class="flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold text-white" style="background: var(--teal);">3</span>
            <div>
              <p class="font-semibold mb-1" style="color: var(--charcoal);">Strip-Out &amp; Dry Fit</p>
              <p class="text-sm leading-relaxed" style="color: var(--text-soft);">We strip out the existing kitchen and carry out a full dry fit of all new carcasses to verify the layout before anything is permanently fixed.</p>
            </div>
          </li>
          <li class="flex gap-4 items-start">
            <span class="flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold text-white" style="background: var(--teal);">4</span>
            <div>
              <p class="font-semibold mb-1" style="color: var(--charcoal);">Fitting &amp; Finishing</p>
              <p class="text-sm leading-relaxed" style="color: var(--text-soft);">All carcasses are levelled and fixed, worktops templated and fitted, doors and drawers adjusted, and all plinths, cornices, and accessories installed.</p>
            </div>
          </li>
          <li class="flex gap-4 items-start">
            <span class="flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold text-white" style="background: var(--teal);">5</span>
            <div>
              <p class="font-semibold mb-1" style="color: var(--charcoal);">Snagging &amp; Sign-Off</p>
              <p class="text-sm leading-relaxed" style="color: var(--text-soft);">A final walk-round with you to check every aspect of the finished installation before we consider the job complete.</p>
            </div>
          </li>
        </ol>
      </div>
    </div>
  </section>

  <!-- Supplier Logos -->
  <SupplierLogos />

  <!-- Process gallery -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container">
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem;">
        <figure style="margin: 0;"><img src="/assets/process/worktop-fitting.webp" alt={`Worktop fitted during ${displayName} kitchen installation`} width="420" height="315" loading="lazy" style="width: 100%; height: auto; border-radius: 0.625rem; display: block;" /><figcaption style="font-size: 0.75rem; color: var(--text-soft); margin-top: 0.375rem; text-align: center;">Worktop Fitting</figcaption></figure>
        <figure style="margin: 0;"><img src="/assets/process/handles-fitting.webp" alt={`Handles fitted during ${displayName} kitchen installation`} width="420" height="315" loading="lazy" style="width: 100%; height: auto; border-radius: 0.625rem; display: block;" /><figcaption style="font-size: 0.75rem; color: var(--text-soft); margin-top: 0.375rem; text-align: center;">Handles &amp; Ironmongery</figcaption></figure>
        <figure style="margin: 0;"><img src="/assets/process/snagging-inspection.webp" alt={`Final snagging inspection on ${displayName} kitchen`} width="420" height="315" loading="lazy" style="width: 100%; height: auto; border-radius: 0.625rem; display: block;" /><figcaption style="font-size: 0.75rem; color: var(--text-soft); margin-top: 0.375rem; text-align: center;">Snagging &amp; Sign-Off</figcaption></figure>
      </div>
    </div>
  </section>

  <!-- Trust Strip -->
  <TrustStrip />

  <!-- FAQ -->
  <section class="section">
    <div class="container">
      <div class="max-w-3xl fade-up">
        <h2 class="text-3xl font-bold mb-8" style="color: var(--navy);">
          Frequently Asked Questions
        </h2>
        <FAQ items={faqItems} schemaId={`faq-retailer-${slug}`} />
      </div>
    </div>
  </section>

  <!-- Internal Links -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container fade-up">
      <InternalLinks
        links={internalLinks}
        heading="Related Pages"
      />
    </div>
  </section>

  <!-- All locations for this retailer -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container">
      <h2 class="text-2xl font-bold mb-2" style="color: var(--navy);">{displayName} Kitchen Installation by Area</h2>
      <p class="mb-6" style="color: var(--text-soft); font-size: 0.9375rem;">We install {displayName} kitchens across Coventry, Warwickshire and Berkshire. Select your area for full local details.</p>
      <ul style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 0.625rem; list-style: none; padding: 0; margin: 0;">
        {locationsData.map((loc) => (
          <li>
            <a href={`/installer/${slug}-${loc.slug}/`}
               style="display: block; padding: 0.625rem 0.875rem; background: #fff; border: 1px solid #E5E7EB; border-radius: 0.5rem; font-size: 0.8125rem; font-weight: 600; color: var(--navy); text-decoration: none;">
              {displayName} — {loc.name}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- What Happens Next -->
  <WhatHappensNext />

  <!-- CTA -->
  <CTA
    heading={`Book Your ${displayName} Kitchen Installation Survey`}
    subtext={`Our £195 pre-installation survey gives you a fixed-price quote for your ${displayName} kitchen. Credited back in full when you proceed.`}
    primaryLabel="Book Your Survey"
    primaryHref="/survey/"
    secondaryLabel="Call 07399 651836"
    secondaryHref="tel:07399651836"
    dark={true}
  />

  <Footer slot="footer" />
  <StickyMobileCTA slot="sticky-cta" />
</Base>
