---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import StickyMobileCTA from "../components/StickyMobileCTA.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import AnswerBlock from "../components/AnswerBlock.astro";
import KeyTakeaway from "../components/KeyTakeaway.astro";
import FAQ from "../components/FAQ.astro";
import SupplierLogos from "../components/SupplierLogos.astro";
import InternalLinks from "../components/InternalLinks.astro";
import CTA from "../components/CTA.astro";
import TrustStrip from "../components/TrustStrip.astro";

const title = "Kitchen Fitter Kenilworth | Install My Kitchen — Pindi Sahota";
const metaDescription = "Expert kitchen fitter in Kenilworth, Warwickshire. Pindi Sahota installs kitchens across CV8 with 30 years experience, premium finish standards, fixed-price quotes, and a £195 survey credited back on booking.";
const canonical = "https://installmykitchen.co.uk/kitchen-fitter-kenilworth/";

const takeawayPoints = [
  "Pindi Sahota is an independent kitchen fitter based in Coundon, Coventry — serving Kenilworth, CV8, and surrounding villages including Burton Green and Balsall Common.",
  "30 years of professional experience, including premium and large-format installations in Kenilworth's substantial Victorian, Edwardian, and modern detached homes.",
  "Fitted the Wren Infinity Plus handleless kitchen in Kenilworth — the case study project on the Install My Kitchen website.",
  "Pre-installation survey at £195, credited back in full when you proceed — fixed-price quote guaranteed.",
];

const faqItems = [
  {
    q: "What standard of finish do Kenilworth kitchen fitters need to deliver?",
    a: "Kenilworth homeowners consistently expect — and deserve — an exceptionally high standard of finish. The town's housing stock is at the premium end of the Warwickshire market: large Victorian and Edwardian detached houses along Coventry Road and Castle Road, 1930s substantial detached properties, and modern executive homes in developments such as Beehive Hill and Whitemoor. Kitchens in these homes are typically larger-than-average, often with 20 or more units, stone worktops, integrated premium appliances, and island configurations. The fitting must be precise: door alignments measured to fractions of a millimetre, worktop joins invisible, integrated appliance panels perfectly flush. Pindi Sahota has 30 years of experience delivering this standard and has fitted numerous kitchens in Kenilworth, including the Wren Infinity Plus handleless installation that forms the site's Wren case study.",
  },
  {
    q: "How much does kitchen fitting cost in Kenilworth?",
    a: "Kitchen fitting costs in Kenilworth are typically higher than the regional average, reflecting the larger kitchen sizes, premium worktop materials, and greater appliance counts common in the town's housing stock. A 15–20 unit kitchen with stone worktops and integrated appliances will typically have fitting labour costs in the range of £2,000–£3,500. Larger installations — 25 units, an island, multiple integrated appliances, bespoke larder towers — will sit above this range. All prices are confirmed as fixed, itemised quotes following Pindi's pre-installation survey. There are no estimates and no retrospective charges.",
  },
  {
    q: "Do you cover CV8?",
    a: "Yes. Pindi covers the whole of the CV8 postcode area, which includes Kenilworth town centre, Castle Road, Beehive Hill, Crackley, and the surrounding villages. He also regularly covers Burton Green and Balsall Common, which are just beyond the CV8 boundary. He is based at 242 Hollyfast Road, Coundon, Coventry CV6 2AH — approximately 8 miles north of Kenilworth — and has been working in the town for many years. Call 07399 651836 to confirm coverage for your specific address.",
  },
  {
    q: "How long does a large kitchen take to install?",
    a: "A large Kenilworth kitchen — typically 18–25 units with an island, stone worktops, and multiple integrated appliances — generally takes between five and eight working days for the installation. Projects at the more complex end, involving structural elements such as a kitchen extension, multiple ceiling-height larder towers, or extensive bespoke work, may take longer. Pindi will give you a realistic and detailed duration estimate during the pre-installation survey, based on the specific room dimensions, the kitchen specification, and any preparation work required. This allows you to plan your household routine and the availability of other trades around the installation.",
  },
  {
    q: "Which premium kitchen brands do you fit in Kenilworth?",
    a: "Pindi fits kitchens from all brands at every price point, including the premium and German brands that are common in Kenilworth's larger properties. These include Wren Kitchens (including the Infinity Plus handleless range, which he has fitted in Kenilworth), Howdens, Magnet, Kutchenhaus, and premium suppliers such as Häcker, Nobilia, Mereway, Neptune, and deVOL. He also fits from IKEA, Wickes, B&Q, Benchmarx, DIY Kitchens, Symphony, and Masterclass. Because he is independent — not employed by any retailer — he can work with any brand without conflict of interest and bring the same meticulous standard of finish regardless of price point.",
  },
];

const internalLinks = [
  {
    label: "Book a pre-installation survey",
    href: "/survey/",
    description: "£195 survey credited back in full when you proceed — the essential first step",
  },
  {
    label: "Kitchen fitting costs explained",
    href: "/costs/",
    description: "Fully itemised guide to what affects kitchen installation prices",
  },
  {
    label: "Kenilworth area page",
    href: "/areas/kenilworth/",
    description: "Detailed installation information for Kenilworth and CV8",
  },
  {
    label: "Wren kitchen in Kenilworth — case study",
    href: "/projects/wren-kitchen-kenilworth/",
    description: "See the Wren Infinity Plus handleless kitchen Pindi fitted in Kenilworth",
  },
  {
    label: "About Pindi Sahota",
    href: "/pindi-sahota/",
    description: "Meet the independent kitchen fitter behind Install My Kitchen",
  },
  {
    label: "Wren kitchen installation",
    href: "/retailers/wren/",
    description: "Fitting your Wren kitchen independently — what you need to know",
  },
  {
    label: "Howdens kitchen installation",
    href: "/retailers/howdens/",
    description: "Why independent fitting is the right choice for your Howdens kitchen",
  },
];

// LocalBusiness JSON-LD
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "Install My Kitchen",
  url: "https://installmykitchen.co.uk",
  telephone: "07399651836",
  email: "info@installmykitchen.co.uk",
  image: "https://installmykitchen.co.uk/images/pindi-sahota.jpg",
  address: {
    "@type": "PostalAddress",
    streetAddress: "242 Hollyfast Road, Coundon",
    addressLocality: "Coventry",
    postalCode: "CV6 2AH",
    addressCountry: "GB",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: 52.4197,
    longitude: -1.5379,
  },
  areaServed: {
    "@type": "City",
    name: "Kenilworth",
  },
  description:
    "Independent kitchen fitting service in Kenilworth, Warwickshire. Pindi Sahota has 30 years of experience fitting premium kitchens from all major retailers including Wren, Howdens, Häcker and Mereway. Fixed-price quotes following a £195 pre-installation survey.",
  priceRange: "££",
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      opens: "08:00",
      closes: "18:00",
    },
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: "Saturday",
      opens: "09:00",
      closes: "13:00",
    },
  ],
};

// Service JSON-LD
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Kitchen Fitting in Kenilworth",
  provider: {
    "@type": "LocalBusiness",
    name: "Install My Kitchen",
    url: "https://installmykitchen.co.uk",
    telephone: "07399651836",
  },
  areaServed: {
    "@type": "City",
    name: "Kenilworth",
  },
  description:
    "Professional independent kitchen fitting and installation service across Kenilworth and CV8, fitting kitchens from all major UK retailers and premium brands including Wren, Howdens, Häcker, Nobilia, Mereway and Neptune. Fixed-price quotes following a pre-installation survey.",
  serviceType: "Kitchen Fitting",
  offers: {
    "@type": "Offer",
    name: "Pre-installation Survey",
    price: "195.00",
    priceCurrency: "GBP",
    description: "Pre-installation survey, fully credited back against the fitting quote when you proceed.",
  },
