---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import StickyMobileCTA from "../../components/StickyMobileCTA.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import AnswerBlock from "../../components/AnswerBlock.astro";
import KeyTakeaway from "../../components/KeyTakeaway.astro";
import FAQ from "../../components/FAQ.astro";
import EnquiryForm from "../../components/EnquiryForm.astro";
import InternalLinks from "../../components/InternalLinks.astro";
import CTA from "../../components/CTA.astro";

import locationsData from "../../data/locations.json";
import remedialData from "../../data/remedial.json";

const PRIORITY_REMEDIAL_SLUGS = [
  "coventry",
  "solihull",
  "leamington-spa",
  "warwick",
  "kenilworth",
  "nuneaton",
  "rugby",
  "reading",
  "bracknell",
  "slough",
  "maidenhead",
  "windsor",
  "wokingham",
  "newbury",
  "ascot",
];

export function getStaticPaths() {
  const PRIORITY_REMEDIAL_SLUGS = [
    "coventry",
    "solihull",
    "leamington-spa",
    "warwick",
    "kenilworth",
    "nuneaton",
    "rugby",
    "reading",
    "bracknell",
    "slough",
    "maidenhead",
    "windsor",
    "wokingham",
    "newbury",
    "ascot",
  ];

  const remedialLocations = PRIORITY_REMEDIAL_SLUGS
    .map((slug) => locationsData.find((l) => l.slug === slug))
    .filter(Boolean) as typeof locationsData;

  const paths: {
    params: { job: string; location: string };
    props: {
      job: typeof remedialData[0];
      location: typeof locationsData[0];
      jobIndex: number;
      locationIndex: number;
    };
  }[] = [];

  remedialData.forEach((job, jobIndex) => {
    remedialLocations.forEach((location, locationIndex) => {
      paths.push({
        params: { job: job.slug, location: location.slug },
        props: { job, location, jobIndex, locationIndex },
      });
    });
  });

  return paths;
}

const { job, location, jobIndex, locationIndex } = Astro.props;

// Pricing — Berkshire locations pay fromPriceBerks, CW locations pay fromPriceCW
const isBerkshire = (location as any).isBerkshire === true;
const fromPrice = isBerkshire ? job.fromPriceBerks : job.fromPriceCW;
const minCallout = isBerkshire ? 75 : 50;
const pricingTierLabel = isBerkshire ? "Berkshire" : "Coventry, Warwickshire & Berkshire";

// Canonical
const canonical = `https://installmykitchen.co.uk/repairs/${job.slug}-${location.slug}/`;

// Title (≤60ch)
const title = `${job.name} in ${location.name} | Install My Kitchen`;

// Meta description (140–160ch)
const metaDescription = `${job.name} in ${location.name} by an independent kitchen specialist. Covering ${location.county} — from £${fromPrice}. Agree price first, no obligation callout. Call 07399 651836.`;

// KeyTakeaway pools — genuinely varied content between them
const takeawayPoolA = [
  `We carry out ${job.name} as a standalone job — no need for a full kitchen replacement.`,
  `From £${fromPrice} in ${location.name} — fixed price agreed before any work starts.`,
  `Independent service: we work for you, not for any retailer or manufacturer.`,
  `Most ${job.name} jobs in ${location.name} are completed in a single visit.`,
];

const takeawayPoolB = [
  `${job.name} carried out by an experienced kitchen fitter based in Coventry.`,
  `We assess the problem on site and confirm the price before we begin — no surprises.`,
  `From £${fromPrice} in ${location.name}, with a minimum call-out of £${minCallout}.`,
  `We carry standard replacement parts, so most jobs need just one visit.`,
];

const poolIndex = (jobIndex * 3 + locationIndex * 2) % 2;
const takeawayPoints = poolIndex === 0 ? takeawayPoolA : takeawayPoolB;

// Internal links — 8 links as per spec
// Get 2 other jobs in the same location for cross-linking
const otherJobs = remedialData
  .filter((j) => j.slug !== job.slug)
  .slice(0, 2);

const internalLinks = [
  {
    label: "Repairs hub",
    href: "/repairs/",
    description: "All 17 kitchen repair and remedial services we offer",
  },
  {
    label: `${otherJobs[0]?.name ?? "Kitchen snagging"} in ${location.name}`,
    href: `/repairs/${otherJobs[0]?.slug ?? "kitchen-snagging"}-${location.slug}/`,
    description: `Related remedial work in ${location.name}`,
  },
  {
    label: `${otherJobs[1]?.name ?? "Drawer runner repair"} in ${location.name}`,
    href: `/repairs/${otherJobs[1]?.slug ?? "drawer-runner-repair"}-${location.slug}/`,
    description: `Related remedial work in ${location.name}`,
  },
  {
    label: `Kitchen installation in ${location.name}`,
    href: `/areas/${location.slug}/`,
    description: `Full independent kitchen installation service across ${location.name}`,
  },
  {
    label: `Kitchen cost guide for ${location.name}`,
    href: `/kitchen-cost/${location.slug}/`,
    description: `Itemised cost guide for ${location.name} — what to expect`,
  },
  {
    label: `Book a survey in ${location.name}`,
    href: `/survey/${location.slug}/`,
    description: `Pre-installation survey — £195, credited back on booking`,
  },
  {
    label: "Contact us",
    href: "/contact/",
    description: "Call, email, or WhatsApp — we respond within one working day",
  },
  {
    label: "Full cost guide",
    href: "/costs/",
    description: "Everything that affects kitchen fitting and repair prices explained",
  },
];

// JSON-LD — Service schema
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: `${job.name} in ${location.name}`,
  provider: {
    "@type": "LocalBusiness",
    name: "Install My Kitchen",
    url: "https://installmykitchen.co.uk",
    telephone: "+447399651836",
    address: {
      "@type": "PostalAddress",
      streetAddress: "242 Hollyfast Road, Coundon",
      addressLocality: "Coventry",
      postalCode: "CV6 2AH",
      addressCountry: "GB",
    },
  },
  areaServed: {
    "@type": "Place",
    name: location.name,
  },
  description: `${job.description.substring(0, 200)}`,
  serviceType: job.name,
  offers: {
    "@type": "Offer",
    priceCurrency: "GBP",
    price: String(fromPrice),
    description: `From £${fromPrice} in ${location.name} — minimum call-out £${minCallout}`,
  },
};

// BreadcrumbList JSON-LD
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: "https://installmykitchen.co.uk/",
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Repairs",
      item: "https://installmykitchen.co.uk/repairs/",
    },
    {
      "@type": "ListItem",
      position: 3,
      name: `${job.name} in ${location.name}`,
      item: canonical,
    },
  ],
};
---

<Base
  title={title}
  description={metaDescription}
  canonical={canonical}
  noHero={true}
>
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <Header slot="header" />

  <!-- Breadcrumbs -->
  <div class="container py-6">
    <Breadcrumbs
      items={[
        { label: "Repairs", href: "/repairs/" },
        {
          label: `${job.name} in ${location.name}`,
          href: `/repairs/${job.slug}-${location.slug}/`,
        },
      ]}
    />
  </div>

  <!-- Hero / intro -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-extrabold mb-5 leading-tight" style="color: var(--navy);">
          {job.name} in {location.name}
        </h1>
        <AnswerBlock
          answer={`Install My Kitchen carries out ${job.name.toLowerCase()} in ${location.name} and the wider ${location.county} area. Work is priced from £${fromPrice} and confirmed before we begin — so you know exactly what you will pay before any tools come out.`}
        />
        <KeyTakeaway points={takeawayPoints} />
      </div>
    </div>
  </section>

  <!-- Section 1: What this job involves -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container">
      <div class="max-w-3xl fade-up">
        <h2 class="text-3xl font-bold mb-4" style="color: var(--navy);">
          What {job.name} Involves
        </h2>
        <p class="text-lg leading-relaxed mb-6" style="color: var(--text-soft);">
          {job.description}
        </p>

        {job.commonCauses && job.commonCauses.length > 0 && (
          <>
            <h3 class="text-xl font-bold mb-3" style="color: var(--navy);">
              Common Reasons Customers Book This Service
            </h3>
            <ul class="space-y-2 mb-4">
              {job.commonCauses.map((cause) => (
                <li class="flex items-start gap-3">
                  <span
                    class="flex-shrink-0 w-5 h-5 rounded-full flex items-center justify-center mt-0.5"
                    style="background: var(--teal); color: #fff;"
                    aria-hidden="true"
                  >
                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="20 6 9 17 4 12"/>
                    </svg>
                  </span>
                  <span class="text-sm leading-relaxed" style="color: var(--text-soft);">{cause}</span>
                </li>
              ))}
            </ul>
          </>
        )}

        {job.typicalTime && (
          <p class="text-sm leading-relaxed" style="color: var(--text-soft);">
            <strong style="color: var(--charcoal);">Typical time on site:</strong> {job.typicalTime}.
          </p>
        )}
      </div>
    </div>
  </section>

  <!-- Section 2: Pricing -->
  <section class="section">
    <div class="container">
      <div class="max-w-3xl fade-up">
        <h2 class="text-3xl font-bold mb-4" style="color: var(--navy);">
          Pricing for {job.name} in {location.name}
        </h2>
        <p class="text-lg leading-relaxed mb-4" style="color: var(--text-soft);">
          Our {job.name.toLowerCase()} service in {location.name} starts from <strong style="color: var(--charcoal);">£{fromPrice}</strong>. The final price depends on the scope of work — number of units affected, whether replacement parts are required, and access within the property.
        </p>
        <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
          We always confirm the price before any work begins. For straightforward jobs where the scope is clear from the initial description, we will provide a fixed quote when you get in touch. For more complex situations where we need to assess on site first, we will quote a maximum price at the beginning of the visit and will not exceed it without your explicit agreement.
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
          <div class="card p-5">
            <p class="text-xs font-bold uppercase tracking-wide mb-1" style="color: var(--teal);">Starting from</p>
            <p class="text-3xl font-extrabold mb-1" style="color: var(--navy);">£{fromPrice}</p>
            <p class="text-sm" style="color: var(--text-soft);">{job.name} in {location.name}</p>
          </div>
          <div class="card p-5">
            <p class="text-xs font-bold uppercase tracking-wide mb-1" style="color: var(--teal);">Minimum call-out</p>
            <p class="text-3xl font-extrabold mb-1" style="color: var(--navy);">£{minCallout}</p>
            <p class="text-sm" style="color: var(--text-soft);">{pricingTierLabel} area</p>
          </div>
        </div>

        <p class="text-sm leading-relaxed" style="color: var(--text-soft);">
          Parts required for the repair are charged at cost plus a small handling margin. We will itemise any parts separately so you can see exactly what you are paying for.
        </p>
      </div>
    </div>
  </section>

  <!-- Enquiry form (between pricing and FAQ) -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container">
      <div class="max-w-2xl mx-auto fade-up">
        <h2 class="text-2xl font-bold mb-2 text-center" style="color: var(--navy);">
          Book {job.name} in {location.name}
        </h2>
        <p class="text-center text-sm mb-8" style="color: var(--text-soft);">
          Describe your issue and we will respond within one working day with availability and a price indication.
        </p>
        <EnquiryForm formTitle={`Enquire About ${job.name}`} showSurveyOption={false} />
      </div>
    </div>
  </section>

  <!-- Section 3: Local area context -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container">
      <div class="max-w-3xl fade-up">
        <h2 class="text-3xl font-bold mb-4" style="color: var(--navy);">
          Kitchen Repairs in {location.name}
        </h2>
        <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
          {location.housingStock}
        </p>
        {location.localNote && (
          <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
            {location.localNote}
          </p>
        )}
        {(location as any).kitchenNotes && (
          <p class="leading-relaxed" style="color: var(--text-soft);">
            {(location as any).kitchenNotes}
          </p>
        )}
      </div>
    </div>
  </section>

  <!-- Section 4: Upsell line and internal links -->
  <section class="section">
    <div class="container">
      <div class="max-w-3xl fade-up">
        <div class="card p-6 mb-8" style="border-left: 4px solid var(--gold); background: rgba(212, 160, 23, 0.04);">
          <p class="text-base leading-relaxed font-medium" style="color: var(--charcoal);">
            {job.upsellLine}
          </p>
        </div>
        <InternalLinks
          links={internalLinks}
          heading={`Related Pages for ${location.name}`}
        />
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container">
      <div class="max-w-3xl fade-up">
        <h2 class="text-3xl font-bold mb-8" style="color: var(--navy);">
          Frequently Asked Questions
        </h2>
        <FAQ
          items={job.faqs.slice(0, 4)}
          schemaId={`faq-${job.slug}-${location.slug}`}
        />
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTA
    heading={`Ready to Book ${job.name} in ${location.name}?`}
    subtext={`We cover ${location.name} and the wider ${location.county} area. Call us or send an enquiry — we confirm availability and price within one working day.`}
    primaryLabel="Send an Enquiry"
    primaryHref="/contact/"
    secondaryLabel="Call 07399 651836"
    secondaryHref="tel:07399651836"
    dark={true}
  />

  <Footer slot="footer" />
  <StickyMobileCTA slot="sticky-cta" />
</Base>
