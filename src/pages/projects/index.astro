---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import StickyMobileCTA from "../../components/StickyMobileCTA.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import CTA from "../../components/CTA.astro";

const title = "Kitchen Installation Projects — Coventry & Warwickshire | Install My Kitchen";
const description =
  "Browse completed kitchen installation projects across Coventry and Warwickshire — Howdens, Wren, IKEA and Magnet installations surveyed, planned and fitted by our team.";
const canonical = "https://www.installmykitchen.co.uk/projects/";

const projects = [
  {
    href: "/projects/howdens-kitchen-earlsdon-coventry/",
    retailer: "Howdens",
    title: "Howdens Greenwich Shaker — Earlsdon, Coventry",
    location: "Earlsdon, Coventry (CV5)",
    units: "16 units",
    duration: "5 days",
    description:
      "A 16-unit Howdens Greenwich Shaker installation in a 1930s semi-detached property. Included quartz worktop co-ordination, integrated appliances and chimney breast scribing.",
    tags: ["Howdens", "Shaker", "Quartz Worktop"],
  },
  {
    href: "/projects/wren-kitchen-kenilworth/",
    retailer: "Wren",
    title: "Wren Infinity Plus Handleless — Kenilworth",
    location: "Kenilworth, Warwickshire (CV8)",
    units: "22 units",
    duration: "7 days",
    description:
      "A 22-unit handleless L-shaped kitchen with island in a detached Kenilworth property. Siemens integrated appliances and Dekton worktop with specialist templating.",
    tags: ["Wren", "Handleless", "Island", "Dekton"],
  },
  {
    href: "/projects/ikea-kitchen-leamington-spa/",
    retailer: "IKEA",
    title: "IKEA METOD / VOXTORP — Leamington Spa",
    location: "Royal Leamington Spa (CV31)",
    units: "18 units",
    duration: "6 days",
    description:
      "An 18-unit IKEA METOD kitchen in a Victorian mid-terrace. Period plasterwork scribing, full flat-pack assembly, quartz worktops and integrated appliances.",
    tags: ["IKEA", "METOD", "Period Property", "Quartz Worktop"],
  },
  {
    href: "/projects/magnet-kitchen-solihull/",
    retailer: "Magnet",
    title: "Magnet Belgravia Painted Shaker — Solihull",
    location: "Solihull (B91)",
    units: "20 units",
    duration: "6 days",
    description:
      "A 20-unit Magnet Belgravia painted in-frame style kitchen in a 1960s detached property. Granite worktops and a range cooker installation co-ordinated with a Gas Safe engineer.",
    tags: ["Magnet", "Painted Shaker", "Granite", "Range Cooker"],
  },
];
---

<Base
  title={title}
  description={description}
  canonical={canonical}
>
  <Header slot="header" />

  <div class="container py-6">
    <Breadcrumbs
      items={[
        { label: "Projects", href: "/projects/" },
      ]}
    />
  </div>

  <!-- Hero -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container">
      <div class="max-w-3xl">
        <h1
          class="text-4xl md:text-5xl font-extrabold mb-5 leading-tight"
          style="color: var(--navy);"
        >
          Kitchen Installation Projects
        </h1>
        <p class="text-lg leading-relaxed" style="color: var(--text-soft);">
          Every kitchen we install is a project we're proud of. Browse our completed kitchen installations across Coventry and Warwickshire — each one surveyed, planned and fitted by our team.
        </p>
      </div>
    </div>
  </section>

  <!-- Project cards -->
  <section class="section">
    <div class="container">
      <div class="max-w-4xl">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {projects.map((project) => (
            <article class="card border border-gray-100 hover:shadow-md transition-shadow duration-200 fade-up">
              <a href={project.href} class="block p-6 group h-full flex flex-col">

                <!-- Tags -->
                <div class="flex flex-wrap gap-2 mb-3">
                  {project.tags.map((tag) => (
                    <span
                      class="inline-block text-xs font-semibold px-2.5 py-0.5 rounded-full"
                      style="background: rgba(20, 184, 166, 0.1); color: var(--teal);"
                    >
                      {tag}
                    </span>
                  ))}
                </div>

                <!-- Title -->
                <h2
                  class="text-lg font-bold mb-3 group-hover:underline leading-snug"
                  style="color: var(--navy);"
                >
                  {project.title}
                </h2>

                <!-- Meta row -->
                <dl class="project-meta mb-3">
                  <div class="meta-row">
                    <dt>Location</dt>
                    <dd>{project.location}</dd>
                  </div>
                  <div class="meta-row">
                    <dt>Units</dt>
                    <dd>{project.units}</dd>
                  </div>
                  <div class="meta-row">
                    <dt>Duration</dt>
                    <dd>{project.duration}</dd>
                  </div>
                </dl>

                <!-- Description -->
                <p class="text-sm leading-relaxed flex-1" style="color: var(--text-soft);">
                  {project.description}
                </p>

                <!-- Link label -->
                <span
                  class="inline-flex items-center gap-1.5 mt-4 text-sm font-semibold"
                  style="color: var(--teal);"
                >
                  Read case study
                  <svg
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <line x1="5" y1="12" x2="19" y2="12" />
                    <polyline points="12 5 19 12 12 19" />
                  </svg>
                </span>
              </a>
            </article>
          ))}
        </div>

        <!-- Photo note -->
        <div class="photo-note fade-up">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="color: var(--teal); flex-shrink: 0; margin-top: 2px;">
            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
            <circle cx="8.5" cy="8.5" r="1.5"></circle>
            <polyline points="21 15 16 10 5 21"></polyline>
          </svg>
          <p>
            Project photos are added as we complete installations. <a href="/contact/" style="color: var(--teal); font-weight: 600;">Contact us</a> to discuss your project.
          </p>
        </div>
      </div>
    </div>
  </section>

  <CTA
    heading="Ready to Start Your Kitchen Project?"
    subtext="Book a pre-installation survey from £195 — credited back in full when you proceed. Covering Coventry, Warwickshire and surrounding areas."
    primaryLabel="Book Your Survey"
    primaryHref="/survey/"
    secondaryLabel="Call 07399 651836"
    secondaryHref="tel:07399651836"
    dark={true}
  />

  <Footer slot="footer" />
  <StickyMobileCTA slot="sticky-cta" />
</Base>

<style>
  .project-meta {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    font-size: 0.8125rem;
  }

  .meta-row {
    display: flex;
    gap: 0.5rem;
  }

  .meta-row dt {
    font-weight: 600;
    color: var(--charcoal);
    min-width: 4.5rem;
  }

  .meta-row dd {
    color: var(--text-soft);
  }

  .photo-note {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    margin-top: 2rem;
    padding: 1rem 1.25rem;
    border-radius: 0.625rem;
    background: rgba(15, 118, 110, 0.05);
    border: 1.5px solid rgba(15, 118, 110, 0.15);
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--text-soft);
  }

  .photo-note p {
    margin: 0;
  }
</style>
