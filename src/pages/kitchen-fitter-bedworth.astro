    "@type": "LocalBusiness",
    name: "Install My Kitchen",
    url: "https://installmykitchen.co.uk",
    telephone: "07399651836",
  },
  areaServed: {
    "@type": "City",
    name: "Bedworth",
  },
  description:
    "Professional independent kitchen fitting and installation service across Bedworth and CV12, fitting kitchens from all major UK retailers including Wren, Howdens, Magnet, IKEA, Wickes and B&Q. Fixed-price quotes following a pre-installation survey.",
  serviceType: "Kitchen Fitting",
  offers: {
    "@type": "Offer",
    name: "Pre-installation Survey",
    price: "195.00",
    priceCurrency: "GBP",
    description: "Pre-installation survey, fully credited back against the fitting quote when you proceed.",
  },
