  name: "Install My Kitchen",
  url: "https://installmykitchen.co.uk",
  telephone: "07399651836",
  email: "info@installmykitchen.co.uk",
  image: "https://installmykitchen.co.uk/images/pindi-sahota.jpg",
  address: {
    "@type": "PostalAddress",
    streetAddress: "242 Hollyfast Road, Coundon",
    addressLocality: "Coventry",
    postalCode: "CV6 2AH",
    addressCountry: "GB",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: 52.4197,
    longitude: -1.5379,
  },
  areaServed: {
    "@type": "City",
    name: "Bedworth",
  },
  description:
    "Independent kitchen fitting service in Bedworth, Warwickshire. Pindi Sahota has 30 years of experience fitting kitchens from all major retailers including Wren, Howdens, Magnet and IKEA. Fixed-price quotes following a £195 pre-installation survey.",
  priceRange: "££",
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      opens: "08:00",
      closes: "18:00",
    },
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: "Saturday",
      opens: "09:00",
      closes: "13:00",
    },
