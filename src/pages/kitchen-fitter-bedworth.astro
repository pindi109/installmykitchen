---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import StickyMobileCTA from "../components/StickyMobileCTA.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import AnswerBlock from "../components/AnswerBlock.astro";
import KeyTakeaway from "../components/KeyTakeaway.astro";
import FAQ from "../components/FAQ.astro";
import SupplierLogos from "../components/SupplierLogos.astro";
import InternalLinks from "../components/InternalLinks.astro";
import CTA from "../components/CTA.astro";
import TrustStrip from "../components/TrustStrip.astro";

const title = "Kitchen Fitter Bedworth | Install My Kitchen — Pindi Sahota";
const metaDescription = "Independent kitchen fitter in Bedworth, Warwickshire. Pindi Sahota provides expert kitchen installation in CV12 with 30 years experience, fixed-price quotes, and a £195 survey credited back on booking.";
const canonical = "https://installmykitchen.co.uk/kitchen-fitter-bedworth/";

const takeawayPoints = [
  "Pindi Sahota is an independent kitchen fitter based in Coundon, Coventry — serving Bedworth, CV12, and all surrounding settlements including Exhall, Ash Green, and Bulkington.",
  "30 years of professional kitchen fitting experience, including the compact galley layouts and restricted spaces typical of Bedworth's post-war housing stock.",
  "Fits kitchens from Wren, Howdens, Magnet, IKEA, Wickes, B&Q, Benchmarx and all other major retailers.",
  "Pre-installation survey at £195, credited back in full when you proceed — fixed-price quote guaranteed.",
];

const faqItems = [
  {
    q: "What does an independent kitchen fitter do in Bedworth?",
    a: "An independent kitchen fitter manages the entire kitchen installation from stripped room to finished result — working directly for you, not for a retailer. In Bedworth, where many homes are 1950s and 1960s post-war semis and terraces with compact galley kitchens, this includes stripping out the existing kitchen, levelling uneven floors, cutting and fitting units to accommodate low ceilings and restricted ceiling heights above wall units, fitting carcasses, doors, drawers, and plinths, cutting worktops, installing sinks and taps, and connecting appliances. Because Pindi is independent, he is accountable only to you — not to a national retailer's call centre — so every decision is made in your interest.",
  },
  {
    q: "How much does kitchen fitting cost in Bedworth?",
    a: "Kitchen fitting costs in Bedworth depend on the size of the kitchen, the complexity of the layout, and the number of appliances. Bedworth's typical post-war semi-detached and terraced kitchens — often compact galley arrangements with 10–14 units — generally fall in the range of £1,100 to £2,000 for fitting labour. Projects that require additional work, such as floor levelling in older properties, extraction routing in restricted ceiling voids, or appliance integration, will sit at the higher end. Pindi provides a fully itemised, fixed-price quote following a pre-installation survey, so there are no hidden charges.",
  },
  {
    q: "Do you cover the CV12 postcode?",
    a: "Yes. Pindi covers the whole of the CV12 postcode area, including Bedworth town centre, Exhall, Ash Green, Bulkington, Goodyears End, Hawkesbury, and Longford. He is based at 242 Hollyfast Road, Coundon, Coventry CV6 2AH — approximately 8 miles from Bedworth town centre — and covers all surrounding areas routinely. If you are unsure whether your specific address is covered, call 07399 651836 and he will confirm.",
  },
  {
    q: "How long does kitchen installation take?",
    a: "Most standard kitchen installations in Bedworth take between three and five working days for the fitting work itself. Compact galley kitchens with straightforward layouts can sometimes be completed in three days. Larger kitchens, or those requiring additional preparation work — such as floor levelling in older post-war properties, replastering after removing a chimney breast, or re-routing extraction through restricted ceiling voids — will take longer. Pindi will give you a realistic duration estimate during the pre-installation survey, based on the actual conditions in your home.",
  },
  {
    q: "Which kitchen retailers do you install in Bedworth?",
    a: "Because Pindi is fully independent, he installs kitchens from any retailer or manufacturer. In Bedworth and the CV12 area, the most common kitchens he fits include Wren, Howdens, Magnet, IKEA, Wickes, B&Q, and Benchmarx. He also fits from DIY Kitchens, Kutchenhaus, Symphony, Masterclass, and premium brands such as Häcker, Nobilia, and Mereway. If your kitchen brand is not listed, call 07399 651836 — in almost every case it can be accommodated.",
  },
];

const internalLinks = [
  {
    label: "Book a pre-installation survey",
    href: "/survey/",
    description: "£195 survey credited back in full when you proceed — the essential first step",
  },
  {
    label: "Kitchen fitting costs explained",
    href: "/costs/",
    description: "Fully itemised guide to what affects kitchen installation prices",
  },
  {
    label: "Bedworth area page",
    href: "/areas/bedworth/",
    description: "Detailed installation information for Bedworth and CV12",
  },
  {
    label: "Completed kitchen projects",
    href: "/projects/",
    description: "Real installations by Pindi across Coventry and the Midlands",
  },
  {
    label: "About Pindi Sahota",
    href: "/pindi-sahota/",
    description: "Meet the independent kitchen fitter behind Install My Kitchen",
  },
  {
    label: "Howdens kitchen installation",
    href: "/retailers/howdens/",
    description: "Why independent fitting is the right choice for your Howdens kitchen",
  },
  {
    label: "Wren kitchen installation",
    href: "/retailers/wren/",
    description: "Fitting your Wren kitchen independently — what you need to know",
  },
];

// LocalBusiness JSON-LD
