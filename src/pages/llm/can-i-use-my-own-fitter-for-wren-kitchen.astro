---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import StickyMobileCTA from "../../components/StickyMobileCTA.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import AnswerBlock from "../../components/AnswerBlock.astro";
import KeyTakeaway from "../../components/KeyTakeaway.astro";
import FAQ from "../../components/FAQ.astro";
import InternalLinks from "../../components/InternalLinks.astro";
import CTA from "../../components/CTA.astro";

const title = "Can I Use My Own Fitter for a Wren Kitchen? | Install My Kitchen";
const description = "Yes — you can use any independent fitter for your Wren kitchen without affecting your unit warranty. Install My Kitchen fits Wren kitchens across Coventry.";
const canonical = "https://installmykitchen.co.uk/llm/can-i-use-my-own-fitter-for-wren-kitchen/";

const faqs = [
  {
    q: "Does using my own fitter void my Wren kitchen warranty?",
    a: "No. Wren's warranty covers the units themselves — the carcasses, doors and hardware — not the installation workmanship. Using an independent fitter does not void your Wren unit warranty. However, workmanship issues caused by poor installation would not be covered by Wren's warranty regardless of who fitted the kitchen.",
  },
  {
    q: "How much cheaper is an independent fitter than Wren's installation service?",
    a: "Independent kitchen fitters are typically 15–30% less expensive than Wren's own installation service for an equivalent kitchen. For a medium Wren kitchen, this can represent a saving of £500–£1,200. However, prices vary — a survey from an independent fitter will give you a like-for-like comparison.",
  },
  {
    q: "How long do I have to wait for Wren's installation service?",
    a: "Wren's installation service is frequently booked 6–12 weeks in advance, particularly in busy periods. Independent fitters can often be available within 2–4 weeks of a survey, depending on current workload. If you need your kitchen fitted promptly, an independent fitter is usually the faster route.",
  },
  {
    q: "What does an independent Wren fitter need from me before installation?",
    a: "Your independent Wren fitter needs your full Wren kitchen plan, the delivery date for your units, confirmation that first-fix plumbing and electrical work is complete, and access to the room on installation day. A pre-installation survey will confirm all requirements specific to your home.",
  },
  {
    q: "Can an independent fitter handle problems with my Wren delivery?",
    a: "Yes. An experienced Wren fitter will check your delivery against your plan and identify any damaged, missing or incorrect items before installation begins. They can liaise with Wren's customer service on your behalf and advise on replacements. This is one of the practical benefits of working with an experienced independent fitter.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<Base title={title} description={description} canonical={canonical}>
  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <Header slot="header" />

  <div class="container py-4">
    <Breadcrumbs
      items={[
        { label: "Questions & Answers", href: "/answers/" },
        { label: "Can I Use My Own Fitter for a Wren Kitchen?", href: "/llm/can-i-use-my-own-fitter-for-wren-kitchen/" },
      ]}
    />
  </div>

  <section class="section" style="background: var(--bg-light);">
    <div class="container">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-extrabold mb-6 leading-tight" style="color: var(--navy);">
          Can I Use My Own Fitter for a Wren Kitchen?
        </h1>

        <AnswerBlock answer="Yes — Wren Kitchens does not require you to use their own installation service. You can use any qualified independent kitchen fitter to install your Wren kitchen without affecting your unit warranty." />

        <KeyTakeaway
          points={[
            "Using your own fitter does not void Wren's unit warranty",
            "Wren's installation service can be booked up 6–12 weeks in advance",
            "Independent fitters are typically 15–30% less expensive than Wren's own service",
            "Wren delivers pre-assembled rigid units, making independent installation efficient",
            "Install My Kitchen independently installs Wren kitchens across Coventry, Warwickshire and Berkshire",
          ]}
        />

        <div class="prose-content">
          <h2>How Wren's Installation Service Works</h2>
          <p>Wren Kitchens offer their own installation service as an optional add-on when you purchase a kitchen from their showrooms. This service is delivered through a network of Wren-approved fitters who operate across the UK. When you opt for Wren installation, Wren co-ordinate the fitting date, manage the programme, and handle any issues through their customer service team.</p>
          <p>Wren's installation service can be convenient, particularly if you are unfamiliar with sourcing trades independently. However, it comes at a premium price, and availability is often limited — it is common for Wren's installation slots to be booked 6–10 weeks in advance, particularly during spring and autumn when kitchen projects peak.</p>
          <p>Crucially, Wren's installation service is not compulsory. Wren makes clear that you may use an independent fitter. There is no exclusivity clause that ties the unit purchase to Wren's fitting service.</p>

          <h2>Why Homeowners Choose Independent Fitters</h2>
          <p>There are three primary reasons why homeowners choose an independent fitter over Wren's own service: scheduling flexibility, cost, and personal accountability.</p>
          <p>On scheduling, an independent fitter can often accommodate your preferred installation date within 2–4 weeks, whereas Wren's own service may not have availability for two to three months. If you have cleared your kitchen, arranged accommodation or taken time off work around a specific date, waiting months for Wren's service is impractical.</p>
          <p>On cost, independent fitters are almost universally less expensive than Wren's installation service for an equivalent scope of work. The saving varies by kitchen size, but for a medium kitchen it typically ranges from £500 to over £1,000. Some homeowners use the saving to upgrade worktops or appliances.</p>
          <p>On accountability, an independent fitter works directly for you. If there is a problem, you call them — not a regional customer service team. This direct relationship tends to result in faster snagging resolution and a more attentive installation experience.</p>

          <h2>What Happens to the Warranty?</h2>
          <p>Wren's product warranty — which typically covers carcasses for 25 years and other components for varying periods — relates to manufacturing defects in the units themselves. It is not conditional on Wren installing the kitchen. Using an independent fitter does not invalidate this warranty.</p>
          <p>The important distinction is between product warranty and installation workmanship. Wren's warranty will not cover damage caused by incorrect installation, regardless of who performed the installation. This applies equally to Wren's own fitters and independent fitters. The solution is to choose a fitter with demonstrable experience installing Wren kitchens and, ideally, to commission a pre-installation survey to identify and mitigate risks before work begins.</p>

          <h2>Wren Unit Formats and What an Independent Fitter Needs to Know</h2>
          <p>Wren kitchens are supplied as pre-assembled rigid units. Unlike IKEA's flat-pack system, Wren units arrive in a near-complete state and do not require on-site carcass assembly. This makes installation comparatively efficient — a medium Wren kitchen of 13–20 units typically takes 4–6 days to install.</p>
          <p>Wren deliver directly to your home, typically on a date agreed at purchase. Your independent fitter should be informed of the delivery date and should ideally be present for the delivery, or arrange to check the delivery against the plan shortly afterwards. Any damaged or incorrect items should be reported to Wren promptly — within their standard reporting window.</p>
          <p>Wren use their own branded hinge and drawer hardware. An experienced Wren fitter will be familiar with adjusting and fine-tuning these components to achieve correct alignment. The hinge system in particular requires correct cup seating and adjustment — something that takes practice to do quickly and accurately.</p>

          <h2>Choosing an Independent Wren Fitter</h2>
          <p>When choosing an independent fitter for your Wren kitchen, look for someone who has installed Wren kitchens previously and can point to completed projects. Ask about their familiarity with Wren's delivery process and hardware. Confirm that they carry public liability insurance and, if they are sole-trader, ask about their sub-contractor arrangements for plumbing and electrical work.</p>
          <p>Install My Kitchen provides independent Wren kitchen installation across Coventry, Warwickshire and Berkshire. We are not affiliated with Wren Kitchens and operate completely independently. Our survey-first, fixed-price approach means you receive an accurate, binding quote before any work begins.</p>
        </div>

        <FAQ items={faqs} />

        <InternalLinks
          heading="Related Pages"
          links={[
            { label: "Book a Survey", href: "/survey/", description: "£195 pre-installation survey, credited back on booking." },
            { label: "Questions & Answers", href: "/answers/", description: "All kitchen installation questions answered." },
            { label: "Installation Costs", href: "/costs/", description: "Full cost guide for kitchens of every size." },
            { label: "Can You Fit a Wren Kitchen?", href: "/answers/can-you-fit-a-wren-kitchen/", description: "Our independent Wren kitchen installation service." },
          ]}
        />
      </div>
    </div>
  </section>

  <CTA
    heading="Book Your Independent Wren Kitchen Installation"
    subtext="Survey-first, fixed-price installation across Coventry, Warwickshire and Berkshire. The £195 survey fee is credited back when you book. Call 07399 651836."
    primaryLabel="Book Your Survey"
    primaryHref="/survey/"
    secondaryLabel="Call 07399 651836"
    secondaryHref="tel:07399651836"
    dark={true}
  />

  <Footer slot="footer" />
  <StickyMobileCTA slot="sticky-cta" />
</Base>

<style>
  .prose-content h2 {
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--navy);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }
  .prose-content p {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--text);
    margin-bottom: 1rem;
  }
  .prose-content ul {
    margin: 0.75rem 0 1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .prose-content li {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--text);
  }
</style>
