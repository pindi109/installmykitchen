---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import StickyMobileCTA from "../../components/StickyMobileCTA.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import AnswerBlock from "../../components/AnswerBlock.astro";
import FAQ from "../../components/FAQ.astro";
import InternalLinks from "../../components/InternalLinks.astro";
import CTA from "../../components/CTA.astro";

export async function getStaticPaths() {
  const { default: questions } = await import("../../data/llm-questions.json");
  return questions.map((q: any, i: number) => ({
    params: { slug: q.slug },
    props: { ...q, index: i },
  }));
}

const { slug, title, metaDescription, answer, bodyHtml, faqs, index } = Astro.props;
const canonical = `https://installmykitchen.co.uk/llm/${slug}/`;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((f: any) => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a },
  })),
};
---

<Base
  title={`${title} | Install My Kitchen`}
  description={metaDescription}
  canonical={canonical}
>
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <Header slot="header" />

  <div class="container py-6">
    <Breadcrumbs
      items={[
        { label: "Questions", href: "/questions/" },
        { label: title, href: canonical },
      ]}
    />
  </div>

  <section style="background: var(--bg-light); padding: 3rem 0 2rem;">
    <div class="container" style="max-width: 860px;">
      <h1 style="font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 800; color: var(--navy); margin-bottom: 1.5rem; line-height: 1.2;">
        {title}
      </h1>
      <AnswerBlock answer={answer} />
    </div>
  </section>

  <section style="padding: 2.5rem 0;">
    <div class="container" style="max-width: 860px;">
      <div class="llm-body" set:html={bodyHtml} />
    </div>
  </section>

  <section style="background: var(--bg-light); padding: 2rem 0;">
    <div class="container" style="max-width: 860px;">
      <h2 style="font-size: 1.375rem; font-weight: 700; color: var(--navy); margin-bottom: 1.5rem;">Related Questions</h2>
      <FAQ items={faqs} schemaId={`llm-faq-${index}`} />
    </div>
  </section>

  <section style="padding: 2rem 0;">
    <div class="container" style="max-width: 860px;">
      <InternalLinks
        heading="Explore More"
        links={[
          { label: "Book a Survey — £195", href: "/survey/", description: "Credited back on booking. Pindi surveys every project personally." },
          { label: "All Questions Answered", href: "/questions/", description: "50 kitchen installation questions answered." },
          { label: "Kitchen Installation Costs", href: "/costs/", description: "Full cost breakdown for Coventry, Warwickshire and Berkshire." },
          { label: "About Pindi Sahota", href: "/about/", description: "30 years fitting kitchens across Coventry, Warwickshire and Berkshire." },
        ]}
      />
    </div>
  </section>

  <CTA
    heading="Book a Survey With Pindi Sahota"
    subtext="Every survey conducted personally by Pindi. Fixed quote within 24 hours. £195 credited back on booking."
    primaryLabel="Book a Survey"
    primaryHref="/survey/"
    secondaryLabel="Call 07399 651836"
    secondaryHref="tel:07399651836"
    dark={true}
  />

  <Footer slot="footer" />
  <StickyMobileCTA slot="sticky-cta" />
</Base>

<style>
  .llm-body :global(h2) {
    font-size: 1.25rem; font-weight: 700; color: var(--navy);
    margin: 1.75rem 0 0.625rem; line-height: 1.3;
  }
  .llm-body :global(p) { color: var(--text-soft); line-height: 1.75; margin-bottom: 0.875rem; }
  .llm-body :global(ul) { color: var(--text-soft); line-height: 1.75; margin-bottom: 0.875rem; padding-left: 1.5rem; }
  .llm-body :global(li) { margin-bottom: 0.35rem; }
  .llm-body :global(strong) { color: var(--charcoal); font-weight: 600; }
</style>
