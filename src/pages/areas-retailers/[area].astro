---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import StickyMobileCTA from "../../components/StickyMobileCTA.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import AnswerBlock from "../../components/AnswerBlock.astro";
import SupplierLogos from "../../components/SupplierLogos.astro";
import InternalLinks from "../../components/InternalLinks.astro";
import CTA from "../../components/CTA.astro";

import locationsData from "../../data/locations.json";
import retailersData from "../../data/retailers.json";

export function getStaticPaths() {
  return locationsData.map((location) => ({
    params: { area: location.slug },
    props: { location },
  }));
}

const { location } = Astro.props;
const { name, slug, county } = location;

// Title — kept ≤60 chars
const title = `Retailers We Fit in ${name} | Install My Kitchen`;

// Meta description — 140–160 chars (verified across all 25 location names)
const metaDescription = `We install kitchens from Wren, Howdens, Magnet, IKEA, Wickes and all major retailers in ${name}, ${county}. Independent — no retailer tie-in.`;

// Canonical points to /areas/{slug}/ as this is a supporting page under that hub
const canonical = `https://installmykitchen.co.uk/areas-retailers/${slug}/`;

// JSON-LD — LocalBusiness + Service
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "Install My Kitchen",
  url: "https://installmykitchen.co.uk",
  telephone: "07399651836",
  email: "info@installmykitchen.co.uk",
  address: {
    "@type": "PostalAddress",
    streetAddress: "242 Hollyfast Road, Coundon",
    addressLocality: "Coventry",
    postalCode: "CV6 2AH",
    addressCountry: "GB",
  },
  areaServed: {
    "@type": "Place",
    name: name,
  },
  description: `Independent kitchen installation service covering ${name} and the wider ${county} area, fitting kitchens from all major UK retailers.`,
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: `Kitchen Retailer Installation in ${name}`,
  provider: {
    "@type": "LocalBusiness",
    name: "Install My Kitchen",
    url: "https://installmykitchen.co.uk",
  },
  areaServed: {
    "@type": "Place",
    name: name,
  },
  description: `Professional independent kitchen fitting service in ${name}, covering all major UK retailers including Wren, Howdens, Magnet, IKEA, Wickes and more.`,
  serviceType: "Kitchen Installation",
};

// Related links for this area
const relatedLinks = [
  {
    label: `Kitchen Installation in ${name}`,
    href: `/areas/${slug}/`,
    description: `Full area page — surveys, pricing and project details for ${name}`,
  },
  {
    label: `Kitchen Fitters in ${name}`,
    href: `/fitter/${slug}/`,
    description: `Meet the fitting team serving ${name} and nearby areas`,
  },
  {
    label: `Kitchen Installation Cost in ${name}`,
    href: `/kitchen-cost/${slug}/`,
    description: `Typical kitchen fitting costs and what affects your quote in ${name}`,
  },
  {
    label: `Book a Survey in ${name}`,
    href: `/survey/${slug}/`,
    description: `Pre-installation survey from £195 — credited back when you proceed`,
  },
];
---

<Base
  title={title}
  description={metaDescription}
  canonical={canonical}
>
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

  <Header slot="header" />

  <!-- Breadcrumbs -->
  <div class="container py-6">
    <Breadcrumbs
      items={[
        { label: "Areas", href: "/areas/" },
        { label: name, href: `/areas/${slug}/` },
        { label: "Retailers We Fit", href: `/areas-retailers/${slug}/` },
      ]}
    />
  </div>

  <!-- Hero -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-extrabold mb-5 leading-tight" style="color: var(--navy);">
          Kitchens We Install in {name} — All Major Retailers
        </h1>
        <AnswerBlock
          answer={`Install My Kitchen fits kitchens from all major UK retailers in ${name}, including Wren, Howdens, Magnet, IKEA, Wickes and more. We are an independent service and are not affiliated with any retailer.`}
        />
      </div>
    </div>
  </section>

  <!-- Body copy -->
  <section class="section">
    <div class="container">
      <div class="max-w-3xl fade-up">
        <p class="text-lg leading-relaxed mb-5" style="color: var(--text-soft);">
          When you purchase a kitchen in {name}, fitting it properly is a separate and equally important decision. Install My Kitchen provides a fully independent installation service across {name} and the wider {county} area, working with whichever retailer you have chosen to buy from. We are not tied to any brand, which means our loyalty is entirely to you and the quality of the finished installation — not to a retailer's sales targets or approved fitter scheme.
        </p>
        <p class="leading-relaxed" style="color: var(--text-soft);">
          Whether your kitchen is arriving flat-packed from IKEA, rigid-built from Wren or Howdens, or supplied through an independent retailer stocking Symphony or Masterclass, our {name} fitting team has the experience to handle it. We carry out a thorough pre-installation survey before a single cabinet is delivered, reviewing your kitchen plan, taking precise measurements, and identifying anything that needs to be resolved before installation day — so the project runs smoothly from start to finish.
        </p>
      </div>
    </div>
  </section>

  <!-- Retailer cards grid -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container">
      <div class="fade-up">
        <h2 class="text-3xl font-bold mb-2" style="color: var(--navy);">
          Retailers We Install in {name}
        </h2>
        <p class="mb-8 text-base leading-relaxed max-w-2xl" style="color: var(--text-soft);">
          Select a retailer below to see details about fitting that brand's kitchens in {name}.
        </p>

        <ul
          class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4"
          role="list"
          aria-label={`Kitchen retailers we install in ${name}`}
        >
          {retailersData.map((retailer) => (
            <li role="listitem">
              <a
                href={`/installer/${retailer.slug}-${slug}/`}
                class="retailer-card"
                aria-label={`${retailer.displayName} kitchen installation in ${name}`}
              >
                <div class="retailer-card-inner">
                  <span
                    class="retailer-name"
                    style={`border-left-color: ${retailer.color};`}
                  >
                    {retailer.displayName}
                  </span>
                  <p class="retailer-note">{retailer.installNote}</p>
                </div>
                <span class="retailer-arrow" aria-hidden="true">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12"/>
                    <polyline points="12 5 19 12 12 19"/>
                  </svg>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Supplier logos + disclaimer -->
  <SupplierLogos heading={`All Retailers We Fit in ${name}`} />

  <!-- Internal links -->
  <section class="section">
    <div class="container">
      <div class="fade-up">
        <InternalLinks
          links={relatedLinks}
          heading={`More About Kitchen Installation in ${name}`}
        />
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTA
    heading={`Book a Survey in ${name}`}
    subtext={`Pre-installation survey from £195 — credited back in full when you proceed. Covering ${name} and the wider ${county} area.`}
    primaryLabel="Book Your Survey"
    primaryHref="/survey/"
    secondaryLabel="Call 07399 651836"
    secondaryHref="tel:07399651836"
    dark={true}
  />

  <Footer slot="footer" />
  <StickyMobileCTA slot="sticky-cta" />
</Base>

<style>
  /* Retailer card */
  .retailer-card {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 1.125rem 1.25rem;
    border-radius: 0.625rem;
    border: 1.5px solid #E5E7EB;
    background: #fff;
    text-decoration: none;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
    height: 100%;
  }

  .retailer-card:hover {
    border-color: var(--teal);
    box-shadow: 0 4px 16px rgba(15, 118, 110, 0.1);
    transform: translateY(-2px);
  }

  .retailer-card:focus-visible {
    outline: 2px solid var(--teal);
    outline-offset: 2px;
  }

  .retailer-card-inner {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    min-width: 0;
    flex: 1;
  }

  .retailer-name {
    font-size: 1rem;
    font-weight: 700;
    color: var(--charcoal);
    line-height: 1.3;
    padding-left: 0.625rem;
    border-left: 3px solid var(--teal);
  }

  .retailer-note {
    font-size: 0.8125rem;
    line-height: 1.55;
    color: var(--text-soft);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .retailer-arrow {
    flex-shrink: 0;
    color: var(--teal);
    opacity: 0.45;
    margin-top: 0.125rem;
    transition: opacity 0.2s, transform 0.2s;
  }

  .retailer-card:hover .retailer-arrow {
    opacity: 1;
    transform: translateX(3px);
  }
</style>
