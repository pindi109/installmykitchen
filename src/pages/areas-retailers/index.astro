---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import StickyMobileCTA from "../../components/StickyMobileCTA.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import AnswerBlock from "../../components/AnswerBlock.astro";
import FAQ from "../../components/FAQ.astro";
import CTA from "../../components/CTA.astro";

import locationsData from "../../data/locations.json";

const faqItems = [
  {
    q: "Which kitchen retailers do you install in each area?",
    a: "We install kitchens from all major UK retailers in every area we cover — including Wren, Howdens, Magnet, IKEA, Wickes, B&Q, Benchmarx, DIY Kitchens, Kutchenhaus, Symphony, Masterclass, and Nolte. We are entirely independent, so our service is not tied to any single brand.",
  },
  {
    q: "Is your installation service independent of the retailers?",
    a: "Yes — Install My Kitchen is not affiliated with, approved by, or employed by any kitchen retailer. We install kitchens you have purchased from any brand. This means our sole focus is the quality of your installation rather than a retailer's targets or approved fitter schemes.",
  },
  {
    q: "Do you charge different prices depending on which retailer's kitchen I've bought?",
    a: "Our installation pricing is based on the scope and complexity of the job — the number of units, the layout, and any optional extras such as worktops, flooring or tiling. We do not apply a premium for specific brands. All costs are agreed in a fixed-price quote following your pre-installation survey.",
  },
  {
    q: "I've bought my kitchen from a retailer not listed. Can you still fit it?",
    a: "Almost certainly. The retailers listed on each area page are the most common brands we encounter, but we fit kitchens from all UK retailers and manufacturers. If your brand isn't listed, please contact us — we will confirm whether we have experience with your specific product and discuss any brand-specific logistics.",
  },
];
---

<Base
  title="Kitchen Retailers We Fit by Area | Install My Kitchen"
  description="Independent kitchen installation from Wren, Howdens, Magnet, IKEA, Wickes and all major retailers — covering all 33 service areas across Coventry, Warwickshire and Berkshire."
  canonical="https://installmykitchen.co.uk/areas-retailers/"
>
  <Header slot="header" />

  <!-- ══════════════════════════════ PAGE HEADER ══════════════════ -->
  <section class="page-header" aria-label="Page header">
    <div class="container">
      <Breadcrumbs items={[{ label: "Retailers by Area", href: "/areas-retailers/" }]} />
      <h1 class="page-h1">Kitchen Retailers We Fit — By Area</h1>
      <p class="page-sub">Select your area to see which kitchen retailers we install in that location across Coventry, Warwickshire and Berkshire.</p>
    </div>
  </section>

  <!-- ══════════════════════════════ MAIN CONTENT ════════════════ -->
  <section class="section" style="background: #fff;" aria-labelledby="retailers-intro">

    <div class="container">

      <AnswerBlock answer="Install My Kitchen installs kitchens from all major UK retailers in every area we cover — Wren, Howdens, Magnet, IKEA, Wickes, B&Q, Benchmarx and more. We are fully independent and not tied to any retailer." />

      <h2 id="retailers-intro" class="section-h2 mb-8">All 33 Areas — Retailers We Install</h2>

      <ul class="areas-grid" role="list" aria-label="Service areas — retailers we fit">
        {locationsData.map((location) => (
          <li role="listitem">
            <a href={`/areas-retailers/${location.slug}/`} class="area-card">
              <div class="area-card-body">
                <span class="area-name">{location.name}</span>
                <span class="area-desc">{location.county} · {location.postcodes[0]}{location.postcodes.length > 1 ? "+" : ""}</span>
              </div>
              <span class="area-arrow" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </span>
            </a>
          </li>
        ))}
      </ul>

      <div class="not-listed-box">
        <p class="not-listed-text">
          <strong>Not on the list?</strong> We may still be able to help. Contact us with your postcode and we'll confirm if we cover your area.
        </p>
        <a href="/contact/" class="btn-primary not-listed-btn">Check Your Area</a>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════ FAQ ═══════════ -->
  <section class="section" style="background: var(--bg-light);" aria-labelledby="faq-heading">
    <div class="container">
      <div class="max-w-3xl mx-auto">
        <h2 id="faq-heading" class="text-2xl md:text-3xl font-bold mb-2 text-center" style="color: var(--charcoal);">
          Retailers by Area — FAQ
        </h2>
        <p class="text-center text-sm mb-10" style="color: var(--text-soft);">
          Common questions about our retailer-independent fitting service.
        </p>
        <FAQ items={faqItems} schemaId="areas-retailers-faq" />
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════ DARK CTA ═══════════ -->
  <CTA
    dark={true}
    heading="Book Your Kitchen Installation"
    subtext="We fit kitchens from all major retailers across Coventry, Warwickshire and Berkshire. Book a survey and get a clear, itemised quote."
    primaryLabel="Book a Survey — £195"
    primaryHref="/survey/"
    secondaryLabel="Contact Us"
    secondaryHref="/contact/"
  />

  <Footer slot="footer" />
  <StickyMobileCTA slot="sticky-cta" />
</Base>

<style>
  /* Page header */
  .page-header {
    background: var(--hero-gradient);
    padding: 3rem 0 3.5rem;
  }

  .page-h1 {
    font-size: clamp(1.625rem, 3vw, 2.5rem);
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.02em;
    margin-top: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .page-sub {
    color: rgba(255, 255, 255, 0.75);
    font-size: 1.0625rem;
    line-height: 1.6;
    max-width: 540px;
  }

  .section-h2 {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--charcoal);
  }

  /* Areas grid */
  .areas-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.875rem;
    list-style: none;
    padding: 0;
    margin: 0 0 2.5rem;
  }

  @media (min-width: 640px) {
    .areas-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .areas-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .area-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 1rem 1.125rem;
    border-radius: 0.875rem;
    border: 1.5px solid var(--border);
    background: var(--bg-light);
    text-decoration: none;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }

  .area-card:hover {
    border-color: var(--teal);
    box-shadow: 0 4px 14px rgba(15, 118, 110, 0.1);
    transform: translateY(-2px);
    background: #fff;
  }

  .area-card-body {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 0;
  }

  .area-name {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--charcoal);
    transition: color 0.15s;
  }

  .area-card:hover .area-name {
    color: var(--teal);
  }

  .area-desc {
    font-size: 0.8125rem;
    color: var(--text-soft);
    line-height: 1.4;
  }

  .area-arrow {
    color: var(--teal);
    opacity: 0.4;
    flex-shrink: 0;
    transition: opacity 0.2s, transform 0.2s;
  }

  .area-card:hover .area-arrow {
    opacity: 1;
    transform: translateX(3px);
  }

  /* Not listed box */
  .not-listed-box {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
    background: rgba(15, 118, 110, 0.05);
    border: 1.5px solid rgba(15, 118, 110, 0.2);
    border-left: 4px solid var(--teal);
    border-radius: 0 0.875rem 0.875rem 0;
    padding: 1.25rem 1.5rem;
  }

  @media (min-width: 640px) {
    .not-listed-box {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  .not-listed-text {
    font-size: 0.9375rem;
    color: var(--text-soft);
    line-height: 1.6;
  }

  .not-listed-text strong {
    color: var(--charcoal);
  }

  .not-listed-btn {
    white-space: nowrap;
    flex-shrink: 0;
  }
</style>
