---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import StickyMobileCTA from "../../components/StickyMobileCTA.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import AnswerBlock from "../../components/AnswerBlock.astro";
import FAQ from "../../components/FAQ.astro";
import SupplierLogos from "../../components/SupplierLogos.astro";
import InternalLinks from "../../components/InternalLinks.astro";
import CTA from "../../components/CTA.astro";

import stylesData from "../../data/styles.json";
import locationsData from "../../data/locations.json";
import faqsData from "../../data/faqs.json";

const STYLE_LOCATION_SLUGS = [
  "coventry",
  "earlsdon",
  "kenilworth",
  "leamington-spa",
  "warwick",
  "rugby",
  "solihull",
  "nuneaton",
  "stratford-upon-avon",
  "hinckley",
];

export function getStaticPaths() {
  const STYLE_LOCATION_SLUGS = [
    "coventry",
    "earlsdon",
    "kenilworth",
    "leamington-spa",
    "warwick",
    "rugby",
    "solihull",
    "nuneaton",
    "stratford-upon-avon",
    "hinckley",
  ];

  const styleLocations = STYLE_LOCATION_SLUGS
    .map((slug) => locationsData.find((l) => l.slug === slug))
    .filter(Boolean) as typeof locationsData;

  const paths: { params: { style: string; location: string }; props: { style: typeof stylesData[0]; location: typeof locationsData[0]; styleIndex: number; locationIndex: number } }[] = [];

  stylesData.forEach((style, styleIndex) => {
    styleLocations.forEach((location, locationIndex) => {
      paths.push({
        params: { style: style.slug, location: location.slug },
        props: { style, location, styleIndex, locationIndex },
      });
    });
  });

  return paths;
}

const { style, location, styleIndex, locationIndex } = Astro.props;
const { name: styleName, slug: styleSlug, description: styleDescription, features } = style;
const { name: locationName, slug: locationSlug, county, description: locationDescription, nearby } = location;

const canonical = `https://installmykitchen.co.uk/styles/${styleSlug}-${locationSlug}/`;

// Title ≤60 chars
const rawTitle = `${styleName} Kitchen Installation ${locationName} | Install My Kitchen`;
const title = rawTitle.length <= 60
  ? rawTitle
  : `${styleName} Kitchens ${locationName} | Install My Kitchen`;

// Meta 140-160 chars
const metaDescription = `Expert ${styleName.toLowerCase()} kitchen installation in ${locationName}, ${county}. Independent fitting service for all major retailers. Fixed-price quotes from a £195 survey.`;

// FAQ — offset by style and location index
const allFaqs = [...faqsData.general, ...faqsData.process, ...faqsData.costs];
const faqOffset = (styleIndex * 4 + locationIndex) % allFaqs.length;
const faqItems = [
  allFaqs[faqOffset % allFaqs.length],
  allFaqs[(faqOffset + 1) % allFaqs.length],
  allFaqs[(faqOffset + 2) % allFaqs.length],
  allFaqs[(faqOffset + 3) % allFaqs.length],
];

// Nearby area links — 3 from nearby array
const nearbyAreaSlugs = (nearby as string[]).slice(0, 3);
const nearbyLinks = nearbyAreaSlugs.map((nearbySlug) => {
  const nearbyLoc = locationsData.find((l) => l.slug === nearbySlug);
  return nearbyLoc
    ? {
        label: `${styleName} Kitchens in ${nearbyLoc.name}`,
        href: `/styles/${styleSlug}-${nearbySlug}/`,
        description: `${nearbyLoc.county}`,
      }
    : null;
}).filter(Boolean) as { label: string; href: string; description: string }[];

const internalLinks = [
  {
    label: `${styleName} Kitchen Style Guide`,
    href: `/styles/${styleSlug}/`,
    description: `Everything about ${styleName.toLowerCase()} kitchen installation`,
  },
  {
    label: `Kitchen Installation in ${locationName}`,
    href: `/areas/${locationSlug}/`,
    description: `Our full service in ${locationName}, ${county}`,
  },
  ...nearbyLinks,
];

// BreadcrumbList JSON-LD
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://installmykitchen.co.uk/" },
    { "@type": "ListItem", position: 2, name: "Styles", item: "https://installmykitchen.co.uk/styles/" },
    { "@type": "ListItem", position: 3, name: styleName, item: `https://installmykitchen.co.uk/styles/${styleSlug}/` },
    { "@type": "ListItem", position: 4, name: locationName, item: canonical },
  ],
};

// Service JSON-LD
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: `${styleName} Kitchen Installation in ${locationName}`,
  provider: {
    "@type": "LocalBusiness",
    name: "Install My Kitchen",
    url: "https://installmykitchen.co.uk",
    telephone: "07399651836",
    address: {
      "@type": "PostalAddress",
      streetAddress: "242 Hollyfast Road, Coundon",
      addressLocality: "Coventry",
      postalCode: "CV6 2AH",
      addressCountry: "GB",
    },
  },
  areaServed: {
    "@type": "Place",
    name: locationName,
  },
  description: `Professional ${styleName.toLowerCase()} kitchen installation across ${locationName}, ${county}. Independent fitting for all major UK kitchen retailers.`,
  serviceType: "Kitchen Installation",
};
---

<Base
  title={title}
  description={metaDescription}
  canonical={canonical}
>
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

  <Header slot="header" />

  <div class="container py-6">
    <Breadcrumbs
      items={[
        { label: "Styles", href: "/styles/" },
        { label: styleName, href: `/styles/${styleSlug}/` },
        { label: locationName, href: canonical },
      ]}
    />
  </div>

  <!-- Hero -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-extrabold mb-5 leading-tight" style="color: var(--navy);">
          {styleName} Kitchen Installation in {locationName}
        </h1>
        <AnswerBlock
          answer={`Install My Kitchen provides expert ${styleName.toLowerCase()} kitchen installation across ${locationName}, ${county}. We fit ${styleName.toLowerCase()} kitchens from all major retailers, delivering a professional finish suited to ${locationName}'s diverse property types.`}
        />
      </div>
    </div>
  </section>

  <!-- Section 1: What this style involves -->
  <section class="section">
    <div class="container">
      <div class="max-w-3xl fade-up">
        <h2 class="text-3xl font-bold mb-4" style="color: var(--navy);">
          What {styleName} Kitchen Installation Involves
        </h2>
        <p class="text-lg leading-relaxed mb-4" style="color: var(--text-soft);">
          {styleDescription}
        </p>
        <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
          Fitting a {styleName.toLowerCase()} kitchen requires a fitter who understands the design intent behind the style, not just the mechanics of assembling cabinetry. Our team is experienced in handling the specific requirements of this style — whether that means precise scribing to achieve clean runs along imperfect walls, careful alignment of inset details, or sympathetic integration of the kitchen into the character of your home.
        </p>
        <p class="leading-relaxed" style="color: var(--text-soft);">
          Every {styleName.toLowerCase()} kitchen we install in {locationName} begins with a detailed pre-installation survey. This allows us to assess the room and review your chosen plan, identifying any potential issues before installation day. The result is a fixed-price quote with no hidden surprises.
        </p>
      </div>
    </div>
  </section>

  <!-- Section 2: Why this style suits the area -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container">
      <div class="max-w-3xl fade-up">
        <h2 class="text-3xl font-bold mb-4" style="color: var(--navy);">
          Why {styleName} Kitchens Work Well in {locationName}
        </h2>
        <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
          {locationDescription}
        </p>
        <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
          The property stock in {locationName} lends itself particularly well to {styleName.toLowerCase()} kitchen design. Whether you are renovating an older character property or updating a modern home, the {styleName.toLowerCase()} style offers the versatility to complement the architecture while delivering a genuinely practical, high-quality kitchen space.
        </p>
        <p class="leading-relaxed" style="color: var(--text-soft);">
          Our installers regularly work throughout {locationName} and the surrounding {county} area, so we are well familiar with the layout characteristics and construction quirks of local properties. This local knowledge directly benefits the planning and execution of your installation, reducing the risk of unexpected complications on the day.
        </p>
      </div>
    </div>
  </section>

  <!-- Feature Grid -->
  <section class="section">
    <div class="container">
      <div class="fade-up">
        <h2 class="text-3xl font-bold mb-8" style="color: var(--navy);">
          Key Features of {styleName} Kitchens
        </h2>
        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-4 list-none p-0 m-0 max-w-3xl">
          {features.map((feature) => (
            <li class="flex items-start gap-3 p-5 rounded-xl border" style="border-color: #E5E7EB; background: #fff;">
              <span class="flex-shrink-0 w-6 h-6 rounded-full flex items-center justify-center mt-0.5" style="background: var(--teal);">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
              </span>
              <span class="text-sm font-medium leading-relaxed" style="color: var(--charcoal);">{feature}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Section 3: Installation considerations -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container">
      <div class="max-w-3xl fade-up">
        <h2 class="text-3xl font-bold mb-4" style="color: var(--navy);">
          Installation Considerations in {locationName}
        </h2>
        <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
          No two kitchens or properties are identical, and {locationName} homes present their own specific considerations. Older properties may have uneven floors, out-of-plumb walls, or original features that need to be accommodated within the kitchen layout. Newer builds can present their own challenges, including tight tolerances where cabinets meet ceilings and underfloor heating considerations for certain worktop materials.
        </p>
        <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
          Our pre-installation survey addresses all of these factors before a single cabinet is fitted. We check floor levels across the entire kitchen footprint, assess wall straightness and any areas that may need scribing panels, and confirm that the planned appliance positions are compatible with the existing or planned service routes. This thorough approach means installation day runs smoothly, without the costly delays that arise from avoidable surprises.
        </p>
        <p class="leading-relaxed" style="color: var(--text-soft);">
          We work alongside your independently appointed plumber and electrician, co-ordinating the sequence of works so that service connections are made at the right stage of the installation. If you need recommendations for reliable local tradespeople in {locationName}, we are happy to make introductions.
        </p>
      </div>
    </div>
  </section>

  <!-- Supplier Logos -->
  <SupplierLogos />

  <!-- FAQ -->
  <section class="section">
    <div class="container">
      <div class="max-w-3xl fade-up">
        <h2 class="text-3xl font-bold mb-8" style="color: var(--navy);">
          Frequently Asked Questions
        </h2>
        <FAQ items={faqItems} schemaId={`faq-style-loc-${styleSlug}-${locationSlug}`} />
      </div>
    </div>
  </section>

  <!-- Internal Links -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container fade-up">
      <InternalLinks
        links={internalLinks}
        heading="Related Pages"
      />
    </div>
  </section>

  <!-- CTA -->
  <CTA
    heading={`Ready to Fit Your ${styleName} Kitchen in ${locationName}?`}
    subtext={`Book a pre-installation survey from £195 — credited back in full when you proceed. Covering ${locationName} and the wider ${county} area.`}
    primaryLabel="Book Your Survey"
    primaryHref="/survey/"
    secondaryLabel="Call 07399 651836"
    secondaryHref="tel:07399651836"
    dark={true}
  />

  <Footer slot="footer" />
  <StickyMobileCTA slot="sticky-cta" />
</Base>
