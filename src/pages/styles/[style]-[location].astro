---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import StickyMobileCTA from "../../components/StickyMobileCTA.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import AnswerBlock from "../../components/AnswerBlock.astro";
import FAQ from "../../components/FAQ.astro";
import SupplierLogos from "../../components/SupplierLogos.astro";
import InternalLinks from "../../components/InternalLinks.astro";
import CTA from "../../components/CTA.astro";

import stylesData from "../../data/styles.json";
import locationsData from "../../data/locations.json";
import faqsData from "../../data/faqs.json";

const STYLE_LOCATION_SLUGS = [
  "coventry",
  "earlsdon",
  "kenilworth",
  "leamington-spa",
  "warwick",
  "rugby",
  "solihull",
  "nuneaton",
  "stratford-upon-avon",
  "hinckley",
];

export function getStaticPaths() {
  const STYLE_LOCATION_SLUGS = [
    "coventry", "canley", "tile-hill", "earlsdon", "allesley",
    "binley", "wyken", "walsgrave", "finham", "stivichall",
    "coundon", "radford", "rugby", "nuneaton", "bedworth",
    "hinckley", "leamington-spa", "kenilworth", "warwick", "balsall-common",
    "meriden", "solihull", "stratford-upon-avon", "southam", "atherstone",
    "reading", "bracknell", "slough", "maidenhead", "windsor",
    "wokingham", "newbury", "ascot",
  ];

  const styleLocations = STYLE_LOCATION_SLUGS
    .map((slug) => locationsData.find((l) => l.slug === slug))
    .filter(Boolean) as typeof locationsData;

  const paths: { params: { style: string; location: string }; props: { style: typeof stylesData[0]; location: typeof locationsData[0]; styleIndex: number; locationIndex: number } }[] = [];

  stylesData.forEach((style, styleIndex) => {
    styleLocations.forEach((location, locationIndex) => {
      paths.push({
        params: { style: style.slug, location: location.slug },
        props: { style, location, styleIndex, locationIndex },
      });
    });
  });

  return paths;
}

const { style, location, styleIndex, locationIndex } = Astro.props;
const { name: styleName, slug: styleSlug, description: styleDescription, features } = style;
const { name: locationName, slug: locationSlug, county, description: locationDescription, nearby } = location;

const canonical = `https://installmykitchen.co.uk/styles/${styleSlug}-${locationSlug}/`;

// Title ≤60 chars
const rawTitle = `${styleName} Kitchen Installation ${locationName} | Install My Kitchen`;
const title = rawTitle.length <= 60
  ? rawTitle
  : `${styleName} Kitchens ${locationName} | Install My Kitchen`;

// Meta 140-160 chars
const metaDescription = `Expert ${styleName.toLowerCase()} kitchen installation in ${locationName}, ${county}. Independent fitting service for all major retailers. Fixed-price quotes from a £195 survey.`;

// Style image set
const styleImgBase = `/assets/styles/${styleSlug}`;
const styleImgs = {
  overview:     `${styleImgBase}/${styleSlug}-overview.webp`,
  doorDetail:   `${styleImgBase}/${styleSlug}-door-detail.webp`,
  installation: `${styleImgBase}/${styleSlug}-installation.webp`,
  finished:     `${styleImgBase}/${styleSlug}-finished-result.webp`,
  inProperty:   `${styleImgBase}/${styleSlug}-in-period-home.webp`,
};

// FAQ — offset by style and location index
const allFaqs = [...faqsData.general, ...faqsData.process, ...faqsData.costs];
const faqOffset = (styleIndex * 4 + locationIndex) % allFaqs.length;
const faqItems = [
  allFaqs[faqOffset % allFaqs.length],
  allFaqs[(faqOffset + 1) % allFaqs.length],
  allFaqs[(faqOffset + 2) % allFaqs.length],
  allFaqs[(faqOffset + 3) % allFaqs.length],
];

// Nearby area links — 3 from nearby array
const nearbyAreaSlugs = (nearby as string[]).slice(0, 3);
const nearbyLinks = nearbyAreaSlugs.map((nearbySlug) => {
  const nearbyLoc = locationsData.find((l) => l.slug === nearbySlug);
  return nearbyLoc
    ? {
        label: `${styleName} Kitchens in ${nearbyLoc.name}`,
        href: `/styles/${styleSlug}-${nearbySlug}/`,
        description: `${nearbyLoc.county}`,
      }
    : null;
}).filter(Boolean) as { label: string; href: string; description: string }[];

const internalLinks = [
  {
    label: `${styleName} Kitchen Style Guide`,
    href: `/styles/${styleSlug}/`,
    description: `Everything about ${styleName.toLowerCase()} kitchen installation`,
  },
  {
    label: `Kitchen Installation in ${locationName}`,
    href: `/areas/${locationSlug}/`,
    description: `Our full service in ${locationName}, ${county}`,
  },
  ...nearbyLinks,
];

// Breadcrumb JSON-LD is emitted once by the <Breadcrumbs> component below.

// Service JSON-LD
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: `${styleName} Kitchen Installation in ${locationName}`,
  provider: {
    "@type": "LocalBusiness",
    name: "Install My Kitchen",
    url: "https://installmykitchen.co.uk",
    telephone: "07399651836",
    address: {
      "@type": "PostalAddress",
      streetAddress: "242 Hollyfast Road, Coundon",
      addressLocality: "Coventry",
      postalCode: "CV6 2AH",
      addressCountry: "GB",
    },
  },
  areaServed: {
    "@type": "Place",
    name: locationName,
  },
  description: `Professional ${styleName.toLowerCase()} kitchen installation across ${locationName}, ${county}. Independent fitting for all major UK kitchen retailers.`,
  serviceType: "Kitchen Installation",
};
---

<Base
  title={title}
  description={metaDescription}
  canonical={canonical}
>
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

  <Header slot="header" />

  <div class="container py-6">
    <Breadcrumbs
      items={[
        { label: "Styles", href: "/styles/" },
        { label: styleName, href: `/styles/${styleSlug}/` },
        { label: locationName, href: canonical },
      ]}
    />
  </div>

  <!-- Hero -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-extrabold mb-5 leading-tight" style="color: var(--navy);">
          {styleName} Kitchen Installation in {locationName}
        </h1>
        <AnswerBlock
          answer={`Install My Kitchen provides expert ${styleName.toLowerCase()} kitchen installation across ${locationName}, ${county}. We fit ${styleName.toLowerCase()} kitchens from all major retailers, delivering a professional finish suited to ${locationName}'s diverse property types.`}
        />
      </div>
    </div>
  </section>

  <!-- Section 1: What this style involves -->
  <section class="section">
    <div class="container">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; align-items: start;" class="fade-up">
        <div>
          <h2 class="text-3xl font-bold mb-4" style="color: var(--navy);">
            What {styleName} Kitchen Installation Involves
          </h2>
          <p class="text-lg leading-relaxed mb-4" style="color: var(--text-soft);">
            {styleDescription}
          </p>
          <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
            Fitting a {styleName.toLowerCase()} kitchen requires a fitter who understands the design intent, not just the mechanics of assembling cabinetry. Our team handles the specific requirements — precise scribing, careful alignment, and sympathetic integration into your home's character.
          </p>
          <p class="leading-relaxed" style="color: var(--text-soft);">
            Every {styleName.toLowerCase()} kitchen we install in {locationName} begins with a detailed pre-installation survey — identifying any issues before installation day and delivering a fixed-price quote with no hidden surprises.
          </p>
        </div>
        <figure style="margin: 0;">
          <img src={styleImgs.overview} alt={`${styleName} kitchen installation in ${locationName} — finished result`} width="680" height="510" loading="lazy" style="width: 100%; height: auto; border-radius: 0.75rem; display: block;" />
        </figure>
      </div>
    </div>
  </section>

  <!-- Section 2: Why this style suits the area -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container">
      <div class="fade-up">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; align-items: start; margin-bottom: 2rem;">
          <figure style="margin: 0;">
            <img src={styleImgs.inProperty} alt={`${styleName} kitchen in a ${locationName} period property`} width="680" height="510" loading="lazy" style="width: 100%; height: auto; border-radius: 0.75rem; display: block;" />
          </figure>
          <div>
            <h2 class="text-3xl font-bold mb-4" style="color: var(--navy);">
              Why {styleName} Kitchens Work Well in {locationName}
            </h2>
            <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
              {locationDescription}
            </p>
            <p class="leading-relaxed" style="color: var(--text-soft);">
              The property stock in {locationName} lends itself particularly well to {styleName.toLowerCase()} kitchen design. Whether renovating an older character property or updating a modern home, the {styleName.toLowerCase()} style offers versatility to complement the architecture while delivering a practical, high-quality result.
            </p>
          </div>
        </div>
        <!-- Full-width finished kitchen -->
        <figure style="margin: 0; padding: 0;">
          <img src={styleImgs.finished} alt={`Completed ${styleName} kitchen in ${locationName} by Install My Kitchen`} width="1200" height="506" loading="lazy" style="width: 100%; height: auto; border-radius: 0.75rem; display: block;" />
        </figure>
      </div>
    </div>
  </section>

  <!-- Feature Grid with door detail image -->
  <section class="section">
    <div class="container">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; align-items: start;" class="fade-up">
        <div>
          <h2 class="text-3xl font-bold mb-8" style="color: var(--navy);">
            Key Features of {styleName} Kitchens
          </h2>
          <ul class="grid grid-cols-1 gap-4 list-none p-0 m-0">
            {features.map((feature) => (
              <li class="flex items-start gap-3 p-4 rounded-xl border" style="border-color: #E5E7EB; background: #fff;">
                <span class="flex-shrink-0 w-6 h-6 rounded-full flex items-center justify-center mt-0.5" style="background: var(--teal);">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                </span>
                <span class="text-sm font-medium leading-relaxed" style="color: var(--charcoal);">{feature}</span>
              </li>
            ))}
          </ul>
        </div>
        <div>
          <figure style="margin: 0 0 1.5rem;">
            <img src={styleImgs.doorDetail} alt={`${styleName} kitchen door detail — close-up of finish and hardware`} width="680" height="510" loading="lazy" style="width: 100%; height: auto; border-radius: 0.75rem; display: block;" />
          </figure>
          <figure style="margin: 0;">
            <img src="/assets/process/drawer-close-up.webp" alt={`Soft-close drawer detail in a ${styleName} kitchen installation`} width="680" height="510" loading="lazy" style="width: 100%; height: auto; border-radius: 0.75rem; display: block;" />
          </figure>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 3: Installation considerations -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; align-items: start;" class="fade-up">
        <div>
          <h2 class="text-3xl font-bold mb-4" style="color: var(--navy);">
            Installation Considerations in {locationName}
          </h2>
          <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
            No two kitchens are identical, and {locationName} homes present their own specific considerations. Older properties may have uneven floors or out-of-plumb walls; newer builds can have tight tolerances where cabinets meet ceilings.
          </p>
          <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
            Our pre-installation survey addresses all of these factors before a single cabinet is fitted — checking floor levels, assessing wall straightness, and confirming service positions. Installation day runs smoothly as a result.
          </p>
          <p class="leading-relaxed" style="color: var(--text-soft);">
            We work alongside your plumber and electrician, co-ordinating the sequence so service connections are made at the right stage. If you need local tradespeople in {locationName}, we are happy to make introductions.
          </p>
        </div>
        <div>
          <figure style="margin: 0 0 1.5rem;">
            <img src={styleImgs.installation} alt={`${styleName} kitchen installation in progress in ${locationName}`} width="680" height="510" loading="lazy" style="width: 100%; height: auto; border-radius: 0.75rem; display: block;" />
          </figure>
          <figure style="margin: 0;">
            <img src="/assets/process/cornice-fitting.webp" alt={`Cornice and trim finishing for ${styleName} kitchen in ${locationName}`} width="680" height="510" loading="lazy" style="width: 100%; height: auto; border-radius: 0.75rem; display: block;" />
          </figure>
        </div>
      </div>
    </div>
  </section>

  <!-- Supplier Logos -->
  <SupplierLogos />

  <!-- FAQ -->
  <section class="section">
    <div class="container">
      <div class="max-w-3xl fade-up">
        <h2 class="text-3xl font-bold mb-8" style="color: var(--navy);">
          Frequently Asked Questions
        </h2>
        <FAQ items={faqItems} schemaId={`faq-style-loc-${styleSlug}-${locationSlug}`} />
      </div>
    </div>
  </section>

  <!-- Internal Links -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container fade-up">
      <InternalLinks
        links={internalLinks}
        heading="Related Pages"
      />
    </div>
  </section>

  <!-- CTA -->
  <CTA
    heading={`Ready to Fit Your ${styleName} Kitchen in ${locationName}?`}
    subtext={`Book a pre-installation survey from £195 — credited back in full when you proceed. Covering ${locationName} and the wider ${county} area.`}
    primaryLabel="Book Your Survey"
    primaryHref="/survey/"
    secondaryLabel="Call 07399 651836"
    secondaryHref="tel:07399651836"
    dark={true}
  />

  <Footer slot="footer" />
  <StickyMobileCTA slot="sticky-cta" />
</Base>
