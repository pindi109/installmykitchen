---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import StickyMobileCTA from "../../components/StickyMobileCTA.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import AnswerBlock from "../../components/AnswerBlock.astro";
import FAQ from "../../components/FAQ.astro";
import SupplierLogos from "../../components/SupplierLogos.astro";
import CTA from "../../components/CTA.astro";

import stylesData from "../../data/styles.json";
import faqsData from "../../data/faqs.json";

export function getStaticPaths() {
  return stylesData.map((style) => ({
    params: { style: style.slug },
    props: { style },
  }));
}

const { style } = Astro.props;
const { name, slug, description, features } = style;

const canonical = `https://installmykitchen.co.uk/styles/${slug}/`;

// Title — ≤60 chars
const title = `${name} Kitchen Installation — Coventry & Warwickshire | Install My Kitchen`;

// Meta description — 140–160 chars, unique per style
const metaDescription = `Expert ${name.toLowerCase()} kitchen installation across Coventry & Warwickshire. Independent fitting for all major retailers. Survey from £195, credited on booking.`;

// Style-specific FAQ — pull from general, offset to vary per style
const faqStartIndex = stylesData.findIndex((s) => s.slug === slug);
const allGeneralFaqs = faqsData.general;
const faqItems = [
  allGeneralFaqs[faqStartIndex % allGeneralFaqs.length],
  allGeneralFaqs[(faqStartIndex + 1) % allGeneralFaqs.length],
  allGeneralFaqs[(faqStartIndex + 2) % allGeneralFaqs.length],
  allGeneralFaqs[(faqStartIndex + 3) % allGeneralFaqs.length],
];

// Areas where this style is popular — varies by style
const popularAreas: Record<string, string[]> = {
  shaker: ["Earlsdon", "Kenilworth", "Warwick", "Leamington Spa"],
  handleless: ["Balsall Common", "Solihull", "Coventry", "Finham"],
  modern: ["Coventry", "Rugby", "Nuneaton", "Walsgrave"],
  traditional: ["Earlsdon", "Warwick", "Stratford-upon-Avon", "Atherstone"],
  contemporary: ["Leamington Spa", "Kenilworth", "Stivichall", "Canley"],
  german: ["Balsall Common", "Solihull", "Finham", "Kenilworth"],
  painted: ["Earlsdon", "Warwick", "Leamington Spa", "Meriden"],
  "solid-wood": ["Allesley", "Meriden", "Stratford-upon-Avon", "Southam"],
  "in-frame": ["Kenilworth", "Warwick", "Leamington Spa", "Stratford-upon-Avon"],
  luxury: ["Solihull", "Kenilworth", "Finham", "Leamington Spa"],
};
const areasForStyle = popularAreas[slug] ?? ["Coventry", "Kenilworth", "Leamington Spa", "Warwick"];
---

<Base
  title={title}
  description={metaDescription}
  canonical={canonical}
>
  <Header slot="header" />

  <div class="container py-6">
    <Breadcrumbs
      items={[
        { label: "Styles", href: "/styles/" },
        { label: name, href: `/styles/${slug}/` },
      ]}
    />
  </div>

  <!-- Hero -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-extrabold mb-5 leading-tight" style="color: var(--navy);">
          {name} Kitchen Installation in Coventry &amp; Warwickshire
        </h1>
        <AnswerBlock
          answer={description}
        />
      </div>
    </div>
  </section>

  <!-- What defines this style -->
  <section class="section">
    <div class="container">
      <div class="max-w-3xl fade-up">
        <h2 class="text-3xl font-bold mb-4" style="color: var(--navy);">
          What Defines a {name} Kitchen?
        </h2>
        <p class="text-lg leading-relaxed mb-4" style="color: var(--text-soft);">
          {description}
        </p>
        <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
          This style has become a firm favourite with homeowners across Coventry and Warwickshire, and our installation teams have extensive experience fitting it across a wide range of property types — from Victorian terraces in Earlsdon to modern extensions in Balsall Common. The way a kitchen is designed and fitted has a significant impact on how well it suits the home's character, and our surveyors are well placed to advise on the considerations specific to this style.
        </p>
        <p class="leading-relaxed" style="color: var(--text-soft);">
          All major UK retailers and manufacturers offer {name.toLowerCase()} kitchen options, which means you have the freedom to choose the brand and price point that works for your budget while still achieving the look you want. Our installation service covers every major supplier, so whichever route you take, we can handle the fitting.
        </p>
      </div>
    </div>
  </section>

  <!-- Feature Grid -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container">
      <div class="fade-up">
        <h2 class="text-3xl font-bold mb-8" style="color: var(--navy);">
          Key Features of {name} Kitchens
        </h2>
        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-4 list-none p-0 m-0 max-w-3xl">
          {features.map((feature) => (
            <li class="flex items-start gap-3 p-5 rounded-xl border" style="border-color: #E5E7EB; background: #fff;">
              <span class="flex-shrink-0 w-6 h-6 rounded-full flex items-center justify-center mt-0.5" style="background: var(--teal);">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
              </span>
              <span class="text-sm font-medium leading-relaxed" style="color: var(--charcoal);">{feature}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Installation considerations -->
  <section class="section">
    <div class="container">
      <div class="max-w-3xl fade-up">
        <h2 class="text-3xl font-bold mb-4" style="color: var(--navy);">
          Installation Considerations for {name} Kitchens
        </h2>
        <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
          Every kitchen style carries its own installation nuances, and {name.toLowerCase()} kitchens are no exception. Our fitters are trained to handle the specific demands of this style, whether that involves precise fitting of integrated hardware, careful scribing to uneven walls, or the additional time required for intricate decorative detailing.
        </p>
        <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
          During your pre-installation survey, we will assess the kitchen space with the specific requirements of your {name.toLowerCase()} kitchen in mind. We check that the floor is sufficiently level for the planned cabinet run, that walls are straight enough for a clean fit without excessive scribing, and that any appliance positions are practical given the style's layout requirements.
        </p>
        <p class="leading-relaxed" style="color: var(--text-soft);">
          Our installation quote covers all cabinetry fitting, door and drawer adjustment, worktop fitting, and integrated appliance installation. We also complete all scribing, infill panels, and cornice and plinth work to ensure a truly finished result.
        </p>
      </div>
    </div>
  </section>

  <!-- Popular areas -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container">
      <div class="max-w-3xl fade-up">
        <h2 class="text-3xl font-bold mb-4" style="color: var(--navy);">
          Popular Areas for {name} Kitchens
        </h2>
        <p class="leading-relaxed mb-6" style="color: var(--text-soft);">
          {name} kitchens are particularly popular in areas with property types that lend themselves to this style. Across our coverage area, we see strong demand from:
        </p>
        <ul class="grid grid-cols-2 gap-3 list-none p-0 m-0">
          {areasForStyle.map((area) => (
            <li>
              <a
                href={`/areas/${area.toLowerCase().replace(/\s+/g, "-").replace(/'/g, "")}/`}
                class="flex items-center gap-2 p-3 rounded-lg border transition-all duration-200 hover:border-teal-500 hover:-translate-y-0.5 text-sm font-semibold"
                style="border-color: #E5E7EB; background: #fff; color: var(--teal);"
              >
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
                {area}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Supplier Logos -->
  <SupplierLogos />

  <!-- FAQ -->
  <section class="section">
    <div class="container">
      <div class="max-w-3xl fade-up">
        <h2 class="text-3xl font-bold mb-8" style="color: var(--navy);">
          Frequently Asked Questions
        </h2>
        <FAQ items={faqItems} schemaId={`faq-style-${slug}`} />
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTA
    heading={`Ready to Fit Your ${name} Kitchen?`}
    subtext={`Book a pre-installation survey from £195 — credited back when you proceed. We cover Coventry, Warwickshire, and surrounding areas.`}
    primaryLabel="Book Your Survey"
    primaryHref="/survey/"
    secondaryLabel="Call 07399 651836"
    secondaryHref="tel:07399651836"
    dark={true}
  />

  <Footer slot="footer" />
  <StickyMobileCTA slot="sticky-cta" />
</Base>
