---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import StickyMobileCTA from "../components/StickyMobileCTA.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import AnswerBlock from "../components/AnswerBlock.astro";
import CTA from "../components/CTA.astro";
import InternalLinks from "../components/InternalLinks.astro";
import SupplierLogos from "../components/SupplierLogos.astro";
import EnquiryForm from "../components/EnquiryForm.astro";

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Pindi Sahota",
  "url": "https://installmykitchen.co.uk/pindi-sahota/",
  "jobTitle": "Kitchen Installation Specialist",
  "description": "Pindi Sahota has 30 years of kitchen installation experience across Coventry and Warwickshire. He is the founder of Install My Kitchen and personally conducts every pre-installation survey.",
  "worksFor": {
    "@type": "LocalBusiness",
    "@id": "https://installmykitchen.co.uk/#business",
    "name": "Install My Kitchen"
  },
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "242 Hollyfast Road",
    "addressLocality": "Coventry",
    "postalCode": "CV6 2AH",
    "addressCountry": "GB"
  },
  "telephone": "+447399651836",
  "email": "info@installmykitchen.co.uk",
  "knowsAbout": [
    "Kitchen Installation",
    "Wren Kitchens",
    "Howdens",
    "Magnet Kitchens",
    "IKEA Kitchen Fitting",
    "German Kitchen Installation",
    "Häcker Kitchens",
    "Nobilia Kitchens",
    "In-Frame Kitchen Installation",
    "Shaker Kitchen Installation",
    "Worktop Fitting",
    "Kitchen Survey",
    "Kitchen Snagging",
    "Coventry Kitchen Fitter",
    "Warwickshire Kitchen Installation"
  ],
  "hasOccupation": {
    "@type": "Occupation",
    "name": "Kitchen Fitter",
    "yearsOfExperience": 30
  },
  "founder": {
    "@type": "Organization",
    "name": "Install My Kitchen",
    "url": "https://installmykitchen.co.uk"
  }
};

const keyFacts = [
  { label: "Experience", value: "30 years in kitchen installation" },
  { label: "Location", value: "Coundon, Coventry (CV6)" },
  { label: "Speciality", value: "Independent kitchen fitting — all major retailers" },
  { label: "Survey", value: "Personally conducts every pre-installation survey" },
  { label: "Quote type", value: "Fixed price — survey before every job" },
];

const retailerBrands = [
  "Wren", "Howdens", "Magnet", "IKEA", "Benchmarx", "Wickes",
  "B&Q", "DIY Kitchens", "Kutchenhaus", "Symphony", "Masterclass", "Magnet Trade",
];

const premiumBrands = [
  "Häcker", "Nobilia", "Mereway", "Neptune", "deVOL",
  "Tom Howley", "Harvey Jones", "Rotpunkt", "Pronorm",
];

const areas = [
  { name: "Coventry", slug: "coventry" },
  { name: "Rugby", slug: "rugby" },
  { name: "Nuneaton", slug: "nuneaton" },
  { name: "Leamington Spa", slug: "leamington-spa" },
  { name: "Kenilworth", slug: "kenilworth" },
  { name: "Warwick", slug: "warwick" },
  { name: "Solihull", slug: "solihull" },
  { name: "Stratford-upon-Avon", slug: "stratford-upon-avon" },
  { name: "Bedworth", slug: "bedworth" },
  { name: "Atherstone", slug: "atherstone" },
  { name: "Solihull", slug: "solihull" },
];

const internalLinks = [
  {
    label: "About Install My Kitchen",
    href: "/about/",
    description: "Background on the business and how we work.",
  },
  {
    label: "Book a Survey",
    href: "/survey/",
    description: "How the pre-installation survey works and what it covers.",
  },
  {
    label: "Installation Projects",
    href: "/projects/",
    description: "Previous installations across Coventry and Warwickshire.",
  },
  {
    label: "Common Questions",
    href: "/questions/",
    description: "Answers to the questions customers ask most often.",
  },
];
---

<Base
  title="Pindi Sahota — Kitchen Installation Specialist, Coventry | Install My Kitchen"
  description="Pindi Sahota — kitchen installation specialist, 30 years experience. Coventry-based founder of Install My Kitchen. Independent kitchen fitter."
  canonical="https://installmykitchen.co.uk/pindi-sahota/"
>
  <!-- Person schema -->
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify(personSchema)} />

  <!-- Header -->
  <Header slot="header" />

  <!-- ══════════════════════════════ PAGE HEADER ══════════════════ -->
  <section class="page-header" aria-label="Page header">
    <div class="container">
      <Breadcrumbs items={[{ label: "Pindi Sahota", href: "/pindi-sahota/" }]} />
      <h1 class="page-h1">Pindi Sahota — Kitchen Installation Specialist</h1>
      <p class="page-sub">Founder of Install My Kitchen. 30 years of kitchen installation experience across Coventry and Warwickshire.</p>
    </div>
  </section>

  <!-- ══════════════════════════════ PROFILE SECTION ═════════════ -->
  <section class="section" style="background: #fff;">
    <div class="container">

      <AnswerBlock answer="Pindi Sahota is a kitchen installation specialist with 30 years of hands-on experience, based in Coundon, Coventry. He is the founder of Install My Kitchen, an independent fitting service covering Coventry and Warwickshire." />

      <div class="profile-grid">

        <!-- Left: Name / title block -->
        <div class="profile-identity">
          <div class="identity-card">
            <p class="identity-name">Pindi Sahota</p>
            <p class="identity-title">Kitchen Installation Specialist</p>
            <p class="identity-company">
              Founder, <a href="/" class="identity-link">Install My Kitchen</a>
            </p>
            <address class="identity-nap not-italic">
              <p>242 Hollyfast Road, Coundon<br />Coventry, CV6 2AH</p>
              <p>
                <a href="tel:07399651836" class="identity-contact-link">07399 651836</a>
              </p>
              <p>
                <a href="mailto:info@installmykitchen.co.uk" class="identity-contact-link">info@installmykitchen.co.uk</a>
              </p>
            </address>
            <a href="/survey/" class="btn-primary identity-btn">
              Book a Survey
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="5" y1="12" x2="19" y2="12"/>
                <polyline points="12 5 19 12 12 19"/>
              </svg>
            </a>
          </div>
        </div>

        <!-- Right: Key facts -->
        <div class="profile-facts">
          <h2 class="facts-heading">Key Facts</h2>
          <dl class="facts-list">
            {keyFacts.map((fact) => (
              <div class="fact-row">
                <dt class="fact-label">{fact.label}</dt>
                <dd class="fact-value">{fact.value}</dd>
              </div>
            ))}
            <div class="fact-row">
              <dt class="fact-label">Retailers fitted</dt>
              <dd class="fact-value">{retailerBrands.join(", ")}</dd>
            </div>
            <div class="fact-row">
              <dt class="fact-label">Premium brands</dt>
              <dd class="fact-value">{premiumBrands.join(", ")}</dd>
            </div>
            <div class="fact-row">
              <dt class="fact-label">Coverage</dt>
              <dd class="fact-value">Coventry, Rugby, Nuneaton, Leamington Spa, Kenilworth, Warwick, Solihull, Stratford-upon-Avon</dd>
            </div>
          </dl>
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════ BIO SECTION ═════════════════ -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container">
      <div class="bio-grid">

        <div class="bio-main">
          <h2 class="section-h2">About Pindi Sahota</h2>

          <p class="body-copy">
            Pindi Sahota is the founder and lead fitter of Install My Kitchen, an independent kitchen installation company based in Coundon, Coventry. With 30 years of hands-on experience, he has fitted hundreds of kitchens across Coventry and Warwickshire — from compact galley kitchens in Victorian terraces to large open-plan kitchen-diner installations in Kenilworth and Leamington Spa.
          </p>

          <p class="body-copy">
            Pindi's approach to kitchen installation is rooted in one principle: do it properly or don't do it at all. Every project begins with a personal survey visit, where he assesses the room against the kitchen plan, identifies any structural or service challenges, and provides a fixed installation quote. He does not subcontract his survey work. He does not quote without visiting the room. He does not start until he is confident the installation can be completed to the standard the kitchen deserves.
          </p>

          <p class="body-copy">
            Over 30 years, Pindi has developed specific expertise in fitting kitchens from every major UK retailer. He understands the differences between rigid pre-assembled units (Wren, Howdens, Magnet) and flat-pack systems (IKEA), between standard consumer-range kitchens and precision-engineered German brands (Häcker, Nobilia, Rotpunkt), between painted shaker doors that demand exact gap consistency and handleless systems that show every millimetre of misalignment. This range of experience — 30 years deep rather than 30 years wide — is what Install My Kitchen brings to every kitchen it fits.
          </p>

          <!-- Principles -->
          <h3 class="subsection-h3">How Pindi Works</h3>
          <div class="principles-grid" role="list" aria-label="Pindi's working principles">

            <div class="principle-card" role="listitem">
              <h4 class="principle-title">Survey First, Always</h4>
              <p class="principle-body">Every installation begins with a personal visit from Pindi. No quotes without seeing the room. No exceptions.</p>
            </div>

            <div class="principle-card" role="listitem">
              <h4 class="principle-title">Fixed-Price Quotes</h4>
              <p class="principle-body">Your quote is fixed before work begins. It will not change unless you change the scope of the job.</p>
            </div>

            <div class="principle-card" role="listitem">
              <h4 class="principle-title">Retailer Independent</h4>
              <p class="principle-body">Not employed by or affiliated with any kitchen retailer. Pindi works for the customer, not a showroom.</p>
            </div>

            <div class="principle-card" role="listitem">
              <h4 class="principle-title">Personal Accountability</h4>
              <p class="principle-body">Pindi is personally involved in every survey and takes responsibility for every installation his team carries out.</p>
            </div>

          </div>
        </div>

        <!-- Sidebar -->
        <aside class="bio-sidebar">
          <div class="sidebar-card">
            <h3 class="sidebar-heading">Speak to Pindi Directly</h3>
            <p class="sidebar-body">Every survey is conducted by Pindi personally. Call to discuss your kitchen or book a visit.</p>
            <a href="tel:07399651836" class="btn-primary sidebar-btn">
              Call 07399 651836
            </a>
            <a href="/survey/" class="sidebar-secondary-btn">
              Book a Survey Online
            </a>
          </div>

          <div class="sidebar-card">
            <h3 class="sidebar-heading">Experience at a Glance</h3>
            <ul class="sidebar-stats" role="list">
              <li role="listitem" class="stat-row">
                <span class="stat-number">30</span>
                <span class="stat-label">Years of experience</span>
              </li>
              <li role="listitem" class="stat-row stat-row--border">
                <span class="stat-number">12+</span>
                <span class="stat-label">Major retailers fitted</span>
              </li>
              <li role="listitem" class="stat-row stat-row--border">
                <span class="stat-number">9+</span>
                <span class="stat-label">Premium brands installed</span>
              </li>
              <li role="listitem" class="stat-row stat-row--border">
                <span class="stat-number">CV6</span>
                <span class="stat-label">Based in Coventry</span>
              </li>
            </ul>
          </div>
        </aside>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════ AREAS SECTION ═══════════════ -->
  <section class="section" style="background: #fff;">
    <div class="container">
      <h2 class="section-h2-centred">Areas Pindi Covers</h2>
      <p class="section-sub">Based in Coundon, Coventry — serving the wider Warwickshire area.</p>

      <ul class="areas-grid" role="list" aria-label="Areas covered by Pindi Sahota">
        {areas.map((area) => (
          <li role="listitem">
            <a href={`/areas/${area.slug}/`} class="area-card">
              <span class="area-name">{area.name}</span>
              <svg class="area-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="5" y1="12" x2="19" y2="12"/>
                <polyline points="12 5 19 12 12 19"/>
              </svg>
            </a>
          </li>
        ))}
      </ul>

      <p class="areas-footnote">
        Not listed here? <a href="/contact/" style="color: var(--teal); font-weight: 600;">Get in touch</a> — coverage extends beyond this list.
      </p>
    </div>
  </section>

  <!-- ══════════════════════════════ SUPPLIER LOGOS ══════════════ -->
  <SupplierLogos heading="Kitchens Pindi Installs" />

  <!-- ══════════════════════════════ BOOK A SURVEY ══════════════ -->
  <section class="section" style="background: #fff;" id="book-survey">
    <div class="container">
      <div class="survey-section">
        <div class="survey-intro">
          <h2 class="section-h2">Book a Survey With Pindi</h2>
          <p class="body-copy">
            Every survey is conducted by Pindi personally. He visits your home, assesses the room against your kitchen plan, and provides a fixed installation quote. There are no call centres, no subcontractors, and no surprises.
          </p>
          <p class="body-copy">
            Call <a href="tel:07399651836" style="color: var(--teal); font-weight: 600;">07399 651836</a> or complete the form below to book your survey.
          </p>
          <div class="survey-detail-block">
            <p class="survey-detail-item">
              <strong>Survey fee:</strong> £195 — credited against your installation balance on booking.
            </p>
            <p class="survey-detail-item">
              <strong>Conducted by:</strong> Pindi Sahota, personally.
            </p>
            <p class="survey-detail-item">
              <strong>Duration:</strong> 45–90 minutes depending on kitchen size.
            </p>
          </div>
        </div>
        <div class="survey-form">
          <EnquiryForm formTitle="Book a Survey" showSurveyOption={false} />
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════ INTERNAL LINKS ══════════════ -->
  <section class="section-sm" style="background: var(--bg-light);">
    <div class="container">
      <InternalLinks links={internalLinks} heading="Learn More" />
    </div>
  </section>

  <!-- ══════════════════════════════ DARK CTA ═══════════════════ -->
  <CTA
    dark={true}
    heading="Book a Survey With Pindi"
    subtext="Every survey is conducted by Pindi personally. Fixed price quote follows every visit. No obligation, no surprises."
    primaryLabel="Book a Survey — £195"
    primaryHref="/survey/"
    secondaryLabel="Call 07399 651836"
    secondaryHref="tel:07399651836"
  />

  <!-- Footer -->
  <Footer slot="footer" />
  <StickyMobileCTA slot="sticky-cta" />
</Base>

<style>
  /* ── Page header ── */
  .page-header {
    background: var(--hero-gradient);
    padding: 3rem 0 3.5rem;
  }

  .page-h1 {
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.02em;
    margin-top: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .page-sub {
    color: rgba(255, 255, 255, 0.75);
    font-size: 1.0625rem;
    line-height: 1.6;
    max-width: 560px;
  }

  /* ── Profile grid ── */
  .profile-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    margin-top: 2rem;
  }

  @media (min-width: 768px) {
    .profile-grid {
      grid-template-columns: 320px 1fr;
      align-items: start;
    }
  }

  /* Identity card (left column) */
  .identity-card {
    background: var(--bg-light);
    border: 1.5px solid var(--border);
    border-top: 4px solid var(--teal);
    border-radius: 1rem;
    padding: 1.75rem;
  }

  .identity-name {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--charcoal);
    letter-spacing: -0.02em;
    margin-bottom: 0.25rem;
  }

  .identity-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--teal);
    margin-bottom: 0.25rem;
  }

  .identity-company {
    font-size: 0.875rem;
    color: var(--text-soft);
    margin-bottom: 1.25rem;
  }

  .identity-link {
    color: var(--teal);
    font-weight: 600;
  }

  .identity-nap {
    font-size: 0.875rem;
    color: var(--text-soft);
    line-height: 1.7;
    margin-bottom: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    border-top: 1px solid var(--border);
    padding-top: 1rem;
  }

  .identity-contact-link {
    color: var(--teal);
    font-weight: 600;
    transition: color 0.15s;
  }

  .identity-contact-link:hover {
    color: var(--teal-bright);
  }

  .identity-btn {
    width: 100%;
    justify-content: center;
    font-size: 0.9375rem;
  }

  /* Key facts (right column) */
  .facts-heading {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--charcoal);
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--teal);
    display: inline-block;
  }

  .facts-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .fact-row {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 0.75rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--border);
    align-items: baseline;
  }

  .fact-row:last-child {
    border-bottom: none;
  }

  .fact-label {
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--charcoal);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    flex-shrink: 0;
  }

  .fact-value {
    font-size: 0.9375rem;
    color: var(--text-soft);
    line-height: 1.6;
  }

  /* ── Bio section layout ── */
  .bio-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 1024px) {
    .bio-grid {
      grid-template-columns: 1fr 300px;
      align-items: start;
    }
  }

  .section-h2 {
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--charcoal);
    margin-top: 0;
    margin-bottom: 1.25rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--teal);
    display: inline-block;
  }

  .body-copy {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--text-soft);
    margin-bottom: 1.125rem;
  }

  .subsection-h3 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--charcoal);
    margin-top: 1.75rem;
    margin-bottom: 1rem;
  }

  /* Principles grid */
  .principles-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .principles-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .principle-card {
    background: #fff;
    border: 1.5px solid var(--border);
    border-left: 4px solid var(--teal);
    border-radius: 0.625rem;
    padding: 1.125rem 1.25rem;
  }

  .principle-title {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--charcoal);
    margin-bottom: 0.375rem;
  }

  .principle-body {
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--text-soft);
    margin: 0;
  }

  /* Bio sidebar */
  .sidebar-card {
    background: #fff;
    border-radius: 1rem;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
    border: 1.5px solid var(--border);
  }

  .sidebar-heading {
    font-size: 1rem;
    font-weight: 700;
    color: var(--charcoal);
    margin-bottom: 0.75rem;
  }

  .sidebar-body {
    font-size: 0.875rem;
    color: var(--text-soft);
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .sidebar-btn {
    width: 100%;
    justify-content: center;
    font-size: 0.9375rem;
    margin-bottom: 0.625rem;
  }

  .sidebar-secondary-btn {
    display: block;
    text-align: center;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--teal);
    padding: 0.625rem 1rem;
    border: 1.5px solid var(--teal);
    border-radius: 50px;
    transition: background 0.15s, color 0.15s;
  }

  .sidebar-secondary-btn:hover {
    background: var(--teal);
    color: #fff;
  }

  /* Stats list */
  .sidebar-stats {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .stat-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 0;
  }

  .stat-row--border {
    border-top: 1px solid var(--border);
  }

  .stat-number {
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--teal);
    line-height: 1;
    flex-shrink: 0;
    min-width: 3.5rem;
  }

  .stat-label {
    font-size: 0.875rem;
    color: var(--text-soft);
    line-height: 1.4;
  }

  /* ── Areas section ── */
  .section-h2-centred {
    font-size: clamp(1.375rem, 2.5vw, 1.875rem);
    font-weight: 800;
    color: var(--charcoal);
    text-align: center;
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
  }

  .section-sub {
    text-align: center;
    font-size: 0.9375rem;
    color: var(--text-soft);
    margin-bottom: 2rem;
  }

  .areas-grid {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }

  @media (min-width: 640px) {
    .areas-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .areas-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .area-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0.875rem 1rem;
    background: #fff;
    border: 1.5px solid var(--border);
    border-radius: 0.625rem;
    text-decoration: none;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }

  .area-card:hover {
    border-color: var(--teal);
    box-shadow: 0 4px 14px rgba(15, 118, 110, 0.1);
    transform: translateY(-1px);
  }

  .area-name {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--teal);
    transition: color 0.15s;
  }

  .area-card:hover .area-name {
    color: var(--teal-bright);
  }

  .area-arrow {
    flex-shrink: 0;
    color: var(--teal);
    opacity: 0.5;
    transition: opacity 0.2s, transform 0.2s;
  }

