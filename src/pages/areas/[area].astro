---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import StickyMobileCTA from "../../components/StickyMobileCTA.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import AnswerBlock from "../../components/AnswerBlock.astro";
import KeyTakeaway from "../../components/KeyTakeaway.astro";
import FAQ from "../../components/FAQ.astro";
import SupplierLogos from "../../components/SupplierLogos.astro";
import InternalLinks from "../../components/InternalLinks.astro";
import CTA from "../../components/CTA.astro";
import TrustStrip from "../../components/TrustStrip.astro";

import locationsData from "../../data/locations.json";
import faqsData from "../../data/faqs.json";

export function getStaticPaths() {
  return locationsData.map((location) => ({
    params: { area: location.slug },
    props: { location },
  }));
}

const { location } = Astro.props;
const { name, slug, county, description, nearby } = location;

const canonical = `https://www.installmykitchen.co.uk/areas/${slug}/`;

// Title — kept ≤60 chars where possible
const title = `Kitchen Installation ${name} | Install My Kitchen`;

// Meta description — unique to each location, 140–160 chars
const metaDescription = `Expert independent kitchen installation in ${name}, ${county}. We fit kitchens from Wren, Howdens, Magnet, IKEA & all major retailers. Free survey available.`;

// KeyTakeaway points — vary by area characteristics
const takeawayPoints = [
  `We serve ${name} and surrounding areas in ${county} with a dedicated installation team.`,
  `All major kitchen retailers covered — Wren, Howdens, Magnet, IKEA, B&Q, Wickes and more.`,
  `Fixed-price quotes following our £195 pre-installation survey (credited back on booking).`,
  `Fully independent — we work for you, not the retailer, ensuring an impartial, professional finish.`,
];

// Pull first 4 general FAQs
const faqItems = faqsData.general.slice(0, 4);

// Nearby area links
const nearbyLinks = (nearby as string[]).map((nearbySlug) => {
  const nearbyLocation = locationsData.find((l) => l.slug === nearbySlug);
  return nearbyLocation
    ? {
        label: `Kitchen Installation in ${nearbyLocation.name}`,
        href: `/areas/${nearbySlug}/`,
        description: `${nearbyLocation.county} — independent installation service`,
      }
    : null;
}).filter(Boolean) as { label: string; href: string; description: string }[];

// LocalBusiness JSON-LD
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "Install My Kitchen",
  url: "https://www.installmykitchen.co.uk",
  telephone: "07399651836",
  email: "info@installmykitchen.co.uk",
  address: {
    "@type": "PostalAddress",
    streetAddress: "242 Hollyfast Road, Coundon",
    addressLocality: "Coventry",
    postalCode: "CV6 2AH",
    addressCountry: "GB",
  },
  areaServed: {
    "@type": "Place",
    name: name,
  },
  description: `Independent kitchen installation service covering ${name} and the wider ${county} area.`,
};

// Service JSON-LD
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: `Kitchen Installation in ${name}`,
  provider: {
    "@type": "LocalBusiness",
    name: "Install My Kitchen",
    url: "https://www.installmykitchen.co.uk",
  },
  areaServed: {
    "@type": "Place",
    name: name,
  },
  description: `Professional independent kitchen installation service across ${name}, fitting kitchens from all major UK retailers including Wren, Howdens, Magnet, IKEA and Wickes.`,
  serviceType: "Kitchen Installation",
};
---

<Base
  title={title}
  description={metaDescription}
  canonical={canonical}
>
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

  <Header slot="header" />

  <div class="container py-6">
    <Breadcrumbs
      items={[
        { label: "Areas", href: "/areas/" },
        { label: name, href: `/areas/${slug}/` },
      ]}
    />
  </div>

  <!-- Hero -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-extrabold mb-5 leading-tight" style="color: var(--navy);">
          Kitchen Installation in {name}
        </h1>
        <AnswerBlock
          answer={`Install My Kitchen provides expert independent kitchen installation across ${name}. We fit kitchens purchased from Wren, Howdens, Magnet, IKEA and all major retailers.`}
        />
        <KeyTakeaway points={takeawayPoints} />
      </div>
    </div>
  </section>

  <!-- Section 1: Kitchen Installation in {name} -->
  <section class="section">
    <div class="container">
      <div class="max-w-3xl fade-up">
        <h2 class="text-3xl font-bold mb-4" style="color: var(--navy);">
          Kitchen Installation in {name}
        </h2>
        <p class="text-lg leading-relaxed mb-4" style="color: var(--text-soft);">
          {description}
        </p>
        <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
          Install My Kitchen is a fully independent fitting service based in Coundon, Coventry. We cover {name} and the surrounding {county} area, handling every aspect of your kitchen installation from initial survey through to final snagging. We work with you — not the retailer — to ensure the job is done to a standard you are happy with.
        </p>
        <p class="leading-relaxed" style="color: var(--text-soft);">
          Whether you are replacing an existing kitchen or fitting one in a newly built or extended property, our team has the experience to manage your project efficiently. We carry out a thorough pre-installation survey before a single cabinet is ordered, so you receive a fixed-price quote with no hidden surprises on installation day.
        </p>
      </div>
    </div>
  </section>

  <!-- Section 2: Retailers We Cover -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container">
      <div class="max-w-3xl fade-up">
        <h2 class="text-3xl font-bold mb-4" style="color: var(--navy);">
          Retailers We Cover in {name}
        </h2>
        <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
          We install kitchens from every major UK retailer and manufacturer. Whether you have chosen a kitchen from Wren Kitchens, Howdens Joinery, Magnet, IKEA, Wickes, B&Q, Benchmarx, DIY Kitchens, Kutchenhaus, Symphony, or Masterclass, our {name} team can handle the installation.
        </p>
        <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
          We also fit kitchens from premium British and German brands including Mereway, Häcker, Nobilia, Neptune, and deVOL. If you are uncertain whether we cover your particular brand or product range, please get in touch — in most cases we can fit it.
        </p>
        <p class="leading-relaxed" style="color: var(--text-soft);">
          Because we hold trade accounts with Howdens and Benchmarx, we can order and collect directly from the local depot, giving you a more streamlined supply chain and reducing the risk of delivery damage. For retail-supplied kitchens, we will co-ordinate the delivery schedule with you to ensure everything arrives on site before installation begins.
        </p>
      </div>
      <div class="mt-10">
        <SupplierLogos />
      </div>
    </div>
  </section>

  <!-- Section 3: Survey & Quote -->
  <section class="section">
    <div class="container">
      <div class="max-w-3xl fade-up">
        <h2 class="text-3xl font-bold mb-4" style="color: var(--navy);">
          Survey &amp; Quote for {name}
        </h2>
        <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
          Every installation we carry out in {name} begins with a pre-installation survey, priced at £195 and credited back in full when you proceed. During the survey, one of our experienced fitters visits your home to take detailed measurements, assess the existing layout, and review your kitchen plan with you. This ensures the installation quote we provide is accurate and fully itemised — no estimates, no surprises.
        </p>
        <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
          Our surveyors check ceiling heights, wall straightness, existing pipework routes, and appliance positions, flagging any potential complications before they become costly problems on installation day. If we spot anything that needs attention from a plumber, electrician, or plasterer, we will advise you at the survey stage so you can plan and budget accordingly.
        </p>
        <p class="leading-relaxed" style="color: var(--text-soft);">
          To book your survey in {name}, call us on <a href="tel:07399651836" class="font-semibold" style="color: var(--teal);">07399 651836</a> or use the enquiry form on our survey page. We typically offer survey appointments within two weeks, and installation slots are usually available within four to eight weeks of the survey.
        </p>
      </div>
    </div>
  </section>

  <!-- Nearby Areas -->
  {nearbyLinks.length > 0 && (
    <section class="section" style="background: var(--bg-light);">
      <div class="container">
        <div class="fade-up">
          <InternalLinks
            links={nearbyLinks}
            heading={`Nearby Areas We Also Cover`}
          />
        </div>
      </div>
    </section>
  )}

  <!-- Local Area Information Section -->
  <section class="section-sm" style="background: var(--bg-light);">
    <div class="container">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Postcodes -->
        <div class="card p-6">
          <h3 class="font-bold text-lg mb-3" style="color: var(--navy);">
            Postcodes We Cover in {location.name}
          </h3>
          <div class="flex flex-wrap gap-2">
            {location.postcodes?.map((pc: string) => (
              <span style="background: var(--teal); color: white; padding: 0.25rem 0.75rem; border-radius: 50px; font-size: 0.875rem; font-weight: 600;">
                {pc}
              </span>
            ))}
          </div>
          {location.travelTime && (
            <p class="text-sm mt-3" style="color: var(--text-soft);">
              Travel time: {location.travelTime}
            </p>
          )}
        </div>

        <!-- Housing Stock -->
        <div class="card p-6">
          <h3 class="font-bold text-lg mb-3" style="color: var(--navy);">
            Housing &amp; Kitchen Types in {location.name}
          </h3>
          <p class="text-sm leading-relaxed" style="color: var(--text-soft);">
            {location.housingStock}
          </p>
        </div>

        <!-- Local Installation Note -->
        <div class="card p-6">
          <h3 class="font-bold text-lg mb-3" style="color: var(--navy);">
            Installation in {location.name}
          </h3>
          <p class="text-sm leading-relaxed" style="color: var(--text-soft);">
            {location.localNote}
          </p>
          <a href={`/survey/${location.slug}/`} class="btn-primary mt-4" style="font-size:0.875rem; padding: 0.625rem 1.25rem;">
            Book Survey in {location.name}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container">
      <div class="max-w-3xl fade-up">
        <h2 class="text-3xl font-bold mb-8" style="color: var(--navy);">
          Frequently Asked Questions
        </h2>
        <FAQ items={faqItems} schemaId={`faq-area-${slug}`} />
      </div>
    </div>
  </section>

  <!-- Trust Strip -->
  <TrustStrip />

  <!-- CTA -->
  <CTA
    heading={`Ready to Book Your Kitchen Installation in ${name}?`}
    subtext={`Book a pre-installation survey from £195 — credited back when you proceed. Covering ${name} and the wider ${county} area.`}
    primaryLabel="Book Your Survey"
    primaryHref="/survey/"
    secondaryLabel="Call 07399 651836"
    secondaryHref="tel:07399651836"
    dark={true}
  />

  <Footer slot="footer" />
  <StickyMobileCTA slot="sticky-cta" />
</Base>
