  "@context": "https://schema.org",
  "@type": "Service",
  name: "Kitchen Fitting in Royal Leamington Spa",
  provider: {
    "@type": "LocalBusiness",
    name: "Install My Kitchen",
    url: "https://installmykitchen.co.uk",
    telephone: "07399651836",
  },
  areaServed: {
    "@type": "City",
    name: "Royal Leamington Spa",
  },
  description:
    "Professional independent kitchen fitting and installation service across Royal Leamington Spa (CV31, CV32, CV33), fitting kitchens from all major UK retailers including IKEA, Wren, Howdens, Magnet and Wickes. Fixed-price quotes following a pre-installation survey. Specialist experience with Regency and Victorian period property kitchens.",
  serviceType: "Kitchen Fitting",
  offers: {
    "@type": "Offer",
