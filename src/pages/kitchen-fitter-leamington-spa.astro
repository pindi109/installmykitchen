<Base
  title={title}
  description={metaDescription}
  canonical={canonical}
>
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

  <Header slot="header" />

  <div class="container py-6">
    <Breadcrumbs
      items={[
        { label: "Kitchen Fitter Leamington Spa", href: "/kitchen-fitter-leamington-spa/" },
      ]}
    />
  </div>

  <!-- Hero -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-extrabold mb-5 leading-tight" style="color: var(--navy);">
          Kitchen Fitter Leamington Spa — Independent Installation by Pindi Sahota
        </h1>
        <AnswerBlock
          answer="Pindi Sahota is an independent kitchen fitter serving Royal Leamington Spa and the surrounding CV31, CV32 and CV33 postcode area. With 30 years of experience — including IKEA METOD installations in Leamington's Victorian terraces — he fits kitchens from every major retailer with a fixed-price quote guaranteed after a £195 pre-installation survey (credited back on booking)."
        />
