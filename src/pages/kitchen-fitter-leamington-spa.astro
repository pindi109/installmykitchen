import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import StickyMobileCTA from "../components/StickyMobileCTA.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import AnswerBlock from "../components/AnswerBlock.astro";
import KeyTakeaway from "../components/KeyTakeaway.astro";
import FAQ from "../components/FAQ.astro";
import SupplierLogos from "../components/SupplierLogos.astro";
import InternalLinks from "../components/InternalLinks.astro";
import CTA from "../components/CTA.astro";
import TrustStrip from "../components/TrustStrip.astro";

const title = "Kitchen Fitter Leamington Spa | Install My Kitchen — Pindi Sahota";
const metaDescription = "Independent kitchen fitter in Royal Leamington Spa. Pindi Sahota delivers expert kitchen installation across CV31, CV32 and CV33 with 30 years experience, fixed-price quotes, and a £195 survey credited back.";
const canonical = "https://installmykitchen.co.uk/kitchen-fitter-leamington-spa/";

const takeawayPoints = [
  "Pindi Sahota is an independent kitchen fitter serving Royal Leamington Spa and the surrounding CV31, CV32 and CV33 postcode area.",
  "30 years of professional kitchen fitting experience, including extensive work in Leamington's challenging period properties — Regency terraces, Victorian villas, and scullery-style kitchens.",
  "Fits kitchens from IKEA, Wren, Howdens, Magnet, Wickes, B&Q, Benchmarx and all other major retailers.",
  "Pre-installation survey at £195, credited back in full when you proceed — fixed-price quote guaranteed with no hidden charges.",
];

const faqItems = [
  {
    q: "What makes Leamington Spa period properties different for kitchen fitting?",
    a: "Royal Leamington Spa has an unusually high concentration of Regency and Victorian period properties — terraces, villas, and sculleries — that present fitting challenges well outside the norm of a modern semi-detached. Walls in the conservation area can be 40mm or more out of plumb, meaning that base and wall units need individual adjustment rather than a simple straight run. Original stone or quarry tile floors under later kitchen tiles are common and can cause significant levelling issues when discovered only on installation day. Scullery-style kitchen spaces — narrow rooms with a single external wall, low ceiling heights, and limited natural light — require precise planning to make the most of every centimetre. Pindi has fitted multiple kitchens across Leamington's period housing stock, including an IKEA METOD installation in a Victorian mid-terrace in the town, and understands what to look for and how to plan around it. This local, practical knowledge is what the pre-installation survey is specifically designed to surface — before anything is ordered.",
  },
  {
    q: "How much does kitchen fitting cost in Leamington Spa?",
    a: "Kitchen fitting costs in Leamington Spa depend on the size of the kitchen, the layout complexity, the number of appliances, and whether any preparatory work is required — particularly in period properties where floor levelling or wall making-good is common. As a guide, a standard 10–15 unit kitchen in a typical Leamington semi or terrace typically costs between £1,300 and £2,600 for fitting labour alone. Period property projects with uneven floors, out-of-plumb walls, or scullery-style spaces will sit higher due to the additional time required. Pindi provides a fully itemised, fixed-price quote following a pre-installation survey, so there are no estimates or retrospective charges. For a detailed breakdown of what affects pricing, visit the kitchen fitting costs page.",
  },
  {
    q: "Do you cover CV31, CV32 and CV33?",
    a: "Yes. Pindi covers all Leamington Spa postcodes: CV31 (Leamington town centre and south), CV32 (north Leamington including Milverton and Lillington), and CV33 (the wider rural area to the east including Radford Semele and Cubbington). He also covers the immediately surrounding areas, including Warwick (CV34), Kenilworth (CV8), and villages within a reasonable radius. Call 07399 651836 to confirm coverage for your specific postcode.",
  },
  {
    q: "How long does kitchen installation take in a Leamington Spa Victorian terrace?",
    a: "In a standard Victorian terrace in Leamington Spa, kitchen installation typically takes between four and six working days for the fitting itself — one to two days longer than a modern semi of equivalent size. The additional time accounts for the out-of-plumb wall adjustment, floor levelling work where required, and the more careful setting-out needed in narrow scullery-style rooms. If the project includes trades co-ordination — a plumber for relocated pipework, or an electrician for a new circuit or extraction route — the overall project programme will be longer. During the pre-installation survey, Pindi will give you a realistic duration estimate based on your specific room, kitchen specification, and any work identified during the survey.",
  },
  {
    q: "Which kitchen retailers do you fit in Leamington Spa?",
    a: "Pindi fits kitchens from every major UK retailer and manufacturer. In Leamington Spa the most common brands he installs are IKEA (including the METOD system fitted in several Leamington terraces), Wren Kitchens, Howdens Joinery, Magnet, Wickes, and B&Q. He also regularly fits Benchmarx, DIY Kitchens, Kutchenhaus, Symphony, and Masterclass, as well as premium and German brands such as Häcker, Nobilia, Mereway, Neptune and deVOL. Because Pindi is fully independent — not contracted to any retailer — you are free to buy from whichever retailer suits your budget and style, and have the installation carried out to the same professional standard regardless of supplier.",
  },
];

const internalLinks = [
  {
    label: "Book a pre-installation survey",
    href: "/survey/",
    description: "£195 survey credited back in full when you proceed — the essential first step",
  },
  {
    label: "Kitchen fitting costs explained",
    href: "/costs/",
    description: "Fully itemised guide to what affects kitchen installation prices",
  },
  {
    label: "Leamington Spa area page",
    href: "/areas/leamington-spa/",
    description: "Detailed installation information for CV31, CV32 and CV33",
  },
  {
    label: "IKEA kitchen in Leamington Spa — project",
    href: "/projects/ikea-kitchen-leamington-spa/",
    description: "See the IKEA METOD installation Pindi completed in a Leamington Victorian terrace",
  },
  {
    label: "About Pindi Sahota",
    href: "/pindi-sahota/",
    description: "Meet the independent kitchen fitter behind Install My Kitchen",
  },
  {
    label: "IKEA kitchen installation",
    href: "/retailers/ikea/",
    description: "How Pindi fits IKEA METOD and SEKTION kitchens independently",
  },
  {
    label: "Howdens kitchen installation",
    href: "/retailers/howdens/",
    description: "Why independent fitting is the right choice for your Howdens kitchen",
  },
  {
    label: "Wren kitchen installation",
    href: "/retailers/wren/",
    description: "Fitting your Wren kitchen independently — what you need to know",
  },
];

// LocalBusiness JSON-LD
