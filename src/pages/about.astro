---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import StickyMobileCTA from "../components/StickyMobileCTA.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import AnswerBlock from "../components/AnswerBlock.astro";
import KeyTakeaway from "../components/KeyTakeaway.astro";
import FAQ from "../components/FAQ.astro";
import CTA from "../components/CTA.astro";
import InternalLinks from "../components/InternalLinks.astro";

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Pindi Sahota",
  "jobTitle": "Kitchen Installation Specialist",
  "description": "Pindi Sahota has 30 years of kitchen installation experience across Coventry, Warwickshire and Berkshire. Founder of Install My Kitchen, independent kitchen fitter serving all major retailers.",
  "worksFor": {
    "@type": "LocalBusiness",
    "name": "Install My Kitchen",
    "url": "https://installmykitchen.co.uk",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "242 Hollyfast Road",
      "addressLocality": "Coventry",
      "postalCode": "CV6 2AH",
      "addressCountry": "GB"
    }
  },
  "knowsAbout": [
    "Kitchen Installation",
    "Wren Kitchens",
    "Howdens Kitchen Installation",
    "IKEA Kitchen Fitting",
    "Magnet Kitchen Installation",
    "German Kitchen Installation",
    "Worktop Fitting",
    "Kitchen Survey",
    "Coventry Kitchen Fitter",
    "Warwickshire Kitchen Installation",
    "In-Frame Kitchen Installation",
    "Premium Kitchen Fitting",
    "Häcker Kitchen Installation",
    "Neptune Kitchen Fitting"
  ],
  "hasOccupation": {
    "@type": "Occupation",
    "name": "Kitchen Fitter",
    "yearsOfExperience": 30,
    "occupationLocation": {
      "@type": "City",
      "name": "Coventry"
    }
  }
};

const keyTakeaways = [
  "30 years on the tools — not a franchise, not a call centre, not a subcontracted team",
  "Every survey conducted personally by Pindi — laser measured, cross-checked against your drawings",
  "Fixed price guaranteed — the quote does not change unless you change the scope",
  "Entirely independent — no retailer affiliation, no commission, no allegiance to any brand",
];

const faqItems = [
  {
    q: "How long has Pindi been fitting kitchens?",
    a: "Pindi has been fitting kitchens for 30 years. He began his career in the construction trades and found his specialism in kitchen installation — the point where carpentry precision, plumbing co-ordination, and fine detail all converge. Kitchen installation has been his full-time focus throughout his professional life."
  },
  {
    q: "Does Pindi do every installation himself?",
    a: "Pindi leads every project and conducts every survey personally. He is present throughout every installation. For larger projects he works alongside a small, trusted team — but Pindi surveys, Pindi oversees, and Pindi signs off. You will not find yourself dealing with someone who was not there on survey day."
  },
  {
    q: "What retailers does Install My Kitchen work with?",
    a: "Install My Kitchen fits kitchens from all major UK retailers and premium brands. Standard retail includes Wren, Howdens, Magnet, IKEA, Wickes, B&amp;Q, Benchmarx, DIY Kitchens, Symphony and Masterclass. Premium brands include Häcker, Nobilia, Rotpunkt, Pronorm, Mereway, Tom Howley, Harvey Jones, Neptune, deVOL, Smallbone and John Lewis of Hungerford. See the full list in the 'What We Install' section on this page."
  },
  {
    q: "Is Install My Kitchen affiliated with any retailer?",
    a: "No. Install My Kitchen is entirely independent. We have no commercial relationship, referral agreement or commission arrangement with any kitchen retailer. When Pindi surveys your kitchen, his only consideration is whether the plans work for your home."
  },
  {
    q: "How do I book a survey with Pindi?",
    a: "Call 07399 651836 or complete the online enquiry form. Survey appointments are typically available within one to two weeks. The survey fee is £195, credited back against your installation on booking."
  }
];

const internalLinks = [
  { label: "Our Services", href: "/services/", description: "Full scope of what the installation covers" },
  { label: "Retailers We Fit", href: "/retailers/", description: "Every brand we have experience fitting" },
  { label: "Areas We Cover", href: "/areas/", description: "Coventry, Warwickshire and surrounding areas" },
  { label: "Cost Guide", href: "/costs/", description: "Transparent pricing and what affects the quote" },
  { label: "Book a Survey", href: "/survey/", description: "Start with a site visit — fixed-price quote follows" },
  { label: "Contact Us", href: "/contact/", description: "Get in touch directly with Pindi" },
];
---

<Base
  title="About Pindi Sahota — 30 Years Installing Kitchens | Install My Kitchen"
  description="Meet Pindi Sahota, founder of Install My Kitchen. 30 years fitting kitchens across Coventry, Warwickshire and Berkshire. Independent, survey-first, fixed-price kitchen installation."
  canonical="https://installmykitchen.co.uk/about/"
>
  <!-- Person schema -->
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify(personSchema)} />

  <!-- Header -->
  <Header slot="header" />

  <!-- ══════════════════════════════ HERO ════════════════════════ -->
  <section class="about-hero" aria-label="Page header">
    <div class="container">
      <Breadcrumbs items={[{ label: "About", href: "/about/" }]} />
      <h1 class="hero-h1">About Pindi Sahota — 30 Years Fitting Kitchens Across Coventry, Warwickshire &amp; Berkshire</h1>
      <div class="hero-answer">
        <AnswerBlock answer="Pindi Sahota founded Install My Kitchen after three decades fitting kitchens across Coventry, Warwickshire and Berkshire. In that time he has installed hundreds of kitchens — from compact terraced house galley kitchens in Earlsdon to large open-plan extensions in Kenilworth and Leamington Spa. His philosophy is simple: survey first, fix price, no surprises, and don't leave until the job is right." />
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════ MAIN CONTENT ════════════════ -->
  <section class="section" style="background: #fff;">
    <div class="container">
      <div class="content-grid">

        <!-- ── Main column ── -->
        <div class="content-main">

          <KeyTakeaway points={keyTakeaways} />

          <!-- Who Is Pindi -->
          <h2 class="section-h2" id="who-is-pindi">Who Is Pindi Sahota?</h2>

          <p class="body-copy">
            Pindi has spent 30 years on the tools. He began his career in the construction trades and found his specialism in kitchen installation — the point where carpentry precision, plumbing co-ordination, and attention to detail all converge. He built Install My Kitchen as a direct response to what he saw in the market: homeowners being rushed through installations by franchise-model fitters with quotas to meet and no personal accountability.
          </p>

          <p class="body-copy">
            Every survey Pindi conducts personally. He measures your room with laser equipment, cross-checks your designer's drawings against reality, assesses your floor levels and wall conditions, and identifies anything that could cause a problem on installation day. He has seen every issue that an uneven Coventry floor or an out-of-plumb Victorian wall can create — and he plans around them before work begins. Not after.
          </p>

          <p class="body-copy">
            Pindi does not rush. The thing that separates a good kitchen installation from an average one is almost always in the detail — the consistency of door gaps, the tightness of a worktop joint, the alignment of a plinth on an uneven floor. These are the details that Pindi has spent 30 years refining. They are also the details that are impossible to rush.
          </p>

          <p class="body-copy">
            Pindi is not employed by any kitchen retailer. He has no commission arrangement, no referral agreement, and no allegiance to any brand. When he surveys your kitchen and reviews your plans, his only question is: does this work for you? He installs kitchens from Wren, Howdens, Magnet, IKEA, Benchmarx, B&amp;Q, Wickes, DIY Kitchens, and premium brands including Häcker, Nobilia, Mereway, Neptune and deVOL. He fits whatever you've bought, to the standard it deserves.
          </p>

          <!-- Our Approach -->
          <h2 class="section-h2" id="our-approach">Our Approach</h2>

          <div class="approach-grid" role="list" aria-label="Our installation principles">

            <div class="approach-card" role="listitem">
              <!-- Icon: clipboard / survey -->
              <div class="approach-icon" aria-hidden="true">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/>
                  <rect x="9" y="3" width="6" height="4" rx="1" ry="1"/>
                  <line x1="9" y1="12" x2="15" y2="12"/>
                  <line x1="9" y1="16" x2="13" y2="16"/>
                </svg>
              </div>
              <h3 class="approach-title">Survey Before Every Job</h3>
              <p class="approach-body">No exceptions. No quote without a site visit. The survey is where problems are found before they become expensive — and where the fixed price is set.</p>
            </div>

            <div class="approach-card" role="listitem">
              <!-- Icon: price tag / fixed cost -->
              <div class="approach-icon" aria-hidden="true">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/>
                  <line x1="7" y1="7" x2="7.01" y2="7"/>
                </svg>
              </div>
              <h3 class="approach-title">Fixed Price Guaranteed</h3>
              <p class="approach-body">The quote does not change unless you change the scope. You know the number before we start, and that number does not move.</p>
            </div>

            <div class="approach-card" role="listitem">
              <!-- Icon: person / single point of contact -->
              <div class="approach-icon" aria-hidden="true">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                  <circle cx="12" cy="7" r="4"/>
                </svg>
              </div>
              <h3 class="approach-title">You Deal With Pindi</h3>
              <p class="approach-body">Not a call centre, not a subcontracted team booked at the last minute. Pindi surveys, Pindi installs, Pindi signs off.</p>
            </div>

            <div class="approach-card" role="listitem">
              <!-- Icon: map pin / local -->
              <div class="approach-icon" aria-hidden="true">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
              </div>
              <h3 class="approach-title">Local and Accountable</h3>
              <p class="approach-body">Based in Coundon, CV6. This is the community we live and work in. Our reputation is built one kitchen at a time on these streets.</p>
            </div>

          </div>

          <!-- What We Install -->
          <h2 class="section-h2" id="what-we-install">What We Install</h2>
          <p class="body-copy">
            Install My Kitchen fits kitchens sourced from across the full market — from high-street retail to trade-only suppliers and premium luxury manufacturers. Pindi has hands-on experience with every system listed below.
          </p>

          <div class="install-grid">

            <div class="install-category">
              <h3 class="install-cat-title">
                <span class="install-cat-icon" aria-hidden="true">
                  <!-- storefront icon -->
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                    <polyline points="9 22 9 12 15 12 15 22"/>
                  </svg>
                </span>
                Standard Retail
              </h3>
              <p class="install-brands">Wren, Howdens, Magnet, Wickes, B&amp;Q, Benchmarx, DIY Kitchens, Symphony, Masterclass, Kutchenhaus</p>
            </div>

            <div class="install-category">
              <h3 class="install-cat-title">
                <span class="install-cat-icon" aria-hidden="true">
                  <!-- tools / trade icon -->
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
                  </svg>
                </span>
                Trade Supply
              </h3>
              <p class="install-brands">Howdens Trade, Magnet Trade, Benchmarx</p>
            </div>

            <div class="install-category install-category--premium">
              <h3 class="install-cat-title">
                <span class="install-cat-icon" aria-hidden="true">
                  <!-- star / premium icon -->
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                  </svg>
                </span>
                Premium &amp; Luxury
              </h3>
              <p class="install-brands">Häcker, Nobilia, Rotpunkt, Pronorm, Mereway, Tom Howley, Harvey Jones, Neptune, deVOL, Smallbone, John Lewis of Hungerford</p>
            </div>

          </div>

          <!-- Why 30 Years Matters -->
          <h2 class="section-h2" id="why-30-years-matters">Why 30 Years Matters</h2>

          <p class="body-copy">
            Thirty years of kitchen installation is not a credential to put on a brochure. It is a body of practical knowledge that only exists because it was earned problem by problem, room by room, over a very long time.
          </p>

          <p class="body-copy">
            It means having fitted every type of floor condition — from poured concrete to suspended timber to the notoriously irregular screeded floors that appear throughout Coventry's post-war housing stock. It means knowing, before you open a box, which conditions will slow you down and why.
          </p>

          <p class="body-copy">
            It means knowing how to scribe an in-frame door to a 30mm out-of-plumb chimney breast without the gap showing. It means knowing that IKEA corner carousels must be positioned before the adjacent carcass is fixed — because after that, there is no access. It means understanding that Häcker's tolerance of 0.5mm gap consistency is not a marketing claim but a genuine demand on the installation process: it requires a level base frame, consistent shimming, and hinge adjustment that takes time.
          </p>

          <p class="body-copy">
            It also means having fitted every major retailer's unit system enough times to know their individual quirks — the way a Wren carcass handles load differently to a Nobilia box, the way Benchmarx fixings differ from Howdens, the way deVOL's handmade frames require a fundamentally different approach to a flatpack run. These are not things you read in a fitting guide. They are things you learn by doing them, repeatedly, over decades.
          </p>

          <div class="experience-callout" role="note">
            <p class="experience-callout-text">
              "The problems that derail a kitchen installation are almost always problems that were visible at survey stage — if you knew what to look for. After 30 years, I know what to look for."
            </p>
            <p class="experience-callout-attr">— Pindi Sahota, Founder, Install My Kitchen</p>
          </div>

          <!-- Areas -->
          <h2 class="section-h2" id="areas-covered">Areas Covered</h2>
          <p class="body-copy">
            Install My Kitchen is based in Coundon, Coventry and covers Coventry city, the wider Warwickshire area, and parts of Solihull and the West Midlands. Regular working areas include:
          </p>

          <div class="areas-grid" role="list" aria-label="Areas covered">
            {[
              { name: "Coventry", slug: "coventry" },
              { name: "Rugby", slug: "rugby" },
              { name: "Nuneaton", slug: "nuneaton" },
              { name: "Leamington Spa", slug: "leamington-spa" },
              { name: "Kenilworth", slug: "kenilworth" },
              { name: "Warwick", slug: "warwick" },
              { name: "Solihull", slug: "solihull" },
              { name: "Stratford-upon-Avon", slug: "stratford-upon-avon" },
            ].map((area) => (
              <a href={`/areas/${area.slug}/`} class="area-pill" role="listitem">{area.name}</a>
            ))}
          </div>

          <p class="body-copy mt-4">
            <a href="/areas/" style="color: var(--teal); font-weight: 600;">View all areas covered &rarr;</a>
          </p>

          <!-- FAQ -->
          <h2 class="section-h2" id="faq">Frequently Asked Questions</h2>
          <FAQ items={faqItems} schemaId="about-faq-schema" />

          <!-- Internal links -->
          <div style="margin-top: 2.5rem;">
            <InternalLinks links={internalLinks} heading="Explore Install My Kitchen" />
          </div>

        </div>

        <!-- ── Sidebar ── -->
        <aside class="content-sidebar">

          <!-- Contact card -->
          <div class="sidebar-card">
            <h3 class="sidebar-heading">Book a Survey With Pindi</h3>
            <p class="sidebar-body">Pindi conducts every survey personally. Call directly or use the online form — appointments typically within 1–2 weeks.</p>
            <address class="sidebar-nap not-italic">
              <p>
                <strong>Install My Kitchen</strong><br />
                242 Hollyfast Road, Coundon<br />
                Coventry, CV6 2AH
              </p>
              <p>
                <a href="tel:07399651836" class="sidebar-link">07399 651836</a>
              </p>
              <p>
                <a href="mailto:info@installmykitchen.co.uk" class="sidebar-link">info@installmykitchen.co.uk</a>
              </p>
            </address>
            <a href="/survey/" class="btn-primary sidebar-btn">Book a Survey — £195</a>
          </div>

          <!-- Credentials card -->
          <div class="sidebar-card">
            <h3 class="sidebar-heading">At a Glance</h3>
            <ul class="cred-list" role="list">
              <li class="cred-item" role="listitem">
                <span class="cred-icon" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                </span>
                30 years kitchen installation experience
              </li>
              <li class="cred-item" role="listitem">
                <span class="cred-icon" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                </span>
                BIKBBI recognised
              </li>
              <li class="cred-item" role="listitem">
                <span class="cred-icon" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                </span>
                Independent — no retailer affiliation
              </li>
              <li class="cred-item" role="listitem">
                <span class="cred-icon" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                </span>
                Fits all major retailers &amp; premium brands
              </li>
              <li class="cred-item" role="listitem">
                <span class="cred-icon" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                </span>
                Based in Coundon, Coventry CV6
              </li>
              <li class="cred-item" role="listitem">
                <span class="cred-icon" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                </span>
                Fixed-price, survey-first on every job
              </li>
            </ul>
          </div>

          <!-- Explore card -->
          <div class="sidebar-card sidebar-links-card">
            <h3 class="sidebar-heading">Explore</h3>
            <ul class="sidebar-nav" role="list">
              <li><a href="/services/" class="sidebar-nav-link">Our Services</a></li>
              <li><a href="/retailers/" class="sidebar-nav-link">Retailers We Fit</a></li>
              <li><a href="/areas/" class="sidebar-nav-link">Areas We Cover</a></li>
              <li><a href="/costs/" class="sidebar-nav-link">Cost Guide</a></li>
              <li><a href="/contact/" class="sidebar-nav-link">Contact Us</a></li>
            </ul>
          </div>

        </aside>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════ CTA ════════════════════════ -->
  <CTA
    dark={true}
    heading="Ready to Book Your Survey?"
    subtext="Pindi visits your home, checks the room, reviews your plans, and gives you a clear fixed price. The £195 survey fee is credited back against your installation on booking."
    primaryLabel="Book a Survey — £195"
    primaryHref="/survey/"
    secondaryLabel="Call 07399 651836"
    secondaryHref="tel:07399651836"
  />

  <!-- Footer -->
  <Footer slot="footer" />
  <StickyMobileCTA slot="sticky-cta" />
</Base>

<style>
  /* ── Hero ─────────────────────────────────────────────────── */
  .about-hero {
    background: var(--hero-gradient);
    padding: 3rem 0 3.5rem;
  }

  .hero-h1 {
    font-size: clamp(1.6rem, 3.2vw, 2.6rem);
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.02em;
    margin-top: 0.75rem;
    margin-bottom: 1.5rem;
    line-height: 1.2;
    max-width: 760px;
  }

  .hero-answer {
    max-width: 720px;
  }

  /* ── Content layout ─────────────────────────────────────── */
  .content-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 1024px) {
    .content-grid {
      grid-template-columns: 1fr 340px;
      align-items: start;
    }
  }

  /* ── Typography ─────────────────────────────────────────── */
  .section-h2 {
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--charcoal);
    margin-top: 2.25rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--teal);
    display: inline-block;
  }

  .body-copy {
    font-size: 0.9375rem;
    line-height: 1.78;
    color: var(--text-soft);
    margin-bottom: 1.125rem;
  }

  .mt-4 {
    margin-top: 1rem;
  }

  /* ── Our Approach grid ──────────────────────────────────── */
  .approach-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  @media (min-width: 640px) {
    .approach-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .approach-card {
    background: var(--bg-light);
    border: 1.5px solid var(--border);
    border-left: 4px solid var(--teal);
    border-radius: 0.625rem;
    padding: 1.25rem 1.375rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .approach-icon {
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 0.5rem;
    background: rgba(15, 118, 110, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--teal);
    flex-shrink: 0;
  }

  .approach-title {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--charcoal);
    margin: 0;
    line-height: 1.3;
  }

  .approach-body {
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--text-soft);
    margin: 0;
  }

  /* ── What We Install ────────────────────────────────────── */
  .install-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  @media (min-width: 640px) {
    .install-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 900px) {
    .install-grid {
      grid-template-columns: 1fr 1fr 1fr;
    }
  }

  .install-category {
    background: var(--bg-light);
    border: 1.5px solid var(--border);
    border-radius: 0.75rem;
    padding: 1.125rem 1.25rem;
  }

