---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import StickyMobileCTA from "../components/StickyMobileCTA.astro";
import SupplierLogos from "../components/SupplierLogos.astro";
import ProcessSteps from "../components/ProcessSteps.astro";
import EnquiryForm from "../components/EnquiryForm.astro";
import FAQ from "../components/FAQ.astro";
import CTA from "../components/CTA.astro";
import TrustStrip from "../components/TrustStrip.astro";
import WhatHappensNext from "../components/WhatHappensNext.astro";

const siteSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "@id": "https://installmykitchen.co.uk/#business",
      "name": "Install My Kitchen",
      "description": "Independent kitchen installation service covering Coventry and Warwickshire. Founded by Pindi Sahota with 30 years of kitchen fitting experience. Survey-first, fixed-price installation for all major retailers.",
      "url": "https://installmykitchen.co.uk",
      "telephone": "+447399651836",
      "email": "info@installmykitchen.co.uk",
      "priceRange": "££",
      "currenciesAccepted": "GBP",
      "paymentAccepted": "Cash, Bank Transfer",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "242 Hollyfast Road",
        "addressLocality": "Coundon",
        "addressRegion": "Coventry",
        "postalCode": "CV6 2AH",
        "addressCountry": "GB"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": "52.4252",
        "longitude": "-1.5371"
      },
      "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "08:00", "closes": "18:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Saturday", "opens": "08:00", "closes": "16:00" }
      ],
      "founder": {
        "@type": "Person",
        "@id": "https://installmykitchen.co.uk/pindi-sahota/",
        "name": "Pindi Sahota",
        "jobTitle": "Kitchen Installation Specialist"
      },
      "areaServed": ["Coventry","Rugby","Nuneaton","Bedworth","Leamington Spa","Kenilworth","Warwick","Solihull","Stratford-upon-Avon","Southam","Atherstone","Hinckley","Balsall Common","Meriden","Earlsdon","Canley","Tile Hill","Allesley","Finham","Stivichall","Coundon","Radford","Binley","Wyken","Walsgrave"],
      "knowsAbout": ["Kitchen Installation","Wren Kitchens","Howdens","Magnet Kitchens","IKEA Kitchen Fitting","German Kitchen Installation","In-Frame Kitchen Installation","Shaker Kitchen Fitting","Worktop Fitting","Kitchen Survey Coventry"],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Kitchen Installation Services",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Kitchen Installation Survey", "description": "Pre-installation survey by Pindi Sahota. Fixed-price quote within 24 hours.", "offers": { "@type": "Offer", "price": "195", "priceCurrency": "GBP", "description": "Survey fee credited back against installation balance on booking" } } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Full Kitchen Installation", "description": "Complete kitchen installation including cabinets, worktops, doors, handles, plinths, appliances and snagging.", "areaServed": "Coventry and Warwickshire" } }
        ]
      },
      "sameAs": ["https://installmykitchen.co.uk"]
    },
    {
      "@type": "WebSite",
      "@id": "https://installmykitchen.co.uk/#website",
      "url": "https://installmykitchen.co.uk",
      "name": "Install My Kitchen",
      "description": "Independent kitchen installation across Coventry and Warwickshire",
      "publisher": { "@id": "https://installmykitchen.co.uk/#business" }
    },
    {
      "@type": "Person",
      "@id": "https://installmykitchen.co.uk/pindi-sahota/",
      "name": "Pindi Sahota",
      "jobTitle": "Kitchen Installation Specialist",
      "description": "30 years of kitchen installation experience. Founder of Install My Kitchen. Based in Coventry.",
      "worksFor": { "@id": "https://installmykitchen.co.uk/#business" }
    }
  ]
};

const faqItems = [
  {
    q: "Do you only install kitchens you supply?",
    a: "No — we install kitchens purchased from any retailer, including Wren, Howdens, Magnet, IKEA, Wickes, B&Q, Benchmarx and many more. We are completely independent.",
  },
  {
    q: "What areas do you cover?",
    a: "We cover Coventry and the wider Warwickshire area, including Rugby, Nuneaton, Leamington Spa, Kenilworth, Warwick, Stratford-upon-Avon, Bedworth and surrounding towns.",
  },
  {
    q: "What does the £195 survey fee include?",
    a: "Our pre-installation survey includes a visit to your home to take precise measurements, review your kitchen plan against the actual room, discuss appliance positions, check services, and identify any potential issues before we start. The £195 fee is credited in full against your installation balance when you confirm your booking date.",
  },
  {
    q: "How long does a kitchen installation take?",
    a: "A typical kitchen installation takes between two and five days depending on the size of the kitchen and the scope of work. We will give you a realistic timeline as part of your written quote.",
  },
  {
    q: "Do you handle appliance installation?",
    a: "Yes — we fit integrated and freestanding appliances including ovens, hobs, dishwashers, washing machines and fridges as part of the installation. We will confirm what's included in your quote before work begins.",
  },
  {
    q: "Do I need to arrange my own plumber and electrician?",
    a: "Yes. Due to high demand we recommend you arrange your own qualified electricians, plumbers and gas engineers before the installation date. We handle all the cabinetry, worktops, appliances and fittings.",
  },
];

const areas = [
  { name: "Coventry", slug: "coventry" },
  { name: "Rugby", slug: "rugby" },
  { name: "Nuneaton", slug: "nuneaton" },
  { name: "Leamington Spa", slug: "leamington-spa" },
  { name: "Kenilworth", slug: "kenilworth" },
  { name: "Warwick", slug: "warwick" },
  { name: "Bedworth", slug: "bedworth" },
  { name: "Stratford-upon-Avon", slug: "stratford-upon-avon" },
];
---

<Base
  title="Kitchen Installation Coventry & Warwickshire | Install My Kitchen"
  description="Expert independent kitchen installation across Coventry and Warwickshire. We fit kitchens from Wren, Howdens, IKEA and more. Survey from £195."
  canonical="https://installmykitchen.co.uk/"
  noHero={true}
>
  <!-- Schema -->
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify(siteSchema)} />

  <!-- Header -->
  <Header slot="header" />

  <!-- ═══════════════════════════════════════════════════ HERO ═══ -->
  <section aria-label="Hero" class="hero-split">
    <!-- Left gradient panel -->
    <div class="hero-left">
      <div class="hero-content">
        <p class="hero-eyebrow">Independent Kitchen Installation · Coventry &amp; Warwickshire</p>
        <h1 class="hero-h1">Already Bought Your Kitchen? <span style="color: var(--teal-bright)">We'll Install It.</span></h1>
        <p class="hero-sub">
          Expert independent installation for kitchens purchased from Wren, Howdens, Magnet,
          IKEA, Wickes and more across Coventry and Warwickshire.
        </p>
        <div class="hero-buttons">
          <a href="/survey/" class="btn-primary hero-btn">
            Book a Survey — £195
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12"/>
              <polyline points="12 5 19 12 12 19"/>
            </svg>
          </a>
          <a href="/guides/" class="btn-secondary hero-btn-sec">
            Get an Installation Guide
          </a>
        </div>
        <p style="font-size:0.8rem; color:rgba(255,255,255,0.5); margin-top:1rem;">
          30 years experience · Fixed price guaranteed · All major retailers
        </p>
      </div>
    </div>

    <!-- Right image panel -->
    <div class="hero-right" aria-hidden="true">
      <img
        src="/assets/hero-home.webp"
        alt="Install My Kitchen — professional kitchen installation specialist in Coventry"
        class="hero-img"
        width="1536"
        height="1024"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
      <!-- Logo overlay -->
      <div class="hero-logo-overlay">
        <img src="/assets/logo.png" alt="Install My Kitchen" class="hero-logo-large" width="200" height="auto" loading="eager" />
      </div>
      <!-- Floating survey credit card -->
      <div class="hero-card">
        <div class="hero-card-icon" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 6L9 17l-5-5"/>
          </svg>
        </div>
        <div>
          <p class="hero-card-title">Survey Fee Credited</p>
          <p class="hero-card-desc">Survey Fee £195 — Credited Back on Booking</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ BENEFIT STRIP ═══ -->
  <section class="section-sm" style="background: var(--bg-light);" aria-label="Key benefits">
    <div class="container">
      <ul class="benefit-strip" role="list">
        <li class="benefit-item" role="listitem">
          <span class="benefit-icon" aria-hidden="true">
            <!-- Checkmark in circle -->
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="9 12 11 14 15 10"/></svg>
          </span>
          <span class="benefit-label">Independent &amp; Retailer Neutral</span>
        </li>
        <li class="benefit-item" role="listitem">
          <span class="benefit-icon" aria-hidden="true">
            <!-- Clock -->
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </span>
          <span class="benefit-label">Fast Slots Available</span>
        </li>
        <li class="benefit-item" role="listitem">
          <span class="benefit-icon" aria-hidden="true">
            <!-- Clipboard -->
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/><line x1="9" y1="12" x2="15" y2="12"/><line x1="9" y1="16" x2="13" y2="16"/></svg>
          </span>
          <span class="benefit-label">Survey Before Installation</span>
        </li>
        <li class="benefit-item" role="listitem">
          <span class="benefit-icon" aria-hidden="true">
            <!-- Star -->
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </span>
          <span class="benefit-label">Experienced Specialists</span>
        </li>
        <li class="benefit-item" role="listitem">
          <span class="benefit-icon" aria-hidden="true">
            <!-- Map pin -->
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </span>
          <span class="benefit-label">Coventry &amp; Warwickshire</span>
        </li>
      </ul>
    </div>
  </section>

  <!-- ═════════════════════════════════════ SUPPLIER LOGOS ════════ -->
  <SupplierLogos heading="We Install Kitchens From All Major Suppliers" />

  <!-- ══════════════════════════════════ PINDI SAHOTA ══════════ -->
  <section style="padding: 60px 0; background: var(--bg-light);">
    <div class="container">
      <div class="pindi-grid">
        <div>
          <p style="color: var(--teal); font-weight: 600; font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.75rem;">Your Installer</p>
          <h2 style="font-size: clamp(1.75rem, 3vw, 2.5rem); font-weight: 800; color: var(--navy); margin-bottom: 1.25rem; line-height: 1.2;">Pindi Sahota — 30 Years on the Tools</h2>
          <p style="color: var(--text-soft); line-height: 1.75; margin-bottom: 1rem; font-size: 1.0625rem;">Pindi Sahota founded Install My Kitchen after three decades fitting kitchens across Coventry and Warwickshire. He surveys every project personally, provides a fixed price, and doesn't leave until the job is right.</p>
          <p style="color: var(--text-soft); line-height: 1.75; margin-bottom: 1.5rem;">Every survey is conducted by Pindi himself — not a salesperson, not a subcontractor. He assesses your room, checks your plans against reality, and provides a fixed installation quote within 24 hours. You deal with Pindi from survey to sign-off.</p>
          <div style="display: flex; flex-wrap: wrap; gap: 1rem; margin-bottom: 1.5rem;">
            <div style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.875rem; font-weight: 600; color: var(--charcoal);">
              <span style="width: 8px; height: 8px; border-radius: 50%; background: var(--teal); display: inline-block;"></span>
              30 years experience
            </div>
            <div style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.875rem; font-weight: 600; color: var(--charcoal);">
              <span style="width: 8px; height: 8px; border-radius: 50%; background: var(--teal); display: inline-block;"></span>
              Personal survey every time
            </div>
            <div style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.875rem; font-weight: 600; color: var(--charcoal);">
              <span style="width: 8px; height: 8px; border-radius: 50%; background: var(--teal); display: inline-block;"></span>
              Fixed price guaranteed
            </div>
            <div style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.875rem; font-weight: 600; color: var(--charcoal);">
              <span style="width: 8px; height: 8px; border-radius: 50%; background: var(--teal); display: inline-block;"></span>
              All major retailers
            </div>
          </div>
          <a href="/pindi-sahota/" style="display: inline-flex; align-items: center; gap: 0.5rem; color: var(--teal); font-weight: 600; font-size: 0.9375rem;">
            Meet Pindi →
          </a>
        </div>
        <div class="card" style="padding: 2rem; border-left: 4px solid var(--teal);">
          <p style="font-size: 1.125rem; color: var(--charcoal); line-height: 1.7; font-style: italic; margin-bottom: 1.25rem;">"The thing that separates a good kitchen installation from an average one is almost always in the detail — the consistency of door gaps, the tightness of a worktop joint, the alignment of a plinth on an uneven floor. These are the details I have spent 30 years refining."</p>
          <div style="display: flex; align-items: center; gap: 0.75rem;">
            <div style="width: 48px; height: 48px; border-radius: 50%; background: var(--teal); display: flex; align-items: center; justify-content: center;">
              <span style="color: white; font-weight: 800; font-size: 1.125rem;">P</span>
            </div>
            <div>
              <div style="font-weight: 700; color: var(--navy);">Pindi Sahota</div>
              <div style="font-size: 0.8125rem; color: var(--text-soft);">Founder, Install My Kitchen</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════ WHY CHOOSE US ══════════ -->
  <section class="section" style="background: #fff;" aria-labelledby="why-choose-heading">
    <div class="container">
      <h2 id="why-choose-heading" class="text-center text-2xl md:text-3xl font-bold mb-3" style="color: var(--charcoal);">
        Why Choose Install My Kitchen
      </h2>
      <p class="text-center text-sm mb-10 max-w-xl mx-auto" style="color: var(--text-soft);">
        Four commitments that set us apart from retailer-tied installation teams.
      </p>
      <ul class="trust-pillars" role="list">
        <li class="trust-card" role="listitem">
          <span class="trust-icon" aria-hidden="true">
            <!-- Clipboard check -->
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/><polyline points="9 12 11 14 15 10"/></svg>
          </span>
          <strong class="trust-title">Survey Before Every Installation</strong>
          <p class="trust-desc">We never quote without seeing your room. Our £195 survey is credited back in full when you confirm your booking date.</p>
        </li>
        <li class="trust-card" role="listitem">
          <span class="trust-icon" aria-hidden="true">
            <!-- Shield with checkmark -->
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
          </span>
          <strong class="trust-title">Fixed Price Guaranteed</strong>
          <p class="trust-desc">Your quote doesn't change. No hidden extras, no surprises on completion day. What we quote is what you pay.</p>
        </li>
        <li class="trust-card" role="listitem">
          <span class="trust-icon" aria-hidden="true">
            <!-- Grid / retailers -->
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
          </span>
          <strong class="trust-title">All Major Retailers</strong>
          <p class="trust-desc">Wren, Howdens, Magnet, IKEA, Wickes, B&amp;Q, Benchmarx and more. If you've bought it, we'll fit it — no exclusions.</p>
        </li>
        <li class="trust-card" role="listitem">
          <span class="trust-icon" aria-hidden="true">
            <!-- Map pin -->
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </span>
          <strong class="trust-title">Coventry &amp; Warwickshire Based</strong>
          <p class="trust-desc">Local, independent, and accountable. Based in Coundon, Coventry — serving the whole region, not parachuted in from elsewhere.</p>
        </li>
      </ul>
    </div>
  </section>

  <!-- ══════════════════════════════════════ "A BETTER WAY" ══════ -->
  <section class="section" style="background: var(--bg-light);" aria-labelledby="better-way-heading">
    <div class="container">
      <div class="split-grid">
        <!-- Left: copy -->
        <div class="split-left fade-up">
          <h2 id="better-way-heading" class="text-2xl md:text-3xl lg:text-4xl font-bold mb-6" style="color: var(--charcoal);">
            A Better Way to Get Your Kitchen Installed
          </h2>
          <ul class="better-list" role="list">
            <li class="better-item" role="listitem">
              <span class="better-tick" aria-hidden="true">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              <span>
                <strong>Truly independent</strong> — we're not employed by any retailer, so you get honest advice and quality work that's in your interest, not theirs.
              </span>
            </li>
            <li class="better-item" role="listitem">
              <span class="better-tick" aria-hidden="true">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              <span>
                <strong>Survey protects you</strong> — we visit before we quote, checking your room against the plan so there are no surprises on installation day.
              </span>
            </li>
            <li class="better-item" role="listitem">
              <span class="better-tick" aria-hidden="true">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              <span>
                <strong>End-to-end fitting</strong> — we handle everything from cabinet assembly to worktop fitting, appliance integration, doors, handles, and final snagging.
              </span>
            </li>
          </ul>
          <a href="/survey/" class="btn-primary mt-8 inline-flex items-center gap-2">
            Book Your Survey
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12"/>
              <polyline points="12 5 19 12 12 19"/>
            </svg>
          </a>
        </div>

        <!-- Right: enquiry form -->
        <div class="split-right fade-up">
          <EnquiryForm formTitle="Get a Free Quote" />
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════ URGENCY BAND ══════════ -->
  <section class="urgency-band" aria-label="Installation slots filling fast">
    <div class="container urgency-inner">
      <p class="urgency-text">
        Installation Slots Are Filling Fast —
        <span class="urgency-highlight">Coventry &amp; Warwickshire's Premier Independent Kitchen Fitter</span>
      </p>
      <a href="/contact/" class="btn-white urgency-btn">
        Check Available Dates →
      </a>
    </div>
  </section>

  <!-- ═══════════════════════════════════════ PROCESS STEPS ══════ -->
  <ProcessSteps />

  <!-- ══════════════════════════════════════ ABOUT SECTION ══════ -->
  <section class="section" style="background: #fff;" aria-labelledby="about-heading">
    <div class="container">
      <div class="about-grid">
        <div class="about-copy fade-up">
          <p class="section-eyebrow">About Install My Kitchen</p>
          <h2 id="about-heading" class="text-2xl md:text-3xl lg:text-4xl font-bold mb-6" style="color: var(--charcoal);">
            Coventry's Independent Kitchen Installation Specialist
          </h2>
          <p class="about-para">
            Install My Kitchen is an independent kitchen installation service based in Coundon, Coventry. We work for homeowners — not retailers — fitting kitchens purchased from any major supplier across Coventry and Warwickshire. As an independent specialist, we have no commercial tie to any showroom or manufacturer, which means our only focus is the quality of your installation and the experience you have along the way.
          </p>
          <p class="about-para">
            Every installation begins with a pre-visit survey. We take precise measurements, review your kitchen plan against the actual room, and identify any potential issues before a single cabinet is unpacked. It takes more time upfront, but it's the difference between an installation that goes smoothly and one that doesn't. We take the details seriously — because it's your home, and the finish matters.
          </p>
          <div class="about-stats" role="list" aria-label="Key service commitments">
            <div class="about-stat" role="listitem">
              <span class="about-stat-label">Survey Before Every Job</span>
            </div>
            <div class="about-stat" role="listitem">
              <span class="about-stat-label">Fixed-Price Quotes</span>
            </div>
            <div class="about-stat" role="listitem">
              <span class="about-stat-label">All Major Retailers</span>
            </div>
            <div class="about-stat" role="listitem">
              <span class="about-stat-label">Coventry &amp; Warwickshire</span>
            </div>
          </div>
          <a href="/survey/" class="btn-primary mt-8 inline-flex items-center gap-2">
            Book Your Survey
