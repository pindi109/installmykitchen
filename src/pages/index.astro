    display: flex; align-items: center; gap: 1rem;
    color: var(--text-soft); font-size: 0.8125rem;
  }
  .est-divider::before, .est-divider::after {
    content: ''; flex: 1; height: 1px; background: var(--border);
  }

  .last-updated-bar {
    background: var(--bg-light);
    border-top: 1px solid var(--border);
    padding: 0.625rem 0;
    text-align: center;
  }
  .last-updated-bar p {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    color: var(--text-soft);
    margin: 0;
  }
  .last-updated-bar svg {
    color: var(--teal);
    flex-shrink: 0;
  }
</style>

<script>
  // ── Before/After Slider ──────────────────────────────────────────
  (function () {
    const wrap = document.getElementById('ba-slider');
    const afterWrap = wrap?.querySelector('.ba-after-wrap');
    const divider  = document.getElementById('ba-divider');
    const afterImg = wrap?.querySelector('.ba-after');
    if (!wrap || !afterWrap || !divider) return;

    let dragging = false;

    function setPos(x) {
      const rect = wrap.getBoundingClientRect();
      let pct = Math.min(Math.max((x - rect.left) / rect.width, 0.02), 0.98);
      afterWrap.style.width = (pct * 100) + '%';
      divider.style.left    = (pct * 100) + '%';
      // Keep after image full-width inside clipped container
      if (afterImg) afterImg.style.width = (1 / pct * 100) + '%';
    }

    wrap.addEventListener('mousedown',  e => { dragging = true; setPos(e.clientX); });
    window.addEventListener('mouseup',  () => { dragging = false; });
    window.addEventListener('mousemove',e => { if (dragging) setPos(e.clientX); });
    wrap.addEventListener('touchstart', e => { dragging = true; setPos(e.touches[0].clientX); }, { passive: true });
    window.addEventListener('touchend', () => { dragging = false; });
    window.addEventListener('touchmove',e => { if (dragging) setPos(e.touches[0].clientX); }, { passive: true });
  })();

  // ── AI Plan Upload ──────────────────────────────────────────────
  (function () {
    const fileInput  = document.getElementById('est-file');
    const label      = document.getElementById('est-upload-label');
    const uploadText = document.getElementById('est-upload-text');
    const aiResult   = document.getElementById('est-ai-result');
    const aiCount    = document.getElementById('est-ai-count');
    const aiNotes    = document.getElementById('est-ai-notes');
    const aiError    = document.getElementById('est-ai-error');
    if (!fileInput) return;

    function resizeImage(file, maxPx = 1200) {
      return new Promise(resolve => {
        const reader = new FileReader();
        reader.onload = e => {
          const img = new Image();
          img.onload = () => {
            const scale = Math.min(1, maxPx / Math.max(img.width, img.height));
            const canvas = document.createElement('canvas');
            canvas.width  = Math.round(img.width  * scale);
            canvas.height = Math.round(img.height * scale);
            canvas.getContext('2d').drawImage(img, 0, 0, canvas.width, canvas.height);
            // Strip base64 prefix → data only
            resolve(canvas.toDataURL('image/jpeg', 0.85).split(',')[1]);
          };
          img.src = e.target.result;
        };
        reader.readAsDataURL(file);
      });
    }

    fileInput.addEventListener('change', async () => {
      const file = fileInput.files[0];
      if (!file) return;

      // Reset UI
      aiResult.style.display = 'none';
      aiError.style.display  = 'none';
      label.classList.add('uploading');
      uploadText.textContent = 'Analysing your kitchen plan…';

      try {
        const base64 = await resizeImage(file);

        const res = await fetch('/.netlify/functions/count-units', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ image: base64, mediaType: 'image/jpeg' }),
        });

        const data = await res.json();

        if (!res.ok || data.error) throw new Error(data.error || 'Analysis failed');
        if (data.units === 0) throw new Error(data.notes || 'Could not count units — try a clearer image');

        // Show result
        aiCount.textContent = `AI counted ${data.units} units → ${data.size.charAt(0).toUpperCase() + data.size.slice(1)} kitchen (${data.confidence} confidence)`;
        aiNotes.textContent = data.notes;
        aiResult.style.display = 'flex';
        uploadText.textContent = file.name;
        label.classList.remove('uploading');

        // Auto-select the size button
        document.getElementById('est-size')?.querySelectorAll('.est-btn').forEach(btn => {
          btn.classList.toggle('est-btn-active', btn.dataset.size === data.size);
        });

        // Trigger price update by dispatching click on the matched button
        const matched = document.querySelector(`#est-size [data-size="${data.size}"]`);
        if (matched) matched.click();

      } catch (err) {
        aiError.textContent  = '⚠ ' + err.message;
        aiError.style.display = 'block';
        label.classList.remove('uploading');
        uploadText.textContent = 'Upload kitchen plan or photo';
      }
    });
  })();

  // ── Instant Price Estimator ─────────────────────────────────────
  (function () {
    const costs = {
      small:  { low: 1800, high: 2800 },
      medium: { low: 2800, high: 4200 },
      large:  { low: 4200, high: 7500 },
    };

    let size = 'small', retailer = 1.0, extras = 0;

    function fmt(n) { return '£' + Math.round(n).toLocaleString('en-GB'); }

    function update() {
      const base = costs[size];
      const low  = Math.round(base.low  * retailer) + extras;
      const high = Math.round(base.high * retailer) + Math.round(extras * 1.5);
      const el = document.getElementById('est-range');
      if (el) el.textContent = fmt(low) + ' – ' + fmt(high);
    }

    // Size buttons
    document.getElementById('est-size')?.querySelectorAll('.est-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.getElementById('est-size').querySelectorAll('.est-btn').forEach(b => b.classList.remove('est-btn-active'));
        btn.classList.add('est-btn-active');
        size = btn.dataset.size;
        update();
      });
    });

    // Retailer buttons
    document.getElementById('est-retailer')?.querySelectorAll('.est-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.getElementById('est-retailer').querySelectorAll('.est-btn').forEach(b => b.classList.remove('est-btn-active'));
        btn.classList.add('est-btn-active');
        retailer = parseFloat(btn.dataset.retailer);
        update();
      });
    });

    // Extras checkboxes
    document.getElementById('est-extras')?.querySelectorAll('input').forEach(cb => {
      cb.addEventListener('change', () => {
        extras = 0;
        document.getElementById('est-extras').querySelectorAll('input:checked').forEach(c => {
          extras += parseInt(c.value);
        });
        update();
      });
    });

    update();
  })();
</script>
