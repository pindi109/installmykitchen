  .est-upload-sub { font-size: 0.8125rem; color: var(--text-soft); }
  .est-ai-result {
    display: flex; align-items: flex-start; gap: 0.875rem;
    background: rgba(15,118,110,0.06); border: 1.5px solid var(--teal);
    border-radius: 0.875rem; padding: 1rem 1.25rem;
  }
  .est-ai-icon { font-size: 1.25rem; color: var(--teal); flex-shrink: 0; }
  .est-ai-count { font-weight: 700; color: var(--navy); margin: 0 0 0.2rem; }
  .est-ai-notes { font-size: 0.8125rem; color: var(--text-soft); margin: 0; }
  .est-ai-error {
    background: rgba(192,57,43,0.06); border: 1.5px solid #c0392b;
    border-radius: 0.875rem; padding: 0.875rem 1.125rem;
    font-size: 0.875rem; color: #c0392b;
  }
