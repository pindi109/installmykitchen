---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import StickyMobileCTA from "../../components/StickyMobileCTA.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import AnswerBlock from "../../components/AnswerBlock.astro";
import FAQ from "../../components/FAQ.astro";
import SupplierLogos from "../../components/SupplierLogos.astro";
import InternalLinks from "../../components/InternalLinks.astro";
import CTA from "../../components/CTA.astro";

import retailersData from "../../data/retailers.json";
import locationsData from "../../data/locations.json";
import faqsData from "../../data/faqs.json";

const PRIORITY_LOCATION_SLUGS = [
  "coventry",
  "canley",
  "tile-hill",
  "earlsdon",
  "allesley",
  "rugby",
  "nuneaton",
  "bedworth",
  "leamington-spa",
  "kenilworth",
  "warwick",
  "solihull",
  "stratford-upon-avon",
  "southam",
  "hinckley",
  "reading",
  "bracknell",
  "slough",
  "maidenhead",
  "windsor",
  "wokingham",
  "newbury",
  "ascot",
];

export function getStaticPaths() {
  const PRIORITY_LOCATION_SLUGS = [
    "coventry", "canley", "tile-hill", "earlsdon", "allesley",
    "binley", "wyken", "walsgrave", "finham", "stivichall",
    "coundon", "radford", "rugby", "nuneaton", "bedworth",
    "hinckley", "leamington-spa", "kenilworth", "warwick", "balsall-common",
    "meriden", "solihull", "stratford-upon-avon", "southam", "atherstone",
    "reading", "bracknell", "slough", "maidenhead", "windsor",
    "wokingham", "newbury", "ascot",
  ];

  const priorityLocations = PRIORITY_LOCATION_SLUGS
    .map((slug) => locationsData.find((l) => l.slug === slug))
    .filter(Boolean) as typeof locationsData;

  const paths: { params: { brand: string; location: string }; props: { retailer: typeof retailersData[0]; location: typeof locationsData[0]; retailerIndex: number; locationIndex: number } }[] = [];

  retailersData.forEach((retailer, retailerIndex) => {
    priorityLocations.forEach((location, locationIndex) => {
      paths.push({
        params: { brand: retailer.slug, location: location.slug },
        props: { retailer, location, retailerIndex, locationIndex },
      });
    });
  });

  return paths;
}

const { retailer, location, retailerIndex, locationIndex } = Astro.props;
const { displayName, slug: brandSlug, description: retailerDescription, installNote } = retailer;
const { name: locationName, slug: locationSlug, county, description: locationDescription, nearby } = location;

const canonical = `https://installmykitchen.co.uk/installer/${brandSlug}-${locationSlug}/`;

// Title ≤60 chars
const rawTitle = `${displayName} Kitchen Installer in ${locationName} | Install My Kitchen`;
const title = rawTitle.length <= 60
  ? rawTitle
  : `${displayName} Installer ${locationName} | Install My Kitchen`;

// Meta 140-160 chars
const metaDescription = `Independent ${displayName} kitchen installation in ${locationName}, ${county}. Expert fitters, not affiliated with ${displayName}. Free survey available — fixed-price quotes guaranteed.`;

// Brand-specific image set — falls back to shared process images
const brandImgMap: Record<string, { overview: string; process: string; detail: string; finished: string }> = {
  wren:        { overview: "/assets/brand/wren/wren-kitchen-overview.webp",    process: "/assets/brand/wren/wren-installation-progress.webp", detail: "/assets/brand/wren/wren-handleless-doors.webp",    finished: "/assets/brand/wren/wren-finished-result.webp"    },
  howdens:     { overview: "/assets/brand/howdens/howdens-kitchen-overview.webp", process: "/assets/brand/howdens/howdens-rigid-units.webp",       detail: "/assets/brand/howdens/howdens-shaker-detail.webp",   finished: "/assets/brand/howdens/howdens-finished-result.webp" },
  ikea:        { overview: "/assets/brand/ikea/ikea-kitchen-overview.webp",    process: "/assets/brand/ikea/ikea-flatpack-assembly.webp",       detail: "/assets/brand/ikea/ikea-door-detail.webp",          finished: "/assets/brand/ikea/ikea-finished-result.webp"    },
  magnet:      { overview: "/assets/brand/magnet/magnet-kitchen-overview.webp",process: "/assets/brand/magnet/magnet-installation.webp",        detail: "/assets/brand/magnet/magnet-door-detail.webp",       finished: "/assets/brand/magnet/magnet-finished-result.webp" },
};
const brandImgs = brandImgMap[brandSlug] ?? {
  overview: "/assets/process/finished-kitchen-neutral.webp",
  process:  "/assets/process/base-units-levelling.webp",
  detail:   "/assets/process/doors-hanging.webp",
  finished: "/assets/process/finished-kitchen-dark.webp",
};

// FAQ — offset by both retailer and location index for variety
const allFaqs = [
  ...faqsData.general,
  ...faqsData.retailers,
  ...faqsData.costs,
  ...faqsData.survey,
];
const faqOffset = (retailerIndex * 3 + locationIndex * 2) % allFaqs.length;
const faqItems = [
  allFaqs[faqOffset % allFaqs.length],
  allFaqs[(faqOffset + 1) % allFaqs.length],
  allFaqs[(faqOffset + 2) % allFaqs.length],
  allFaqs[(faqOffset + 3) % allFaqs.length],
];

// Nearby combos — pick 2 nearby areas paired with same retailer
const nearbyAreaSlugs = (nearby as string[]).slice(0, 2);
const nearbyComboLinks = nearbyAreaSlugs.map((nearbySlug) => {
  const nearbyLoc = locationsData.find((l) => l.slug === nearbySlug);
  return nearbyLoc
    ? {
        label: `${displayName} Installation in ${nearbyLoc.name}`,
        href: `/installer/${brandSlug}-${nearbySlug}/`,
        description: `${nearbyLoc.county} — independent ${displayName} fitting`,
      }
    : null;
}).filter(Boolean) as { label: string; href: string; description: string }[];

// Internal links
const internalLinks = [
  {
    label: `${displayName} Kitchen Installation`,
    href: `/retailers/${brandSlug}/`,
    description: `Our full independent fitting service for ${displayName} kitchens`,
  },
  {
    label: `Kitchen Installation in ${locationName}`,
    href: `/areas/${locationSlug}/`,
    description: `Our complete service across ${locationName}`,
  },
  ...nearbyComboLinks,
  {
    label: `${displayName} Kitchen Installation Cost`,
    href: `/cost/${brandSlug}-cost/`,
    description: `What to budget for fitting your ${displayName} kitchen`,
  },
  {
    label: `Kitchen Installation Cost in ${locationName}`,
    href: `/kitchen-cost/${locationSlug}/`,
    description: `Local pricing guide for ${locationName} homeowners`,
  },
  {
    label: `Kitchen Fitter in ${locationName}`,
    href: `/fitter/${locationSlug}/`,
    description: `Find a trusted independent kitchen fitter in ${locationName}`,
  },
  {
    label: `Book Your Survey in ${locationName}`,
    href: `/survey/${locationSlug}/`,
    description: `Home visit, precise measurements, and a fixed-price quote`,
  },
  {
    label: `Book Your Pre-Installation Survey`,
    href: `/survey/`,
    description: `Our £195 survey fee is credited back in full when you proceed`,
  },
  {
    label: `Compare Kitchen Retailers`,
    href: `/comparisons/`,
    description: `Side-by-side comparisons to help you choose the right supplier`,
  },
  {
    label: `About Pindi Sahota — Your Installer`,
    href: `/pindi-sahota/`,
    description: `20+ years of trade experience fitting kitchens across Coventry, Warwickshire & Berkshire`,
  },
  {
    label: `Completed Kitchen Projects`,
    href: `/projects/`,
    description: `Browse real installations carried out by Install My Kitchen`,
  },
].slice(0, 10);

// Breadcrumb JSON-LD is emitted once by the <Breadcrumbs> component below.

// Service JSON-LD
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: `${displayName} Kitchen Installation in ${locationName}`,
  provider: {
    "@type": "LocalBusiness",
    name: "Install My Kitchen",
    url: "https://installmykitchen.co.uk",
    telephone: "07399651836",
    address: {
      "@type": "PostalAddress",
      streetAddress: "242 Hollyfast Road, Coundon",
      addressLocality: "Coventry",
      postalCode: "CV6 2AH",
      addressCountry: "GB",
    },
  },
  areaServed: {
    "@type": "Place",
    name: locationName,
  },
  description: `Independent installation service for ${displayName} kitchens in ${locationName}, ${county}. Install My Kitchen is not affiliated with ${displayName}.`,
  serviceType: "Kitchen Installation",
};
---

<Base
  title={title}
  description={metaDescription}
  canonical={canonical}
>
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

  <Header slot="header" />

  <div class="container py-6">
    <Breadcrumbs
      items={[
        { label: "Areas", href: "/areas/" },
        { label: locationName, href: `/areas/${locationSlug}/` },
        { label: `${displayName} Installation`, href: canonical },
      ]}
    />
  </div>

  <!-- Hero -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-extrabold mb-5 leading-tight" style="color: var(--navy);">
          {displayName} Kitchen Installation in {locationName}
        </h1>
        <AnswerBlock
          answer={`Install My Kitchen provides independent ${displayName} kitchen installation across ${locationName}. We fit kitchens purchased from ${displayName} — we are not affiliated with them.`}
        />
      </div>
    </div>
  </section>

  <!-- Section 1: About this retailer + location -->
  <section class="section">
    <div class="container">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; align-items: start;" class="fade-up">
        <div>
          <h2 class="text-3xl font-bold mb-4" style="color: var(--navy);">
            Fitting {displayName} Kitchens in {locationName}
          </h2>
          <p class="text-lg leading-relaxed mb-4" style="color: var(--text-soft);">
            {retailerDescription}
          </p>
          <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
            {locationDescription}
          </p>
          <p class="leading-relaxed" style="color: var(--text-soft);">
            Install My Kitchen is a fully independent fitting service. We install {displayName} kitchens throughout {locationName} and the wider {county} area, working solely for you rather than the retailer.
          </p>
        </div>
        <figure style="margin: 0;">
          <img src={brandImgs.overview} alt={`${displayName} kitchen installation in ${locationName}`} width="680" height="510" loading="lazy" style="width: 100%; height: auto; border-radius: 0.75rem; display: block;" />
        </figure>
      </div>
      <!-- Full-width installation image -->
      <figure style="margin: 2.5rem 0 0; padding: 0;">
        <img src="/assets/process/base-units-levelling.webp" alt={`Kitchen base units being levelled during ${displayName} installation in ${locationName}`} width="1200" height="506" loading="lazy" style="width: 100%; height: auto; border-radius: 0.75rem; display: block;" />
      </figure>
    </div>
  </section>

  <!-- Section 2: Delivery & logistics -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container">
      <div class="fade-up">
        <h2 class="text-3xl font-bold mb-6" style="color: var(--navy);">
          What to Expect: {displayName} Installation in {locationName}
        </h2>
        <!-- Image + text -->
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; align-items: start; margin-bottom: 2rem;">
          <figure style="margin: 0;">
            <img src="/assets/process/delivery-checking.webp" alt={`${displayName} kitchen delivery being checked before installation in ${locationName}`} width="680" height="510" loading="lazy" style="width: 100%; height: auto; border-radius: 0.75rem; display: block;" />
          </figure>
          <div>
            <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
              {installNote}
            </p>
            <p class="leading-relaxed" style="color: var(--text-soft);">
              Every {displayName} kitchen installation we carry out in {locationName} begins with a pre-installation survey at your home. Our experienced fitters visit to take detailed measurements, check your {displayName} kitchen plan against the actual room, and identify any issues before they become problems on installation day.
            </p>
          </div>
        </div>
        <!-- Full-width worktop image -->
        <figure style="margin: 0 0 2rem; padding: 0;">
          <img src="/assets/process/worktop-fitting.webp" alt={`Worktop being professionally fitted as part of ${displayName} kitchen installation in ${locationName}`} width="1200" height="506" loading="lazy" style="width: 100%; height: auto; border-radius: 0.75rem; display: block;" />
        </figure>
        <!-- Text + image -->
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; align-items: start;">
          <div>
            <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
              On installation day we begin with a full strip-out of your existing kitchen, then carry out a dry fit of all new carcasses to confirm the layout before anything is permanently fixed. Every door, drawer, hinge, and fitting is carefully adjusted.
            </p>
            <p class="leading-relaxed" style="color: var(--text-soft);">
              Our lead fitter carries out a thorough snagging walk-round with you before the job is signed off. Nothing is left unfinished.
            </p>
          </div>
          <figure style="margin: 0;">
            <img src="/assets/process/snagging-inspection.webp" alt={`Snagging inspection on completion of ${displayName} kitchen in ${locationName}`} width="680" height="510" loading="lazy" style="width: 100%; height: auto; border-radius: 0.75rem; display: block;" />
          </figure>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 3: Why independent fitting matters -->
  <section class="section">
    <div class="container">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; align-items: start;" class="fade-up">
        <div>
          <h2 class="text-3xl font-bold mb-4" style="color: var(--navy);">
            Why Choose an Independent Fitter for Your {displayName} Kitchen?
          </h2>
          <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
            Many homeowners in {locationName} choose to separate the supply of their kitchen from the installation, and for good reason. An independent fitter works solely to your brief — no upsell, no retailer margin, just a fixed-price installation based on the actual work.
          </p>
          <p class="leading-relaxed mb-4" style="color: var(--text-soft);">
            Our fitters are experienced across the full {displayName} product range and understand the specific requirements of fitting their cabinetry to a professional standard.
          </p>
          <p class="leading-relaxed" style="color: var(--text-soft);">
            We cover {locationName} as part of our broader service across Coventry, Warwickshire and Berkshire. Our local knowledge of {locationName}'s property types means we can plan and execute your installation efficiently.
          </p>
        </div>
        <div>
          <figure style="margin: 0 0 1.5rem;">
            <img src={brandImgs.finished} alt={`Completed ${displayName} kitchen installation in ${locationName}`} width="680" height="510" loading="lazy" style="width: 100%; height: auto; border-radius: 0.75rem; display: block;" />
          </figure>
          <figure style="margin: 0;">
            <img src="/assets/process/handles-fitting.webp" alt={`Handles being fitted during ${displayName} kitchen installation in ${locationName}`} width="680" height="510" loading="lazy" style="width: 100%; height: auto; border-radius: 0.75rem; display: block;" />
          </figure>
        </div>
      </div>
      <!-- Process gallery strip -->
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-top: 2.5rem;">
        <figure style="margin: 0;">
          <img src="/assets/process/survey-measuring.webp" alt={`Pre-installation survey for ${displayName} kitchen in ${locationName}`} width="420" height="315" loading="lazy" style="width: 100%; height: auto; border-radius: 0.625rem; display: block;" />
          <figcaption style="font-size: 0.75rem; color: var(--text-soft); margin-top: 0.5rem; text-align: center;">1. Survey &amp; Planning</figcaption>
        </figure>
        <figure style="margin: 0;">
          <img src={brandImgs.process} alt={`${displayName} kitchen installation in progress in ${locationName}`} width="420" height="315" loading="lazy" style="width: 100%; height: auto; border-radius: 0.625rem; display: block;" />
          <figcaption style="font-size: 0.75rem; color: var(--text-soft); margin-top: 0.5rem; text-align: center;">2. Installation</figcaption>
        </figure>
        <figure style="margin: 0;">
          <img src={brandImgs.overview} alt={`Finished ${displayName} kitchen in ${locationName}`} width="420" height="315" loading="lazy" style="width: 100%; height: auto; border-radius: 0.625rem; display: block;" />
          <figcaption style="font-size: 0.75rem; color: var(--text-soft); margin-top: 0.5rem; text-align: center;">3. Completed Kitchen</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- Supplier Logos -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container">
      <p class="text-sm mb-6" style="color: var(--text-soft);">
        Install My Kitchen is not affiliated with any kitchen retailer. Logos shown for identification purposes only.
      </p>
      <SupplierLogos />
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container">
      <div class="max-w-3xl fade-up">
        <h2 class="text-3xl font-bold mb-8" style="color: var(--navy);">
          Frequently Asked Questions
        </h2>
        <FAQ items={faqItems} schemaId={`faq-installer-${brandSlug}-${locationSlug}`} />
      </div>
    </div>
  </section>

  <!-- Internal Links -->
  <section class="section" style="background: var(--bg-light);">
    <div class="container fade-up">
      <InternalLinks
        links={internalLinks}
        heading="Related Pages"
      />
    </div>
  </section>

  <!-- CTA -->
  <CTA
    heading={`Book Your ${displayName} Installation Survey in ${locationName}`}
    subtext={`Our £195 pre-installation survey gives you a fixed-price quote for your ${displayName} kitchen in ${locationName}. The fee is credited back in full when you proceed.`}
    primaryLabel="Book Your Survey"
    primaryHref="/survey/"
    secondaryLabel="Call 07399 651836"
    secondaryHref="tel:07399651836"
    dark={true}
  />

  <Footer slot="footer" />
  <StickyMobileCTA slot="sticky-cta" />
</Base>
