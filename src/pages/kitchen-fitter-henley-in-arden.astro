            width="4032"
            height="3024"
            loading="lazy"
            class="gallery-img gallery-img--landscape"
          />
          <figcaption class="gallery-caption">Grey shaker kitchen with black granite worktop — Henley-in-Arden, Warwickshire</figcaption>
        </figure>
        <figure class="gallery-item">
          <img
            src="/assets/kitchen-fitter/kitchen-fitter-henley-in-arden-white-kitchen-marble-island-3024x4032.webp"
