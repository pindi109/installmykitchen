---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import StickyMobileCTA from "../components/StickyMobileCTA.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import AnswerBlock from "../components/AnswerBlock.astro";
import KeyTakeaway from "../components/KeyTakeaway.astro";
import FAQ from "../components/FAQ.astro";
import SupplierLogos from "../components/SupplierLogos.astro";
import InternalLinks from "../components/InternalLinks.astro";
import CTA from "../components/CTA.astro";
import TrustStrip from "../components/TrustStrip.astro";

const title = "Kitchen Fitter Nuneaton | Install My Kitchen — Pindi Sahota";
const metaDescription = "Independent kitchen fitter in Nuneaton. Pindi Sahota provides expert kitchen installation across CV10, CV11 and Bedworth with 30 years experience, fixed-price quotes and a £195 survey credited back.";
const canonical = "https://installmykitchen.co.uk/kitchen-fitter-nuneaton/";

const takeawayPoints = [
  "Pindi Sahota is an independent kitchen fitter based in Coundon, Coventry — covering Nuneaton, Bedworth, CV10, CV11, CV12, and all surrounding postcodes.",
  "30 years of professional kitchen fitting experience across Nuneaton's varied housing stock, from post-war semis to modern new-build estates at Bermuda Park.",
  "Fits kitchens from Wren, Howdens, Magnet, IKEA, Wickes, B&Q, Benchmarx and all other major retailers.",
  "Pre-installation survey at £195, credited back in full when you proceed — fixed-price quote guaranteed.",
];

const faqItems = [
  {
    q: "What does an independent kitchen fitter offer in Nuneaton?",
    a: "An independent kitchen fitter like Pindi Sahota manages every stage of a kitchen installation without being tied to any retailer or franchise. This means he works exclusively for you — visiting your home in Nuneaton to carry out a proper pre-installation survey, building a fixed-price quote based on real conditions in your room, and then carrying out the full installation himself. The service covers stripping out the old kitchen, levelling and preparing the room, fitting all carcasses, doors, drawers, and plinths, cutting and fitting worktops, connecting sinks, taps, and appliances, and finishing with all decorative trim. Many Nuneaton properties — particularly post-war council stock now owner-occupied and 1960s–80s semis — have modest kitchen footprints with tight access corridors. This is exactly the kind of challenge that rewards a survey-first, experienced independent fitter over a retailer scheme operative working to a template.",
  },
  {
    q: "How much does kitchen fitting cost in Nuneaton?",
    a: "Kitchen fitting costs in Nuneaton vary depending on the size of the kitchen, the number of appliances, worktop material and linear metres, floor condition, and whether any preparatory work — levelling, plastering, or modifications to plumbing and electrical routes — is required. As a guide, a standard 10–15 unit kitchen in a typical Nuneaton semi or terrace costs between £1,100 and £2,400 for labour alone. Tight-access kitchens in smaller post-war properties may require additional time, while larger open-plan kitchen-diners or kitchens with islands will sit at the higher end. Pindi provides a fully itemised, fixed-price quote following the pre-installation survey — no estimates, no retrospective charges. For a full breakdown of what drives pricing, see the kitchen fitting costs page.",
  },
  {
    q: "Do you cover CV10 and CV11?",
    a: "Yes. Pindi covers all Nuneaton and Bedworth postcodes including CV10, CV11, and CV12. He regularly works across Nuneaton town centre, Bedworth, Camp Hill, Stockingford, Whitestone, Weddington, Galley Common, and Attleborough. Nuneaton is approximately 10 miles north of Pindi's base in Coundon, Coventry, making it a core part of his regular coverage area. If you would like to confirm coverage for your specific address, call 07399 651836.",
  },
  {
    q: "How long does installation take in Nuneaton?",
    a: "Most standard kitchen installations in Nuneaton take between three and five working days for the fitting work itself. Kitchens in properties with restricted access — tight doorways, narrow hallways, or compact kitchen footprints common in Nuneaton's post-war and 1960s–80s housing — can require additional time for manoeuvring and fitting carcasses carefully without damage to the surrounding room. Larger kitchens, open-plan layouts, or projects requiring trades co-ordination will also take longer. Pindi will give you a realistic programme estimate during the pre-installation survey based on your specific property, so you can plan accordingly.",
  },
  {
    q: "Which kitchen retailers do you fit in Nuneaton?",
    a: "Pindi fits kitchens from all major UK retailers and manufacturers. The brands most commonly installed across Nuneaton and Bedworth include Wren Kitchens, Howdens Joinery, Magnet, IKEA, Wickes, B&Q, and Benchmarx. He also fits mid-range and premium brands including DIY Kitchens, Kutchenhaus, Symphony, Masterclass, Häcker, Nobilia, Mereway, Neptune, and deVOL. Because Pindi is fully independent, you are free to buy from whichever retailer suits your budget and style — he is not employed by or affiliated with any of them. If your brand is not listed, call 07399 651836 to check.",
  },
];

const internalLinks = [
  {
    label: "Book a pre-installation survey",
    href: "/survey/",
    description: "£195 survey credited back in full when you proceed — the essential first step",
  },
  {
    label: "Kitchen fitting costs explained",
    href: "/costs/",
    description: "Fully itemised guide to what affects kitchen installation prices",
  },
  {
    label: "Nuneaton area page",
    href: "/areas/nuneaton/",
    description: "Detailed installation information for Nuneaton, Bedworth, CV10, CV11 and CV12",
  },
  {
    label: "Completed kitchen projects",
    href: "/projects/",
    description: "Real installations by Pindi across Nuneaton, Coventry, and the Midlands",
  },
  {
    label: "About Pindi Sahota",
    href: "/pindi-sahota/",
    description: "Meet the independent kitchen fitter behind Install My Kitchen",
  },
  {
    label: "Howdens kitchen installation",
    href: "/retailers/howdens/",
    description: "Why independent fitting is the right choice for your Howdens kitchen",
  },
  {
    label: "Wren kitchen installation",
    href: "/retailers/wren/",
    description: "Fitting your Wren kitchen independently — what you need to know",
  },
];

// LocalBusiness JSON-LD
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "Install My Kitchen",
