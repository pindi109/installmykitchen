  "@context": "https://schema.org",
  "@type": "Service",
  name: "Kitchen Fitting in Nuneaton",
  provider: {
    "@type": "LocalBusiness",
    name: "Install My Kitchen",
    url: "https://installmykitchen.co.uk",
    telephone: "07399651836",
  },
  areaServed: {
    "@type": "City",
    name: "Nuneaton",
  },
  description:
    "Professional independent kitchen fitting and installation service across Nuneaton, Bedworth, and surrounding Warwickshire areas, covering CV10, CV11 and CV12. Fits kitchens from all major UK retailers including Wren, Howdens, Magnet, IKEA, Wickes and B&Q. Fixed-price quotes following a pre-installation survey.",
  serviceType: "Kitchen Fitting",
  offers: {
    "@type": "Offer",
    name: "Pre-installation Survey",
    price: "195.00",
    priceCurrency: "GBP",
    description: "Pre-installation survey, fully credited back against the fitting quote when you proceed.",
