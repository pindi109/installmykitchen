---
const year = new Date().getFullYear();
---

<footer style="background: #0F172A;" class="text-white">

  <!-- Main 4-column grid -->
  <div class="container py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-8">

      <!-- Col 1: Logo + strapline + NAP + social -->
      <div class="lg:col-span-1">
        <!-- Logo -->
        <a href="/" class="inline-flex items-center gap-2 mb-4" aria-label="Install My Kitchen — home">
          <span class="bg-white rounded-lg p-1 flex-shrink-0 flex items-center justify-center">
            <img src="/assets/logo.png" alt="" class="h-8 w-8 object-contain" width="32" height="32" aria-hidden="true" />
          </span>
          <span class="text-white font-bold text-lg leading-tight">Install My Kitchen</span>
        </a>

        <!-- Strapline -->
        <p class="text-white/60 text-sm leading-relaxed mb-6">
          Buy your kitchen anywhere.<br />
          We'll install it properly.
        </p>

        <!-- NAP -->
        <address class="not-italic text-sm text-white/70 space-y-2">
          <div class="flex items-start gap-2">
            <svg class="mt-0.5 flex-shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            <span>242 Hollyfast Road, Coundon,<br />Coventry, CV6 2AH</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="flex-shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.1a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            <a href="tel:07399651836" class="hover:text-white transition-colors">07399 651836</a>
          </div>
          <div class="flex items-center gap-2">
            <svg class="flex-shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
            <a href="mailto:info@installmykitchen.co.uk" class="hover:text-white transition-colors break-all">info@installmykitchen.co.uk</a>
          </div>
        </address>

      </div>

      <!-- Col 2: Services -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Services</h3>
        <ul class="space-y-2.5 text-sm text-white/70">
          <li><a href="/services/cabinet-installation/" class="hover:text-white transition-colors">Cabinet Installation</a></li>
          <li><a href="/services/worktop-fitting/" class="hover:text-white transition-colors">Worktop Fitting</a></li>
          <li><a href="/services/appliance-installation/" class="hover:text-white transition-colors">Appliance Installation</a></li>
          <li><a href="/services/door-fitting/" class="hover:text-white transition-colors">Door &amp; Drawer Fitting</a></li>
          <li><a href="/services/snagging/" class="hover:text-white transition-colors">Snagging &amp; Adjustments</a></li>
          <li><a href="/survey/" class="hover:text-white transition-colors">Survey &amp; Quote — £195</a></li>
          <li>
            <a href="/services/" class="font-semibold transition-colors" style="color: #14B8A6;">
              All Services →
            </a>
          </li>
        </ul>
      </div>

      <!-- Col 3: Retailer Kitchens -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Retailer Kitchens</h3>
        <ul class="space-y-2.5 text-sm text-white/70 mb-6">
          <li><a href="/retailers/wren/" class="hover:text-white transition-colors">Wren Kitchens</a></li>
          <li><a href="/retailers/howdens/" class="hover:text-white transition-colors">Howdens</a></li>
          <li><a href="/retailers/magnet/" class="hover:text-white transition-colors">Magnet</a></li>
          <li><a href="/retailers/ikea/" class="hover:text-white transition-colors">IKEA</a></li>
          <li><a href="/retailers/wickes/" class="hover:text-white transition-colors">Wickes</a></li>
          <li><a href="/retailers/bq/" class="hover:text-white transition-colors">B&amp;Q</a></li>
          <li><a href="/retailers/benchmarx/" class="hover:text-white transition-colors">Benchmarx</a></li>
          <li><a href="/premium/" class="hover:text-white transition-colors">Premium Kitchens</a></li>
          <li>
            <a href="/retailers/" class="font-semibold transition-colors" style="color: #14B8A6;">
              All Retailers →
            </a>
          </li>
        </ul>

        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Kitchen Styles</h3>
        <ul class="space-y-2.5 text-sm text-white/70">
          <li><a href="/styles/shaker/" class="hover:text-white transition-colors">Shaker Kitchens</a></li>
          <li><a href="/styles/handleless/" class="hover:text-white transition-colors">Handleless Kitchens</a></li>
          <li><a href="/styles/german/" class="hover:text-white transition-colors">German Kitchens</a></li>
          <li><a href="/styles/in-frame/" class="hover:text-white transition-colors">In-Frame Kitchens</a></li>
        </ul>
      </div>

      <!-- Col 4: Areas + Helpful Links -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Areas We Cover</h3>
        <ul class="space-y-2.5 text-sm text-white/70 mb-6">
          <li><a href="/areas/coventry/" class="hover:text-white transition-colors">Coventry</a></li>
          <li><a href="/areas/rugby/" class="hover:text-white transition-colors">Rugby</a></li>
          <li><a href="/areas/nuneaton/" class="hover:text-white transition-colors">Nuneaton</a></li>
          <li><a href="/areas/leamington-spa/" class="hover:text-white transition-colors">Leamington Spa</a></li>
          <li><a href="/areas/kenilworth/" class="hover:text-white transition-colors">Kenilworth</a></li>
          <li><a href="/areas/warwick/" class="hover:text-white transition-colors">Warwick</a></li>
          <li><a href="/areas/solihull/" class="hover:text-white transition-colors">Solihull</a></li>
          <li><a href="/areas/stratford-upon-avon/" class="hover:text-white transition-colors">Stratford-upon-Avon</a></li>
          <li>
            <a href="/areas/" class="font-semibold transition-colors" style="color: #14B8A6;">
              All 25 Areas →
            </a>
          </li>
        </ul>

        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Helpful Links</h3>
        <ul class="space-y-2.5 text-sm text-white/70">
          <li><a href="/costs/" class="hover:text-white transition-colors">Cost Guide</a></li>
          <li><a href="/checklist/" class="hover:text-white transition-colors">Installation Checklist</a></li>
          <li><a href="/guides/" class="hover:text-white transition-colors">Installation Guides</a></li>
          <li><a href="/questions/" class="hover:text-white transition-colors">Questions &amp; Answers</a></li>
          <li><a href="/comparisons/" class="hover:text-white transition-colors">Comparisons</a></li>
          <li><a href="/projects/" class="hover:text-white transition-colors">Kitchen Projects</a></li>
          <li><a href="/about/" class="hover:text-white transition-colors">About Us</a></li>
          <li><a href="/pindi-sahota/" class="hover:text-white transition-colors">Pindi Sahota</a></li>
          <li><a href="/contact/" class="hover:text-white transition-colors">Contact</a></li>
          <li><a href="/html-sitemap/" class="hover:text-white transition-colors">Site Map</a></li>
        </ul>
      </div>

    </div><!-- /.grid -->

    <!-- Affiliation disclaimer -->
    <p class="mt-10 pt-8 border-t border-white/10 text-xs text-white/40 leading-relaxed max-w-3xl">
      Install My Kitchen is an independent kitchen installation service and is not affiliated with, endorsed by, or an official partner of Wren, Howdens, Magnet, IKEA, Wickes, B&Q, Benchmarx or any other retailer. We install kitchens purchased from these suppliers.
    </p>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10" style="background: rgba(0,0,0,0.25);">
    <div class="container py-4 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-white/50">
      <div class="flex flex-wrap items-center justify-center sm:justify-start gap-x-4 gap-y-1">
        <span>&copy; {year} Install My Kitchen. All rights reserved.</span>
        <a href="/privacy/" class="hover:text-white transition-colors">Privacy</a>
        <a href="/terms/" class="hover:text-white transition-colors">Terms</a>
        <a href="/sitemap.xml" class="hover:text-white transition-colors">Sitemap</a>
      </div>
      <a
        href="/survey/"
        class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full font-semibold text-white text-xs transition-all duration-200 hover:-translate-y-0.5 flex-shrink-0"
        style="background: #D4A017;"
      >
        Book a Survey
      </a>
    </div>
  </div>

</footer>
