---
export interface Props {
  formTitle?: string;
  showSurveyOption?: boolean;
}

const {
  formTitle = "Get a Free Quote",
  showSurveyOption = true,
} = Astro.props;
---

<div class="card p-8 md:p-10">
  <h2 class="text-2xl font-bold mb-1" style="color: var(--charcoal);">{formTitle}</h2>
  <p class="text-sm mb-8" style="color: var(--text-soft);">
    Fill in the form below and we'll get back to you within one working day.
  </p>

  <!-- Netlify form — data-netlify="true" enables Netlify Forms processing -->
  <form
    name="enquiry"
    method="POST"
    action="/thank-you/"
    data-netlify="true"
    netlify
    netlify-honeypot="bot-field"
    enctype="multipart/form-data"
    class="space-y-6"
    novalidate
    data-enquiry-form
  >
    <!-- Hidden field required by Netlify -->
    <input type="hidden" name="form-name" value="enquiry" />

    <!-- Honeypot — hidden from real users, bots fill it in -->
    <p class="hidden" aria-hidden="true">
      <label>
        Don't fill this in if you're human:
        <input name="bot-field" tabindex="-1" autocomplete="off" />
      </label>
    </p>

    <!-- Row: Name + Phone -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      <!-- Name -->
      <div class="form-group">
        <label for="field-name" class="form-label">
          Full Name <span class="text-red-500" aria-hidden="true">*</span>
        </label>
        <input
          id="field-name"
          type="text"
          name="name"
          autocomplete="name"
          required
          class="form-input"
          placeholder="e.g. Sarah Johnson"
          aria-required="true"
        />
        <span class="form-error hidden" aria-live="polite">Please enter your name.</span>
      </div>

      <!-- Phone -->
      <div class="form-group">
        <label for="field-phone" class="form-label">
          Phone Number <span class="text-red-500" aria-hidden="true">*</span>
        </label>
        <input
          id="field-phone"
          type="tel"
          name="phone"
          autocomplete="tel"
          required
          class="form-input"
          placeholder="e.g. 07700 900000"
          aria-required="true"
        />
        <span class="form-error hidden" aria-live="polite">Please enter a phone number.</span>
      </div>
    </div>

    <!-- Row: Email + Postcode -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      <!-- Email -->
      <div class="form-group">
        <label for="field-email" class="form-label">
          Email Address <span class="text-red-500" aria-hidden="true">*</span>
        </label>
        <input
          id="field-email"
          type="email"
          name="email"
          autocomplete="email"
          required
          class="form-input"
          placeholder="you@example.com"
          aria-required="true"
        />
        <span class="form-error hidden" aria-live="polite">Please enter a valid email address.</span>
      </div>

      <!-- Postcode -->
      <div class="form-group">
        <label for="field-postcode" class="form-label">
          Postcode <span class="text-red-500" aria-hidden="true">*</span>
        </label>
        <input
          id="field-postcode"
          type="text"
          name="postcode"
          autocomplete="postal-code"
          required
          class="form-input"
          placeholder="e.g. CV6 2AH"
          aria-required="true"
        />
        <span class="form-error hidden" aria-live="polite">Please enter your postcode.</span>
      </div>
    </div>

    <!-- Kitchen supplier -->
    <div class="form-group">
      <label for="field-supplier" class="form-label">Kitchen Supplier</label>
      <div class="select-wrapper">
        <select id="field-supplier" name="supplier" class="form-input form-select">
          <option value="">— Select if known —</option>
          <option value="Wren">Wren Kitchens</option>
          <option value="Howdens">Howdens</option>
          <option value="Magnet">Magnet</option>
          <option value="IKEA">IKEA</option>
          <option value="Wickes">Wickes</option>
          <option value="B&Q">B&amp;Q</option>
          <option value="Benchmarx">Benchmarx</option>
          <option value="DIY Kitchens">DIY Kitchens</option>
          <option value="Other">Other</option>
          <option value="Not sure">Not sure yet</option>
        </select>
        <!-- Chevron -->
        <svg class="select-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="6 9 12 15 18 9" />
        </svg>
      </div>
    </div>

    <!-- Do you have plans/drawings? -->
    <fieldset class="form-group">
      <legend class="form-label mb-3">Do you have plans or drawings?</legend>
      <div class="flex flex-wrap gap-6">
        <label class="radio-label">
          <input type="radio" name="has_plans" value="Yes" class="radio-input" />
          <span class="radio-custom" aria-hidden="true"></span>
          <span>Yes</span>
        </label>
        <label class="radio-label">
          <input type="radio" name="has_plans" value="No" class="radio-input" />
          <span class="radio-custom" aria-hidden="true"></span>
          <span>No</span>
        </label>
      </div>
    </fieldset>

    <!-- Preferred start date -->
    <div class="form-group">
      <label for="field-start-date" class="form-label">Preferred Start Date</label>
      <input
        id="field-start-date"
        type="date"
        name="preferred_start_date"
        class="form-input"
      />
    </div>

    <!-- Do you need a survey? (conditional on showSurveyOption) -->
    {showSurveyOption && (
      <fieldset class="form-group">
        <legend class="form-label mb-1">Do you need a survey?</legend>
        <p class="text-xs mb-3" style="color: var(--text-soft);">
          Survey fee £195 — credited against installation balance on booking.
        </p>
        <div class="flex flex-wrap gap-6">
          <label class="radio-label">
            <input type="radio" name="needs_survey" value="Yes" class="radio-input" />
            <span class="radio-custom" aria-hidden="true"></span>
            <span>Yes</span>
          </label>
          <label class="radio-label">
            <input type="radio" name="needs_survey" value="No" class="radio-input" />
            <span class="radio-custom" aria-hidden="true"></span>
            <span>No</span>
          </label>
          <label class="radio-label">
            <input type="radio" name="needs_survey" value="Not sure" class="radio-input" />
            <span class="radio-custom" aria-hidden="true"></span>
            <span>Not sure</span>
          </label>
        </div>
      </fieldset>
    )}

    <!-- Upload plan or photos -->
    <div class="form-group">
      <label for="field-uploads" class="form-label">Upload Plan or Photos</label>
      <p class="text-xs mb-2" style="color: var(--text-soft);">Optional — images or PDF plans (multiple files accepted).</p>
      <div class="file-upload-wrapper">
        <input
          id="field-uploads"
          type="file"
          name="uploads"
          multiple
          accept="image/*,.pdf"
          class="file-input"
          aria-describedby="file-hint"
        />
        <div class="file-upload-label" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--teal);">
            <polyline points="16 16 12 12 8 16"/>
            <line x1="12" y1="12" x2="12" y2="21"/>
            <path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"/>
          </svg>
          <span id="file-hint" class="text-sm" style="color: var(--text-soft);">Click to choose files, or drag and drop</span>
        </div>
      </div>
    </div>

    <!-- Message -->
    <div class="form-group">
      <label for="field-message" class="form-label">Message</label>
      <textarea
        id="field-message"
        name="message"
        rows="4"
        class="form-input"
        placeholder="Tell us anything else we should know — kitchen size, special requirements, existing flooring, etc."
      ></textarea>
    </div>

    <!-- Submit -->
    <div class="pt-2">
      <button
        type="submit"
        class="btn-primary inline-flex items-center gap-2 w-full sm:w-auto justify-center"
        data-submit-btn
      >
        Send Enquiry
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12"/>
          <polyline points="12 5 19 12 12 19"/>
        </svg>
      </button>
      <p class="mt-3 text-xs" style="color: var(--text-soft);">
        We'll respond within one working day. Your details are never shared with third parties.
      </p>
    </div>

  </form>
</div>

<style>
  /* Form field base */
  .form-label {
    display: block;
    font-size: 0.875rem;
    font-weight: 600;
    margin-bottom: 0.375rem;
    color: var(--charcoal);
  }

  .form-input {
    display: block;
    width: 100%;
    padding: 0.625rem 0.875rem;
    border-radius: 0.5rem;
    border: 1.5px solid #D1D5DB;
    background: #fff;
    font-size: 0.9375rem;
    color: var(--charcoal);
    transition: border-color 0.15s, box-shadow 0.15s;
    outline: none;
    font-family: inherit;
  }

  .form-input:focus {
    border-color: var(--teal);
    box-shadow: 0 0 0 3px rgba(15, 118, 110, 0.15);
  }

  .form-input::placeholder {
    color: #9CA3AF;
  }

  /* Error state */
  .form-input.is-error {
    border-color: #EF4444;
    box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.1);
  }

  .form-error {
    display: block;
    margin-top: 0.3rem;
    font-size: 0.8125rem;
    color: #DC2626;
  }

  .form-error.hidden {
    display: none;
  }

  /* Select */
  .select-wrapper {
    position: relative;
  }

  .form-select {
    appearance: none;
    -webkit-appearance: none;
    padding-right: 2.5rem;
    cursor: pointer;
  }

  .select-chevron {
    position: absolute;
    right: 0.875rem;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
    color: #6B7280;
  }

  /* Textarea */
  textarea.form-input {
    resize: vertical;
    min-height: 6rem;
  }

  /* Radio buttons */
  .radio-label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
    font-size: 0.9375rem;
    color: var(--charcoal);
    user-select: none;
  }

  .radio-input {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }

  .radio-custom {
    width: 1.125rem;
    height: 1.125rem;
    border-radius: 50%;
    border: 2px solid #D1D5DB;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: border-color 0.15s, background 0.15s;
  }

  .radio-input:checked + .radio-custom {
    border-color: var(--teal);
    background: var(--teal);
    box-shadow: inset 0 0 0 3px #fff;
  }

  .radio-input:focus-visible + .radio-custom {
    box-shadow: 0 0 0 3px rgba(15, 118, 110, 0.25);
  }

  /* File upload */
  .file-upload-wrapper {
    position: relative;
    border: 2px dashed #D1D5DB;
    border-radius: 0.5rem;
    padding: 1.25rem 1rem;
    text-align: center;
    transition: border-color 0.15s, background 0.15s;
    cursor: pointer;
  }

  .file-upload-wrapper:hover,
  .file-upload-wrapper:focus-within {
    border-color: var(--teal);
    background: rgba(15, 118, 110, 0.03);
  }

  .file-input {
    position: absolute;
    inset: 0;
    opacity: 0;
    width: 100%;
    height: 100%;
    cursor: pointer;
  }

  .file-upload-label {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    pointer-events: none;
  }
</style>

<script>
  (function () {
    const form = document.querySelector<HTMLFormElement>('[data-enquiry-form]');
    if (!form) return;

    const requiredInputs = form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>(
      'input[required], textarea[required]'
    );

    // Inline validation on blur
    requiredInputs.forEach((input) => {
      input.addEventListener('blur', () => validateField(input));
      input.addEventListener('input', () => {
        if (input.classList.contains('is-error')) validateField(input);
      });
    });

    function validateField(input: HTMLInputElement | HTMLTextAreaElement) {
      const group = input.closest('.form-group');
      const errorEl = group?.querySelector('.form-error');
      const valid = input.checkValidity();
      input.classList.toggle('is-error', !valid);
      if (errorEl) errorEl.classList.toggle('hidden', valid);
    }

    // Full validation on submit
    form.addEventListener('submit', (e) => {
      let hasError = false;
      requiredInputs.forEach((input) => {
        if (!input.checkValidity()) {
          validateField(input);
          if (!hasError) {
            input.focus();
            hasError = true;
          }
        }
      });
      if (hasError) e.preventDefault();
    });

    // File upload label update
    const fileInput = form.querySelector<HTMLInputElement>('[name="uploads"]');
    const fileHint = form.querySelector<HTMLElement>('#file-hint');
    if (fileInput && fileHint) {
      fileInput.addEventListener('change', () => {
        const count = fileInput.files?.length ?? 0;
        fileHint.textContent = count
          ? `${count} file${count > 1 ? 's' : ''} selected`
          : 'Click to choose files, or drag and drop';
      });
    }
  })();
</script>
