---
import RetailerLogo from "./RetailerLogo.astro";

export interface Props {
  heading?: string;
}

const { heading = "We Install Kitchens From All Major Suppliers" } = Astro.props;

const retailers = [
  { slug: "wren",         href: "/retailers/wren/" },
  { slug: "howdens",      href: "/retailers/howdens/" },
  { slug: "magnet",       href: "/retailers/magnet/" },
  { slug: "benchmarx",   href: "/retailers/benchmarx/" },
  { slug: "ikea",         href: "/retailers/ikea/" },
  { slug: "bq",           href: "/retailers/bq/" },
  { slug: "wickes",       href: "/retailers/wickes/" },
  { slug: "diy-kitchens", href: "/retailers/diy-kitchens/" },
  { slug: "kutchenhaus",  href: "/retailers/kutchenhaus/" },
  { slug: "symphony",     href: "/retailers/symphony/" },
  { slug: "masterclass",  href: "/retailers/masterclass/" },
];
---

<section class="section" style="background: var(--bg-light);">
  <div class="container">

    <h2 class="text-center text-2xl md:text-3xl font-bold mb-3" style="color: var(--charcoal);">
      {heading}
    </h2>
    <p class="text-center text-sm mb-10 max-w-xl mx-auto" style="color: var(--text-soft);">
      We work independently of all retailers — you buy, we install.
    </p>

    <ul class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4" role="list" aria-label="Supported kitchen suppliers">
      {retailers.map((r) => (
        <li role="listitem">
          <a
            href={r.href}
            class="logo-card"
            aria-label={`We install ${r.slug.replace(/-/g,' ')} kitchens`}
          >
            <RetailerLogo slug={r.slug} size="md" />
          </a>
        </li>
      ))}
    </ul>

    <p class="text-center mt-6 text-sm font-medium" style="color: var(--teal);">
      + many more — if you've bought it, we can install it.
    </p>

    <p class="mt-10 pt-8 border-t border-gray-200 text-xs italic leading-relaxed text-center max-w-3xl mx-auto" style="color: #9CA3AF;">
      Install My Kitchen is an independent kitchen installation service and is not affiliated with, endorsed by, or an official partner of Wren, Howdens, Magnet, IKEA, Wickes, B&amp;Q, Benchmarx or any other retailer. We install kitchens purchased from these suppliers.
    </p>

  </div>
</section>

<style>
  .logo-card {
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.75rem;
    background: #fff;
    border: 1.5px solid #E5E7EB;
    padding: 0.625rem;
    transition: box-shadow 0.2s, transform 0.2s;
    overflow: hidden;
  }
  .logo-card:hover {
    box-shadow: 0 6px 20px rgba(0,0,0,0.1);
    transform: translateY(-3px);
    border-color: #d1d5db;
  }
</style>
