---
// WhatHappensNext — 3-step post-enquiry process section
// Static content, no props required
// Desktop: horizontal 3-col | Mobile: vertical stack
---

<section class="whn-section" aria-labelledby="whn-heading">
  <div class="container">

    <!-- Heading -->
    <div class="whn-header fade-up">
      <h2 id="whn-heading" class="whn-title">What Happens Next?</h2>
      <p class="whn-subtitle">Simple. Transparent. Fixed Price.</p>
    </div>

    <!-- Steps -->
    <ol class="whn-steps" aria-label="What happens after you enquire">

      <!-- Step 1: Book a Survey -->
      <li class="whn-step fade-up">
        <div class="whn-step-inner">
          <div class="whn-number" aria-hidden="true">1</div>
          <div class="whn-icon" aria-hidden="true">
            <!-- Calendar icon -->
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
              <line x1="16" y1="2" x2="16" y2="6"/>
              <line x1="8" y1="2" x2="8" y2="6"/>
              <line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
          </div>
          <h3 class="whn-step-title">Book a Survey</h3>
          <p class="whn-step-desc">
            Call <a href="tel:07399651836" class="whn-tel-link">07399 651836</a> or complete our online form. We'll book a survey appointment within 1&ndash;2&nbsp;weeks at your home.
          </p>
          <a href="/survey/" class="btn-primary whn-cta-btn">
            Book Now
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12"/>
              <polyline points="12 5 19 12 12 19"/>
            </svg>
          </a>
        </div>
        <!-- Connector arrow — desktop only -->
        <div class="whn-connector" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </div>
      </li>

      <!-- Step 2: Get Your Fixed Quote -->
      <li class="whn-step fade-up">
        <div class="whn-step-inner">
          <div class="whn-number" aria-hidden="true">2</div>
          <div class="whn-icon" aria-hidden="true">
            <!-- Clipboard/document icon -->
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="16" y1="13" x2="8" y2="13"/>
              <line x1="16" y1="17" x2="8" y2="17"/>
              <polyline points="10 9 9 9 8 9"/>
            </svg>
          </div>
          <h3 class="whn-step-title">Get Your Fixed Quote</h3>
          <p class="whn-step-desc">
            Our surveyor visits, checks your room and plans, and provides a fixed installation quote within&nbsp;24&nbsp;hours. No surprises.
          </p>
        </div>
        <!-- Connector arrow — desktop only -->
        <div class="whn-connector" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </div>
      </li>

      <!-- Step 3: Your Kitchen is Installed -->
      <li class="whn-step fade-up">
        <div class="whn-step-inner">
          <div class="whn-number" aria-hidden="true">3</div>
          <div class="whn-icon" aria-hidden="true">
            <!-- House/kitchen icon -->
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
              <polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
          </div>
          <h3 class="whn-step-title">Your Kitchen is Installed</h3>
          <p class="whn-step-desc">
            We arrive on your start date and complete your installation to a fixed programme. Final snagging check before handover.
          </p>
        </div>
      </li>

    </ol>

    <!-- Trust pills -->
    <div class="whn-pills fade-up" aria-label="Key guarantees">
      <span class="whn-pill whn-pill--gold">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        Survey Fee: &pound;195
      </span>
      <span class="whn-pill whn-pill--teal">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        Credited Back on Booking
      </span>
      <span class="whn-pill whn-pill--teal">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        Fixed Price Guarantee
      </span>
      <span class="whn-pill whn-pill--gold">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        12-Month Warranty
      </span>
    </div>

  </div>
</section>

<style>
  /* ── Section wrapper ── */
  .whn-section {
    background: #fff;
    padding: 5rem 0 4rem;
    border-top: 1px solid #F3F4F6;
    border-bottom: 1px solid #F3F4F6;
  }

  @media (min-width: 768px) {
    .whn-section {
      padding: 6rem 0 5rem;
    }
  }

  /* ── Header ── */
  .whn-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .whn-title {
    font-size: clamp(1.625rem, 3.5vw, 2.5rem);
    font-weight: 800;
    color: var(--charcoal);
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
  }

  .whn-subtitle {
    font-size: 1.0625rem;
    color: var(--text-soft);
    font-weight: 500;
  }

  /* ── Steps list ── */
  .whn-steps {
    list-style: none;
    padding: 0;
    margin: 0 0 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .whn-steps {
      flex-direction: row;
      align-items: stretch;
      gap: 0;
    }
  }

  /* ── Individual step ── */
  .whn-step {
    position: relative;
    display: flex;
    align-items: stretch;
  }

  @media (min-width: 768px) {
    .whn-step {
      flex: 1;
      align-items: center;
    }
  }

  /* ── Step inner card ── */
  .whn-step-inner {
    background: #F8F9FA;
    border: 1px solid #E5E7EB;
    border-radius: 16px;
    padding: 2rem 1.5rem 1.75rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.625rem;
    flex: 1;
    transition: box-shadow 0.25s ease, transform 0.25s ease;
  }

  .whn-step-inner:hover {
    box-shadow: 0 8px 32px rgba(15, 118, 110, 0.12);
    transform: translateY(-3px);
  }

  /* ── Teal number circle ── */
  .whn-number {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background: var(--teal);
    color: #fff;
    font-size: 1rem;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 12px rgba(15, 118, 110, 0.35);
    flex-shrink: 0;
    margin-bottom: 0.25rem;
  }

  /* ── Icon ── */
  .whn-icon {
    width: 3rem;
    height: 3rem;
    border-radius: 12px;
    background: rgba(15, 118, 110, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--teal);
    flex-shrink: 0;
  }

  /* ── Step title ── */
  .whn-step-title {
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--charcoal);
    line-height: 1.25;
    margin: 0.25rem 0 0;
  }

  /* ── Step description ── */
  .whn-step-desc {
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--text-soft);
    margin: 0;
    max-width: 22rem;
  }

  .whn-tel-link {
    color: var(--teal);
    font-weight: 600;
    text-decoration: underline;
    text-decoration-color: transparent;
    transition: text-decoration-color 0.2s;
  }

  .whn-tel-link:hover {
    text-decoration-color: var(--teal);
  }

  /* ── CTA button in step 1 ── */
  .whn-cta-btn {
    margin-top: 0.5rem;
    padding: 0.6875rem 1.5rem;
    font-size: 0.9375rem;
  }

  /* ── Connector arrows (desktop only) ── */
  .whn-connector {
    display: none;
  }

  @media (min-width: 768px) {
    .whn-connector {
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--teal);
      opacity: 0.45;
      flex-shrink: 0;
      width: 2.5rem;
      padding: 0 0.25rem;
    }
  }

  /* ── Trust pills row ── */
  .whn-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
    justify-content: center;
    margin-top: 0.5rem;
  }

  .whn-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.4375rem 1rem;
    border-radius: 999px;
    font-size: 0.8125rem;
    font-weight: 700;
    white-space: nowrap;
  }

  .whn-pill--teal {
    background: rgba(15, 118, 110, 0.1);
    color: var(--teal);
    border: 1px solid rgba(15, 118, 110, 0.2);
  }

  .whn-pill--gold {
    background: rgba(212, 160, 23, 0.1);
    color: #7a5200;
    border: 1px solid rgba(212, 160, 23, 0.3);
  }
</style>
