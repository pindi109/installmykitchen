---
// No props — buttons are site-wide constants.
// DECISION: "Call" → tel:07399651836 | "Book a Survey" → /survey/ | "Get a Quote" → /contact/#quote
//           Three-item bar. Adjusted padding/sizing to fit all three cleanly.
---

<div
  id="sticky-mobile-cta"
  class="md:hidden fixed bottom-0 left-0 right-0 z-40 flex gap-2 px-3 py-2.5 transition-transform duration-300"
  style="background: rgba(15,23,42,0.97); box-shadow: 0 -4px 24px rgba(0,0,0,0.3); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);"
  aria-label="Quick action bar"
>
  <!-- "Call" — white/ghost, tap-to-call -->
  <a
    href="tel:07399651836"
    class="flex-1 flex flex-col items-center justify-center gap-0.5 py-2 rounded-xl font-semibold text-white transition-all duration-200 active:scale-95"
    style="background: rgba(255,255,255,0.1); min-width: 0;"
    aria-label="Call Install My Kitchen"
  >
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.6 3.48 2 2 0 0 1 3.57 1.5h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.04a16 16 0 0 0 6.05 6.05l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
    </svg>
    <span style="font-size: 0.6875rem; line-height: 1;">Call</span>
  </a>

  <!-- "Book a Survey" — teal primary -->
  <a
    href="/survey/"
    class="flex-1 flex flex-col items-center justify-center gap-0.5 py-2 rounded-xl font-semibold text-white transition-all duration-200 active:scale-95"
    style="background: #0F766E; min-width: 0;"
  >
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
      <line x1="16" y1="2" x2="16" y2="6"/>
      <line x1="8" y1="2" x2="8" y2="6"/>
      <line x1="3" y1="10" x2="21" y2="10"/>
    </svg>
    <span style="font-size: 0.6875rem; line-height: 1;">Book Survey</span>
  </a>

  <!-- "Get a Quote" — gold outline -->
  <a
    href="/contact/#quote"
    class="flex-1 flex flex-col items-center justify-center gap-0.5 py-2 rounded-xl font-semibold transition-all duration-200 active:scale-95 border"
    style="color: #D4A017; border-color: #D4A017; background: transparent; min-width: 0;"
  >
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
    </svg>
    <span style="font-size: 0.6875rem; line-height: 1;">Get Quote</span>
  </a>
</div>

<!-- Spacer so fixed bar doesn't overlap page content on mobile -->
<div class="md:hidden h-[64px]" aria-hidden="true" id="sticky-cta-spacer"></div>

<script>
  (function () {
    const cta = document.getElementById("sticky-mobile-cta");
    const spacer = document.getElementById("sticky-cta-spacer");
    if (!cta) return;

    let footerObserver: IntersectionObserver | null = null;
    const footer = document.querySelector("footer");

    // Hide bar when footer is visible (user has scrolled to bottom)
    if (footer) {
      footerObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              cta.style.transform = "translateY(120%)";
              if (spacer) spacer.style.display = "none";
            } else {
              cta.style.transform = "";
              if (spacer) spacer.style.display = "";
            }
          });
        },
        { threshold: 0.1 }
      );
      footerObserver.observe(footer);
    }
  })();
</script>
