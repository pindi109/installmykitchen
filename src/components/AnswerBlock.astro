---
export interface Props {
  answer: string;
}

const { answer } = Astro.props;
---

<!--
  AnswerBlock — "Quick Answer" for AEO/featured-snippet targeting.
  Structured for AI overview pickup: concise, direct, semantically clear.
-->
<div
  class="answer-block"
  role="note"
  aria-label="Quick answer"
  itemscope
  itemtype="https://schema.org/Answer"
>
  <div class="answer-inner">
    <div class="answer-label" aria-hidden="true">
      <!-- Lightning bolt icon -->
      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
      </svg>
      <span>Quick Answer</span>
    </div>
    <p class="answer-text" itemprop="text">{answer}</p>
  </div>
</div>

<style>
  .answer-block {
    border-left: 4px solid var(--teal);
    background: rgba(15, 118, 110, 0.06);
    border-radius: 0 0.625rem 0.625rem 0;
    padding: 1rem 1.25rem;
    margin-bottom: 1.5rem;
  }

  .answer-inner {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .answer-label {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--teal);
  }

  .answer-text {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--charcoal);
    font-weight: 500;
    margin: 0;
  }
</style>
