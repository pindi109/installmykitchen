---
import "../styles/global.css";
import heroManifest from "../../public/hero-manifest.json";
import altTagsData from "../data/alt-tags.json";

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  noHero?: boolean; // pass true on pages with their own custom hero section
}

const {
  title,
  description,
  canonical,
  ogTitle,
  ogDescription,
  ogImage = "https://www.installmykitchen.co.uk/assets/logo.png",
  noHero = false,
} = Astro.props;

const resolvedCanonical = canonical ?? Astro.url.href;
const resolvedOgTitle = ogTitle ?? title;
const resolvedOgDescription = ogDescription ?? description;

// Derive slug from URL (strip leading + trailing slashes)
const pathSlug = Astro.url.pathname.replace(/^\//, "").replace(/\/$/, "");
const heroSrc: string =
  (heroManifest as Record<string, string>)[pathSlug] ??
  "/assets/hero-placeholder.svg";
const heroAlt: string =
  (altTagsData as Record<string, string>)[pathSlug] ??
  "Kitchen fitting service West Midlands – Install My Kitchen";
const hasRealHero = !heroSrc.includes("placeholder");
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="index, follow" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={resolvedCanonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={resolvedCanonical} />
    <meta property="og:title" content={resolvedOgTitle} />
    <meta property="og:description" content={resolvedOgDescription} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:site_name" content="Install My Kitchen" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={resolvedOgTitle} />
    <meta name="twitter:description" content={resolvedOgDescription} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Global styles are injected by Astro via the frontmatter import below.
         DECISION: Imported in frontmatter (not <link>) so Astro/Vite bundles and
         fingerprints the CSS at build time. The <style> tag approach would scope it. -->

    <!-- Schema slot (FAQPage, BreadcrumbList, LocalBusiness, etc.) -->
    <slot name="schema" />
  </head>

  <body>
    <!-- Header -->
    <slot name="header" />

    <!-- Page hero image (manifest-driven, skipped on pages with custom heroes) -->
    {!noHero && hasRealHero && (
      <div style="width:100%;height:clamp(240px,38vw,520px);overflow:hidden;line-height:0;">
        <img
          src={heroSrc}
          alt={heroAlt}
          width="1834"
          height="1024"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          style="width:100%;height:100%;object-fit:cover;object-position:center;display:block;"
        />
      </div>
    )}

    <!-- Main content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <slot name="footer" />

    <!-- Sticky mobile CTA -->
    <slot name="sticky-cta" />

    <!-- Fade-up animation (IntersectionObserver, respects prefers-reduced-motion) -->
    <script>
      (function () {
        const prefersReduced = window.matchMedia(
          "(prefers-reduced-motion: reduce)"
        ).matches;
        if (prefersReduced) return;

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("visible");
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12 }
        );

        document.querySelectorAll(".fade-up").forEach((el) => {
          observer.observe(el);
        });
      })();
    </script>
  </body>
</html>
